(** Any uniform modulus bound on the exponential partial sums yields a convergent
    subsequence in `(complex, dist_complex)`. This is the boundedness-to-compactness
    bridge needed for eventual existence proofs. **)
// Proof in RealAnalysis2.1782844916.mg
ProofArchived complex_exp_partial_sum_seq_bounded_subseq_converges :
  forall z :e complex,
  forall M :e R,
    (forall n :e omega,
      modulus_CSNo
        (complex_partial_sum_seq
          (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
          n)
      <= M) ->
    exists y : set -> set,
      subseq_of
        (complex_partial_sum_seq
          (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k)))
        y
      /\ exists l :e complex, ms_seq_limit complex dist_complex y l.


(** A Cauchy exponential partial-sum sequence converges as soon as the partial sums
    are uniformly bounded in modulus. This combines the bounded-subsequence bridge
    with the general metric-space theorem `ms_cauchy_subseq_limit_imp_limit`. **)
// Proof in RealAnalysis2.1782845403.mg
ProofArchived complex_exp_partial_sum_seq_has_limit_of_cauchy_and_bounded :
  forall z :e complex,
  forall M :e R,
    ms_cauchy_seq
      complex
      dist_complex
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k)))
    ->
    (forall n :e omega,
      modulus_CSNo
        (complex_partial_sum_seq
          (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
          n)
      <= M) ->
    exists l :e complex,
      ms_seq_limit
        complex
        dist_complex
        (complex_partial_sum_seq
          (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k)))
        l.


// Proof in RealAnalysis2.1783045346.mg
