//GOD1:328624 right_basis_transform : "the family obtained from #9 using the coefficient matrix #10" | $b_j=\sum_i #9_i#10_{ij}$
Definition right_basis_transform :
  set -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> set -> set -> set :=
