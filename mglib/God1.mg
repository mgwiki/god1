// Proof in RealAnalysis2.1780523170.mg
ProofArchived arzela_diag_subseq_pointwise_limit_exists :
  forall X,
  forall dX : set -> set -> set,
  forall fn : set -> set,
  forall e : set -> set,
    is_metric X dX ->
    ms_seq_compact X dX X ->
    pointwise_bounded_fun_seq X fn ->
    ms_equicontinuous_on X dX complex dist_complex X fn ->
    (forall n :e omega, e n :e X) ->
    (forall x :e X,
      forall eps :e R,
        0 < eps ->
        exists n :e omega, dX x (e n) < eps) ->
    subseq_of fn (arzela_diag_subseq fn e) ->
    (forall m :e omega,
      exists l :e complex,
        ms_seq_limit complex dist_complex
          (fun n : set => ((arzela_diag_subseq fn e) n) (e m))
          l) ->
    forall x :e X,
      exists l :e complex,
        ms_seq_limit complex dist_complex
          (fun n : set => ((arzela_diag_subseq fn e) n) x)
          l.

// Proof in RealAnalysis2.1780523170.mg
ProofArchived arzela_diag_subseq_uniform_limit :
  forall X,
  forall dX : set -> set -> set,
  forall fn : set -> set,
  forall e : set -> set,
    is_metric X dX ->
    ms_seq_compact X dX X ->
    pointwise_bounded_fun_seq X fn ->
    ms_equicontinuous_on X dX complex dist_complex X fn ->
    (forall n :e omega, e n :e X) ->
    (forall x :e X,
      forall eps :e R,
        0 < eps ->
        exists n :e omega, dX x (e n) < eps) ->
    subseq_of fn (arzela_diag_subseq fn e) ->
    (forall m :e omega,
      exists l :e complex,
        ms_seq_limit complex dist_complex
          (fun n : set => ((arzela_diag_subseq fn e) n) (e m))
          l) ->
    exists f,
      ms_uniformly_converges_to
        X dX complex dist_complex X (arzela_diag_subseq fn e) f.

(** The explicit diagonal subsequence inherits the pointwise boundedness
    and equicontinuity hypotheses from the original sequence. **)
// Proof in RealAnalysis2.1780509203.mg
ProofArchived arzela_diag_subseq_inherited_props :
  forall X,
  forall dX : set -> set -> set,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    ms_equicontinuous_on X dX complex dist_complex X fn ->
    (forall n :e omega, e n :e X) ->
    pointwise_bounded_fun_seq X (arzela_diag_subseq fn e)
    /\ ms_equicontinuous_on X dX complex dist_complex X (arzela_diag_subseq fn e).

(** Packaged nonempty branch of Arzelà–Ascoli:
    use the explicit dense diagonal subsequence and upgrade it to a uniform limit. **)
// Proof in RealAnalysis2.1780523170.mg
ProofArchived arzela_ascoli_nonempty_branch :
  forall X,
  forall dX : set -> set -> set,
  forall fn : set -> set,
    is_metric X dX ->
    ms_seq_compact X dX X ->
    pointwise_bounded_fun_seq X fn ->
    ms_equicontinuous_on X dX complex dist_complex X fn ->
    nonempty X ->
    exists gn : set -> set,
      subseq_of fn gn
      /\ exists f,
           ms_uniformly_converges_to X dX complex dist_complex X gn f.

// Proof in RealAnalysis2.1780523170.mg
ProofArchived arzela_ascoli :
  forall X,
  forall dX : set -> set -> set,
  forall fn : set -> set,
    is_metric X dX ->
    ms_seq_compact X dX X ->
    (forall n :e omega,
      ms_continuous_on (fun x : set => (fn n) x) X dX complex dist_complex X) ->
    pointwise_bounded_fun_seq X fn ->
    ms_equicontinuous_on X dX complex dist_complex X fn ->
    uniformly_bounded_fun_seq X fn
    /\ exists gn : set -> set,
         subseq_of fn gn
         /\ exists f,
              ms_uniformly_converges_to X dX complex dist_complex X gn f.

// Proof sketch (real2.tex):
// 1) Uniform boundedness: use equicontinuity with eps=1 to get delta>0; use compactness of X to extract a finite
//    delta-net {x1,...,xk}; use pointwise boundedness at each xj to get bounds Mj, then show a uniform bound
//    M := 1 + max_j Mj for all x in X and all n.
// 2) Uniformly convergent subsequence: (a) extract a countable dense D ⊂ X; (b) apply a diagonal subsequence
//    selection argument on D to get a subsequence converging pointwise on D; (c) use equicontinuity + finite
//    subcover arguments to show the subsequence is uniformly Cauchy on X; (d) use completeness of `complex`
//    (with `dist_complex`) to obtain a uniform limit f.
// Missing infrastructure to formalize: compact -> totally bounded/finite covers, compact -> separable,
// diagonal subsequence lemma on countable sets, and completeness of (complex, dist_complex).

End form82.

