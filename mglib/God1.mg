//GOD1:60785 group_homomorphism : "#7 is a homomorphism from the group #1 to the group #3" | $#7:#1\to #3$
Definition group_homomorphism :
  set -> (set -> set -> set) ->
  set -> (set -> set -> set) ->
  (set -> set) -> prop :=
  fun G mulG H mulH f =>
    group G mulG
    /\ group H mulH
    /\ (forall x :e G, f x :e H)
    /\ (forall x y :e G,
      f (mulG x y) = mulH (f x) (f y)).

