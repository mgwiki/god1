        (matrix_submatrix (ordsucc (ordsucc m)) (ordsucc (ordsucc m))
          (fun i => rows i) (fun j => j)
          (affine_membership_coordinate_matrix K addK mulK
            T addT smulT E action n (ordsucc m) P Q R))
      = ring_zero K addK).
