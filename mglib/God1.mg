Theorem god1_group_int_power_power_negative_nat_case :
  forall G, forall mul:set -> set -> set, forall x,
    group G mul -> x :e G ->
    forall p :e int, forall n :e omega,
      group_int_power G mul (group_int_power G mul x p) (minus_SNo n)
