    nondegenerate_sesquilinear_form K addK mulK star M addL smul f ->
    forall x :e L, forall y,
      (y = orthogonal_projection K addK L addL M f x
      <-> y :e M /\ forall z :e M,
        f (addL x (module_negation L addL y)) z = ring_zero K addK).
