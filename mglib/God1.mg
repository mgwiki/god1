ProofArchived null_set_evenodd_rseq_even_witness :
  forall rseq1,
  forall rseq2,
  forall k,
  forall m :e omega,
    k = 2 * m ->
    null_set_evenodd_rseq rseq1 rseq2 k = rseq1 m.

