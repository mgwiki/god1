    identity uses only the exponential addition law. **)
// Proof in RealAnalysis2.1783046439.mg
ProofArchived complex_exp_mul_Complex_i_product_eq_1_of_has_limits_and_add :
  forall z :e complex,
    (exists l :e complex,
      ms_seq_limit
        complex
        dist_complex
        (complex_partial_sum_seq
          (fun k : set => div_CSNo (exp_CSNo_nat (mul_CSNo Complex_i z) k) (factorial k)))
        l)
    ->
    (exists l :e complex,
      ms_seq_limit
        complex
        dist_complex
        (complex_partial_sum_seq
          (fun k : set =>
            div_CSNo (exp_CSNo_nat (minus_CSNo (mul_CSNo Complex_i z)) k) (factorial k)))
        l)
    ->
    (forall z :e complex,
     forall w :e complex,
       complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w))
    ->
    mul_CSNo
      (complex_exp (mul_CSNo Complex_i z))
      (complex_exp (minus_CSNo (mul_CSNo Complex_i z)))
    = 1.

