      complex
      dist_complex
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k)))
    ->
    (forall n :e omega,
      modulus_CSNo
        (complex_partial_sum_seq
          (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
          n)
      <= M)
    ->
    (forall z :e complex,
     forall w :e complex,
       complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w))
    ->
    exists l :e complex,
      ms_seq_limit
        complex
        dist_complex
        (complex_partial_sum_seq
          (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k)))
        l.


(** The exponential partial-sum sequence has at least one complex limit.
    This packages the existence problem needed to place `complex_exp z`
    back in `complex`. **)
// Proof in RealAnalysis2.1782898466.mg
ProofArchived complex_exp_partial_sum_seq_has_limit :
  forall z :e complex,
