  apply andI.
  - exact (god1_group_word_append_letters G mul B p f a
      (omega_nat_p p hp) hf ha).
  - apply (eq_i_tra
      (mul z a)
      (mul (group_word_product G mul f p) a)
      (group_word_product G mul (group_word_append p f a) (ordsucc p))).
    - f_equal.
