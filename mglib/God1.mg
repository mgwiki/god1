(** Negation can be pulled through the numerator of a complex quotient. **)
Transparent div_CSNo.
// Proof in RealAnalysis2.1782843521.mg
ProofArchived minus_div_CSNo_num :
  forall z,
  forall w,
    CSNo z ->
    CSNo w ->
    div_CSNo (minus_CSNo z) w = minus_CSNo (div_CSNo z w).
Opaque div_CSNo.

(** Multiplying by `i` converts division by `2 i` into division by `2`. **)
// Proof in RealAnalysis2.1782846490.mg
ProofArchived complex_i_mul_div_2i_eq_div_2 :
  forall z :e complex,
    mul_CSNo Complex_i (div_CSNo z (mul_CSNo 2 Complex_i)) = div_CSNo z 2.

(** The two half-sums `(a+b)/2` and `(a-b)/2` recombine to recover `a`. **)
// Proof in RealAnalysis2.1782846490.mg
ProofArchived complex_add_div_2_add_sub_div_2_eq :
  forall a :e complex,
  forall b :e complex,
    add_CSNo
      (div_CSNo (add_CSNo a b) 2)
      (div_CSNo (add_CSNo a (minus_CSNo b)) 2)
    = a.

(** Moved later than the book order because it depends on the quotient-normalization
    helpers above.  This is the conditional algebraic core of Euler's formula. **)
// Proof in RealAnalysis2.1782846490.mg
ProofArchived complex_exp_mul_Complex_i_of_exp_in_complex :
  forall z :e complex,
    complex_exp (mul_CSNo Complex_i z) :e complex ->
    complex_exp (minus_CSNo (mul_CSNo Complex_i z)) :e complex ->
    complex_exp (mul_CSNo Complex_i z)
    =
    add_CSNo (complex_cos z) (mul_CSNo Complex_i (complex_sin z)).

(** Once `complex_exp` is known to map `complex` to `complex`, Euler's formula
    no longer depends on the addition law hypothesis. **)
// Proof in RealAnalysis2.1783093828.mg
