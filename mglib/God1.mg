Section form90.

(** real2.tex: sec:powerseries (Power series and analytic functions) [scaffolding]. **)

(** Term c_n x^n for a real sequence c and a real x. **)
//LLM power_series_term : "the #1-th term of the power series with coefficients #2 at #3" | $\mathrm{power\_series\_term}(#1,#2,#3)$
Definition power_series_term : (set -> set) -> set -> set -> set :=
  fun c x n =>
    (c n) * (x ^ n).

(** Formal power series sum at x (defined as sum_series of the term sequence). **)
//LLM power_series_sum : "the sum of the power series with coefficients #1 at #2" | $\mathrm{power\_series\_sum}(#1,#2)$
Definition power_series_sum : (set -> set) -> set -> set :=
  fun c x =>
    sum_series (fun n => power_series_term c x n).

End form90.

