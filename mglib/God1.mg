        (complex_cos z)
        (minus_CSNo (mul_CSNo Complex_i (complex_sin z))))
    = 1)
  ->
  forall z :e complex,
    add_CSNo
      (mul_CSNo (complex_cos z) (complex_cos z))
      (mul_CSNo (complex_sin z) (complex_sin z))
    = 1.

