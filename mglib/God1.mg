(** real2.tex: sec:stoneweier (Stone–Weierstrass) [scaffolding, added early]. **)

// A subset A of functions X->R is an algebra if closed under addition, multiplication, and scalar multiplication.
//LLM is_R_function_algebra : "#1 is a real function algebra" | $\mathrm{is\_R\_function\_algebra}(#1,#2)$
Definition is_R_function_algebra :
  set ->
  set ->
  prop :=
  fun X A =>
    A c= setexp R X
    /\ (forall f :e A, forall g :e A, (fun x :e X => (f x) + (g x)) :e A)
    /\ (forall f :e A, forall g :e A, (fun x :e X => (f x) * (g x)) :e A)
    /\ (forall c :e R, forall f :e A, (fun x :e X => c * (f x)) :e A).

(** Projections for `is_R_function_algebra`. **)
// Proof in RealAnalysis2.1780156947.mg
ProofArchived is_R_function_algebra_subq_setexp :
  forall X,
  forall A,
    is_R_function_algebra X A ->
    A c= setexp R X.

// Proof in RealAnalysis2.1780156947.mg
ProofArchived is_R_function_algebra_add_closed :
  forall X,
  forall A,
    is_R_function_algebra X A ->
    (forall f :e A, forall g :e A, (fun x :e X => (f x) + (g x)) :e A).

// Proof in RealAnalysis2.1780156947.mg
ProofArchived is_R_function_algebra_mul_closed :
  forall X,
  forall A,
    is_R_function_algebra X A ->
    (forall f :e A, forall g :e A, (fun x :e X => (f x) * (g x)) :e A).

// Proof in RealAnalysis2.1780156947.mg
ProofArchived is_R_function_algebra_smul_closed :
  forall X,
  forall A,
    is_R_function_algebra X A ->
    (forall c :e R, forall f :e A, (fun x :e X => c * (f x)) :e A).

(** A separates points if for any distinct x,y there exists f with f x != f y. **)
//LLM separates_points : "#1 separates points" | $\mathrm{separates\_points}(#1,#2)$
Definition separates_points :
  set ->
  set ->
  prop :=
  fun X A =>
    forall x :e X, forall y :e X, x <> y ->
      exists f :e A, f x <> f y.

(** Contains constants: every constant function belongs to A. **)
//LLM contains_constants : "#1 contains the constant functions" | $\mathrm{contains\_constants}(#1,#2)$
Definition contains_constants :
  set ->
  set ->
  prop :=
  fun X A =>
    forall c :e R, (fun x :e X => c) :e A.

(** Vanishes at no point: for every x there exists a function in A
    whose value at x is nonzero. **)
//LLM vanishes_at_no_point : "#1 vanishes at no point" | $\mathrm{vanishes\_at\_no\_point}(#1,#2)$
Definition vanishes_at_no_point :
  set ->
  set ->
  prop :=
  fun X A =>
    forall x :e X,
      exists f :e A, f x <> 0.

(** If A contains constants, then A is nonempty. **)
// Proof in RealAnalysis2.1780156947.mg
ProofArchived contains_constants_nonempty :
  forall X,
  forall A,
    contains_constants X A ->
    nonempty A.

(** Constant functions imply the weaker Stone–Weierstrass hypothesis
    of vanishing at no point. **)
// Proof in RealAnalysis2.1780562747.mg
ProofArchived contains_constants_imp_vanishes_at_no_point :
  forall X,
  forall A,
    contains_constants X A ->
    vanishes_at_no_point X A.

(** Complex-valued analogue: algebra of functions X -> C closed under
    pointwise complex addition, multiplication, and scalar multiplication. **)
//LLM is_C_function_algebra : "#1 is a complex function algebra" | $\mathrm{is\_C\_function\_algebra}(#1,#2)$
Definition is_C_function_algebra :
  set ->
  set ->
  prop :=
  fun X A =>
    A c= setexp complex X
    /\ (forall f :e A, forall g :e A, (fun x :e X => (f x) + (g x)) :e A)
    /\ (forall f :e A, forall g :e A, (fun x :e X => (f x) * (g x)) :e A)
    /\ (forall c :e complex, forall f :e A, (fun x :e X => c * (f x)) :e A).

(** Projections for `is_C_function_algebra`. **)
// Proof in RealAnalysis2.1780565774.mg
ProofArchived is_C_function_algebra_subq_setexp :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    A c= setexp complex X.

// Proof in RealAnalysis2.1780565774.mg
ProofArchived is_C_function_algebra_add_closed :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    (forall f :e A, forall g :e A, (fun x :e X => (f x) + (g x)) :e A).

// Proof in RealAnalysis2.1780565774.mg
ProofArchived is_C_function_algebra_mul_closed :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    (forall f :e A, forall g :e A, (fun x :e X => (f x) * (g x)) :e A).

// Proof in RealAnalysis2.1780565774.mg
ProofArchived is_C_function_algebra_smul_closed :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    (forall c :e complex, forall f :e A, (fun x :e X => c * (f x)) :e A).

(** Complex constants belong to the algebra. **)
//LLM contains_complex_constants : "#1 contains the complex constant functions" | $\mathrm{contains\_complex\_constants}(#1,#2)$
Definition contains_complex_constants :
  set ->
  set ->
  prop :=
  fun X A =>
    forall c :e complex, (fun x :e X => c) :e A.

(** Complex constants imply nonemptiness. **)
// Proof in RealAnalysis2.1780564080.mg
ProofArchived contains_complex_constants_nonempty :
  forall X,
  forall A,
    contains_complex_constants X A ->
    nonempty A.

(** Real-valued members of a complex algebra.  This is the carrier used
    in the complex Stone–Weierstrass reduction to the real case. **)
//LLM real_members_of_complex_algebra : "the real members of the complex algebra #1" | $\mathrm{real\_members\_of\_complex\_algebra}(#1,#2)$
Definition real_members_of_complex_algebra :
  set ->
  set ->
  set :=
  fun X A =>
    {f :e A | forall x :e X, f x :e R}.

(** The real-valued part is a subset of the ambient complex algebra. **)
// Proof in RealAnalysis2.1780564080.mg
ProofArchived real_members_of_complex_algebra_subq :
  forall X,
  forall A,
    real_members_of_complex_algebra X A c= A.

(** Under the complex-algebra hypothesis, the real-valued part lands in
    `setexp R X`. **)
// Proof in RealAnalysis2.1780565774.mg
ProofArchived real_members_of_complex_algebra_subq_setexp_R :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    real_members_of_complex_algebra X A c= setexp R X.

(** Complex constants restrict to real constants on the real-valued part. **)
// Proof in RealAnalysis2.1780564080.mg
ProofArchived contains_complex_constants_imp_contains_constants_real_members_of_complex_algebra :
  forall X,
  forall A,
    contains_complex_constants X A ->
    contains_constants X (real_members_of_complex_algebra X A).

(** Hence the real-valued part is nonempty as soon as the complex algebra
    contains the constants. **)
// Proof in RealAnalysis2.1780564080.mg
ProofArchived contains_complex_constants_imp_real_members_nonempty :
  forall X,
  forall A,
    contains_complex_constants X A ->
    nonempty (real_members_of_complex_algebra X A).

(** If two complex numbers differ, then either their real parts differ or
    their imaginary parts differ.  This is the basic separation step used
    in the complex-to-real Stone–Weierstrass reduction. **)
// Proof in RealAnalysis2.1780564080.mg
ProofArchived complex_neq_imp_Re_neq_or_Im_neq :
  forall z :e complex,
  forall w :e complex,
    z <> w ->
    Re z <> Re w \/ Im z <> Im w.

(** Nonzero complex numbers have a nonzero real or imaginary part. **)
// Proof in RealAnalysis2.1780564988.mg
ProofArchived complex_nonzero_imp_Re_nonzero_or_Im_nonzero :
  forall z :e complex,
    z <> 0 ->
    Re z <> 0 \/ Im z <> 0.

(** Members of a complex algebra evaluate to complex numbers on the carrier. **)
// Proof in RealAnalysis2.1780565774.mg
ProofArchived is_C_function_algebra_eval_in_complex :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    forall f :e A,
    forall x :e X,
      f x :e complex.

(** A separating complex witness already separates in either the real or the
    imaginary coordinate. **)
// Proof in RealAnalysis2.1780565774.mg
ProofArchived complex_witness_separates_by_Re_or_Im :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    forall f :e A,
    forall x :e X,
    forall y :e X,
      f x <> f y ->
      Re (f x) <> Re (f y) \/ Im (f x) <> Im (f y).

(** Likewise, a nonzero complex witness has either nonzero real or nonzero
    imaginary part. **)
// Proof in RealAnalysis2.1780565774.mg
ProofArchived complex_witness_nonzero_by_Re_or_Im :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    forall f :e A,
    forall x :e X,
      f x <> 0 ->
      Re (f x) <> 0 \/ Im (f x) <> 0.

(** Corrected pointwise closure projections for the complex algebra
    scaffold.  These use ordinary addition and multiplication on
    complex-valued functions, matching the book. **)
// Proof in RealAnalysis2.1780565774.mg
ProofArchived is_C_function_algebra_add_closed_ptwise :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    forall f :e real_members_of_complex_algebra X A,
    forall g :e real_members_of_complex_algebra X A,
      (fun x :e X => (f x) + (g x)) :e real_members_of_complex_algebra X A.

// Proof in RealAnalysis2.1780565774.mg
ProofArchived real_members_of_complex_algebra_mul_closed :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    forall f :e real_members_of_complex_algebra X A,
    forall g :e real_members_of_complex_algebra X A,
      (fun x :e X => (f x) * (g x)) :e real_members_of_complex_algebra X A.

// Proof in RealAnalysis2.1780565774.mg
ProofArchived real_members_of_complex_algebra_smul_closed :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    forall c :e R,
    forall f :e real_members_of_complex_algebra X A,
      (fun x :e X => c * (f x)) :e real_members_of_complex_algebra X A.

// Proof in RealAnalysis2.1780565774.mg
ProofArchived is_C_function_algebra_imp_real_members_is_R_function_algebra :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    is_R_function_algebra X (real_members_of_complex_algebra X A).

(** Self-adjointness for the complex Stone–Weierstrass theorem. **)
//LLM self_adjoint_function_algebra : "#1 is a self-adjoint function algebra" | $\mathrm{self\_adjoint\_function\_algebra}(#1,#2)$
Definition self_adjoint_function_algebra :
  set ->
  set ->
  prop :=
  fun X A =>
    forall f :e A, (fun x :e X => conj_CSNo (f x)) :e A.

(** Projection from self-adjointness. **)
// Proof in RealAnalysis2.1780566560.mg
ProofArchived self_adjoint_function_algebra_conj_closed :
  forall X,
  forall A,
    self_adjoint_function_algebra X A ->
    forall f :e A,
      (fun x :e X => conj_CSNo (f x)) :e A.

(** The scalar 1/2 is a complex number. **)
// Proof in RealAnalysis2.1780566560.mg
ProofArchived complex_half_mem :
  (1 :/: 2) :e complex.

(** Pointwise negation is available in any complex function algebra, via
    scalar multiplication by -1. **)
// Proof in RealAnalysis2.1780566560.mg
ProofArchived is_C_function_algebra_neg_closed :
  forall X,
  forall A,
    is_C_function_algebra X A ->
  forall f :e A,
      (fun x :e X => (- 1) * (f x)) :e A.

(** The scalar `(-i)/2` is complex.  This is the coefficient that will be
    needed for the imaginary-part reduction. **)
// Proof in RealAnalysis2.1780566560.mg
ProofArchived complex_minus_i_half_mem :
  (mul_CSNo (minus_CSNo Complex_i) (1 :/: 2)) :e complex.

(** Named pointwise complex function combinators for the Stone–Weierstrass
    reduction. These avoid brittle higher-order inline lambda terms in
    closure proofs. **)
//LLM complex_conj_fun : "the complex conjugate function associated to #1" | $\mathrm{complex\_conj\_fun}(#1,#2)$
Definition complex_conj_fun :
  set ->
  set ->
  set :=
  fun X f =>
    (fun x :e X => conj_CSNo (f x)).

//LLM complex_add_fun : "the pointwise sum of complex-valued functions #1 and #2" | $\mathrm{complex\_add\_fun}(#1,#2,#3)$
Definition complex_add_fun :
  set ->
  set ->
  set ->
  set :=
  fun X f g =>
    (fun x :e X => add_CSNo (f x) (g x)).

//LLM complex_smul_fun : "the pointwise scalar multiple of the complex-valued function #1" | $\mathrm{complex\_smul\_fun}(#1,#2,#3)$
Definition complex_smul_fun :
  set ->
  set ->
  set ->
  set :=
  fun X c f =>
    (fun x :e X => c * (f x)).

// Real-part carrier combination `(f + conj f)/2`.
//LLM complex_real_combo_fun : "the real linear combination of complex-valued functions #1 and #2" | $\mathrm{complex\_real\_combo\_fun}(#1,#2)$
Definition complex_real_combo_fun :
  set ->
  set ->
  set :=
  fun X f =>
    complex_smul_fun
      X
      (1 :/: 2)
      (complex_add_fun X f (complex_conj_fun X f)).

// Imaginary-part carrier combination `(-i)/2` times `(f - conj f)`.
//LLM complex_imag_combo_fun : "the imaginary linear combination of complex-valued functions #1 and #2" | $\mathrm{complex\_imag\_combo\_fun}(#1,#2)$
Definition complex_imag_combo_fun :
  set ->
  set ->
  set :=
  fun X f =>
    complex_smul_fun
      X
      (mul_CSNo (minus_CSNo Complex_i) (1 :/: 2))
      (complex_add_fun
        X
        f
        (complex_smul_fun X (- 1) (complex_conj_fun X f))).

// Proof in RealAnalysis2.1780566927.mg
ProofArchived self_adjoint_function_algebra_conj_closed_named :
  forall X,
  forall A,
    self_adjoint_function_algebra X A ->
    forall f :e A,
      complex_conj_fun X f :e A.

(** Moved earlier than its narrative position in `real2.tex` so the
    multiplication bridge can use it without a forward reference. **)
// Proof in RealAnalysis2.1780580543.mg
ProofArchived mul_CSNo_of_pairs :
  forall x :e real,
  forall y :e real,
  forall u :e real,
  forall v :e real,
    mul_CSNo (SNo_pair x y) (SNo_pair u v)
      =
    SNo_pair (x * u + - (v * y)) (v * x + y * u).

Axiom is_C_function_algebra_smul_closed_named :
  forall X,
  forall A,
    is_C_function_algebra X A ->
    forall c :e complex,
    forall f :e A,
      complex_smul_fun X c f :e A.

(** A complex number with zero imaginary part is real. **)
// Proof in RealAnalysis2.1780567594.mg
ProofArchived complex_Im_zero_imp_real :
  forall z :e complex,
    Im z = 0 ->
    z :e real.

// Proof in RealAnalysis2.1780567594.mg
ProofArchived complex_conj_fun_eval :
  forall X,
  forall f,
  forall x :e X,
    complex_conj_fun X f x = conj_CSNo (f x).

// Proof in RealAnalysis2.1780582057.mg
ProofArchived complex_conj_fun_eval_complex :
  forall X,
  forall f,
  forall x :e X,
    f x :e complex ->
    complex_conj_fun X f x :e complex.

// Proof in RealAnalysis2.1780577819.mg
ProofArchived complex_add_fun_eval :
  forall X,
  forall f,
  forall g,
  forall x :e X,
    complex_add_fun X f g x = add_CSNo (f x) (g x).

// Proof in RealAnalysis2.1780582057.mg
ProofArchived complex_add_fun_eval_complex :
  forall X,
  forall f,
  forall g,
  forall x :e X,
    f x :e complex ->
    g x :e complex ->
    complex_add_fun X f g x :e complex.

Axiom complex_smul_fun_eval :
  forall X,
  forall c,
  forall f,
  forall x :e X,
    complex_smul_fun X c f x = c * (f x).

// Proof in RealAnalysis2.1780585014.mg
ProofArchived complex_real_combo_fun_eval :
  forall X,
  forall f,
  forall x :e X,
    complex_real_combo_fun X f x
      =
    (1 :/: 2) * (add_CSNo (f x) (conj_CSNo (f x))).

// Proof in RealAnalysis2.1780585014.mg
ProofArchived complex_imag_combo_fun_eval :
  forall X,
  forall f,
  forall x :e X,
    complex_imag_combo_fun X f x
      =
    (mul_CSNo (minus_CSNo Complex_i) (1 :/: 2))
      *
    (add_CSNo (f x) ((- 1) * (conj_CSNo (f x)))).

// Proof in RealAnalysis2.1780568982.mg
ProofArchived complex_real_combo_csno_eq_Re :
  forall z :e complex,
    mul_CSNo (1 :/: 2) (add_CSNo z (conj_CSNo z)) = Re z.

// Proof in RealAnalysis2.1780568982.mg
ProofArchived complex_real_combo_csno_real :
  forall z :e complex,
    mul_CSNo (1 :/: 2) (add_CSNo z (conj_CSNo z)) :e real.

// Proof in RealAnalysis2.1780572066.mg
ProofArchived complex_pair_eta :
  forall x :e real,
  forall y :e real,
    SNo_pair x y = add_CSNo x (mul_CSNo Complex_i y).

// Proof in RealAnalysis2.1780572066.mg
ProofArchived add_CSNo_of_pairs :
  forall x :e real,
  forall y :e real,
  forall u :e real,
  forall v :e real,
    add_CSNo (SNo_pair x y) (SNo_pair u v) = SNo_pair (x + u) (y + v).

