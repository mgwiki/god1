// Proof in RealAnalysis2.1780557463.mg
ProofArchived null_set_binunion_sum_merge_of_limits :
  forall n :e omega,
  forall eps :e R,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    0 < eps ->
    (forall k :e omega, 0 < rseq1 k) ->
    (forall k :e omega, 0 < rseq2 k) ->
    seq_limit
      (partial_sum_seq
        (fun k => pow_R (rseq1 k) n))
      (sum_series
        (fun k => pow_R (rseq1 k) n)) ->
    seq_limit
      (partial_sum_seq
        (fun k => pow_R (rseq2 k) n))
      (sum_series
        (fun k => pow_R (rseq2 k) n)) ->
    sum_series (fun k => pow_R (rseq1 k) n) < eps :/: 2 ->
    sum_series (fun k => pow_R (rseq2 k) n) < eps :/: 2 ->
  exists rseq :e setexp R omega,
    (forall k :e omega, 0 < rseq k)
    /\ sum_series (fun k => pow_R (rseq k) n) < eps.

(** Explicit fallback-free even/odd merge: cover shape only. **)
// Proof in RealAnalysis2.1780543312.mg
ProofArchived null_set_evenodd_cover_shape_merge_explicit :
  forall n :e omega,
  forall S,
  forall T,
  forall cseq1 :e setexp (Rn n) omega,
  forall rseq1 :e setexp R omega,
  forall cseq2 :e setexp (Rn n) omega,
  forall rseq2 :e setexp R omega,
    (forall k :e omega, 0 < rseq1 k) ->
    S c= (\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq1 k) (rseq1 k)) ->
    (forall k :e omega, 0 < rseq2 k) ->
    T c= (\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq2 k) (rseq2 k)) ->
    exists cseq :e setexp (Rn n) omega,
    exists rseq :e setexp R omega,
      (forall k :e omega, 0 < rseq k)
      /\ (S :\/: T) c= (\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq k) (rseq k)).

(** Explicit fallback-free even/odd merge: cover and summability in one witness package. **)
// Proof in RealAnalysis2.1780559648.mg
ProofArchived null_set_evenodd_cover_sum_merge_explicit_of_limits :
  forall n :e omega,
  forall eps :e R,
  forall S,
  forall T,
  forall cseq1 :e setexp (Rn n) omega,
  forall rseq1 :e setexp R omega,
  forall cseq2 :e setexp (Rn n) omega,
  forall rseq2 :e setexp R omega,
    0 < eps ->
    (forall k :e omega, 0 < rseq1 k) ->
    S c= (\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq1 k) (rseq1 k)) ->
    seq_limit
      (partial_sum_seq
        (fun k => pow_R (rseq1 k) n))
      (sum_series
        (fun k => pow_R (rseq1 k) n)) ->
    sum_series (fun k => pow_R (rseq1 k) n) < eps :/: 2 ->
    (forall k :e omega, 0 < rseq2 k) ->
    T c= (\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq2 k) (rseq2 k)) ->
    seq_limit
      (partial_sum_seq
        (fun k => pow_R (rseq2 k) n))
      (sum_series
        (fun k => pow_R (rseq2 k) n)) ->
    sum_series (fun k => pow_R (rseq2 k) n) < eps :/: 2 ->
    exists cseq :e setexp (Rn n) omega,
    exists rseq :e setexp R omega,
      (forall k :e omega, 0 < rseq k)
      /\ (S :\/: T) c= (\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq k) (rseq k))
      /\ sum_series (fun k => pow_R (rseq k) n) < eps.

(** Combined cover-and-summability merge step for binary unions of null-set witnesses.
    This isolates the remaining interleaving argument from the outer null-set proof. **)

