      (omega_SNo (ordsucc n) hsnomega)
      (factorial_SNo n hnomega)).
  - apply eq_sym.
    exact (factorial_ordsucc_eq_imp n hnomega).
Qed.

Theorem god1_permutation_group_ordinal_order_step :
