(** The Euler-pair product always expands to the cosine-square plus sine-square
    expression because `complex_exp` is already known to be complex-valued. **)
// Proof in RealAnalysis2.1783044062.mg
ProofArchived complex_euler_pair_expanded_eq_cos_sq_add_sin_sq :
  forall z :e complex,
    mul_CSNo
      (add_CSNo (complex_cos z) (mul_CSNo Complex_i (complex_sin z)))
      (add_CSNo
        (complex_cos z)
        (minus_CSNo (mul_CSNo Complex_i (complex_sin z))))
    =
    add_CSNo
      (mul_CSNo (complex_cos z) (complex_cos z))
      (mul_CSNo (complex_sin z) (complex_sin z)).

(** Algebraic transfer: if the Euler pair product is `1` and its expansion is
    the cosine/sine quadratic expression, then that quadratic expression is
    also `1`. **)
// Proof in RealAnalysis2.1783102260.mg
ProofArchived complex_cos_sq_add_complex_sin_sq_of_euler_pair_product_eq_1_and_expanded :
  (forall z :e complex,
    mul_CSNo
      (add_CSNo (complex_cos z) (mul_CSNo Complex_i (complex_sin z)))
      (add_CSNo
        (complex_cos z)
        (minus_CSNo (mul_CSNo Complex_i (complex_sin z))))
    = 1)
  ->
  (forall z :e complex,
    mul_CSNo
      (add_CSNo (complex_cos z) (mul_CSNo Complex_i (complex_sin z)))
      (add_CSNo
        (complex_cos z)
        (minus_CSNo (mul_CSNo Complex_i (complex_sin z))))
    =
    add_CSNo
      (mul_CSNo (complex_cos z) (complex_cos z))
      (mul_CSNo (complex_sin z) (complex_sin z)))
  ->
  forall z :e complex,
    add_CSNo
      (mul_CSNo (complex_cos z) (complex_cos z))
      (mul_CSNo (complex_sin z) (complex_sin z))
    = 1.

(** The archived Euler-pair expansion theorem packages the second hypothesis in
    the previous transfer lemma, so a product-equals-`1` hypothesis alone
    suffices. **)
