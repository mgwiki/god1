(** Parity identities for complex cosine and sine. **)
// Proof in RealAnalysis2.1782898466.mg
ProofArchived complex_cos_minus :
  forall z :e complex,
    complex_cos (minus_CSNo z) = complex_cos z.

// Proof in RealAnalysis2.1782898466.mg
ProofArchived complex_sin_minus :
  forall z :e complex,
    complex_sin (minus_CSNo z) = minus_CSNo (complex_sin z).

(** Moved earlier from the later translation-combine block so the
    `sec:complexexp` Euler-product bridge can use the generic complex-operation
    substitution layer without a forward reference. In `real2.tex` these belong
    with the generic complex-operation substitution material. **)
// Proof in RealAnalysis2.1780632857.mg
ProofArchived mul_CSNo_eq_subst :
  forall z1 z2 w1 w2,
    z1 = z2 ->
    w1 = w2 ->
    mul_CSNo z1 w1 = mul_CSNo z2 w2.

// Proof in RealAnalysis2.1780632857.mg
ProofArchived add_CSNo_eq_subst :
  forall z1 z2 w1 w2,
    z1 = z2 ->
    w1 = w2 ->
    add_CSNo z1 w1 = add_CSNo z2 w2.

(** The complex sums `(-1) + 1` and `1 + (-1)` both collapse to `0`. **)
// Proof in RealAnalysis2.1782857613.mg
ProofArchived complex_add_neg_one_1_eq_0 :
  add_CSNo (- 1) 1 = 0.

// Proof in RealAnalysis2.1782857613.mg
ProofArchived complex_add_1_neg_one_eq_0 :
  add_CSNo 1 (- 1) = 0.

(** The complex number `-1` is in `complex`. **)
// Proof in RealAnalysis2.1782858580.mg
ProofArchived complex_neg_one :
  (- 1) :e complex.

// Proof in RealAnalysis2.1782860327.mg
ProofArchived complex_eq_refl :
  forall z :e complex,
    z = z.

// Proof in RealAnalysis2.1782861233.mg
ProofArchived complex_add_eq_compat_left :
  forall x :e complex,
  forall y :e complex,
  forall z :e complex,
    y = z -> add_CSNo x y = add_CSNo x z.

// Proof in RealAnalysis2.1782861233.mg
ProofArchived complex_mul_eq_compat_left :
  forall x :e complex,
  forall y :e complex,
  forall z :e complex,
    y = z -> mul_CSNo x y = mul_CSNo x z.

// Proof in RealAnalysis2.1782862139.mg
ProofArchived complex_add_eq_compat_right :
  forall x :e complex,
  forall y :e complex,
  forall z :e complex,
    x = y -> add_CSNo x z = add_CSNo y z.

// Proof in RealAnalysis2.1782862139.mg
ProofArchived complex_mul_eq_compat_right :
  forall x :e complex,
  forall y :e complex,
  forall z :e complex,
    x = y -> mul_CSNo x z = mul_CSNo y z.

(** Under the exponential addition law, the factors `e^{iz}` and `e^{-iz}`
    multiply to `1`.  This is the direct algebraic input for the later
    Pythagorean identity. **)
// Proof in RealAnalysis2.1782854715.mg
ProofArchived complex_exp_mul_Complex_i_product_eq_1_of_add :
  (forall z :e complex,
  forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w))
  ->
  forall z :e complex,
    mul_CSNo
      (complex_exp (mul_CSNo Complex_i z))
      (complex_exp (minus_CSNo (mul_CSNo Complex_i z)))
    = 1.

(** Self-source alias for the local exponential product identity whose only
    hypothesis is the exponential addition law. **)


(** Route-explicit alias: derive the exponential product identity directly
    from the addition law. **)

(** The extra complex-valuedness hypothesis is redundant here: the Euler-product
    identity already follows from the exponential addition law alone. **)
// Proof in RealAnalysis2.1783093281.mg
ProofArchived complex_exp_mul_Complex_i_product_eq_1_of_add_and_in_complex :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  forall z :e complex,
    mul_CSNo
      (complex_exp (mul_CSNo Complex_i z))
      (complex_exp (minus_CSNo (mul_CSNo Complex_i z)))
    = 1.

(** Self-source alias for the local exponential product identity with explicit
    complex-valuedness hypothesis. **)


(** Route-explicit alias: derive the exponential product identity directly
    from the addition law, with redundant complex-valuedness input. **)

