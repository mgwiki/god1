(** Basic cancellation/rearrangement lemmas for addition on R. **)
(** (Proofs are omitted for now; fill these in when needed for improper-integral algebra.) **)

// Proof in 1777506143.mg
ProofArchived R_add_cancel_L :
  forall x y z :e R, x + y = x + z -> y = z.

// Proof in 1777506143.mg
ProofArchived R_add_cancel_R :
  forall x y z :e R, y + x = z + x -> y = z.

// Proof in 1777506143.mg
ProofArchived R_eq_tail_of_eq_head_add :
  forall u v w :e R, u = v + w -> w = (- v) + u.

End form15.

Section form16.

// Proof in 1777388823.mg
ProofArchived R_add_Lt_compat : forall x y z :e R, x < y -> x + z < y + z.

// Proof in 1777388823.mg
ProofArchived R_add_Le_compat : forall x y z :e R, x <= y -> x + z <= y + z.

// Proof in 1777388823.mg
ProofArchived R_pos_mul_Lt_compat : forall x y z :e R, 0 < z -> x < y -> x * z < y * z.

