(** real2.tex: continuity at x iff oscillation at x is 0. **)
// Proof in RealAnalysis2.1778912228.mg
ProofArchived Rn_continuous_at_iff_oscillation_zero :
  forall n :e omega,
  forall D,
  forall f : set -> set,
  forall x :e D,
    D c= (Rn n) ->
    bounded_fun D f ->
    (ms_continuous_at f D (Rn_dist n) R dist_R x <-> Rn_oscillation n D f x = 0).

// Note: `Rn_continuous_at_iff_oscillation_zero` is now fully proved/archived.

(** Supremum is monotone under inclusion of the domain. **)
// Proof in RealAnalysis2.1778918234.mg
ProofArchived sup_on_Le_of_domain_subq :
  forall D,
  forall E,
  forall f : set -> set,
    D c= E ->
    nonempty D ->
    bounded_fun E f ->
    sup_on f D <= sup_on f E.

(** If y is within delta of x, then the subspace ball around y of radius delta is contained in the subspace ball around x of radius delta+delta. **)
// Proof in RealAnalysis2.1778920490.mg
ProofArchived Rn_ball_subspace_subq_of_dist :
  forall n :e omega,
  forall D,
  forall x :e D,
  forall y :e D,
    D c= (Rn n) ->
    forall delta :e R,
      0 < delta ->
      Rn_dist n x y < delta ->
      (Rn_ball_subspace n D y delta) c= (Rn_ball_subspace n D x (delta + delta)).

(** If x is not in D and D is closed, then x has a neighborhood disjoint from D and hence disjoint from {x in D | eps <= osc(x)}. **)
// Proof in RealAnalysis2.1778920490.mg
ProofArchived Rn_oscillation_ge_set_open_compl_notinD :
  forall n :e omega,
  forall D,
  forall f : set -> set,
  forall eps :e R,
    D c= (Rn n) ->
    ms_closed (Rn n) (Rn_dist n) D ->
    bounded_fun D f ->
    forall x :e (Rn n),
      x /:e D ->
      exists delta :e R,
        0 < delta
        /\ forall y :e (Rn n),
             Rn_dist n x y < delta ->
             y :e ((Rn n) :\: (Rn_discontinuities_eps n D f eps)).

(** Main local estimate for the oscillation proof: if y is within delta=t0/2 of x and osc_delta(x,t0) < eps, then y is not in {y in D | eps <= osc(y)}. **)
// Proof in RealAnalysis2.1778920490.mg
ProofArchived Rn_oscillation_ge_set_open_compl_inD_contra :
  forall n :e omega,
  forall D,
  forall f : set -> set,
  forall eps :e R,
    D c= (Rn n) ->
    bounded_fun D f ->
    forall x :e D,
    forall t0 :e R,
      0 < t0 ->
      Rn_oscillation_delta n D f x t0 < eps ->
      forall y :e (Rn n),
        Rn_dist n x y < (t0 :/: 2) ->
        y :e (Rn_discontinuities_eps n D f eps) ->
        False.

(** If x is in D but not in {x in D | eps <= osc(x)}, then there is a neighborhood around x disjoint from that set. **)
// Proof in RealAnalysis2.1778920490.mg
ProofArchived Rn_oscillation_ge_set_open_compl_inD :
  forall n :e omega,
  forall D,
  forall f : set -> set,
  forall eps :e R,
    D c= (Rn n) ->
    bounded_fun D f ->
    forall x :e D,
      x /:e (Rn_discontinuities_eps n D f eps) ->
      exists delta :e R,
        0 < delta
        /\ forall y :e (Rn n),
             Rn_dist n x y < delta ->
             y :e ((Rn n) :\: (Rn_discontinuities_eps n D f eps)).

(** real2.tex: for closed D, the set {x in D : o(f,x) >= eps} is closed. **)
// Proof in RealAnalysis2.1778920490.mg
ProofArchived Rn_oscillation_ge_set_closed :
  forall n :e omega,
  forall D,
  forall f : set -> set,
  forall eps :e R,
    D c= (Rn n) ->
    ms_closed (Rn n) (Rn_dist n) D ->
    bounded_fun D f ->
    ms_closed
      (Rn n) (Rn_dist n)
      (Rn_discontinuities_eps n D f eps).

// Partial proof attempt saved in `scratch/Rn_oscillation_ge_set_closed_attempt.mg`.
// Partial proof attempt (this session) saved in `scratch/Rn_oscillation_ge_set_closed_attempt2.mg`.

End form84.

Section form85.

(** real2.tex: sec:jordansets (Jordan measurable sets) [scaffolding].
    Note: the book defines Jordan measurability via Riemann integrability of the indicator function.
    We add basic topological notions (interior/closure/boundary) in a metric space and use
    the equivalent characterization “boundary is null” as a working definition for now. **)

(** Metric-space boundedness: S is contained in some closed ball around a point. **)
//LLM ms_bounded : "#1 is bounded" | $\mathrm{ms\_bounded}(#1,#2,#3)$
Definition ms_bounded :
  set ->
  (set -> set -> set) ->
  set ->
  prop :=
  fun X d S =>
    S c= X
    /\ exists x :e X, exists R :e R,
         forall y :e S, d x y <= R.

(** Interior of S: points admitting a positive-radius ball contained in S. **)
//LLM ms_interior : "the interior of #1" | $\mathrm{ms\_interior}(#1,#2,#3)$
Definition ms_interior :
  set ->
  (set -> set -> set) ->
  set ->
  set :=
  fun X d S =>
    {x :e X |
      exists delta :e R,
        0 < delta /\ forall y :e X, d x y < delta -> y :e S}.

(** Closure of S: points x such that every ball B(x,delta) intersects S. **)
//LLM ms_closure : "the closure of #1" | $\mathrm{ms\_closure}(#1,#2,#3)$
Definition ms_closure :
  set ->
  (set -> set -> set) ->
  set ->
  set :=
  fun X d S =>
    {x :e X |
      forall delta :e R, 0 < delta ->
        exists y :e S, d x y < delta}.

(** Boundary of S: ∂S = closure(S) \ interior(S). **)
//LLM ms_boundary : "the boundary of #1" | $\mathrm{ms\_boundary}(#1,#2,#3)$
Definition ms_boundary :
  set ->
  (set -> set -> set) ->
  set ->
  set :=
  fun X d S =>
    (ms_closure X d S) :\: (ms_interior X d S).

(** Indicator function χ_S on a carrier X (returns 1 on S and 0 off S). **)
//LLM indicator_fun : "the indicator function of #1" | $\mathrm{indicator\_fun}(#1,#2,#3)$
Definition indicator_fun :
  set ->
  set ->
  set ->
  set :=
  fun X S x =>
    if x :e S then 1 else 0.

(** Set-encoded indicator function χ_S :e setexp R X (as a function with explicit domain X). **)
//LLM indicator_set : "the support set of the indicator function #1" | $\mathrm{indicator\_set}(#1,#2)$
Definition indicator_set :
  set ->
  set ->
  set :=
  fun X S =>
    (fun x :e X => if x :e S then 1 else 0).

(** Working definition: a Jordan measurable set in R^n is bounded and has null boundary. **)
//LLM jordan_measurable_Rn : "#1 is Jordan measurable in the real vector space of dimension #2" | $\mathrm{jordan\_measurable\_Rn}(#1,#2)$
Definition jordan_measurable_Rn :
  set ->
  set ->
  prop :=
  fun n S =>
    ms_bounded (Rn n) (Rn_dist n) S
    /\ is_null_set_Rn n (ms_boundary (Rn n) (Rn_dist n) S).

(** Projection from `ms_bounded`: the bounded set lies in the carrier. **)
// Proof in RealAnalysis2.1780523536.mg
ProofArchived ms_bounded_subq :
  forall X,
  forall d : set -> set -> set,
  forall S,
    ms_bounded X d S ->
    S c= X.

(** Interior is always a subset of the ambient carrier. **)
// Proof in RealAnalysis2.1780523536.mg
ProofArchived ms_interior_subq :
  forall X,
  forall d : set -> set -> set,
  forall S,
    ms_interior X d S c= X.

(** Closure is always a subset of the ambient carrier. **)
// Proof in RealAnalysis2.1780523536.mg
ProofArchived ms_closure_subq :
  forall X,
  forall d : set -> set -> set,
  forall S,
    ms_closure X d S c= X.

(** Boundary is always a subset of the ambient carrier. **)
// Proof in RealAnalysis2.1780523536.mg
ProofArchived ms_boundary_subq :
  forall X,
  forall d : set -> set -> set,
  forall S,
    ms_boundary X d S c= X.

(** The set-encoded indicator function is real-valued on the carrier. **)
// Proof in RealAnalysis2.1780523536.mg
ProofArchived indicator_set_in_setexp :
  forall X,
  forall S,
    indicator_set X S :e setexp R X.

(** A Jordan measurable set in `R^n` is in particular a subset of `R^n`. **)
// Proof in RealAnalysis2.1780523536.mg
ProofArchived jordan_measurable_Rn_subq_Rn :
  forall n,
  forall S,
    jordan_measurable_Rn n S ->
    S c= (Rn n).

(** Projection from `jordan_measurable_Rn`: boundedness. **)
// Proof in RealAnalysis2.1780523536.mg
ProofArchived jordan_measurable_Rn_bounded :
  forall n,
  forall S,
    jordan_measurable_Rn n S ->
    ms_bounded (Rn n) (Rn_dist n) S.

(** Projection from `jordan_measurable_Rn`: the boundary is null. **)
// Proof in RealAnalysis2.1780523536.mg
ProofArchived jordan_measurable_Rn_boundary_null :
  forall n,
  forall S,
    jordan_measurable_Rn n S ->
    is_null_set_Rn n (ms_boundary (Rn n) (Rn_dist n) S).

(** In a metric space, interior points of a subset of `X` are points of the subset itself. **)
// Proof in RealAnalysis2.1780523902.mg
ProofArchived ms_interior_subq_set :
  forall X,
  forall d : set -> set -> set,
  forall S,
    is_metric X d ->
    S c= X ->
    ms_interior X d S c= S.

(** Any subset of the carrier lies in its metric closure. **)
// Proof in RealAnalysis2.1780523902.mg
ProofArchived Subq_ms_closure :
  forall X,
  forall d : set -> set -> set,
  forall S,
    is_metric X d ->
    S c= X ->
    S c= ms_closure X d S.

(** On points of `X` that lie in `S`, the indicator set evaluates to `1`. **)
// Proof in RealAnalysis2.1780523902.mg
ProofArchived indicator_set_eval_in :
  forall X,
  forall S,
  forall x :e X,
    x :e S ->
    indicator_set X S x = 1.

(** On points of `X` outside `S`, the indicator set evaluates to `0`. **)
// Proof in RealAnalysis2.1780523902.mg
ProofArchived indicator_set_eval_out :
  forall X,
  forall S,
  forall x :e X,
    x /:e S ->
    indicator_set X S x = 0.

(** The boundary is always a subset of the closure. **)
// Proof in RealAnalysis2.1780523902.mg
ProofArchived ms_boundary_subq_closure :
  forall X,
  forall d : set -> set -> set,
  forall S,
    ms_boundary X d S c= ms_closure X d S.

(** Outside the carrier, the set-encoded indicator function evaluates to `0`. **)
// Proof in RealAnalysis2.1780523902.mg
ProofArchived indicator_set_eval_outside :
  forall X,
  forall S,
  forall x,
    x /:e X ->
    indicator_set X S x = 0.

(** The boundary of a Jordan measurable set is a subset of `R^n`. **)
// Proof in RealAnalysis2.1780523902.mg
ProofArchived jordan_measurable_Rn_boundary_subq_Rn :
  forall n,
  forall S,
    jordan_measurable_Rn n S ->
    ms_boundary (Rn n) (Rn_dist n) S c= (Rn n).

(** Interior is monotone with respect to set inclusion. **)
// Proof in RealAnalysis2.1780524991.mg
ProofArchived ms_interior_monotone :
  forall X,
  forall d : set -> set -> set,
  forall S,
  forall T,
    S c= T ->
    ms_interior X d S c= ms_interior X d T.

(** Closure is monotone with respect to set inclusion. **)
// Proof in RealAnalysis2.1780524991.mg
ProofArchived ms_closure_monotone :
  forall X,
  forall d : set -> set -> set,
  forall S,
  forall T,
    S c= T ->
    ms_closure X d S c= ms_closure X d T.

(** Every open subset of a metric space is contained in its interior. **)
// Proof in RealAnalysis2.1780524991.mg
ProofArchived ms_open_subq_ms_interior :
  forall X,
  forall d : set -> set -> set,
  forall V,
    ms_open X d V ->
    V c= ms_interior X d V.

(** The metric interior is open. **)
// Proof in RealAnalysis2.1780524991.mg
ProofArchived ms_open_ms_interior :
  forall X,
  forall d : set -> set -> set,
  forall S,
    is_metric X d ->
    ms_open X d (ms_interior X d S).

(** Interior is idempotent. **)
// Proof in RealAnalysis2.1780524991.mg
ProofArchived ms_interior_idem :
  forall X,
  forall d : set -> set -> set,
  forall S,
    is_metric X d ->
    ms_interior X d (ms_interior X d S) = ms_interior X d S.

(** Interior points lie in the closure. **)
// Proof in RealAnalysis2.1780524991.mg
ProofArchived ms_interior_subq_closure :
  forall X,
  forall d : set -> set -> set,
  forall S,
    is_metric X d ->
    S c= X ->
    ms_interior X d S c= ms_closure X d S.

(** Closure is idempotent in a metric space. **)
// Proof in RealAnalysis2.1780524991.mg
ProofArchived ms_closure_idem :
  forall X,
  forall d : set -> set -> set,
  forall S,
    is_metric X d ->
    S c= X ->
    ms_closure X d (ms_closure X d S) = ms_closure X d S.

(** The boundary of the closure is contained in the original boundary. **)
// Proof in RealAnalysis2.1780524991.mg
ProofArchived ms_boundary_closure_subq_boundary :
  forall X,
  forall d : set -> set -> set,
  forall S,
    is_metric X d ->
    S c= X ->
    ms_boundary X d (ms_closure X d S) c= ms_boundary X d S.

(** The boundary of the interior is contained in the original boundary. **)
// Proof in RealAnalysis2.1780524991.mg
ProofArchived ms_boundary_interior_subq_boundary :
  forall X,
  forall d : set -> set -> set,
  forall S,
    is_metric X d ->
    S c= X ->
    ms_boundary X d (ms_interior X d S) c= ms_boundary X d S.

(** A subset of a bounded set is bounded. **)
// Proof in RealAnalysis2.1780524991.mg
ProofArchived ms_bounded_subq_set :
  forall X,
  forall d : set -> set -> set,
  forall S,
  forall T,
    T c= S ->
    ms_bounded X d S ->
    ms_bounded X d T.

(** The closure of a bounded set is bounded. **)
// Proof in RealAnalysis2.1780525540.mg
ProofArchived ms_closure_bounded :
  forall X,
  forall d : set -> set -> set,
  forall S,
    is_metric X d ->
    ms_bounded X d S ->
    ms_bounded X d (ms_closure X d S).

(** The interior of a Jordan measurable set is Jordan measurable. **)
// Proof in RealAnalysis2.1780524991.mg
ProofArchived jordan_measurable_Rn_interior :
  forall n,
  forall S,
    jordan_measurable_Rn n S ->
    jordan_measurable_Rn n (ms_interior (Rn n) (Rn_dist n) S).

(** The closure of a Jordan measurable set is Jordan measurable. **)
// Proof in RealAnalysis2.1780525540.mg
ProofArchived jordan_measurable_Rn_closure :
  forall n,
  forall S,
    jordan_measurable_Rn n S ->
    jordan_measurable_Rn n (ms_closure (Rn n) (Rn_dist n) S).

(** The closure is contained in every closed superset. **)
// Proof in RealAnalysis2.1780526568.mg
ProofArchived ms_closure_subq_of_closed :
  forall X,
  forall d : set -> set -> set,
  forall S,
  forall E,
    is_metric X d ->
    S c= E ->
    ms_closed X d E ->
    ms_closure X d S c= E.

(** Choice function extracting a forbidden radius from a failed closure condition. **)
//LLM ms_closure_gap_witness : "a closure-gap witness for #1" | $\mathrm{ms\_closure\_gap\_witness}(#1,#2,#3,#4)$
Definition ms_closure_gap_witness :
  set ->
  (set -> set -> set) ->
  set ->
  set ->
  set :=
  fun X d S x =>
    Eps_i
      (fun delta =>
        ~(delta :e R -> 0 < delta -> exists y :e S, d x y < delta)).

(** The gap witness extracted from failure of closure-approximation is a positive
    real radius with no point of `S` inside that radius. **)
// Proof in RealAnalysis2.1780528387.mg
ProofArchived ms_closure_gap_witness_spec :
  forall X,
  forall d : set -> set -> set,
  forall S,
  forall x,
    ~(forall delta :e R, 0 < delta -> exists y :e S, d x y < delta) ->
    (ms_closure_gap_witness X d S x) :e R
    /\ (0 < (ms_closure_gap_witness X d S x)
        /\ ~(exists y :e S, d x y < (ms_closure_gap_witness X d S x))).

(** The half-radius ball around a closure-gap witness point stays outside the closure. **)
// Proof in RealAnalysis2.1780529600.mg
ProofArchived ms_closure_gap_halfball_subq_complement :
  forall X,
  forall d : set -> set -> set,
  forall S,
  forall x,
    is_metric X d ->
    S c= X ->
    x :e X ->
    ~(forall delta :e R, 0 < delta -> exists y :e S, d x y < delta) ->
    forall z :e X,
      d x z < ((ms_closure_gap_witness X d S x) :/: 2) ->
      z :e X :\: ms_closure X d S.

(** The closure of a subset of `X` is closed. **)
// Proof in RealAnalysis2.1780529600.mg
ProofArchived ms_closed_ms_closure :
  forall X,
  forall d : set -> set -> set,
  forall S,
    is_metric X d ->
    S c= X ->
    ms_closed X d (ms_closure X d S).

(** If an open set lies in `A`, then it lies in the interior of `A`. **)
// Proof in RealAnalysis2.1780526568.mg
ProofArchived ms_open_subq_ms_interior_of_subq :
  forall X,
  forall d : set -> set -> set,
  forall V,
  forall A,
    ms_open X d V ->
    V c= A ->
    V c= ms_interior X d A.

(** The closure of an intersection is contained in the intersection of the closures. **)
// Proof in RealAnalysis2.1780526568.mg
ProofArchived ms_closure_binintersect_subq :
  forall X,
  forall d : set -> set -> set,
  forall S,
  forall T,
    ms_closure X d (S :/\: T) c= (ms_closure X d S) :/\: (ms_closure X d T).

(** Interior distributes over binary intersection in a metric space. **)
// Proof in RealAnalysis2.1780526568.mg
ProofArchived ms_interior_binintersect_eq :
  forall X,
  forall d : set -> set -> set,
  forall S,
  forall T,
    is_metric X d ->
    S c= X ->
    T c= X ->
    ms_interior X d (S :/\: T) = (ms_interior X d S) :/\: (ms_interior X d T).

(** The boundary of an intersection is contained in the union of the boundaries. **)
// Proof in RealAnalysis2.1780526568.mg
ProofArchived ms_boundary_binintersect_subq_binunion :
  forall X,
  forall d : set -> set -> set,
  forall S,
  forall T,
    is_metric X d ->
    S c= X ->
    T c= X ->
    ms_boundary X d (S :/\: T) c=
      (ms_boundary X d S) :\/: (ms_boundary X d T).

(** Binary intersections preserve Jordan measurability. **)

End form85.

Section form86.

(** real2.tex: sec:mvgreenstheorem (Green's theorem) [scaffolding]. **)

(** Type-I domain in R^2: region between two graphs y=f(x) and y=g(x) over (a,b). **)
//LLM typeI_domain_R2 : "a type-#1 domain in #2^2" | $\mathrm{typeI\_domain\_R2}(#1,#2,#3,#4)$
Definition typeI_domain_R2 :
  set ->
  set ->
  (set -> set) ->
  (set -> set) ->
  set :=
  fun a b f g =>
    {p :e (Rn 2) |
      (p 0) :e (Ioo a b)
      /\ (p 1) :e (Ioo (f (p 0)) (g (p 0)))}.

End form86.

Section form87.

(** real2.tex: sec:mvchangeofvars (Change of variables) [scaffolding]. **)

(** Jacobian matrix of f at x: the matrix associated to the derivative linear map. **)
//LLM sv_jacobian_matrix : "the Jacobian matrix of #1" | $\mathrm{sv\_jacobian\_matrix}(#1,#2,#3,#4,#5)$
Definition sv_jacobian_matrix :
  set ->
  set ->
  (set -> set) ->
  set ->
  set ->
  set :=
  fun n m f U x =>
    matrix_of_linear_Rn n m (sv_derivative_at n m f U x).

(** Placeholder for the Jacobian determinant J_f(x) in R^n.
    The determinant machinery is added later; for now this is a stub definition. **)
//REAL2:105763 jacobian_det : "the Jacobian determinant of #2 at #4" | $J_{#2}(#4)$
//LLM jacobian_det : "the Jacobian determinant of #2 at #4" | $J_{#2}(#4)$
Definition jacobian_det :
  set ->
  (set -> set) ->
  set ->
  set ->
  set :=
  fun n f U x =>
    0.

End form87.

