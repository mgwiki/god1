Section TaggedSets.
Let tag : set -> set := fun alpha => SetAdjoin alpha {1}.
Postfix ' 100 := tag.

// Proof in 100thms_12b.mg
ProofArchived not_TransSet_Sing1 : ~TransSet {1}.

// Proof in 100thms_12b.mg
ProofArchived not_ordinal_Sing1 : ~ordinal {1}.

// Proof in 100thms_12b.mg
ProofArchived tagged_not_ordinal : forall y, ~ordinal (y ').

// Proof in 100thms_12b.mg
ProofArchived tagged_notin_ordinal : forall alpha y, ordinal alpha -> (y ') /:e alpha.

