Theorem god1_s32_theorem3_corollary_coprime_polynomials_bezout :
  forall K, forall add mul:set -> set -> set,
  forall n :e omega,
  forall f :e (multivariate_polynomial_ring K add 1) :^: n,
    field K add mul ->
    let P := multivariate_polynomial_ring K add 1 in
