    (fun i => fraction_class K add mul (c i,b i)).
admit.
//GOD1PRF:963373 Now the proof of Lemma 5 ; start with $n=2$. Since $b_{1}$ and $b_{2}$ are coprime, there exist $u_{1}, u_{2} \in \mathrm{~K}$ such that
claim h_s31_l5_theorem1_formal_call :
  forall K0, forall add0 mul0:set -> set -> set, forall x0 y0 :e K0,
    principal_ideal_domain K0 add0 mul0 ->
    (coprime_elements K0 add0 mul0 x0 y0
    <-> exists u0 v0 :e K0,
      add0 (mul0 u0 x0) (mul0 v0 y0) = ring_one K0 mul0).
apply god1_s31_theorem1_bezout_coprime_interface.
claim h_s31_l5_two_denominator_case : forall b1 b2 :e K,
  coprime_elements K add mul b1 b2 ->
  exists u1 u2 :e K,
    add (mul u1 b1) (mul u2 b2) = ring_one K mul.
admit.
//GOD1PRF:963683 which establishes Lemma 5 in this case. In the general case we argue by induction on $n$; since (Corollary to Theorem 6) $b_{n}$ is prime to $b_{1} \ldots b_{n-1}$, and since the lemma has already been proved for a product of two factors, we can write
claim h_s31_l5_theorem6_corollary_formal_call :
  forall K0, forall add0 mul0:set -> set -> set,
  forall n0 :e omega, forall x0 :e K0, forall y0 :e K0 :^: n0,
    principal_ideal_domain K0 add0 mul0 ->
    x0 <> ring_zero K0 add0 ->
    (forall i :e n0, y0 i <> ring_zero K0 add0) ->
    (forall i :e n0, coprime_elements K0 add0 mul0 x0 (y0 i)) ->
    coprime_elements K0 add0 mul0 x0
      (ring_finite_product K0 add0 mul0 n0 (fun i => y0 i)).
apply god1_s31_theorem6_corollary_coprime_to_each_factor.
claim h_s31_l5_last_denominator_coprime :
  coprime_elements K add mul (b (Union n))
