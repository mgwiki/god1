//GOD1:804975 exponent_total_degree : "the total degree of exponent tuple #2" | $|#2|$
Definition exponent_total_degree : set -> (set -> set) -> set :=
  fun n exponent =>
    ring_finite_sum omega add_SNo n (fun i => exponent i).

//GOD1:804975 polynomial_total_degree : "the total degree of polynomial #5, with omega representing minus infinity" | $d^0(#5)$
Definition polynomial_total_degree :
  set -> (set -> set -> set) -> set -> set -> set :=
  fun K add n f =>
    if f = (fun exponent :e omega :^: n => ring_zero K add)
    then omega
    else Eps_i (fun d =>
      d :e omega
      /\ (exists exponent :e omega :^: n,
        f exponent <> ring_zero K add
        /\ exponent_total_degree n (fun i => exponent i) = d)
      /\ forall exponent :e omega :^: n,
        f exponent <> ring_zero K add ->
        exponent_total_degree n (fun i => exponent i) c= d).

//GOD1:804975 polynomial_partial_degree : "the degree of polynomial #6 in indeterminate #5, with omega representing minus infinity" | $d_{X_{#5}}(#6)$
Definition polynomial_partial_degree :
  set -> (set -> set -> set) -> set -> set -> set -> set :=
  fun K add n i f =>
    if f = (fun exponent :e omega :^: n => ring_zero K add)
    then omega
    else Eps_i (fun d =>
      d :e omega
      /\ (exists exponent :e omega :^: n,
        f exponent <> ring_zero K add /\ exponent i = d)
      /\ forall exponent :e omega :^: n,
        f exponent <> ring_zero K add -> exponent i c= d).

//GOD1:805532 homogeneous_polynomial : "polynomial #6 is homogeneous of total degree #5" | $#6\text{ is homogeneous of degree }#5$
Definition homogeneous_polynomial :
  set -> (set -> set -> set) -> set -> set -> set -> prop :=
  fun K add n d f =>
    f :e multivariate_polynomial_ring K add n
    /\ forall exponent :e omega :^: n,
      f exponent <> ring_zero K add ->
      exponent_total_degree n (fun i => exponent i) = d.

//GOD1:806412 polynomial_degree_addition : "addition of polynomial degrees, with omega representing minus infinity" | $#1+#2$
Definition polynomial_degree_addition : set -> set -> set :=
  fun d e => if d = omega \/ e = omega then omega else d + e.

//GOD1:806412 polynomial_degree_le : "comparison of polynomial degrees, with omega representing minus infinity" | $#1\leq #2$
Definition polynomial_degree_le : set -> set -> prop :=
  fun d e => d = omega \/ (e <> omega /\ d c= e).

Theorem god1_polynomial_degree_bounds :
  forall K, forall add mul:set -> set -> set,
  forall n :e omega, forall f g :e multivariate_polynomial_ring K add n,
    commutative_ring K add mul ->
    (polynomial_degree_le
      (polynomial_total_degree K add n
        (polynomial_addition K add n f g))
      (polynomial_total_degree K add n f)
    \/ polynomial_degree_le
      (polynomial_total_degree K add n
        (polynomial_addition K add n f g))
      (polynomial_total_degree K add n g))
    /\ polynomial_degree_le
      (polynomial_total_degree K add n
        (polynomial_multiplication K add mul n f g))
      (polynomial_degree_addition
        (polynomial_total_degree K add n f)
        (polynomial_total_degree K add n g)).
let K add mul.
let n.
assume hn.
let f.
assume hf.
let g.
assume hg hRing.
apply andI.
//GOD1PRF:806363 The total degree of $f$ is denoted by $d^{0}(f)$, just as in the case of a single indeterminate. We have inequalities
claim h_s27_degree_bounds_statement :
  polynomial_degree_le
    (polynomial_total_degree K add n (polynomial_addition K add n f g))
    (polynomial_total_degree K add n f)
  \/ polynomial_degree_le
    (polynomial_total_degree K add n (polynomial_addition K add n f g))
    (polynomial_total_degree K add n g).
admit.
//GOD1PRF:806498 d^{0}(f+g) & \leqslant \max \left(d^{0}(f), d^{0}(g)\right)  \tag{4}\\
claim h_s27_degree_sum_bound :
  polynomial_degree_le
    (polynomial_total_degree K add n (polynomial_addition K add n f g))
    (polynomial_total_degree K add n f)
  \/ polynomial_degree_le
    (polynomial_total_degree K add n (polynomial_addition K add n f g))
    (polynomial_total_degree K add n g).
admit.
//GOD1PRF:806569 d^{0}(f g) & \leqslant d^{0}(f)+d^{0}(g) \tag{5}
claim h_s27_degree_product_bound :
  polynomial_degree_le
    (polynomial_total_degree K add n
      (polynomial_multiplication K add mul n f g))
    (polynomial_degree_addition
      (polynomial_total_degree K add n f)
      (polynomial_total_degree K add n g)).
admit.
//GOD1PRF:806633 For if $p, q$ are the degrees of $f, g$ respectively, then we may write
claim h_s27_degree_homogeneous_decomposition : exists F G:set -> set,
  forall r :e omega,
    homogeneous_polynomial K add n r (F r)
    /\ homogeneous_polynomial K add n r (G r).
admit.
//GOD1PRF:806774 (in general we denote by $u_{r}$ the sum of the monomials of total degree $r$ in a polynomial $u$ ). Adding term by term, we see that $f+g$ does not contain monomials whose degree exceeds the greater of $p$ and $q$, whence (4) follows. Also $f g$ is the sum of the products $f_{i} g_{j}$, and clearly each $f_{i} g_{j}$ is homogeneous of degree $i+j$; hence the monomials which effectively appear in the product $f g$ are of total degree at most $p+q$, which proves (5).
claim h_s27_degree_bounds_conclusion :
  polynomial_degree_le
    (polynomial_total_degree K add n
      (polynomial_multiplication K add mul n f g))
    (polynomial_degree_addition
      (polynomial_total_degree K add n f)
      (polynomial_total_degree K add n g)).
admit.
Admitted.

Theorem god1_s27_section2_degree_conventions :
  forall d,
    polynomial_degree_addition omega d = omega
    /\ polynomial_degree_addition d omega = omega.
let d.
apply andI.
Admitted.

Theorem god1_s27_theorem1_polynomial_ring_over_domain_and_product_degree :
  forall K, forall add mul:set -> set -> set,
  forall n :e omega, 0 :e n ->
    integral_domain K add mul ->
    integral_domain
      (multivariate_polynomial_ring K add n)
      (polynomial_addition K add n)
      (polynomial_multiplication K add mul n)
    /\ forall f g :e multivariate_polynomial_ring K add n,
      polynomial_total_degree K add n
        (polynomial_multiplication K add mul n f g)
      = polynomial_degree_addition
        (polynomial_total_degree K add n f)
        (polynomial_total_degree K add n g).
let K add mul.
let n.
assume hn hPositive hDomain.
apply andI.
//GOD1PRF:807351 theorem 1. Let K be a commutative integral domain. Then, for each integer $n \geqslant 1$, the ring $\mathrm{K}\left[\mathrm{X}_{1}, \ldots, \mathrm{X}_{n}\right]$ is an integral domain. Moreover, for all $f, g \in \mathrm{~K}\left[\mathrm{X}_{1}, \ldots, \mathrm{X}_{n}\right]$, we have
claim h_s27_t1_statement :
  integral_domain
    (multivariate_polynomial_ring K add n)
    (polynomial_addition K add n)
    (polynomial_multiplication K add mul n)
  /\ forall f g :e multivariate_polynomial_ring K add n,
    polynomial_total_degree K add n
      (polynomial_multiplication K add mul n f g)
    = polynomial_degree_addition
      (polynomial_total_degree K add n f)
      (polynomial_total_degree K add n g).
admit.
//GOD1PRF:807676 To show that $\mathrm{K}\left[\mathrm{X}_{1}, \ldots, \mathrm{X}_{n}\right]$ is an integral domain we use the relation
claim h_s27_t1_recursive_polynomial_ring_reduction :
  integral_domain
    (multivariate_polynomial_ring K add n)
    (polynomial_addition K add n)
    (polynomial_multiplication K add mul n).
admit.
//GOD1PRF:807958 this allows us, arguing by induction on $n(*)$, to reduce to the case $n=1$.\\
claim h_s27_t1_induction_reduces_to_one_variable :
  integral_domain
    (multivariate_polynomial_ring K add 1)
    (polynomial_addition K add 1)
    (polynomial_multiplication K add mul 1) ->
  integral_domain
    (multivariate_polynomial_ring K add n)
    (polynomial_addition K add n)
    (polynomial_multiplication K add mul n).
admit.
//GOD1PRF:808174 be two non-zero polynomials in one indeterminate, with coefficients in K . It is clear that $f g$ contains a single term of degree $p+q$, namely
claim h_s27_t1_one_variable_leading_term :
  forall f g :e multivariate_polynomial_ring K add 1,
    f <> (fun exponent :e omega :^: 1 => ring_zero K add) ->
    g <> (fun exponent :e omega :^: 1 => ring_zero K add) ->
    polynomial_multiplication K add mul 1 f g
      <> (fun exponent :e omega :^: 1 => ring_zero K add).
admit.
//GOD1PRF:808356 since K is an integral domain, we have $a_{p} b_{q} \neq 0$ and therefore $f g \neq 0$. This proves the first assertion of the theorem.
claim h_s27_t1_domain_conclusion :
  integral_domain
    (multivariate_polynomial_ring K add n)
    (polynomial_addition K add n)
    (polynomial_multiplication K add mul n).
admit.
//GOD1PRF:808493 For the second assertion (in the general case of several indeterminates) we write
claim h_s27_t1_homogeneous_decomposition :
  forall f :e multivariate_polynomial_ring K add n,
    exists F:set -> set, forall r :e omega,
      homogeneous_polynomial K add n r (F r).
admit.
//GOD1PRF:808705 it is clear that the homogeneous part of total degree $p+q$ in $f g$ is $f_{p} g_{q}$; since we know already that $\mathrm{K}\left[\mathrm{X}_{1}, \ldots, \mathrm{X}_{n}\right]$ is an integral domain, we have $f_{p} g_{q} \neq 0$. Hence $f g$ is of total degree $p+q$, and the proof is complete.
claim h_s27_t1_product_degree_nonzero_case :
  forall f g :e multivariate_polynomial_ring K add n,
    f <> (fun exponent :e omega :^: n => ring_zero K add) ->
    g <> (fun exponent :e omega :^: n => ring_zero K add) ->
    polynomial_total_degree K add n
      (polynomial_multiplication K add mul n f g)
    = polynomial_degree_addition
      (polynomial_total_degree K add n f)
      (polynomial_total_degree K add n g).
admit.
//GOD1PRF:809002 Remark 4. In fact we have proved that
claim h_s27_t1_nonzero_scope : forall f g :e multivariate_polynomial_ring K add n,
  f <> (fun exponent :e omega :^: n => ring_zero K add) ->
  g <> (fun exponent :e omega :^: n => ring_zero K add) ->
  polynomial_total_degree K add n
    (polynomial_multiplication K add mul n f g)
  = polynomial_degree_addition
    (polynomial_total_degree K add n f)
    (polynomial_total_degree K add n g).
admit.
//GOD1PRF:809077 only under the assumption that $f$ and $g$ are non-zero. But if $f=0$ the formula becomes $-\infty=-\infty+d^{0}(g)$ and therefore is true by virtue of our conventions (see section 2) for the symbol $-\infty$.\\
claim h_s27_t1_section2_degree_convention_formal_call :
  forall d,
    polynomial_degree_addition omega d = omega
    /\ polynomial_degree_addition d omega = omega.
apply god1_s27_section2_degree_conventions.
claim h_s27_t1_zero_cases : forall f g :e multivariate_polynomial_ring K add n,
  (f = (fun exponent :e omega :^: n => ring_zero K add)
    \/ g = (fun exponent :e omega :^: n => ring_zero K add)) ->
  polynomial_total_degree K add n
    (polynomial_multiplication K add mul n f g)
  = polynomial_degree_addition
    (polynomial_total_degree K add n f)
    (polynomial_total_degree K add n g).
admit.
Admitted.

(** § 28. Polynomial functions. **)

//GOD1:810103 polynomial_evaluation : "the value of polynomial #9 at #10 in #4" | $#9(#10)$
Definition polynomial_evaluation :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> set -> (set -> set) -> set :=
  fun K addK mulK L addL mulL n f u =>
    polynomial_value_in_ring_elements L addL mulL K n u
      (fun exponent => f exponent).

//GOD1:810103 polynomial_zero : "#10 is a zero of polynomial #9" | $#9(#10)=0$
Definition polynomial_zero :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> set -> (set -> set) -> prop :=
  fun K addK mulK L addL mulL n f u =>
    (fun i :e n => u i) :e L :^: n
    /\ polynomial_evaluation K addK mulK L addL mulL n f u
      = ring_zero L addL.

//GOD1:810103 polynomial_function : "#10 is a polynomial function on #4^#7 with coefficients in #1" | $#10:#4^{#7}\to #4$
Definition polynomial_function :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> prop :=
  fun K addK mulK L addL mulL n phi =>
    exists f :e multivariate_polynomial_ring K addK n,
      forall u :e L :^: n,
        phi u = polynomial_evaluation K addK mulK L addL mulL n f
          (fun i => u i).

//GOD1:810103 polynomial_mapping : "#11 is a polynomial mapping from #4^#7 to #4^#8 with coefficients in #1" | $#11:#4^{#7}\to #4^{#8}$
Definition polynomial_mapping :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> set -> (set -> set) -> prop :=
  fun K addK mulK L addL mulL n r phi =>
    (forall u :e L :^: n, phi u :e L :^: r)
    /\ forall j :e r,
      polynomial_function K addK mulK L addL mulL n
        (fun u => phi u j).

Theorem god1_s28_lemma2_root_bound_interface :
  forall K, forall add mul:set -> set -> set,
  forall f :e multivariate_polynomial_ring K add 1, forall d :e omega,
    integral_domain K add mul ->
    polynomial_total_degree K add 1 f = d ->
    finite {a :e K|polynomial_zero K add mul K add mul 1 f (fun i => a)}
    /\ finite_cardinality
      {a :e K|polynomial_zero K add mul K add mul 1 f (fun i => a)} c= d.
let K add mul f.
assume hf.
let d.
assume hd hDomain hDegree.
apply andI.
Admitted.

Theorem god1_s28_theorem1_one_variable_interface :
  forall K, forall add mul:set -> set -> set,
  forall f g :e multivariate_polynomial_ring K add 1,
    integral_domain K add mul -> not (finite K) ->
    (f = g <-> forall x :e K :^: 1,
      polynomial_evaluation K add mul K add mul 1 f (fun i => x i)
      = polynomial_evaluation K add mul K add mul 1 g (fun i => x i)).
let K add mul f.
assume hf.
let g.
assume hg hDomain hInfinite.
apply iffI.
Admitted.

Theorem god1_polynomial_evaluation_homomorphism_and_kernel :
  forall L, forall add mul:set -> set -> set, forall K,
  forall n :e omega, forall u :e L :^: n,
    commutative_ring L add mul -> subring L add mul K ->
    let P := multivariate_polynomial_ring K add n in
    let addP := polynomial_addition K add n in
    let mulP := polynomial_multiplication K add mul n in
    let ev := polynomial_evaluation K add mul L add mul n in
    (forall f g :e P,
      ev (addP f g) (fun i => u i)
        = add (ev f (fun i => u i)) (ev g (fun i => u i))
      /\ ev (mulP f g) (fun i => u i)
        = mul (ev f (fun i => u i)) (ev g (fun i => u i)))
    /\ {ev f (fun i => u i)|f :e P}
      = subring_generated_by L add mul K {u i|i :e n}
    /\ {f :e P|ev f (fun i => u i) = ring_zero L add}
      = {f :e P|algebraic_relation L add mul K n
        (fun i => u i) (fun exponent => f exponent)}.
let L add mul K.
let n.
assume hn.
let u.
assume hu hL hK.
apply andI.
//GOD1PRF:813385 Let K be a commutative ring, L a commutative ring containing K , and $n$ an integer $\geqslant 1$. Given elements $u_{1}, \ldots, u_{n} \in \mathrm{~L}$, consider the mapping
claim h_s28_evaluation_mapping : forall f :e multivariate_polynomial_ring K add n,
  polynomial_evaluation K add mul L add mul n f (fun i => u i) :e L.
admit.
//GOD1PRF:814016 On the other hand, the mapping $v$ is a ring homomorphism; in other words (since (3) shows that $v(1)=1$ ) we have the relations
claim h_s28_evaluation_homomorphism : forall f g :e multivariate_polynomial_ring K add n,
  polynomial_evaluation K add mul L add mul n
    (polynomial_addition K add n f g) (fun i => u i)
    = add
      (polynomial_evaluation K add mul L add mul n f (fun i => u i))
      (polynomial_evaluation K add mul L add mul n g (fun i => u i))
  /\ polynomial_evaluation K add mul L add mul n
    (polynomial_multiplication K add mul n f g) (fun i => u i)
    = mul
      (polynomial_evaluation K add mul L add mul n f (fun i => u i))
      (polynomial_evaluation K add mul L add mul n g (fun i => u i)).
admit.
//GOD1PRF:814945 which is the relation (5). The proof of (6) is analogous, but slightly more complicated.\\
claim h_s28_evaluation_product_relation :
  forall f g :e multivariate_polynomial_ring K add n,
    polynomial_evaluation K add mul L add mul n
      (polynomial_multiplication K add mul n f g) (fun i => u i)
    = mul
      (polynomial_evaluation K add mul L add mul n f (fun i => u i))
      (polynomial_evaluation K add mul L add mul n g (fun i => u i)).
admit.
//GOD1PRF:815036 Moreover, it is clear that the properties (3), (4), (5)and (6) characterize the mapping $v$, and that the image under $v$ of the polynomial ring $\mathrm{K}\left[\mathrm{X}_{1}, \ldots, \mathrm{X}_{n}\right]$ is precisely the subring $\mathrm{K}\left[u_{1}, \ldots, u_{n}\right]$ of L generated by K and the elements $u_{1}, \ldots, u_{n}$ of L .
claim h_s28_evaluation_image :
  {polynomial_evaluation K add mul L add mul n f (fun i => u i)|
    f :e multivariate_polynomial_ring K add n}
  = subring_generated_by L add mul K {u i|i :e n}.
admit.
//GOD1PRF:815384 Remark 1. The kernel of the homomorphism $v$ consists of all polynomials $f$ such that $f\left(u_{1}, \ldots, u_{n}\right)=0$, i.e., of all families of elements $\left(a_{r_{1} \ldots r_{n}}\right)$ of K , almost all zero, such that
claim h_s28_evaluation_kernel :
  {f :e multivariate_polynomial_ring K add n|
    polynomial_evaluation K add mul L add mul n f (fun i => u i)
      = ring_zero L add}
  = {f :e multivariate_polynomial_ring K add n|
    polynomial_zero K add mul L add mul n f (fun i => u i)}.
admit.
//GOD1PRF:815692 in other words, the kernel of $v$ consists of the algebraic relations between $u_{1}, \ldots, u_{n}$ with coefficients in K , as defined in § 26, section 2. In practice we make no distinction between these algebraic relations and the polynomials $f$ with coefficients in K such that $f\left(u_{1}, \ldots, u_{n}\right)=0$.
claim h_s28_s26_section2_algebraic_relation_formal_call :
  {f :e multivariate_polynomial_ring K add n|
    polynomial_evaluation K add mul L add mul n f (fun i => u i)
      = ring_zero L add}
  = {f :e multivariate_polynomial_ring K add n|
    algebraic_relation L add mul K n
      (fun i => u i) (fun exponent => f exponent)}.
admit.
Admitted.

Theorem god1_s28_theorem1_polynomials_over_infinite_domain_determined_by_values :
  forall K, forall add mul:set -> set -> set,
  forall n :e omega,
  forall f g :e multivariate_polynomial_ring K add n,
    integral_domain K add mul -> not (finite K) ->
    (f = g <-> forall x :e K :^: n,
      polynomial_evaluation K add mul K add mul n f (fun i => x i)
      = polynomial_evaluation K add mul K add mul n g (fun i => x i)).
let K add mul.
let n.
assume hn.
let f.
assume hf.
let g.
assume hg hDomain hInfinite.
apply iffI.
//GOD1PRF:818772 theorem 1. Let $f, g$ be two polynomials in $n$ indeterminates with coefficients in an infinite integral domain K. For $f$ and $g$ to be equal it is necessary and sufficient that
claim h_s28_t1_statement :
  f = g <-> forall x :e K :^: n,
    polynomial_evaluation K add mul K add mul n f (fun i => x i)
    = polynomial_evaluation K add mul K add mul n g (fun i => x i).
admit.
//GOD1PRF:819017 By considering the polynomial $f-g$, it is clearly enough to show that, for every polynomial $h \in \mathrm{~K}\left[\mathrm{X}_{1}, \ldots, \mathrm{X}_{n}\right]$, the relation
claim h_s28_t1_zero_polynomial_reduction :
  (forall h :e multivariate_polynomial_ring K add n,
    (forall x :e K :^: n,
      polynomial_evaluation K add mul K add mul n h (fun i => x i)
        = ring_zero K add) ->
    h = (fun exponent :e omega :^: n => ring_zero K add)) ->
  f = g <-> forall x :e K :^: n,
    polynomial_evaluation K add mul K add mul n f (fun i => x i)
    = polynomial_evaluation K add mul K add mul n g (fun i => x i).
admit.
//GOD1PRF:819256 implies $h=0$. The proof of this is in several steps.\\
claim h_s28_t1_zero_criterion : forall h :e multivariate_polynomial_ring K add n,
  (forall x :e K :^: n,
    polynomial_evaluation K add mul K add mul n h (fun i => x i)
      = ring_zero K add) ->
  h = (fun exponent :e omega :^: n => ring_zero K add).
admit.
//GOD1PRF:821365 In the case of polynomials in one indeterminate, Theorem 1 follows immediately from Lemma 2, since the latter shows that, if the ground ring K is an integral domain, a polynomial $h \in \mathrm{~K}[\mathrm{X}]$ cannot have an infinite number of zeros in K unless it is the zero polynomial.
claim h_s28_t1_lemma2_formal_call :
  forall K0, forall add0 mul0:set -> set -> set,
  forall h0 :e multivariate_polynomial_ring K0 add0 1, forall d0 :e omega,
    integral_domain K0 add0 mul0 ->
    polynomial_total_degree K0 add0 1 h0 = d0 ->
    finite {a :e K0|polynomial_zero K0 add0 mul0 K0 add0 mul0 1 h0 (fun i => a)}
    /\ finite_cardinality
      {a :e K0|polynomial_zero K0 add0 mul0 K0 add0 mul0 1 h0 (fun i => a)} c= d0.
apply god1_s28_lemma2_root_bound_interface.
claim h_s28_t1_one_variable_case_formal_call :
  forall K0, forall add0 mul0:set -> set -> set,
  forall f0 g0 :e multivariate_polynomial_ring K0 add0 1,
    integral_domain K0 add0 mul0 -> not (finite K0) ->
    (f0 = g0 <-> forall x0 :e K0 :^: 1,
      polynomial_evaluation K0 add0 mul0 K0 add0 mul0 1 f0 (fun i => x0 i)
      = polynomial_evaluation K0 add0 mul0 K0 add0 mul0 1 g0 (fun i => x0 i)).
apply god1_s28_theorem1_one_variable_interface.
//GOD1PRF:821656 It remains to prove Theorem 1 in the case of a polynomial $h$ in $n$ indeterminates, and we shall do this by induction on $n$. We may write
claim h_s28_t1_one_variable_induction_call :
  forall f0 g0 :e multivariate_polynomial_ring K add 1,
    f0 = g0 <-> forall x0 :e K :^: 1,
      polynomial_evaluation K add mul K add mul 1 f0 (fun i => x0 i)
      = polynomial_evaluation K add mul K add mul 1 g0 (fun i => x0 i).
let f0.
assume hf0.
let g0.
assume hg0.
apply (god1_s28_theorem1_one_variable_interface K add mul f0 hf0 g0 hg0 hDomain hInfinite).
claim h_s28_t1_inductive_decomposition : forall h :e multivariate_polynomial_ring K add n,
  exists H:set -> set, forall r :e omega,
    H r :e multivariate_polynomial_ring K add (Union n).
admit.
//GOD1PRF:821956 with polynomials $h_{r} \in \mathrm{~K}\left[\mathrm{X}_{1}, \ldots, \mathrm{X}_{n-1}\right]$. Suppose that $h(x)=0$ for all $x \in \mathrm{~K}^{n}$; then we have
claim h_s28_t1_coefficient_polynomials : forall h :e multivariate_polynomial_ring K add n,
  exists H:set -> set, forall r :e omega,
    H r :e multivariate_polynomial_ring K add (Union n).
admit.
//GOD1PRF:822151 for all $y \in \mathrm{~K}^{n-1}$ and all $t \in \mathrm{~K}$. For a given $y \in \mathrm{~K}^{n-1}$, we see therefore that the polynomial
claim h_s28_t1_specialized_polynomial_vanishes :
  forall h :e multivariate_polynomial_ring K add n,
