(** real1.tex: Fundamental theorem of calculus (both forms) and change of variables. **)

(** Mean-value bound: endpoint difference lies between inf/sup slopes times interval length. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived Fdiff_bound_by_inf_sup_Icc :
  forall a b :e R, a < b ->
  forall F f : set -> set,
    continuous_on F (Icc a b) ->
    (forall x :e Ioo a b, deriv_at F (Ioo a b) x (f x)) ->
    bounded_fun (Icc a b) f ->
    inf_on f (Icc a b) * (b + (- a)) <= F b + (- (F a))
    /\ F b + (- (F a)) <= sup_on f (Icc a b) * (b + (- a)).

(** Subinterval wrapper of `Fdiff_bound_by_inf_sup_Icc` inside a larger interval. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived Fdiff_bound_by_inf_sup_subinterval :
  forall a b :e R, a < b ->
  forall F f : set -> set,
    continuous_on F (Icc a b) ->
    (forall x :e Ioo a b, deriv_at F (Ioo a b) x (f x)) ->
    bounded_fun (Icc a b) f ->
    forall u v :e Icc a b,
      u < v ->
      inf_on f (Icc u v) * (v + (- u)) <= F v + (- (F u))
      /\ F v + (- (F u)) <= sup_on f (Icc u v) * (v + (- u)).

// Proof in RealAnalysis1May042026a.mg
ProofArchived FTCv1_Icc :
  forall a b :e R, a <= b ->
  forall F f : set -> set,
    continuous_on F (Icc a b) ->
    (forall x :e Ioo a b, deriv_at F (Ioo a b) x (f x)) ->
    riemann_integrable_Icc a b f ->
    riemann_integral_Icc a b f = F b + (- (F a)).

(** Define the integral-primitive with basepoint a on Icc a b. **)
//LLM integral_primitive_Icc : "the integral primitive icc associated to #1" | $\int #1$
Definition integral_primitive_Icc : set -> (set -> set) -> set -> set :=
  fun a f x => riemann_integral_Icc a x f.

// Proof in RealAnalysis1May042026a.mg
ProofArchived lower_darboux_integral_Icc_ge_inf_mul_len :
  forall a b :e R, a < b ->
  forall f : set -> set,
    bounded_fun (Icc a b) f ->
    inf_on f (Icc a b) * (b + (- a)) <= lower_darboux_integral_Icc a b f.

// Proof in RealAnalysis1May042026a.mg
ProofArchived upper_darboux_integral_Icc_le_sup_mul_len :
  forall a b :e R, a < b ->
  forall f : set -> set,
    bounded_fun (Icc a b) f ->
    upper_darboux_integral_Icc a b f <= sup_on f (Icc a b) * (b + (- a)).

// Proof in RealAnalysis1May042026a.mg
ProofArchived integral_primitive_Icc_lipschitz_continuous_on :
  forall a b :e R, a < b ->
  forall f : set -> set,
    riemann_integrable_Icc a b f ->
    let F := integral_primitive_Icc a f in
      lipschitz_continuous_on F (Icc a b).

// Proof in RealAnalysis1May042026a.mg
ProofArchived integral_primitive_Icc_continuous_on :
  forall a b :e R, a < b ->
  forall f : set -> set,
    riemann_integrable_Icc a b f ->
    let F := integral_primitive_Icc a f in
      continuous_on F (Icc a b).

// Proof in RealAnalysis1May042026a.mg
ProofArchived diffquot_integral_primitive_Icc_eq_integral_gt :
  forall a b :e R, a < b ->
  forall f : set -> set,
    riemann_integrable_Icc a b f ->
    forall c x :e Icc a b, c < x ->
      let F := integral_primitive_Icc a f in
        diffquot F c x
          = (riemann_integral_Icc c x f) :/: (x + (- c)).

// Proof in RealAnalysis1May042026a.mg
ProofArchived diffquot_integral_primitive_Icc_eq_integral_lt :
  forall a b :e R, a < b ->
  forall f : set -> set,
    riemann_integrable_Icc a b f ->
    forall c x :e Icc a b, x < c ->
      let F := integral_primitive_Icc a f in
        diffquot F c x
          = (riemann_integral_Icc x c f) :/: (c + (- x)).

// Proof in RealAnalysis1May042026a.mg
ProofArchived dist_R_Icc_left_le :
  forall c t x :e R, c <= t -> t <= x ->
    dist_R t c <= dist_R x c.

// Proof in RealAnalysis1May042026a.mg
ProofArchived dist_R_Icc_right_le :
  forall x t c :e R, x <= t -> t <= c ->
    dist_R t c <= dist_R x c.

// Proof in RealAnalysis1May042026a.mg
ProofArchived riemann_integral_Icc_between_inf_sup_mul_len :
  forall a b :e R, a < b ->
  forall f : set -> set,
    riemann_integrable_Icc a b f ->
    inf_on f (Icc a b) * (b + (- a)) <= riemann_integral_Icc a b f
    /\ riemann_integral_Icc a b f <= sup_on f (Icc a b) * (b + (- a)).

// Proof in RealAnalysis1May042026a.mg
ProofArchived riemann_integral_Icc_between_inf_sup_div_len :
  forall a b :e R, a < b ->
  forall f : set -> set,
    riemann_integrable_Icc a b f ->
    inf_on f (Icc a b) <= (riemann_integral_Icc a b f) :/: (b + (- a))
    /\ (riemann_integral_Icc a b f) :/: (b + (- a)) <= sup_on f (Icc a b).

(** dist_R_lt_imp_bounds moved earlier (form38). **)

