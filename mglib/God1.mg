      (fun scalar u => (smulR (u 0) scalar,smulR (u 1) scalar))
      M addM (fun scalar x => smulR x scalar) (fun u => addM (u 0) (u 1)))
    (fun u v => (addM (u 0) (v 0),addM (u 1) (v 1)))
