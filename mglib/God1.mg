Theorem god1_group_words_subset :
  forall G, forall mul:set -> set -> set, forall B,
    group_words G mul B c= G.
let G mul B.
let z.
assume hz.
exact (SepE1 G (fun u => group_word_represented G mul B u) z hz).
Qed.

Theorem god1_group_words_represented :
