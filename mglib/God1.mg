    exists c :e K :^: n,
      fraction_class K add mul
        (a,ring_finite_product K add mul n (fun i => b i))
      = module_finitely_supported_sum
        (fraction_field K add mul) (fraction_addition K add mul) n
        (fun i => fraction_class K add mul (c i,b i)).
