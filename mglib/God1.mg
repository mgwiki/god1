          (fun u => polynomial_fraction K add mul (h (u 0) (u 1))
            (ring_nat_power
              (multivariate_polynomial_ring K add 1)
              (polynomial_addition K add 1)
              (polynomial_multiplication K add mul 1)
              (q (u 0)) (u 1))))
