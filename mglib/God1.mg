ProofArchived null_set_binunion_rseq_mem :
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    (fun k :e omega => null_set_binunion_rseq rseq1 rseq2 k)
      :e setexp R omega.

// Proof in RealAnalysis2.1780535583.mg
ProofArchived null_set_binunion_rseq_pos :
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    (forall k :e omega, 0 < rseq1 k) ->
    (forall k :e omega, 0 < rseq2 k) ->
    forall k :e omega,
      0 < (fun k :e omega => null_set_binunion_rseq rseq1 rseq2 k) k.

// Proof in RealAnalysis2.1780533286.mg
ProofArchived null_set_binunion_ball_tag0 :
  forall n :e omega,
  forall cseq1 :e setexp (Rn n) omega,
  forall cseq2 :e setexp (Rn n) omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
  forall k :e omega,
    ms_ball (Rn n) (Rn_dist n) (cseq1 k) (rseq1 k)
    =
    ms_ball
      (Rn n)
      (Rn_dist n)
      ((fun j :e omega => null_set_binunion_cseq n cseq1 cseq2 j) (nat_pair 0 k))
      ((fun j :e omega => null_set_binunion_rseq rseq1 rseq2 j) (nat_pair 0 k)).

// Proof in RealAnalysis2.1780533286.mg
ProofArchived null_set_binunion_ball_tag1 :
