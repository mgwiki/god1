(*** Sigma X Y = {(x,y) | x in X, y in Y x} ***)
//LLM Sigma : "the dependent sum of #1 and #2" | $\Sigma_{#1} #2$
Definition Sigma : set -> (set -> set) -> set :=
fun X Y => \/_ x :e X, {pair x y|y :e Y x}.
(* Unicode Sigma_ "2211" *)
Binder+ Sigma_ , := Sigma.

