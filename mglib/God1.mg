ProofArchived Sigma_E : forall X:set, forall Y:set->set, forall z:set, z :e (Sigma_ x :e X, Y x) -> exists x :e X, exists y :e Y x, z = pair x y.

//LLM setprod : "the Cartesian product of #1 and #2" | $#1 \times #2$
Definition setprod : set->set->set := fun X Y:set => Sigma_ x :e X, Y.
