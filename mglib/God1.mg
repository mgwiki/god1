//LLM inj : "#1 is an injection from #2 to #3" | $#3 : #1 \hookrightarrow #2$
Definition inj : set->set->(set->set)->prop :=
  fun X Y f =>
  (forall u :e X, f u :e Y)
  /\
  (forall u v :e X, f u = f v -> u = v).

