// Proof in 100thms_12b.mg
ProofArchived recip_SNo_pos_invR: forall x, SNo x -> 0 < x -> x * recip_SNo_pos x = 1.

// Proof in 100thms_12b.mg
ProofArchived recip_SNo_pos_is_pos: forall x, SNo x -> 0 < x -> 0 < recip_SNo_pos x.

// Proof in 100thms_12b.mg
ProofArchived recip_SNo_pos_invol: forall x, SNo x -> 0 < x -> recip_SNo_pos (recip_SNo_pos x) = x.

// Proof in 100thms_12b.mg
ProofArchived recip_SNo_pos_eps_: forall n, nat_p n -> recip_SNo_pos (eps_ n) = 2 ^ n.

// Proof in 100thms_12b.mg
ProofArchived recip_SNo_pos_pow_2: forall n, nat_p n -> recip_SNo_pos (2 ^ n) = eps_ n.

// Proof in 100thms_12b.mg
ProofArchived recip_SNo_pos_2: recip_SNo_pos 2 = eps_ 1.

End recip_SNo_pos.
//LLM recip_SNo : "the recip sno associated to #1" | $\frac{1}{#1}$
Definition recip_SNo : set -> set := fun x => if 0 < x then recip_SNo_pos x else if x < 0 then - recip_SNo_pos (- x) else 0.

// Proof in 100thms_12b.mg
ProofArchived recip_SNo_poscase: forall x, 0 < x -> recip_SNo x = recip_SNo_pos x.

// Proof in 100thms_12b.mg
ProofArchived recip_SNo_negcase: forall x, SNo x -> x < 0 -> recip_SNo x = - recip_SNo_pos (- x).

// Proof in 100thms_12b.mg
ProofArchived recip_SNo_0: recip_SNo 0 = 0.

// Proof in 100thms_12b.mg
ProofArchived SNo_recip_SNo: forall x, SNo x -> SNo (recip_SNo x).

// Proof in 100thms_12b.mg
ProofArchived recip_SNo_invR: forall x, SNo x -> x <> 0 -> x * recip_SNo x = 1.

// Proof in 100thms_12b.mg
ProofArchived recip_SNo_invL: forall x, SNo x -> x <> 0 -> recip_SNo x * x = 1.

// Proof in 100thms_12b.mg
ProofArchived mul_SNo_nonzero_cancel_L: forall x y z, SNo x -> x <> 0 -> SNo y -> SNo z -> x * y = x * z -> y = z.

// Proof in 100thms_12b.mg
ProofArchived recip_SNo_pow_2 : forall n, nat_p n -> recip_SNo (2 ^ n) = eps_ n.

// Proof in 100thms_12b.mg
ProofArchived recip_SNo_of_pos_is_pos: forall x, SNo x -> 0 < x -> 0 < recip_SNo x.

//LLM div_SNo : "the div sno associated to #1" | $\frac{#1}{#2}$
Definition div_SNo : set -> set -> set := fun x y => x * recip_SNo y.

Infix :/: 353 := div_SNo.

