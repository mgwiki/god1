//LLM SNoElts_ : "the surreal-number construction sno elts " | $\mathrm{SNoElts\_}(#1)$
Definition SNoElts_ : set -> set := fun alpha => alpha :\/: {beta '|beta :e alpha}.

// Proof in 100thms_12b.mg
ProofArchived SNoElts_mon : forall alpha beta, alpha c= beta -> SNoElts_ alpha c= SNoElts_ beta.

//LLM SNo_ : "the surreal-number construction sno " | $\mathrm{SNo\_}(#1,#2)$
Definition SNo_ : set -> set -> prop := fun alpha x =>
    x c= SNoElts_ alpha
 /\ forall beta :e alpha, exactly1of2 (beta ' :e x) (beta :e x).
//LLM PSNo : "the class of positive surreal numbers" | $\mathrm{PSNo}(#1,#2)$
Definition PSNo : set -> (set -> prop) -> set :=
  fun alpha p => {beta :e alpha|p beta} :\/: {beta '|beta :e alpha, ~p beta}.

// Proof in 100thms_12b.mg
ProofArchived PNoEq_PSNo : forall alpha, ordinal alpha -> forall p:set -> prop, PNoEq_ alpha (fun beta => beta :e PSNo alpha p) p.

// Proof in 100thms_12b.mg
ProofArchived SNo_PSNo : forall alpha, ordinal alpha -> forall p:set -> prop, SNo_ alpha (PSNo alpha p).

// Proof in 100thms_12b.mg
ProofArchived SNo_PSNo_eta_ : forall alpha x, ordinal alpha -> SNo_ alpha x -> x = PSNo alpha (fun beta => beta :e x).

(* Parameter SNo "87d7604c7ea9a2ae0537066afb358a94e6ac0cd80ba277e6b064422035a620cf" "11faa7a742daf8e4f9aaf08e90b175467e22d0e6ad3ed089af1be90cfc17314b" *)
//LLM SNo : "the surreal number represented by #1" | $\mathrm{SNo}(#1)$
Definition SNo : set -> prop := fun x => exists alpha, ordinal alpha /\ SNo_ alpha x.

// Proof in 100thms_12b.mg
ProofArchived SNo_SNo : forall alpha, ordinal alpha -> forall z, SNo_ alpha z -> SNo z.

(* Parameter SNoLev "bf1decfd8f4025a2271f2a64d1290eae65933d0f2f0f04b89520449195f1aeb8" "293b77d05dab711767d698fb4484aab2a884304256765be0733e6bd5348119e8" *)
//LLM SNoLev : "the surreal-number construction sno lev" | $\mathrm{SNoLev}(#1)$
Definition SNoLev : set -> set := fun x => Eps_i (fun alpha => ordinal alpha /\ SNo_ alpha x).

// Proof in 100thms_12b.mg
ProofArchived SNoLev_uniq_Subq : forall x alpha beta, ordinal alpha -> ordinal beta -> SNo_ alpha x -> SNo_ beta x -> alpha c= beta.

// Proof in 100thms_12b.mg
ProofArchived SNoLev_uniq : forall x alpha beta, ordinal alpha -> ordinal beta -> SNo_ alpha x -> SNo_ beta x -> alpha = beta.

// Proof in 100thms_12b.mg
ProofArchived SNoLev_prop : forall x, SNo x -> ordinal (SNoLev x) /\ SNo_ (SNoLev x) x.

// Proof in 100thms_12b.mg
ProofArchived SNoLev_ordinal : forall x, SNo x -> ordinal (SNoLev x).

// Proof in 100thms_12b.mg
ProofArchived SNoLev_ : forall x, SNo x -> SNo_ (SNoLev x) x.

// Proof in 100thms_12b.mg
ProofArchived SNo_PSNo_eta : forall x, SNo x -> x = PSNo (SNoLev x) (fun beta => beta :e x).

// Proof in 100thms_12b.mg
ProofArchived SNoLev_PSNo : forall alpha, ordinal alpha -> forall p:set -> prop, SNoLev (PSNo alpha p) = alpha.

// Proof in 100thms_12b.mg
ProofArchived SNo_Subq : forall x y, SNo x -> SNo y -> SNoLev x c= SNoLev y -> (forall alpha :e SNoLev x, alpha :e x <-> alpha :e y) -> x c= y.

//LLM SNoEq_ : "the surreal-number construction sno eq " | $\mathrm{SNoEq\_}(#1,#2,#3)$
Definition SNoEq_ : set -> set -> set -> prop
 := fun alpha x y => PNoEq_ alpha (fun beta => beta :e x) (fun beta => beta :e y).

// Proof in 100thms_12b.mg
ProofArchived SNoEq_I : forall alpha x y, (forall beta :e alpha, beta :e x <-> beta :e y) -> SNoEq_ alpha x y.

// Proof in 100thms_12b.mg
ProofArchived SNo_eq : forall x y, SNo x -> SNo y -> SNoLev x = SNoLev y -> SNoEq_ (SNoLev x) x y -> x = y.

End TaggedSets.
//LLM SNoLt : "#1 is strictly less than #2 as surreal numbers" | $\mathrm{SNoLt}(#1,#2)$
Definition SNoLt : set -> set -> prop :=
  fun x y => PNoLt (SNoLev x) (fun beta => beta :e x) (SNoLev y) (fun beta => beta :e y).
Infix < 490 := SNoLt.
//LLM SNoLe : "#1 is less than or equal to #2 as surreal numbers" | $\mathrm{SNoLe}(#1,#2)$
Definition SNoLe : set -> set -> prop :=
  fun x y => PNoLe (SNoLev x) (fun beta => beta :e x) (SNoLev y) (fun beta => beta :e y).
(* Unicode <= "2264" *)
Infix <= 490 := SNoLe.

// Proof in 100thms_12b.mg
ProofArchived SNoLtLe : forall x y, x < y -> x <= y.

// Proof in 100thms_12b.mg
ProofArchived SNoLeE : forall x y, SNo x -> SNo y -> x <= y -> x < y \/ x = y.

// Proof in 100thms_12b.mg
ProofArchived SNoEq_sym_ : forall alpha x y, SNoEq_ alpha x y -> SNoEq_ alpha y x.

// Proof in 100thms_12b.mg
ProofArchived SNoEq_tra_ : forall alpha x y z, SNoEq_ alpha x y -> SNoEq_ alpha y z -> SNoEq_ alpha x z.

// Proof in 100thms_12b.mg
ProofArchived SNoLtE : forall x y, SNo x -> SNo y -> x < y ->
 forall p:prop,
    (forall z, SNo z -> SNoLev z :e SNoLev x :/\: SNoLev y -> SNoEq_ (SNoLev z) z x -> SNoEq_ (SNoLev z) z y -> x < z -> z < y -> SNoLev z /:e x -> SNoLev z :e y -> p)
 -> (SNoLev x :e SNoLev y -> SNoEq_ (SNoLev x) x y -> SNoLev x :e y -> p)
 -> (SNoLev y :e SNoLev x -> SNoEq_ (SNoLev y) x y -> SNoLev y /:e x -> p)
 -> p.

(** The analogous thm to PNoLtI1 can be recovered by SNoLt_tra (transitivity) and SNoLtI2 and SNoLtI3. **)
// Proof in 100thms_12b.mg
ProofArchived SNoLtI2 : forall x y,
     SNoLev x :e SNoLev y
  -> SNoEq_ (SNoLev x) x y
  -> SNoLev x :e y
  -> x < y.

// Proof in 100thms_12b.mg
ProofArchived SNoLtI3 : forall x y,
     SNoLev y :e SNoLev x
  -> SNoEq_ (SNoLev y) x y
  -> SNoLev y /:e x
  -> x < y.

