assume hG hx.
let p.
assume hp.
let n.
assume hn.
exact (nat_ind
  (fun m =>
    group_int_power G mul (group_int_power G mul x p) (minus_SNo m)
      = group_int_power G mul x (mul_SNo p (minus_SNo m)))
