(** The `n = 0` exponential summand at `z = 0` equals `1`. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived ms_seq_limit_unique :
  forall X,
  forall d : set -> set -> set,
  forall x : set -> set,
  forall l1,
  forall l2,
    is_metric X d ->
    ms_seq_limit X d x l1 ->
    ms_seq_limit X d x l2 ->
    l1 = l2.

(** If a complex point lies within every positive epsilon-ball around `1`, then it is `1`. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived complex_eq_1_of_dist_lt_all_eps :
  forall z :e complex,
    (forall eps :e R, 0 < eps -> dist_complex 1 z < eps) ->
    z = 1.

(** The base point `1` has zero distance from itself in the complex metric. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived dist_complex_1_1_eq_0 :
  dist_complex 1 1 = 0.

(** Every sufficiently late partial sum in the `complex_exp 0` series lies within
    any positive epsilon-ball around `1`. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived complex_exp_0_tail :
  forall eps :e R,
    0 < eps ->
    exists N :e omega,
      forall n :e omega,
        N <= n ->
        dist_complex
          (complex_partial_sum_seq
            (fun k : set => div_CSNo (exp_CSNo_nat 0 k) (factorial k))
            n)
          1
        < eps.

(** The partial-sum sequence defining `complex_exp 0` converges to `1`. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived complex_exp_0_seq_limit :
  ms_seq_limit
    complex
    dist_complex
    (complex_partial_sum_seq
      (fun k : set => div_CSNo (exp_CSNo_nat 0 k) (factorial k)))
    1.

(** Raw packaging of the `complex_exp 0` convergence data before folding it into
    the `ms_seq_limit` definition. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived complex_exp_0_seq_limit_raw :
  (forall n :e omega,
    complex_partial_sum_seq
      (fun k : set => div_CSNo (exp_CSNo_nat 0 k) (factorial k))
      n
    :e complex)
  /\ 1 :e complex
  /\ forall eps :e R,
       0 < eps ->
       exists N :e omega,
         forall n :e omega,
           N <= n ->
           dist_complex
             (complex_partial_sum_seq
               (fun k : set => div_CSNo (exp_CSNo_nat 0 k) (factorial k))
               n)
             1
           < eps.

(** The complex exponential at `0` is `1`. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived complex_exp_0 :
  complex_exp 0 = 1.

(** The complex sum `1 + 1` is the surreal number `2`. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived add_CSNo_1_1_eq_2 :
  add_CSNo 1 1 = 2.

(** The numeral `2` is a complex number. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived complex_2 :
  2 :e complex.

(** Right-cancellation for multiplication by a fixed nonzero complex factor. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived complex_mul_commonR_cancel_nonzero :
  forall z0 :e complex,
    z0 <> 0 ->
    forall z :e complex,
    forall w :e complex,
      mul_CSNo z z0 = mul_CSNo w z0 ->
      z = w.

(** Dividing `2` by itself in `complex` gives `1`. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived div_CSNo_2_2_eq_1 :
  div_CSNo 2 2 = 1.

Transparent recip_CSNo div_CSNo.

(** A zero numerator divides to zero against any nonzero complex denominator. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived div_CSNo_0_nonzero_den :
  forall z :e complex,
    z <> 0 ->
    div_CSNo 0 z = 0.

(** The basic imaginary unit is nonzero. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived Complex_i_nonzero :
  Complex_i <> 0.

(** The complex number `2 i` is nonzero. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived mul_CSNo_2_Complex_i_nonzero :
  mul_CSNo 2 Complex_i <> 0.

// Proof in RealAnalysis2.1782815868.mg
ProofArchived complex_cos_0 :
  complex_cos 0 = 1.

// Proof in RealAnalysis2.1782815868.mg
ProofArchived complex_sin_0 :
  complex_sin 0 = 0.

Opaque recip_CSNo div_CSNo.

(** Specialized finite series-product bridge for the complex exponential partial sums. **)
// Proof in RealAnalysis2.1782833511.mg
ProofArchived complex_exp_partial_sum_product :
  forall z :e complex,
  forall w :e complex,
  forall m :e omega,
  forall n :e omega,
    mul_CSNo
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
        m)
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat w k) (factorial k))
        n)
    =
    complex_partial_sum_seq
      (fun i : set =>
        complex_partial_sum_seq
          (fun j : set =>
            mul_CSNo
              (div_CSNo (exp_CSNo_nat z i) (factorial i))
              (div_CSNo (exp_CSNo_nat w j) (factorial j)))
          n)
      m.

(** Diagonal-index version of the exponential-series product bridge. **)
// Proof in RealAnalysis2.1782833511.mg
ProofArchived complex_exp_partial_sum_product_diag :
  forall z :e complex,
  forall w :e complex,
  forall n :e omega,
    mul_CSNo
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
        n)
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat w k) (factorial k))
        n)
    =
    complex_partial_sum_seq
      (fun i : set =>
        complex_partial_sum_seq
          (fun j : set =>
            mul_CSNo
              (div_CSNo (exp_CSNo_nat z i) (factorial i))
              (div_CSNo (exp_CSNo_nat w j) (factorial j)))
          n)
      n.

(** Swapped-diagonal version of the exponential-series product bridge. **)
// Proof in RealAnalysis2.1782835299.mg
ProofArchived complex_exp_partial_sum_product_diag_swapped :
  forall z :e complex,
  forall w :e complex,
  forall n :e omega,
    mul_CSNo
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
        n)
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat w k) (factorial k))
        n)
    =
    complex_partial_sum_seq
      (fun j : set =>
        complex_partial_sum_seq
          (fun i : set =>
            mul_CSNo
              (div_CSNo (exp_CSNo_nat z i) (factorial i))
              (div_CSNo (exp_CSNo_nat w j) (factorial j)))
          n)
      n.

(** Row-factor form of the swapped exponential-series rectangle. **)
// Proof in RealAnalysis2.1782836206.mg
ProofArchived complex_exp_partial_sum_product_diag_swapped_row_factor :
  forall z :e complex,
  forall w :e complex,
  forall n :e omega,
    complex_partial_sum_seq
      (fun j : set =>
        complex_partial_sum_seq
          (fun i : set =>
            mul_CSNo
              (div_CSNo (exp_CSNo_nat z i) (factorial i))
              (div_CSNo (exp_CSNo_nat w j) (factorial j)))
          n)
      n
    =
    complex_partial_sum_seq
      (fun j : set =>
        mul_CSNo
          (complex_partial_sum_seq
            (fun i : set => div_CSNo (exp_CSNo_nat z i) (factorial i))
            n)
          (div_CSNo (exp_CSNo_nat w j) (factorial j)))
      n.

(** Rectangular row-factor form of the swapped exponential-series rectangle. **)
// Proof in RealAnalysis2.1782838684.mg
ProofArchived complex_exp_partial_sum_product_rect_swapped_row_factor :
  forall z :e complex,
  forall w :e complex,
  forall m :e omega,
  forall n :e omega,
    complex_partial_sum_seq
      (fun j : set =>
        complex_partial_sum_seq
          (fun i : set =>
            mul_CSNo
              (div_CSNo (exp_CSNo_nat z i) (factorial i))
              (div_CSNo (exp_CSNo_nat w j) (factorial j)))
          n)
      m
    =
    complex_partial_sum_seq
      (fun j : set =>
        mul_CSNo
          (complex_partial_sum_seq
            (fun i : set => div_CSNo (exp_CSNo_nat z i) (factorial i))
            n)
          (div_CSNo (exp_CSNo_nat w j) (factorial j)))
      m.

(** The swapped exponential-series rectangle fully refactors as the product of
    the two diagonal exponential partial sums. **)
// Proof in RealAnalysis2.1782836206.mg
ProofArchived complex_exp_partial_sum_product_diag_swapped_factored :
  forall z :e complex,
  forall w :e complex,
  forall n :e omega,
    complex_partial_sum_seq
      (fun j : set =>
        complex_partial_sum_seq
          (fun i : set =>
            mul_CSNo
              (div_CSNo (exp_CSNo_nat z i) (factorial i))
              (div_CSNo (exp_CSNo_nat w j) (factorial j)))
          n)
      n
    =
    mul_CSNo
      (complex_partial_sum_seq
        (fun i : set => div_CSNo (exp_CSNo_nat z i) (factorial i))
        n)
      (complex_partial_sum_seq
        (fun j : set => div_CSNo (exp_CSNo_nat w j) (factorial j))
        n).

(** Tail-splitting form of the swapped row-factorized exponential rectangle. **)
// Proof in RealAnalysis2.1782838684.mg
ProofArchived complex_exp_partial_sum_product_diag_swapped_row_factor_add_nat_split :
  forall z :e complex,
  forall w :e complex,
  forall M :e omega,
  forall n :e omega,
    complex_partial_sum_seq
      (fun j : set =>
        mul_CSNo
          (complex_partial_sum_seq
            (fun i : set => div_CSNo (exp_CSNo_nat z i) (factorial i))
            n)
          (div_CSNo (exp_CSNo_nat w j) (factorial j)))
      (add_nat M n)
    =
    add_CSNo
      (complex_partial_sum_seq
        (fun j : set =>
          mul_CSNo
            (complex_partial_sum_seq
              (fun i : set => div_CSNo (exp_CSNo_nat z i) (factorial i))
              n)
            (div_CSNo (exp_CSNo_nat w j) (factorial j)))
        M)
      (mul_CSNo
        (complex_partial_sum_seq
          (fun i : set => div_CSNo (exp_CSNo_nat z i) (factorial i))
          n)
        (complex_partial_sum_seq
          (fun j : set =>
            div_CSNo
              (exp_CSNo_nat w (add_nat M j))
              (factorial (add_nat M j)))
          n)).

(** Tail-splitting form of the rectangular swapped row-factorized exponential rectangle. **)
// Proof in RealAnalysis2.1782838990.mg
ProofArchived complex_exp_partial_sum_product_rect_swapped_row_factor_add_nat_split :
  forall z :e complex,
  forall w :e complex,
  forall M :e omega,
  forall m :e omega,
  forall n :e omega,
    complex_partial_sum_seq
      (fun j : set =>
        complex_partial_sum_seq
          (fun i : set =>
            mul_CSNo
              (div_CSNo (exp_CSNo_nat z i) (factorial i))
              (div_CSNo (exp_CSNo_nat w j) (factorial j)))
          n)
      (add_nat M m)
    =
    add_CSNo
      (complex_partial_sum_seq
        (fun j : set =>
          complex_partial_sum_seq
            (fun i : set =>
              mul_CSNo
                (div_CSNo (exp_CSNo_nat z i) (factorial i))
                (div_CSNo (exp_CSNo_nat w j) (factorial j)))
            n)
        M)
      (mul_CSNo
        (complex_partial_sum_seq
          (fun i : set => div_CSNo (exp_CSNo_nat z i) (factorial i))
          n)
        (complex_partial_sum_seq
          (fun j : set =>
            div_CSNo
              (exp_CSNo_nat w (add_nat M j))
              (factorial (add_nat M j)))
          m)).

(** Tail-series form of the rectangular swapped exponential product rectangle. **)
// Proof in RealAnalysis2.1782839356.mg
ProofArchived complex_exp_partial_sum_product_rect_swapped_tail_series_eq :
  forall z :e complex,
  forall w :e complex,
  forall M :e omega,
  forall m :e omega,
  forall n :e omega,
    complex_partial_sum_seq
      (tail_series
        (fun j : set =>
          complex_partial_sum_seq
            (fun i : set =>
              mul_CSNo
                (div_CSNo (exp_CSNo_nat z i) (factorial i))
                (div_CSNo (exp_CSNo_nat w j) (factorial j)))
            n)
        M)
      m
    =
    mul_CSNo
      (complex_partial_sum_seq
        (fun i : set => div_CSNo (exp_CSNo_nat z i) (factorial i))
        n)
      (complex_partial_sum_seq
        (fun j : set =>
          div_CSNo
            (exp_CSNo_nat w (add_nat M j))
            (factorial (add_nat M j)))
        m).

(** Diagonal specialization of the swapped exponential tail-series identity. **)
// Proof in RealAnalysis2.1782839356.mg
ProofArchived complex_exp_partial_sum_product_diag_swapped_tail_series_eq :
  forall z :e complex,
  forall w :e complex,
  forall M :e omega,
  forall n :e omega,
    complex_partial_sum_seq
      (tail_series
        (fun j : set =>
          complex_partial_sum_seq
            (fun i : set =>
              mul_CSNo
                (div_CSNo (exp_CSNo_nat z i) (factorial i))
                (div_CSNo (exp_CSNo_nat w j) (factorial j)))
            n)
        M)
      n
    =
    mul_CSNo
      (complex_partial_sum_seq
        (fun i : set => div_CSNo (exp_CSNo_nat z i) (factorial i))
        n)
      (complex_partial_sum_seq
        (fun j : set =>
          div_CSNo
            (exp_CSNo_nat w (add_nat M j))
            (factorial (add_nat M j)))
        n).

(** The shifted `w`-series partial sum is exactly the tail-series partial sum. **)
// Proof in RealAnalysis2.1782839661.mg
ProofArchived complex_exp_shifted_w_partial_sum_eq_tail_series :
  forall w :e complex,
  forall M :e omega,
  forall m :e omega,
    complex_partial_sum_seq
      (fun j : set =>
        div_CSNo
          (exp_CSNo_nat w (add_nat M j))
          (factorial (add_nat M j)))
      m
    =
    complex_partial_sum_seq
      (tail_series
        (fun j : set => div_CSNo (exp_CSNo_nat w j) (factorial j))
        M)
      m.

(** Tail-series form of the rectangular swapped exponential product rectangle,
    with the shifted `w`-series written via `tail_series`. **)
// Proof in RealAnalysis2.1782839661.mg
ProofArchived complex_exp_partial_sum_product_rect_swapped_tail_series_eq' :
  forall z :e complex,
  forall w :e complex,
  forall M :e omega,
  forall m :e omega,
  forall n :e omega,
    complex_partial_sum_seq
      (tail_series
        (fun j : set =>
          complex_partial_sum_seq
            (fun i : set =>
              mul_CSNo
                (div_CSNo (exp_CSNo_nat z i) (factorial i))
                (div_CSNo (exp_CSNo_nat w j) (factorial j)))
            n)
        M)
      m
    =
    mul_CSNo
      (complex_partial_sum_seq
        (fun i : set => div_CSNo (exp_CSNo_nat z i) (factorial i))
        n)
      (complex_partial_sum_seq
        (tail_series
          (fun j : set => div_CSNo (exp_CSNo_nat w j) (factorial j))
          M)
        m).

(** Diagonal specialization with the shifted `w`-series written via `tail_series`. **)
// Proof in RealAnalysis2.1782839661.mg
ProofArchived complex_exp_partial_sum_product_diag_swapped_tail_series_eq' :
  forall z :e complex,
  forall w :e complex,
  forall M :e omega,
  forall n :e omega,
    complex_partial_sum_seq
      (tail_series
        (fun j : set =>
          complex_partial_sum_seq
            (fun i : set =>
              mul_CSNo
                (div_CSNo (exp_CSNo_nat z i) (factorial i))
                (div_CSNo (exp_CSNo_nat w j) (factorial j)))
            n)
        M)
      n
    =
    mul_CSNo
      (complex_partial_sum_seq
        (fun i : set => div_CSNo (exp_CSNo_nat z i) (factorial i))
        n)
      (complex_partial_sum_seq
        (tail_series
          (fun j : set => div_CSNo (exp_CSNo_nat w j) (factorial j))
          M)
        n).

(** Substitution on the argument of the complex exponential. **)
// Proof in RealAnalysis2.1782842193.mg
ProofArchived complex_exp_eq_subst_arg :
  forall z w,
    z = w ->
    complex_exp z = complex_exp w.

(** Substitution on the argument of complex cosine. **)
// Proof in RealAnalysis2.1782842193.mg
ProofArchived complex_cos_eq_subst_arg :
  forall z w,
    z = w ->
    complex_cos z = complex_cos w.

(** Substitution on the argument of complex sine. **)
// Proof in RealAnalysis2.1782842193.mg
ProofArchived complex_sin_eq_subst_arg :
  forall z w,
    z = w ->
    complex_sin z = complex_sin w.

(** Unfolding lemma for complex cosine. **)
// Proof in RealAnalysis2.1782843521.mg
ProofArchived complex_cos_unfold :
  forall z,
    complex_cos z
    =
    div_CSNo
      (add_CSNo
        (complex_exp (mul_CSNo Complex_i z))
        (complex_exp (minus_CSNo (mul_CSNo Complex_i z))))
      2.

(** Unfolding lemma for complex sine. **)
// Proof in RealAnalysis2.1782843521.mg
ProofArchived complex_sin_unfold :
  forall z,
    complex_sin z
    =
    div_CSNo
      (add_CSNo
        (complex_exp (mul_CSNo Complex_i z))
        (minus_CSNo (complex_exp (minus_CSNo (mul_CSNo Complex_i z)))))
      (mul_CSNo 2 Complex_i).

(** If a metric-space sequence has at least one limit, then `ms_lim_seq` picks a limit. **)
// Proof in RealAnalysis2.1782844067.mg
ProofArchived ms_lim_seq_limit_of_exists :
  forall X,
  forall d : set -> set -> set,
  forall x : set -> set,
    (exists l, ms_seq_limit X d x l) ->
    ms_seq_limit X d x (ms_lim_seq X d x).

(** If a metric-space sequence has at least one limit, then `ms_lim_seq` lies in the ambient space. **)
// Proof in RealAnalysis2.1782844067.mg
ProofArchived ms_lim_seq_in_space_of_exists :
  forall X,
  forall d : set -> set -> set,
  forall x : set -> set,
    (exists l, ms_seq_limit X d x l) ->
    ms_lim_seq X d x :e X.

(** real2.tex: sec:complexexp — law of exponents for the complex exponential. **)

(** If the complex exponential is complex-valued and satisfies the law of
    exponents, then it never vanishes.  This isolates the standard
    `e^z e^{-z} = 1` argument from the remaining analytic work needed to
    establish closure and the law of exponents themselves. **)
// Proof in RealAnalysis2.1782849512.mg
ProofArchived complex_exp_nonzero_of_add_and_in_complex :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  forall z :e complex,
    complex_exp z <> 0.

(** Self-source alias for the nonvanishing wrapper with redundant
    complex-valuedness hypothesis. **)


(** Under the same closure and exponent-addition hypotheses, the reciprocal of
    `e^z` is `e^{-z}`.  This isolates the algebraic reciprocal argument from
    the remaining convergence work. **)
// Proof in RealAnalysis2.1782849512.mg
ProofArchived complex_exp_recip_neg_of_add_and_in_complex :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  forall z :e complex,
    recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z).

(** Self-source alias for the reciprocal wrapper with redundant
    complex-valuedness hypothesis. **)


(** Packaging both standard algebraic consequences of exponent-addition in one
    place keeps later callers from repeating the same pair of archived wrappers. **)
// Proof in RealAnalysis2.1783257327.mg
ProofArchived complex_exp_nonzero_and_recip_neg_of_add_and_in_complex :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  (forall z :e complex,
     complex_exp z <> 0)
  /\
  (forall z :e complex,
     recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z)).

(** The same packaged exponent-addition consequences are sometimes more useful
    with the reciprocal identity listed before nonvanishing. **)
// Proof in RealAnalysis2.1783258793.mg
ProofArchived complex_exp_recip_neg_and_nonzero_of_add_and_in_complex :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  (forall z :e complex,
     recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z))
  /\
  (forall z :e complex,
     complex_exp z <> 0).

(** Under the addition-law hypotheses, the two global package orders are
    interderivable by swapping the conjunction components. **)
// Proof in RealAnalysis2.1783270939.mg
ProofArchived complex_exp_recip_neg_and_nonzero_of_nonzero_and_recip_neg_of_add_and_in_complex :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  ((forall z :e complex,
      complex_exp z <> 0)
   /\
   (forall z :e complex,
      recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z))) ->
  ((forall z :e complex,
      recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z))
   /\
   (forall z :e complex,
      complex_exp z <> 0)).

(** The converse package-order conversion is equally immediate under the same
    addition-law hypotheses. **)
// Proof in RealAnalysis2.1783270939.mg
ProofArchived complex_exp_nonzero_and_recip_neg_of_recip_neg_and_nonzero_of_add_and_in_complex :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  ((forall z :e complex,
      recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z))
   /\
   (forall z :e complex,
      complex_exp z <> 0)) ->
  ((forall z :e complex,
      complex_exp z <> 0)
   /\
   (forall z :e complex,
      recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z))).

(** If nonvanishing has already been established globally under the
    exponent-addition hypotheses, the packaged nonzero/reciprocal consequence
    follows by supplying only the missing reciprocal half. **)
// Proof in RealAnalysis2.1783259279.mg
ProofArchived complex_exp_nonzero_and_recip_neg_of_add_and_in_complex_of_nonzero :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  (forall z :e complex,
     complex_exp z <> 0) ->
  (forall z :e complex,
     complex_exp z <> 0)
  /\
  (forall z :e complex,
     recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z)).

(** Symmetrically, if the reciprocal identity has already been established
    globally, the reverse-order packaged consequence follows by supplying only
    the missing nonvanishing half. **)
// Proof in RealAnalysis2.1783259279.mg
ProofArchived complex_exp_recip_neg_and_nonzero_of_add_and_in_complex_of_recip_neg :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  (forall z :e complex,
     recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z)) ->
  (forall z :e complex,
     recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z))
  /\
  (forall z :e complex,
     complex_exp z <> 0).

(** If the reciprocal identity is already established globally, the
    nonzero/reciprocal packaged consequence follows by supplying only the
    missing nonvanishing half. **)
// Proof in RealAnalysis2.1783259766.mg
ProofArchived complex_exp_nonzero_and_recip_neg_of_add_and_in_complex_of_recip_neg :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  (forall z :e complex,
     recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z)) ->
  (forall z :e complex,
     complex_exp z <> 0)
  /\
  (forall z :e complex,
     recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z)).

(** Symmetrically, if nonvanishing is already established globally, the
    reverse-order packaged consequence follows by supplying only the missing
    reciprocal half. **)
// Proof in RealAnalysis2.1783259766.mg
ProofArchived complex_exp_recip_neg_and_nonzero_of_add_and_in_complex_of_nonzero :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  (forall z :e complex,
     complex_exp z <> 0) ->
  (forall z :e complex,
     recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z))
  /\
  (forall z :e complex,
     complex_exp z <> 0).

(** A packaged global nonzero/reciprocal consequence under the addition law
    should project back to nonvanishing under a named wrapper. **)
// Proof in RealAnalysis2.1783271494.mg
ProofArchived complex_exp_nonzero_of_nonzero_and_recip_neg_of_add_and_in_complex :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  ((forall z :e complex,
      complex_exp z <> 0)
   /\
   (forall z :e complex,
      recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z))) ->
  forall z :e complex,
    complex_exp z <> 0.

(** The same packaged global nonzero/reciprocal consequence should also project
    directly to the reciprocal identity. **)
// Proof in RealAnalysis2.1783271494.mg
ProofArchived complex_exp_recip_neg_of_nonzero_and_recip_neg_of_add_and_in_complex :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  ((forall z :e complex,
      complex_exp z <> 0)
   /\
   (forall z :e complex,
      recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z))) ->
  forall z :e complex,
    recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z).

(** Dually, a packaged global reciprocal/nonzero consequence should project back
    to nonvanishing under its own named wrapper. **)
// Proof in RealAnalysis2.1783271494.mg
ProofArchived complex_exp_nonzero_of_recip_neg_and_nonzero_of_add_and_in_complex :
  (forall z :e complex, complex_exp z :e complex) ->
  (forall z :e complex,
   forall w :e complex,
     complex_exp (add_CSNo z w) = mul_CSNo (complex_exp z) (complex_exp w)) ->
  ((forall z :e complex,
      recip_CSNo (complex_exp z) = complex_exp (minus_CSNo z))
   /\
   (forall z :e complex,
      complex_exp z <> 0)) ->
  forall z :e complex,
    complex_exp z <> 0.

(** And the reciprocal/nonzero package should project back to the reciprocal
    identity without forcing a manual conjunction reordering. **)
// Proof in RealAnalysis2.1783271494.mg
ProofArchived complex_exp_recip_neg_of_recip_neg_and_nonzero_of_add_and_in_complex :
