Definition SNo_max_of : set -> set -> prop := fun X x => x :e X /\ SNo x /\ forall y :e X, SNo y -> y <= x.
//LLM SNo_min_of : "the surreal-number construction sno min of" | $\mathrm{SNo\_min\_of}(#1,#2)$
