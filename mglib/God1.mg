// Proof in 100thms_12b.mg
ProofArchived Inj0_setsum_0L : forall X:set, 0 :+: X = Inj0 X.

// Proof in 100thms_12b.mg
ProofArchived Inj1_setsum_1L : forall X:set, 1 :+: X = Inj1 X.

Section pair_setsum.
Let pair := setsum.
//LLM proj0 : "the first projection of #1" | $\pi_0(#1)$
Definition proj0 : set -> set := fun Z => {Unj z|z :e Z, exists x:set, Inj0 x = z}.
//LLM proj1 : "the second projection of #1" | $\pi_1(#1)$
Definition proj1 : set -> set := fun Z => {Unj z|z :e Z, exists y:set, Inj1 y = z}.

// Proof in 100thms_12b.mg
