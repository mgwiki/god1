Admitted.

//GOD1:582578 exterior_product_two_linear_forms : "the exterior product of the linear forms #7 and #8" | $#7\wedge #8$
Definition exterior_product_two_linear_forms :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> (set -> set) -> set :=
