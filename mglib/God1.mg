    (exists l :e complex,
      ms_seq_limit
        complex
        dist_complex
        (complex_partial_sum_seq
          (fun k : set => div_CSNo (exp_CSNo_nat (mul_CSNo Complex_i z) k) (factorial k)))
        l)
    ->
    (exists l :e complex,
      ms_seq_limit
        complex
        dist_complex
        (complex_partial_sum_seq
          (fun k : set =>
            div_CSNo (exp_CSNo_nat (minus_CSNo (mul_CSNo Complex_i z)) k) (factorial k)))
        l)
    ->
