// Proof in RealAnalysis2.1780591909.mg
ProofArchived complex_mul_pairs_rhs_complex :
  forall x :e real,
  forall y :e real,
  forall u :e real,
  forall v :e real,
    SNo_pair (x * u + - (v * y)) (v * x + y * u) :e complex.

Axiom complex_mul_pairs_eq_pair_raw :
  forall x :e real,
  forall y :e real,
  forall u :e real,
  forall v :e real,
    mul_CSNo (SNo_pair x y) (SNo_pair u v)
      =
    SNo_pair (x * u + - (v * y)) (v * x + y * u).

Axiom complex_neg_one_pair_eq_pair :
  forall a :e real,
  forall b :e real,
    mul_CSNo (- 1) (SNo_pair a b)
      = SNo_pair (- a) (- b).

// Proof in RealAnalysis2.1780589606.mg
ProofArchived complex_minus_i_half_eq_pair :
  mul_CSNo (minus_CSNo Complex_i) (1 :/: 2)
    = SNo_pair 0 (- (1 :/: 2)).

// Proof in RealAnalysis2.1780589606.mg
ProofArchived complex_imag_combo_pair_product_re_eq :
  forall b :e real,
    Re
      (mul_CSNo
        (SNo_pair 0 (- (1 :/: 2)))
        (SNo_pair 0 (b + b)))
      = b.

// Proof in RealAnalysis2.1780589606.mg
ProofArchived complex_imag_combo_pair_product_im_eq :
  forall b :e real,
    Im
      (mul_CSNo
        (SNo_pair 0 (- (1 :/: 2)))
        (SNo_pair 0 (b + b)))
      = 0.

// Proof in RealAnalysis2.1780589606.mg
ProofArchived complex_imag_combo_pair_product_eq_pair :
  forall b :e real,
    mul_CSNo
      (mul_CSNo (minus_CSNo Complex_i) (1 :/: 2))
      (SNo_pair 0 (b + b))
      = SNo_pair b 0.

(** Moved slightly later than its narrative position in `real2.tex` so it can
    depend directly on the already archived pair-product identities above. **)
// Proof in RealAnalysis2.1780593486.mg
ProofArchived complex_imag_combo_pair_product_eq_pair_of_scalar_pair :
  forall b :e real,
    mul_CSNo
      (SNo_pair 0 (- (1 :/: 2)))
      (SNo_pair 0 (b + b))
      = SNo_pair b 0.

(** Complex constants imply the same nonvanishing hypothesis. **)
// Proof in RealAnalysis2.1780562993.mg
ProofArchived contains_complex_constants_imp_vanishes_at_no_point :
  forall X,
  forall A,
    contains_complex_constants X A ->
    vanishes_at_no_point X A.

End form83.

Section form84.

(** real2.tex: sec:riemannlebesgue (The set of Riemann integrable functions). **)

(** The open ray (0,∞) is nonempty. **)
// Proof in RealAnalysis2.1778902889.mg
ProofArchived Ioi0_nonempty : nonempty (Ioi 0).

(** Eliminating membership in a product `setprod X Y` into membership of the coordinates. **)
// Proof in RealAnalysis2.1778900363.mg
ProofArchived setprod_elim_0_1 :
  forall X,
  forall Y,
  forall p :e setprod X Y,
    p 0 :e X /\ p 1 :e Y.

(** Subspace ball B_D(x,delta) := B_{R^n}(x,delta) ∩ D. **)
//LLM Rn_ball_subspace : "the ball subspace of the real vector space of dimension #1" | $\mathrm{Rn\_ball\_subspace}(#1,#2,#3,#4)$
Definition Rn_ball_subspace :
  set ->
  set ->
  set ->
  set ->
  set :=
  fun n D x delta =>
    (ms_ball (Rn n) (Rn_dist n) x delta) :/\: D.

(** Nonemptiness of the subspace ball around a point in D, for delta>0. **)
// Proof in RealAnalysis2.1778897897.mg
ProofArchived Rn_ball_subspace_nonempty :
  forall n :e omega,
  forall D,
  forall x :e D,
    D c= (Rn n) ->
    forall delta :e R, 0 < delta ->
      nonempty (Rn_ball_subspace n D x delta).

(** Boundedness of the oscillation integrand on pairs in B_D(x,delta). **)
// Proof in RealAnalysis2.1778897897.mg
ProofArchived Rn_osc_integrand_bounded :
  forall n :e omega,
  forall D,
  forall f : set -> set,
  forall x :e D,
    bounded_fun D f ->
    forall delta :e R, 0 < delta ->
      bounded_fun
        (setprod (Rn_ball_subspace n D x delta) (Rn_ball_subspace n D x delta))
        (fun p => (f (p 0)) + (- (f (p 1)))).

(** Sanity check: closure under negation/addition in R. **)
// Proof in RealAnalysis2.1778897897.mg
ProofArchived R_add_minus_closed_sanity :
  forall x :e R, forall y :e R, x + (- y) :e R.

(** The center point is always in the subspace ball for delta>0. **)
// Proof in RealAnalysis2.1778900363.mg
ProofArchived Rn_ball_subspace_center_mem :
  forall n :e omega,
  forall D,
  forall x :e D,
    D c= (Rn n) ->
    forall delta :e R, 0 < delta ->
      x :e Rn_ball_subspace n D x delta.

(** If y is within delta of x (in the metric), then y is in the subspace ball B_D(x,delta). **)
// Proof in RealAnalysis2.1778900363.mg
ProofArchived Rn_ball_subspace_mem_of_dist :
  forall n :e omega,
  forall D,
  forall x :e D,
    D c= (Rn n) ->
    forall delta :e R, 0 < delta ->
    forall y :e D,
      Rn_dist n y x < delta ->
      y :e Rn_ball_subspace n D x delta.

(** Oscillation o(f,x,delta) as sup_{y1,y2 in B_D(x,delta)} (f(y1)-f(y2)). **)
//LLM Rn_oscillation_delta : "the oscillation delta of #1 in the real vector space of dimension #2" | $\mathrm{Rn\_oscillation\_delta}(#1,#2,#3,#4,#5)$
Definition Rn_oscillation_delta :
  set ->
  set ->
  (set -> set) ->
  set ->
  set ->
  set :=
  fun n D f x delta =>
    sup_on
      (fun p => (f (p 0)) + (- (f (p 1))))
      (setprod (Rn_ball_subspace n D x delta) (Rn_ball_subspace n D x delta)).

(** Real-valuedness of oscillation_delta for bounded f. **)
// Proof in RealAnalysis2.1778897897.mg
ProofArchived Rn_oscillation_delta_R_closed :
  forall n :e omega,
  forall D,
  forall f : set -> set,
  forall x :e D,
    D c= (Rn n) ->
    bounded_fun D f ->
    forall delta :e R, 0 < delta ->
      Rn_oscillation_delta n D f x delta :e R.

(** Oscillation_delta is always nonnegative (since the pair (x,x) gives value 0). **)
// Proof in RealAnalysis2.1778900363.mg
ProofArchived Rn_oscillation_delta_nonneg :
  forall n :e omega,
  forall D,
  forall f : set -> set,
  forall x :e D,
    D c= (Rn n) ->
    bounded_fun D f ->
    forall delta :e R, 0 < delta ->
      0 <= Rn_oscillation_delta n D f x delta.

(** Boundedness of delta ↦ oscillation_delta on (0,∞) for bounded f. **)
// Proof in RealAnalysis2.1778900363.mg
ProofArchived bounded_fun_Rn_oscillation_delta_Ioi0 :
  forall n :e omega,
  forall D,
  forall f : set -> set,
  forall x :e D,
    D c= (Rn n) ->
    bounded_fun D f ->
    bounded_fun (Ioi 0) (fun delta => Rn_oscillation_delta n D f x delta).

(** Oscillation o(f,x) := inf_{delta>0} o(f,x,delta). **)
//LLM Rn_oscillation : "the oscillation of #1 in the real vector space of dimension #2" | $\mathrm{Rn\_oscillation}(#1,#2,#3,#4)$
Definition Rn_oscillation :
  set ->
  set ->
  (set -> set) ->
  set ->
  set :=
  fun n D f x =>
    inf_on (fun delta => Rn_oscillation_delta n D f x delta) (Ioi 0).

(** Discontinuity set S := {x in D : o(f,x) > 0}. **)
//LLM Rn_discontinuities : "the set of discontinuities of #1 in the real vector space of dimension #2" | $\mathrm{Rn\_discontinuities}(#1,#2,#3)$
Definition Rn_discontinuities :
  set ->
  set ->
  (set -> set) ->
  set :=
  fun n D f =>
    {x :e D | 0 < Rn_oscillation n D f x}.

(** Thresholded discontinuity set S_eps := {x in D : o(f,x) >= eps}. **)
//LLM Rn_discontinuities_eps : "the epsilon-discontinuity set of #1 in the real vector space of dimension #2" | $\mathrm{Rn\_discontinuities\_eps}(#1,#2,#3,#4)$
Definition Rn_discontinuities_eps :
  set ->
  set ->
  (set -> set) ->
  set ->
  set :=
  fun n D f eps =>
    {x :e D | eps <= Rn_oscillation n D f x}.

(** real2.tex: continuity at x implies oscillation at x is 0. **)
// Proof in RealAnalysis2.1778906743.mg
ProofArchived Rn_continuous_at_imp_oscillation_zero :
  forall n :e omega,
  forall D,
  forall f : set -> set,
  forall x :e D,
    D c= (Rn n) ->
    bounded_fun D f ->
    ms_continuous_at f D (Rn_dist n) R dist_R x ->
    Rn_oscillation n D f x = 0.

(** real2.tex: oscillation at x is 0 implies continuity at x. **)
// Proof in RealAnalysis2.1778912228.mg
ProofArchived Rn_oscillation_zero_imp_continuous_at :
  forall n :e omega,
  forall D,
  forall f : set -> set,
  forall x :e D,
    D c= (Rn n) ->
    bounded_fun D f ->
    Rn_oscillation n D f x = 0 ->
    ms_continuous_at f D (Rn_dist n) R dist_R x.

