ProofArchived real_Archimedean2: forall x y :e real, 0 < x -> exists n :e omega, y < n * x.

(** Extended reals (with - omega and omega as - infinity and + infinity).
    They are simply defined the same was as the reals without ruling out - omega and omega explicitly.
 **)
//LLM ext_real : "the set of extended real numbers" | $\overline{\mathbb{R}}$
Definition ext_real : set := {x :e SNoS_ (ordsucc omega)| forall q :e SNoS_ omega, (forall k :e omega, abs_SNo (q + - x) < eps_ k) -> q = x}.

// Proof in 1777388823.mg
ProofArchived ext_real_I : forall x :e SNoS_ (ordsucc omega),
    (forall q :e SNoS_ omega, (forall k :e omega, abs_SNo (q + - x) < eps_ k) -> q = x)
 -> x :e ext_real.

// Proof in 1777388823.mg
ProofArchived ext_real_E : forall x :e ext_real,
    x :e SNoS_ (ordsucc omega) /\ (forall q :e SNoS_ omega, (forall k :e omega, abs_SNo (q + - x) < eps_ k) -> q = x).

// Proof in 1777388823.mg
ProofArchived ext_real_SNoS_ordsucc_omega : ext_real c= SNoS_ (ordsucc omega).

// Proof in 1777388823.mg
ProofArchived ext_real_SNo : forall x :e ext_real, SNo x.

// Proof in 1777388823.mg
ProofArchived real_ext_real: real c= ext_real.

// Proof in 1777388823.mg
ProofArchived infinite_ext_real_lem: forall q :e SNoS_ omega, ~(abs_SNo (omega + - q) < 1).

// Proof in 1777388823.mg
ProofArchived omega_ext_real: omega :e ext_real.

// Proof in 1777388823.mg
ProofArchived minus_omega_ext_real: - omega :e ext_real.

// Proof in 1777388823.mg
ProofArchived ext_real_cases: forall x :e ext_real, forall p:prop,
    (x = - omega -> p)
 -> (x :e real -> p)
 -> (x = omega -> p)
 -> p.

//LLM upper_ext_real : "the upper extension of #1 to the extended reals" | $\mathrm{upper\_ext\_real}$
Definition upper_ext_real : set := {x :e SNoS_ (ordsucc omega)| x <> - omega /\ forall q :e SNoS_ omega, (forall k :e omega, abs_SNo (q + - x) < eps_ k) -> q = x}.

// Proof in 1777388823.mg
ProofArchived upper_ext_real_I : forall x :e SNoS_ (ordsucc omega),
    x <> - omega
 -> (forall q :e SNoS_ omega, (forall k :e omega, abs_SNo (q + - x) < eps_ k) -> q = x)
 -> x :e upper_ext_real.

// Proof in 1777388823.mg
ProofArchived upper_ext_real_E : forall x :e upper_ext_real,
  forall p:prop,
       (x :e SNoS_ (ordsucc omega)
    -> (x <> - omega)
    -> (forall q :e SNoS_ omega, (forall k :e omega, abs_SNo (q + - x) < eps_ k) -> q = x)
    -> p)
   -> p.

// Proof in 1777388823.mg
ProofArchived upper_ext_real_SNoS_ordsucc_omega : upper_ext_real c= SNoS_ (ordsucc omega).

// Proof in 1777388823.mg
ProofArchived upper_ext_real_SNo : forall x :e upper_ext_real, SNo x.

// Proof in 1777388823.mg
ProofArchived real_upper_ext_real: real c= upper_ext_real.

//LLM lower_ext_real : "the lower extension of #1 to the extended reals" | $\mathrm{lower\_ext\_real}$
Definition lower_ext_real : set := {x :e SNoS_ (ordsucc omega)| x <> omega /\ forall q :e SNoS_ omega, (forall k :e omega, abs_SNo (q + - x) < eps_ k) -> q = x}.

// Proof in 1777388823.mg
ProofArchived lower_ext_real_I : forall x :e SNoS_ (ordsucc omega),
    x <> omega
 -> (forall q :e SNoS_ omega, (forall k :e omega, abs_SNo (q + - x) < eps_ k) -> q = x)
 -> x :e lower_ext_real.

// Proof in 1777388823.mg
ProofArchived lower_ext_real_E : forall x :e lower_ext_real,
  forall p:prop,
       (x :e SNoS_ (ordsucc omega)
    -> (x <> omega)
    -> (forall q :e SNoS_ omega, (forall k :e omega, abs_SNo (q + - x) < eps_ k) -> q = x)
    -> p)
   -> p.

// Proof in 1777388823.mg
ProofArchived lower_ext_real_SNoS_ordsucc_omega : lower_ext_real c= SNoS_ (ordsucc omega).

// Proof in 1777388823.mg
ProofArchived lower_ext_real_SNo : forall x :e lower_ext_real, SNo x.

// Proof in 1777388823.mg
ProofArchived real_lower_ext_real: real c= lower_ext_real.

// Proof in 1777388823.mg
ProofArchived SNoS_omega_dense_ext_real: forall x y :e ext_real, x < y -> exists q :e SNoS_ omega, x < q /\ q < y.

// Proof in 1777388823.mg
ProofArchived SNoS_omega_dense_real: forall x y :e real, x < y -> exists q :e SNoS_ omega, x < q /\ q < y.

End Reals.

