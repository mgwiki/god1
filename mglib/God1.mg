                  (fun k => mul (matrix_entry Lambda i k) (eta k))))
            /\ forall y :e K :^: p,
              linear_system_solution K add mul n p A b y ->
              (forall k :e p,
                k /:e {cols i|i :e n} -> y k = eta k) -> y = x.
