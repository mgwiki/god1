(** Explicit convergence bridge for the positive `pow_R` series used in the
    fallback-free null-set merge. This isolates the remaining semantic gap:
    turning the raw `sum_series < eps` hypothesis into a genuine convergence
    hypothesis for the component series. **)
// Proof in RealAnalysis2.1780556729.mg
ProofArchived pow_R_sum_series_lt_imp_bounded_above_of_limit :
  forall n :e omega,
  forall eps :e R,
  forall rseq :e setexp R omega,
    (forall k :e omega, 0 < rseq k) ->
    seq_limit
      (partial_sum_seq
        (fun k => pow_R (rseq k) n))
      (sum_series
        (fun k => pow_R (rseq k) n)) ->
    sum_series (fun k => pow_R (rseq k) n) < eps ->
    bounded_above_seq
      (partial_sum_seq
        (fun k => pow_R (rseq k) n)).

// Proof in RealAnalysis2.1780558981.mg
ProofArchived nonneg_bounded_above_seq_imp_bounded_seq :
  forall x : set -> set,
    R_seq x ->
    nonneg_seq x ->
    bounded_above_seq x ->
    bounded_seq x.

// Proof in RealAnalysis2.1780559648.mg
ProofArchived seq_limit_imp_convergent_seq :
  forall x : set -> set,
  forall l :e R,
    seq_limit x l ->
    convergent_seq x.

// Proof in RealAnalysis2.1780559648.mg
