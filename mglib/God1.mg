(** eps_ n is the Surreal Number 1/2^n, without needing to define division or exponents first **)
//LLM eps_ : "the eps  associated to #1" | $\mathrm{eps\_}(#1)$
Definition eps_ : set -> set := fun n => {0} :\/: {(ordsucc m) ' | m :e n}.

