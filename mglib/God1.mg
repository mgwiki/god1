(** § 11. Linear relations in a module. **)

//GOD1:232289 almost_all_zero : "almost all terms of #3 indexed by #1 are the zero #2" | $#3_i=0\text{ for almost all }i\in #1$
Definition almost_all_zero :
  set -> set -> (set -> set) -> prop :=
  fun I zero f => finite {i :e I|f i <> zero}.

//GOD1:232710 module_finitely_supported_sum : "the sum of the finitely supported family #5 indexed by #4" | $\sum_{i\in #4}#5_i$
Definition module_finitely_supported_sum :
  set -> (set -> set -> set) -> set -> (set -> set) -> set :=
  fun M addM I f =>
    group_word_product M addM
      (fun j => f (finite_enumeration {i :e I|f i <> module_zero M addM} j))
      (finite_cardinality {i :e I|f i <> module_zero M addM}).

//GOD1:212931 linear_representation : "#10 represents #9 as a linear combination of the family #8" | $#9=\sum_i #10_i#8_i$
Definition linear_representation :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> set -> (set -> set) -> prop :=
  fun K addK mulK M addM smul I a x coeff =>
    (forall i :e I, coeff i :e K)
    /\ almost_all_zero I (ring_zero K addK) coeff
    /\ x = module_finitely_supported_sum M addM I
      (fun i => smul (coeff i) (a i)).

//GOD1:212931 linear_combination : "#9 is a linear combination of the family #8 indexed by #7" | $#9\in\operatorname{span}(#8)$
Definition linear_combination :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> set -> prop :=
  fun K addK mulK M addM smul I a x =>
    x :e M
    /\ (forall i :e I, a i :e M)
    /\ exists coeff:set -> set,
      linear_representation
        K addK mulK M addM smul I a x coeff.

//GOD1:217293 submodule_generated_by_family : "the submodule of #4 generated by the family #8 indexed by #7" | $\operatorname{span}_{#1}\{#8_i:i\in#7\}$
Definition submodule_generated_by_family :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> set :=
  fun K addK mulK M addM smul I a =>
    {x :e M|linear_combination K addK mulK M addM smul I a x}.

Theorem god1_s11_theorem1_linear_combinations_form_generated_submodule :
  forall K, forall addK mulK:set -> set -> set,
  forall M, forall addM smul:set -> set -> set,
  forall n :e omega, forall a:set -> set,
    left_module K addK mulK M addM smul ->
    (forall i :e n, a i :e M) ->
    submodule K addK mulK M addM smul
      (submodule_generated_by_family K addK mulK M addM smul n a)
    /\ (forall i :e n,
      a i :e submodule_generated_by_family
        K addK mulK M addM smul n a)
    /\ (forall N,
      submodule K addK mulK M addM smul N ->
      (forall i :e n, a i :e N) ->
      submodule_generated_by_family
        K addK mulK M addM smul n a c= N).
let K addK mulK M addM smul n.
assume hn.
let a.
assume hM ha.
apply andI.
//GOD1PRF:215970 First of all, the relation
//GOD1PRF:216060 and similar relations for $a_{2}, \ldots, a_{n}$ show that $\mathrm{M}^{\prime}$ contains $a_{1}, \ldots, a_{n}$.
//GOD1PRF:216174 On the other hand, every submodule of M which contains $a_{1}, \ldots, a_{n}$ also contains $\xi_{1} a_{1}, \ldots, \xi_{n} a_{n}$, for all $\xi_{1}, \ldots, \xi_{n} \in \mathrm{~K}$, and hence also contains $\xi_{1} a_{1}+\cdots+\xi_{n} a_{n}$.
//GOD1PRF:216420 Hence every submodule of M which contains $a_{1}, \ldots, a_{n}$ contains the set $\mathrm{M}^{\prime}$.
//GOD1PRF:216526 The proof will therefore be complete if we show that $\mathrm{M}^{\prime}$ is in fact a submodule of M.
//GOD1PRF:216725 be any two elements of $\mathrm{M}^{\prime}$.
//GOD1PRF:216771 Then a trivial calculation shows that
//GOD1PRF:216961 it follows that $\lambda x+\mu y \in \mathbf{M}^{\prime}$ for all scalars $\lambda, \mu \in \mathbf{K}$, and therefore $\mathbf{M}^{\prime}$ is a submodule of M .\\
Admitted.

//GOD1:217701 generating_family : "the family #8 indexed by #7 generates the module #4" | $\operatorname{span}(#8)=#4$
Definition generating_family :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> prop :=
  fun K addK mulK M addM smul I a =>
    (forall i :e I, a i :e M)
    /\ submodule_generated_by_family
      K addK mulK M addM smul I a = M.

//GOD1:217701 finitely_generated_module : "the left module #4 is finitely generated" | $#4\text{ is finitely generated}$
Definition finitely_generated_module :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) -> prop :=
  fun K addK mulK M addM smul =>
    left_module K addK mulK M addM smul
    /\ exists I, finite I /\ exists a:set -> set,
      generating_family K addK mulK M addM smul I a.

//GOD1:218070 finite_dimensional_vector_space : "#4 is a finite-dimensional vector space over #1" | $\dim_{#1}(#4)<\infty$
Definition finite_dimensional_vector_space :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) -> prop :=
  fun K addK mulK M addM smul =>
    left_vector_space K addK mulK M addM smul
    /\ finitely_generated_module K addK mulK M addM smul.

//GOD1:220495 linear_relation : "#10 is a linear relation between the family #8 indexed by #7" | $\sum_i #10_i#8_i=0$
Definition linear_relation :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> (set -> set) -> prop :=
  fun K addK mulK M addM smul I a coeff =>
    linear_representation K addK mulK M addM smul I a
      (module_zero M addM) coeff.

//GOD1:220700 linearly_independent_family : "the family #8 indexed by #7 is linearly independent" | $#8_i\text{ are linearly independent}$
Definition linearly_independent_family :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> prop :=
  fun K addK mulK M addM smul I a =>
    left_module K addK mulK M addM smul
    /\ (forall i :e I, a i :e M)
    /\ forall coeff:set -> set,
      linear_relation K addK mulK M addM smul I a coeff ->
      forall i :e I, coeff i = ring_zero K addK.

Theorem god1_s11_theorem2_unique_coordinates_iff_independent :
  forall K, forall addK mulK:set -> set -> set,
  forall M, forall addM smul:set -> set -> set,
  forall n :e omega, forall a:set -> set, forall x,
    left_module K addK mulK M addM smul ->
    linear_combination K addK mulK M addM smul n a x ->
    ((exists coeff:set -> set,
        linear_representation
          K addK mulK M addM smul n a x coeff
        /\ forall eta:set -> set,
          linear_representation
            K addK mulK M addM smul n a x eta ->
          forall i :e n, eta i = coeff i)
      <-> linearly_independent_family
        K addK mulK M addM smul n a).
let K addK mulK M addM smul n.
assume hn.
let a x.
assume hM hx.
apply iffI.
//GOD1PRF:222338 It is enough to remark that, if ( $\lambda_{1}, \ldots, \lambda_{n}$ ) is a linear relation between $a_{1}, \ldots, a_{n}$, then $\lambda_{1} a_{1}+\cdots+\lambda_{n} a_{n}=0$ and therefore
//GOD1PRF:222658 Clearly this property characterizes linear relations between the given vectors $a_{1}, \ldots, a_{n}$.\\
Admitted.

//GOD1:225809 module_basis : "the family #8 indexed by #7 is a basis of the module #4" | $#8\text{ is a basis of }#4$
Definition module_basis :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> prop :=
  fun K addK mulK M addM smul I a =>
    linearly_independent_family K addK mulK M addM smul I a
    /\ generating_family K addK mulK M addM smul I a.

//GOD1:225809 finitely_generated_free_module : "the left module #4 is finitely generated and free" | $#4\text{ is a finitely generated free }#1\text{-module}$
Definition finitely_generated_free_module :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) -> prop :=
  fun K addK mulK M addM smul =>
    left_module K addK mulK M addM smul
    /\ exists I, finite I /\ exists a:set -> set,
      module_basis K addK mulK M addM smul I a.

//GOD1:235053 free_module : "the left module #4 is free" | $#4\text{ is a free }#1\text{-module}$
Definition free_module :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) -> prop :=
  fun K addK mulK M addM smul =>
    left_module K addK mulK M addM smul
    /\ exists I, exists a:set -> set,
      module_basis K addK mulK M addM smul I a.

//GOD1:227777 basis_coordinates : "the coordinates of #10 in the basis #8 indexed by #7" | $[#10]_{#8}$
Definition basis_coordinates :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> set -> set :=
  fun K addK mulK M addM smul I a x =>
    Eps_i (fun coeff =>
      coeff :e K :^: I
      /\ linear_representation
        K addK mulK M addM smul I a x (fun i => coeff i)).

//GOD1:227777 basis_coordinate_function : "the #9-coordinate function for the basis #8" | $f_{#9}$
Definition basis_coordinate_function :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> set -> set -> set :=
  fun K addK mulK M addM smul I a i x =>
    basis_coordinates K addK mulK M addM smul I a x i.

Theorem god1_basis_unique_coordinates_and_coordinate_linearity :
  forall K, forall addK mulK:set -> set -> set,
  forall M, forall addM smul:set -> set -> set,
  forall I, forall a:set -> set,
    module_basis K addK mulK M addM smul I a ->
    (forall x :e M,
      linear_representation K addK mulK M addM smul I a x
        (fun i => basis_coordinates K addK mulK M addM smul I a x i)
      /\ (forall coeff:set -> set,
        linear_representation K addK mulK M addM smul I a x coeff ->
        forall i :e I,
          coeff i = basis_coordinates K addK mulK M addM smul I a x i))
    /\ (forall i :e I, forall x y :e M,
      basis_coordinate_function K addK mulK M addM smul I a i (addM x y)
      = addK
        (basis_coordinate_function K addK mulK M addM smul I a i x)
        (basis_coordinate_function K addK mulK M addM smul I a i y))
    /\ (forall i :e I, forall scalar :e K, forall x :e M,
      basis_coordinate_function K addK mulK M addM smul I a i (smul scalar x)
      = mulK scalar
        (basis_coordinate_function K addK mulK M addM smul I a i x)).
let K addK mulK M addM smul I a.
assume hBasis.
apply andI.
