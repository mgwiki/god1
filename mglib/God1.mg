//LLM If_i : "the if-then-else operator on propositions" | $\mathrm{If\_i}(#1,#2,#3)$
Definition If_i : prop->set->set->set := (fun p x y => Eps_i (fun z:set => p /\ z = x \/ ~p /\ z = y)).
Notation IfThenElse If_i.

