//LLM factorial_step_fun : "the factorial step function associated to #1" | $\mathrm{factorial\_step\_fun}(#1,#2)$
Definition factorial_step_fun : set -> set -> set :=
  fun i => fun r => mul_SNo r (ordsucc i).

(** Factorial takes natural-number values on `omega`. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived factorial_nat :
  forall n :e omega,
    nat_p (factorial n).

(** Factorial takes surreal-number values on `omega`. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived factorial_SNo :
  forall n :e omega,
    SNo (factorial n).

(** Factorial is strictly positive on `omega`. **)
// Proof in RealAnalysis2.1782815868.mg
ProofArchived factorial_pos :
  forall n :e omega,
    0 < factorial n.

(** Factorial at a successor unfolds by one multiplication step.
    Megalodon already knows this bounded proposition from the unbounded
    helper below, so keep the book-facing name as an alias declaration. **)
Axiom factorial_ordsucc_eq :
  forall n :e omega,
    factorial (ordsucc n) = mul_SNo (factorial n) (ordsucc n).

(** Unbounded helper form of the factorial-successor recursion. **)
// Proof in RealAnalysis2.1782871946.mg
ProofArchived factorial_ordsucc_eq_imp :
  forall n,
    n :e omega ->
    factorial (ordsucc n) = mul_SNo (factorial n) (ordsucc n).

(** Factorial values are never zero. **)
// Proof in RealAnalysis2.1782872732.mg
ProofArchived factorial_nonzero :
  forall n :e omega,
    factorial n <> 0.

(** The factorial at `0` is `1`. **)
// Proof in RealAnalysis2.1782904198.mg
ProofArchived factorial_0_eq_1 :
  factorial 0 = 1.

(** Unbounded helper form of factorial nonvanishing.
    Megalodon already indexes this proposition from the bounded theorem
    above, so keep the helper name as an alias declaration. **)

(** Factorial values are complex numbers. **)
// Proof in RealAnalysis2.1782833511.mg
ProofArchived factorial_in_complex :
  forall n :e omega,
    factorial n :e complex.

(** Moved earlier from the later polynomial block because the nonzero
    ratio-test branch needs closure of complex powers immediately. In
    `real2.tex` this belongs with the elementary complex-power identities. **)
// Proof in RealAnalysis2.1780595603.mg
ProofArchived complex_exp_CSNo_nat_in_complex :
  forall z :e complex,
  forall n :e omega,
    exp_CSNo_nat z n :e complex.

(** Every exponential-series term is complex-valued on complex inputs. **)
// Proof in RealAnalysis2.1782833511.mg
ProofArchived complex_exp_term_in_complex :
  forall z :e complex,
  forall n :e omega,
    div_CSNo (exp_CSNo_nat z n) (factorial n) :e complex.

(** The term sequence for the complex exponential power series. **)
//LLM complex_exp_term_seq : "the sequence of terms in the complex exponential series at #1" | $\mathrm{complex\_exp\_term\_seq}(#1,#2)$
Definition complex_exp_term_seq : set -> set -> set :=
  fun z => fun n => div_CSNo (exp_CSNo_nat z n) (factorial n).

(** Partial sums of the complex exponential series stay in `complex`. **)
// Proof in RealAnalysis2.1782833511.mg
ProofArchived complex_exp_partial_sum_seq_in_complex :
  forall z :e complex,
  forall n :e omega,
    complex_partial_sum_seq
      (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
      n
    :e complex.

(** Real-valued modulus sequence associated to the complex exponential terms. **)
//LLM complex_exp_term_modulus_seq : "the sequence of term moduli in the complex exponential series at #1" | $\mathrm{complex\_exp\_term\_modulus\_seq}(#1,#2)$
Definition complex_exp_term_modulus_seq : set -> set -> set :=
  fun z => fun n => modulus_CSNo (div_CSNo (exp_CSNo_nat z n) (factorial n)).

(** The modulus sequence of complex exponential terms is a real sequence. **)
// Proof in RealAnalysis2.1782866372.mg
ProofArchived complex_exp_term_modulus_seq_R_seq :
  forall z :e complex,
    R_seq (complex_exp_term_modulus_seq z).

(** The modulus sequence of complex exponential terms is termwise nonnegative. **)
// Proof in RealAnalysis2.1782866372.mg
ProofArchived complex_exp_term_modulus_seq_nonneg :
  forall z :e complex,
    nonneg_seq (complex_exp_term_modulus_seq z).

(** Since the exponential-term modulus sequence is pointwise nonnegative, taking
    real absolute values does nothing to its terms. This is the bookkeeping
    simplification needed before applying the ratio-test infrastructure. **)
// Proof in RealAnalysis2.1782886530.mg
ProofArchived complex_exp_term_modulus_abs_eq :
  forall z :e complex,
  forall n :e omega,
    abs_SNo (complex_exp_term_modulus_seq z n)
    =
    complex_exp_term_modulus_seq z n.

(** The generic ratio-absolute-value sequence collapses to the ordinary quotient
    for the already-nonnegative exponential-term modulus sequence. **)
// Proof in RealAnalysis2.1782889123.mg
ProofArchived ratio_abs_seq_complex_exp_term_modulus_seq_eq :
  forall z :e complex,
  forall n :e omega,
    ratio_abs_seq (complex_exp_term_modulus_seq z) n
    =
    (complex_exp_term_modulus_seq z (ordsucc n))
      :/:
    (complex_exp_term_modulus_seq z n).

(** On real inputs, the squared complex modulus is the ordinary square. **)
// Proof in RealAnalysis2.1782889123.mg
ProofArchived abs_sqr_CSNo_real_eq_sqr :
  forall x :e real,
    abs_sqr_CSNo x = x ^ 2.

(** A nonnegative real viewed as a complex number has modulus equal to itself. **)
// Proof in RealAnalysis2.1782889123.mg
ProofArchived modulus_CSNo_nonneg_real_eq :
  forall x :e real,
    0 <= x ->
    modulus_CSNo x = x.

(** Moved below `modulus_CSNo_eq_subst_arg` to avoid a forward reference.
    In the book order this is just a local real strict-drop simplification for
    the shell-witness argument. **)

(** Factorial values, viewed as complex numbers, have modulus equal to themselves. **)
// Proof in RealAnalysis2.1782889123.mg
ProofArchived modulus_CSNo_factorial_eq :
  forall n :e omega,
    modulus_CSNo (factorial n) = factorial n.

(** Successor naturals, viewed as complex numbers, have modulus equal to themselves. **)
// Proof in RealAnalysis2.1782889123.mg
ProofArchived modulus_CSNo_ordsucc_eq :
  forall n :e omega,
    modulus_CSNo (ordsucc n) = ordsucc n.

(** The squared complex modulus is always a real number.
    Megalodon already indexes this proposition, so keep the name here as an
    alias declaration and build later local proofs on it. **)

(** The complex modulus is always a real number.
    Megalodon already indexes this proposition, so keep the book-facing name
    here as an alias declaration. **)

(** Partial sums of the exponential-term modulus sequence are nonnegative. **)
// Proof in RealAnalysis2.1782866678.mg
ProofArchived complex_exp_term_modulus_partial_sum_nonneg :
  forall z :e complex,
  forall n :e omega,
    0 <= partial_sum_seq (complex_exp_term_modulus_seq z) n.

(** The modulus partial sums for the exponential series form a monotone
    increasing real sequence. **)
// Proof in RealAnalysis2.1782866678.mg
ProofArchived complex_exp_term_modulus_partial_sum_monotone_inc :
  forall z :e complex,
    monotone_inc (partial_sum_seq (complex_exp_term_modulus_seq z)).

(** Convergence of the exponential-term modulus series is equivalent to the
    bounded-above property for its partial sums. **)
// Proof in RealAnalysis2.1782866984.mg
ProofArchived complex_exp_term_modulus_convergent_iff_bounded_above :
  forall z :e complex,
    (convergent_series (complex_exp_term_modulus_seq z)
     <->
     bounded_above_seq (partial_sum_seq (complex_exp_term_modulus_seq z))).

(** Any convergent modulus series for the complex exponential terms yields a
    bounded-above partial-sum majorant. **)
// Proof in RealAnalysis2.1782866984.mg
ProofArchived complex_exp_term_modulus_bounded_above_of_convergent :
  forall z :e complex,
    convergent_series (complex_exp_term_modulus_seq z) ->
    bounded_above_seq (partial_sum_seq (complex_exp_term_modulus_seq z)).

(** A bounded-above partial-sum majorant forces convergence of the exponential-term
    modulus series. **)
// Proof in RealAnalysis2.1782866984.mg
ProofArchived complex_exp_term_modulus_convergent_of_bounded_above :
  forall z :e complex,
    bounded_above_seq (partial_sum_seq (complex_exp_term_modulus_seq z)) ->
    convergent_series (complex_exp_term_modulus_seq z).

(** Moved earlier from the later polynomial-tail block because the
    `sec:complexexp` zero-argument majorant branch needs the basic vanishing
    fact for positive powers of `0` directly. In `real2.tex` it belongs with the
    elementary complex exponential power identities, not with the FTA tail
    manipulations that happened to reuse it later. **)
// Proof in RealAnalysis2.1780649792.mg
ProofArchived complex_exp_CSNo_nat_0_nonzero :
  forall k :e omega,
    k <> 0 ->
    exp_CSNo_nat 0 k = 0.

(** Triangle-inequality majorant for complex partial sums by the partial sums of
    termwise moduli. This is the core finite-sum estimate needed to transfer
    real-series boundedness to the complex exponential partial sums. **)
// Proof in RealAnalysis2.1782873698.mg
ProofArchived modulus_CSNo_add_Le :
  forall u :e complex,
  forall v :e complex,
    modulus_CSNo (add_CSNo u v) <= modulus_CSNo u + modulus_CSNo v.

(** Triangle-inequality majorant for complex partial sums by the partial sums of
    termwise moduli. This is the core finite-sum estimate needed to transfer
    real-series boundedness to the complex exponential partial sums. **)
Axiom modulus_CSNo_0_eq_0 :
  modulus_CSNo 0 = 0.

(** Triangle-inequality majorant for complex partial sums by the partial sums of
    termwise moduli. This is the core finite-sum estimate needed to transfer
    real-series boundedness to the complex exponential partial sums. **)
// Proof in RealAnalysis2.1782874604.mg
ProofArchived modulus_CSNo_eq_subst_arg :
  forall z :e complex,
  forall w :e complex,
    z = w ->
    modulus_CSNo z = modulus_CSNo w.

(** If `0 < t < 1`, then the real perturbation `1 - t` has complex modulus
    strictly below `1`.  This is the base real strict-drop estimate for the
    remaining small-radius shell-witness work. **)
// Proof in RealAnalysis2.1782949227.mg
ProofArchived complex_add_1_minus_real_modulus_lt_1 :
  forall t :e real,
    0 < t ->
    t < 1 ->
    modulus_CSNo (add_CSNo 1 (minus_CSNo t)) < 1.

(** Any positive real admits a smaller positive real strictly below `1`.  This
    is the scalar-selection helper needed for the remaining local shell-witness
    constructions. **)
// Moved below `existsI_mem_local`, which its proof now uses directly.

// Moved below `dist_complex_eq_subst_argL`, which its proof now uses directly.

(** Triangle-inequality majorant for complex partial sums by the partial sums of
    termwise moduli. This is the core finite-sum estimate needed to transfer
    real-series boundedness to the complex exponential partial sums. **)
// Proof in RealAnalysis2.1782874604.mg
ProofArchived complex_modulus_seq_R_seq :
  forall x : set -> set,
    (forall n :e omega, x n :e complex) ->
    R_seq (fun n : set => modulus_CSNo (x n)).

(** Triangle-inequality majorant for complex partial sums by the partial sums of
    termwise moduli. This is the core finite-sum estimate needed to transfer
    real-series boundedness to the complex exponential partial sums. **)
// Proof in RealAnalysis2.1782874604.mg
ProofArchived complex_partial_sum_seq_modulus_Le_partial_sum_seq_term_modulus_0 :
  forall x : set -> set,
    (forall n :e omega, x n :e complex) ->
    modulus_CSNo (complex_partial_sum_seq x 0)
    <=
    partial_sum_seq (fun k : set => modulus_CSNo (x k)) 0.

(** Triangle-inequality majorant for complex partial sums by the partial sums of
    termwise moduli. This is the core finite-sum estimate needed to transfer
    real-series boundedness to the complex exponential partial sums. **)
// Proof in RealAnalysis2.1782875992.mg
ProofArchived complex_partial_sum_seq_modulus_succ_eq :
  forall x : set -> set,
    (forall n :e omega, x n :e complex) ->
    forall n :e omega,
      modulus_CSNo (complex_partial_sum_seq x (ordsucc n))
      =
      modulus_CSNo (add_CSNo (complex_partial_sum_seq x n) (x n)).

(** Triangle-inequality majorant for complex partial sums by the partial sums of
    termwise moduli. This is the core finite-sum estimate needed to transfer
    real-series boundedness to the complex exponential partial sums. **)
// Proof in RealAnalysis2.1782875992.mg
ProofArchived complex_modulus_partial_sum_seq_succ_eq :
  forall x : set -> set,
    (forall n :e omega, x n :e complex) ->
    forall n :e omega,
      partial_sum_seq (fun k : set => modulus_CSNo (x k)) (ordsucc n)
      =
      partial_sum_seq (fun k : set => modulus_CSNo (x k)) n
      +
      modulus_CSNo (x n).

(** Triangle-inequality majorant for complex partial sums by the partial sums of
    termwise moduli. This is the core finite-sum estimate needed to transfer
    real-series boundedness to the complex exponential partial sums. **)
// Proof in RealAnalysis2.1782875992.mg
ProofArchived complex_partial_sum_seq_modulus_Le_partial_sum_seq_term_modulus_S :
  forall x : set -> set,
    (forall n :e omega, x n :e complex) ->
    forall n :e omega,
      modulus_CSNo (complex_partial_sum_seq x n)
      <=
      partial_sum_seq (fun k : set => modulus_CSNo (x k)) n
      ->
      modulus_CSNo (complex_partial_sum_seq x (ordsucc n))
      <=
      partial_sum_seq (fun k : set => modulus_CSNo (x k)) (ordsucc n).

(** Triangle-inequality majorant for complex partial sums by the partial sums of
    termwise moduli. This is the core finite-sum estimate needed to transfer
    real-series boundedness to the complex exponential partial sums. **)
// Proof in RealAnalysis2.1782875992.mg
ProofArchived complex_partial_sum_seq_modulus_Le_partial_sum_seq_term_modulus :
  forall x : set -> set,
    (forall n :e omega, x n :e complex) ->
    forall n :e omega,
      modulus_CSNo (complex_partial_sum_seq x n)
      <=
      partial_sum_seq (fun k : set => modulus_CSNo (x k)) n.

(** Specialization of the complex partial-sum majorant to the exponential
    series terms. **)
// Proof in RealAnalysis2.1782875992.mg
ProofArchived complex_exp_partial_sum_seq_modulus_Le_majorant :
  forall z :e complex,
  forall n :e omega,
    modulus_CSNo
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
        n)
    <=
    partial_sum_seq (complex_exp_term_modulus_seq z) n.

(** A bounded-above majorant for the modulus series yields a uniform modulus
    bound on the corresponding complex exponential partial sums. **)
// Proof in RealAnalysis2.1782875992.mg
ProofArchived complex_exp_partial_sum_seq_bounded_of_majorant_bounded_above :
  forall z :e complex,
    bounded_above_seq (partial_sum_seq (complex_exp_term_modulus_seq z)) ->
    exists M :e R,
      forall n :e omega,
        modulus_CSNo
          (complex_partial_sum_seq
            (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
            n)
        <= M.

(** Tail shifting preserves pointwise nonnegativity of a real sequence. **)
// Proof in RealAnalysis2.1782877078.mg
ProofArchived tail_series_nonneg :
  forall x : set -> set,
    nonneg_seq x ->
    forall M :e omega,
      nonneg_seq (tail_series x M).

(** For a nonnegative real series, each finite tail partial sum equals the
    distance between the corresponding two full partial sums. **)
// Proof in RealAnalysis2.1782877078.mg
ProofArchived partial_sum_seq_tail_series_eq_dist_nonneg :
  forall x : set -> set,
    R_seq x ->
    nonneg_seq x ->
    forall M :e omega,
    forall n :e omega,
      partial_sum_seq (tail_series x M) n
      =
      dist_R
        (partial_sum_seq x (add_nat M n))
        (partial_sum_seq x M).

(** Equality transport for the left argument of `dist_complex`. **)
// Proof in RealAnalysis2.1782879852.mg
ProofArchived dist_complex_eq_subst_argL :
  forall z1 :e complex,
  forall z2 :e complex,
  forall w :e complex,
    z1 = z2 ->
    dist_complex z1 w = dist_complex z2 w.

// Proof in RealAnalysis2.1782951033.mg
ProofArchived dist_complex_minus_zero_eq :
  forall z :e complex,
    dist_complex (minus_CSNo z) 0 = dist_complex z 0.

(** Complex exponential tail differences are bounded by the corresponding real
    tail partial sums of the modulus majorant series. **)
// Proof in RealAnalysis2.1782881359.mg
ProofArchived complex_exp_partial_sum_seq_dist_Le_majorant_tail :
  forall z :e complex,
  forall M :e omega,
  forall n :e omega,
    dist_complex
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
        (add_nat M n))
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
        M)
    <=
    partial_sum_seq (tail_series (complex_exp_term_modulus_seq z) M) n.

(** Repackage the tail-majorant estimate in the direct `N + n` form used by the
    real Cauchy witness on majorant partial sums. **)
// Proof in RealAnalysis2.1782886530.mg
ProofArchived complex_exp_partial_sum_seq_dist_Le_majorant_add_nat :
  forall z :e complex,
  forall M :e omega,
  forall n :e omega,
    dist_complex
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
        (add_nat M n))
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
        M)
    <=
    dist_R
      (partial_sum_seq (complex_exp_term_modulus_seq z) (add_nat M n))
      (partial_sum_seq (complex_exp_term_modulus_seq z) M).

(** Ordered partial-sum distances for the complex exponential are bounded by
    the corresponding ordered distances of the real modulus-majorant partial
    sums. This is the shape needed to transport real Cauchy estimates to the
    complex partial sums. **)
// Proof in RealAnalysis2.1782898466.mg
ProofArchived complex_exp_partial_sum_seq_dist_Le_majorant_ordered :
  forall z :e complex,
  forall m :e omega,
  forall n :e omega,
    m <= n ->
    dist_complex
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
        m)
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
        n)
    <=
    dist_R
      (partial_sum_seq (complex_exp_term_modulus_seq z) m)
      (partial_sum_seq (complex_exp_term_modulus_seq z) n).

(** Arbitrary complex exponential partial-sum distances are bounded by the
    corresponding real modulus-majorant partial-sum distances. **)
// Proof in RealAnalysis2.1782898466.mg
ProofArchived complex_exp_partial_sum_seq_dist_Le_majorant :
  forall z :e complex,
  forall m :e omega,
  forall n :e omega,
    dist_complex
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
        m)
      (complex_partial_sum_seq
        (fun k : set => div_CSNo (exp_CSNo_nat z k) (factorial k))
        n)
    <=
    dist_R
      (partial_sum_seq (complex_exp_term_modulus_seq z) m)
      (partial_sum_seq (complex_exp_term_modulus_seq z) n).

