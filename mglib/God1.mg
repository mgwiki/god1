          addE smul 2
          (fun k => if k = 0
            then endomorphism_power_kernel K addK mulK E addE smul u (Union i)
            else F i)
        /\ (0 :e Union i ->
          (forall x :e F i, u x :e F (Union i))
          /\ inj (F i) (F (Union i)) u).
