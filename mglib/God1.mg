ProofArchived null_set_evenodd_cseq_odd_witness :
  forall n,
  forall cseq1,
  forall cseq2,
  forall k,
  forall m :e omega,
    k = ordsucc (2 * m) ->
    null_set_evenodd_cseq n cseq1 cseq2 k = cseq2 m.

// Proof in RealAnalysis2.1780538786.mg
ProofArchived null_set_evenodd_rseq_odd_witness :
  forall rseq1,
  forall rseq2,
  forall k,
  forall m :e omega,
    k = ordsucc (2 * m) ->
    null_set_evenodd_rseq rseq1 rseq2 k = rseq2 m.

// Proof in RealAnalysis2.1780538786.mg
ProofArchived null_set_evenodd_cseq_mem :
  forall n :e omega,
  forall cseq1 :e setexp (Rn n) omega,
  forall cseq2 :e setexp (Rn n) omega,
    (fun k :e omega => null_set_evenodd_cseq n cseq1 cseq2 k)
      :e setexp (Rn n) omega.

// Proof in RealAnalysis2.1780538786.mg
ProofArchived null_set_evenodd_rseq_mem :
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    (fun k :e omega => null_set_evenodd_rseq rseq1 rseq2 k)
      :e setexp R omega.

// Proof in RealAnalysis2.1780538786.mg
ProofArchived null_set_evenodd_rseq_pos :
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    (forall k :e omega, 0 < rseq1 k) ->
    (forall k :e omega, 0 < rseq2 k) ->
    forall k :e omega,
      0 < null_set_evenodd_rseq rseq1 rseq2 k.

(** Even-indexed balls in the fallback-free merge recover the first witness family exactly. **)
// Proof in RealAnalysis2.1780538786.mg
ProofArchived null_set_evenodd_ball_even :
  forall n :e omega,
  forall cseq1 :e setexp (Rn n) omega,
  forall cseq2 :e setexp (Rn n) omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
  forall k :e omega,
    ms_ball (Rn n) (Rn_dist n) (cseq1 k) (rseq1 k)
    =
    ms_ball
      (Rn n)
      (Rn_dist n)
      ((fun j :e omega => null_set_evenodd_cseq n cseq1 cseq2 j) (2 * k))
      ((fun j :e omega => null_set_evenodd_rseq rseq1 rseq2 j) (2 * k)).

(** Odd-indexed balls in the fallback-free merge recover the second witness family exactly. **)
// Proof in RealAnalysis2.1780538786.mg
ProofArchived null_set_evenodd_ball_odd :
  forall n :e omega,
  forall cseq1 :e setexp (Rn n) omega,
  forall cseq2 :e setexp (Rn n) omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
  forall k :e omega,
    ms_ball (Rn n) (Rn_dist n) (cseq2 k) (rseq2 k)
    =
    ms_ball
      (Rn n)
      (Rn_dist n)
      ((fun j :e omega => null_set_evenodd_cseq n cseq1 cseq2 j) (ordsucc (2 * k)))
      ((fun j :e omega => null_set_evenodd_rseq rseq1 rseq2 j) (ordsucc (2 * k))).

(** The fallback-free even/odd merge covers the union of the two original ball families. **)
// Proof in RealAnalysis2.1780538786.mg
ProofArchived null_set_evenodd_cover_subq :
  forall n :e omega,
  forall cseq1 :e setexp (Rn n) omega,
  forall cseq2 :e setexp (Rn n) omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    (((\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq1 k) (rseq1 k))
      :\/:
      (\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq2 k) (rseq2 k)))
     c=
     (\/_ k :e omega,
       ms_ball
         (Rn n)
         (Rn_dist n)
         ((fun j :e omega => null_set_evenodd_cseq n cseq1 cseq2 j) k)
         ((fun j :e omega => null_set_evenodd_rseq rseq1 rseq2 j) k))).

// Proof in RealAnalysis2.1780542465.mg
ProofArchived null_set_evenodd_pow_term_even :
  forall n :e omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
  forall k :e omega,
    pow_R
      (((fun j :e omega => null_set_evenodd_rseq rseq1 rseq2 j) (2 * k)))
      n
    =
    pow_R (rseq1 k) n.

// Proof in RealAnalysis2.1780542465.mg
ProofArchived null_set_evenodd_pow_term_odd :
  forall n :e omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
  forall k :e omega,
    pow_R
      (((fun j :e omega => null_set_evenodd_rseq rseq1 rseq2 j) (ordsucc (2 * k))))
      n
    =
    pow_R (rseq2 k) n.

(** Every term in the even/odd merged power series is strictly positive. **)
// Proof in RealAnalysis2.1780542465.mg
ProofArchived null_set_evenodd_pow_term_pos :
  forall n :e omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
  (forall k :e omega, 0 < rseq1 k) ->
  (forall k :e omega, 0 < rseq2 k) ->
  forall k :e omega,
    pow_R
      (((fun j :e omega => null_set_evenodd_rseq rseq1 rseq2 j) k))
      n
    :e Ioi 0.

(** The merged even/odd power sequence is a real sequence. **)
// Proof in RealAnalysis2.1780542465.mg
ProofArchived null_set_evenodd_pow_R_seq :
  forall n :e omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
  (forall k :e omega, 0 < rseq1 k) ->
  (forall k :e omega, 0 < rseq2 k) ->
    R_seq
      (fun k =>
        pow_R
          (((fun j :e omega => null_set_evenodd_rseq rseq1 rseq2 j) k))
          n).

(** Positive real sequences stay real after applying `pow_R` with a natural exponent. **)
// Proof in RealAnalysis2.1780543858.mg
ProofArchived pow_R_seq_of_pos :
  forall n :e omega,
  forall rseq :e setexp R omega,
    (forall k :e omega, 0 < rseq k) ->
    R_seq (fun k => pow_R (rseq k) n).

// First step of the even/odd merged partial sums: the next term after the even index comes from the first sequence.
// Proof in RealAnalysis2.1780543858.mg
ProofArchived null_set_evenodd_pow_partial_sum_even_step :
  forall n :e omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
  forall k :e omega,
    partial_sum_seq
      (fun j : set =>
        pow_R
          (((fun i :e omega => null_set_evenodd_rseq rseq1 rseq2 i) j))
          n)
      (ordsucc (2 * k))
    =
    partial_sum_seq
      (fun j : set =>
        pow_R
          (((fun i :e omega => null_set_evenodd_rseq rseq1 rseq2 i) j))
          n)
      (2 * k)
    +
    pow_R (rseq1 k) n.

// Second step of the even/odd merged partial sums: the next term after the odd index comes from the second sequence.
// Proof in RealAnalysis2.1780543858.mg
ProofArchived null_set_evenodd_pow_partial_sum_odd_step :
  forall n :e omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
  forall k :e omega,
    partial_sum_seq
      (fun j : set =>
        pow_R
          (((fun i :e omega => null_set_evenodd_rseq rseq1 rseq2 i) j))
          n)
      (2 * (ordsucc k))
    =
    partial_sum_seq
      (fun j : set =>
        pow_R
          (((fun i :e omega => null_set_evenodd_rseq rseq1 rseq2 i) j))
          n)
      (ordsucc (2 * k))
    +
    pow_R (rseq2 k) n.

(** Exact even-index partial sums for the fallback-free even/odd merged power sequence.
    This is the main remaining algebraic bridge needed for the summability proof in `sec:outermeasure`. **)
// Proof in RealAnalysis2.1780547846.mg
ProofArchived R_add_quad_reassoc :
  forall a b c d :e R,
    ((a + b) + c) + d = (a + c) + (b + d).

// Proof in RealAnalysis2.1780547846.mg
ProofArchived R_add_three_reassoc_swap :
  forall a b c :e R,
    (a + b) + c = (a + c) + b.

// Proof in RealAnalysis2.1780547846.mg
ProofArchived null_set_evenodd_pow_partial_sum_even_eq :
  forall n :e omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    (forall k :e omega, 0 < rseq1 k) ->
    (forall k :e omega, 0 < rseq2 k) ->
    forall k :e omega,
      partial_sum_seq
        (fun j : set =>
          pow_R
            (((fun i :e omega => null_set_evenodd_rseq rseq1 rseq2 i) j))
            n)
        (2 * k)
      =
      partial_sum_seq
        (fun j : set => pow_R (rseq1 j) n)
        k
      +
      partial_sum_seq
        (fun j : set => pow_R (rseq2 j) n)
        k.

// Proof in RealAnalysis2.1780547846.mg
ProofArchived null_set_evenodd_pow_partial_sum_odd_eq :
  forall n :e omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    (forall k :e omega, 0 < rseq1 k) ->
    (forall k :e omega, 0 < rseq2 k) ->
    forall k :e omega,
      partial_sum_seq
        (fun j : set =>
          pow_R
            (((fun i :e omega => null_set_evenodd_rseq rseq1 rseq2 i) j))
            n)
        (ordsucc (2 * k))
      =
      partial_sum_seq
        (fun j : set => pow_R (rseq1 j) n)
        (ordsucc k)
      +
      partial_sum_seq
        (fun j : set => pow_R (rseq2 j) n)
        k.

(** For a nonnegative convergent real series, every partial sum is bounded by the chosen sum.
    Megalodon reports this proposition is already known elsewhere; keep it as an axiom here.
    The removed local proof is preserved in `scratch/partial_sum_seq_Le_sum_series_of_nonneg_conv.proof.bck0630.mg`. **)
Axiom partial_sum_seq_Le_sum_series_of_nonneg_conv :
  forall x : set -> set,
    R_seq x ->
    nonneg_seq x ->
    convergent_series x ->
    forall n :e omega,
      partial_sum_seq x n <= sum_series x.

(** Half-epsilon additive estimate for sums of convergent real series.
    Megalodon reports this proposition is already known elsewhere; keep it as an axiom here.
    The removed local proof is preserved in `scratch/sum_series_add_lt_of_half_bounds_conv.proof.bck0630.mg`. **)
Axiom sum_series_add_lt_of_half_bounds_conv :
  forall x y : set -> set,
    R_seq x ->
    R_seq y ->
    convergent_series x ->
    convergent_series y ->
    forall eps :e R,
      sum_series x < eps :/: 2 ->
      sum_series y < eps :/: 2 ->
      sum_series (seq_add x y) < eps.

(** Positive real sequences become nonnegative after applying `pow_R` with a natural exponent. **)
// Proof in RealAnalysis2.1780545727.mg
ProofArchived pow_R_seq_nonneg_of_pos :
  forall n :e omega,
  forall rseq :e setexp R omega,
    (forall k :e omega, 0 < rseq k) ->
    nonneg_seq (fun k => pow_R (rseq k) n).

(** The even/odd merged power series is nonnegative termwise. **)
// Proof in RealAnalysis2.1780545727.mg
ProofArchived null_set_evenodd_pow_nonneg_seq :
  forall n :e omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    (forall k :e omega, 0 < rseq1 k) ->
    (forall k :e omega, 0 < rseq2 k) ->
    nonneg_seq
      (fun j : set =>
        pow_R
          (((fun i :e omega => null_set_evenodd_rseq rseq1 rseq2 i) j))
          n).

(** Megalodon reports this proposition is already known elsewhere; keep it as an axiom. **)
Axiom null_set_evenodd_cover_merge :
  forall n :e omega,
  forall cseq1 :e setexp (Rn n) omega,
  forall cseq2 :e setexp (Rn n) omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    (forall k :e omega, 0 < rseq1 k) ->
    (forall k :e omega, 0 < rseq2 k) ->
    exists cseq :e setexp (Rn n) omega,
    exists rseq :e setexp R omega,
      (forall k :e omega, 0 < rseq k)
      /\ (((\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq1 k) (rseq1 k))
           :\/:
           (\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq2 k) (rseq2 k)))
          c=
          (\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq k) (rseq k))).

(** Doubling indices defines a subsequence function on `omega`. This is the
    bookkeeping needed for the even-partial-sum subsequence in the fallback-free
    merge argument. **)
// Proof in RealAnalysis2.1780552672.mg
ProofArchived mul2_subseq_fun :
  subseq_fun (fun n => 2 * n).

(** Convergence-based reduction for the fallback-free even/odd power merge.
    The saved proof attempt is in
    `scratch/null_set_evenodd_rseq_pow_series_lt_of_conv.proof_attempt.bck0628.mg`.
    This isolates the remaining semantic gap in `null_set_evenodd_rseq_pow_series_lt`
    to obtaining convergence of the two component power series from the outer
    null-set witness hypotheses. **)
// Proof in RealAnalysis2.1780555937.mg
ProofArchived null_set_evenodd_pow_partial_sum_bounded_above_of_conv :
  forall n :e omega,
  forall eps :e R,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    0 < eps ->
    (forall k :e omega, 0 < rseq1 k) ->
    (forall k :e omega, 0 < rseq2 k) ->
    convergent_series (fun k => pow_R (rseq1 k) n) ->
    convergent_series (fun k => pow_R (rseq2 k) n) ->
    sum_series (fun k => pow_R (rseq1 k) n) < eps :/: 2 ->
    sum_series (fun k => pow_R (rseq2 k) n) < eps :/: 2 ->
    bounded_above_seq
      (partial_sum_seq
        (fun k =>
          pow_R
            (((fun k :e omega => null_set_evenodd_rseq rseq1 rseq2 k) k))
            n)).

// Proof in RealAnalysis2.1780553458.mg
ProofArchived partial_sum_seq_ordsucc_limit_of_conv :
  forall x : set -> set,
    R_seq x ->
    convergent_series x ->
    seq_limit
      (fun k : set => partial_sum_seq x (ordsucc k))
      (sum_series x).

// Proof in RealAnalysis2.1780553458.mg
ProofArchived null_set_evenodd_pow_partial_sum_even_limit_of_conv :
