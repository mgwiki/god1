assume hf0.
let g0.
assume hg0.
apply (god1_s28_theorem1_one_variable_interface K add mul f0 hf0 g0 hg0 hDomain hInfinite).
claim h_s28_t1_specialized_coefficients_zero : forall H:set -> set,
  (forall r :e omega, H r :e multivariate_polynomial_ring K add (Union n)) ->
