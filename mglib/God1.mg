      exists a :e K, a <> ring_zero K add
        /\ d = polynomial_constant K add mul 1 a)
    <-> exists u :e P :^: n,
      module_finitely_supported_sum P addP n
        (fun i => mulP (u i) (f i))
      = polynomial_constant K add mul 1 (ring_one K mul)).
