ProofArchived null_set_binunion_cseq_eq_tag1_witness :
  forall n,
  forall cseq1,
  forall cseq2,
  forall k,
  forall m :e omega,
    k = nat_pair 1 m ->
    null_set_binunion_cseq n cseq1 cseq2 k = cseq2 m.

