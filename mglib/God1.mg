Section form92.

(** real2.tex: sec:complexexp (Complex exponential and trigonometric functions) [scaffolding]. **)

//LLM complex_partial_sum_seq : "the sequence of complex partial sums associated to #1" | $\mathrm{complex\_partial\_sum\_seq}(#1)$
Definition complex_partial_sum_seq : (set -> set) -> (set -> set) :=
  fun x => fun n => nat_primrec 0 (fun i r => add_CSNo r (x i)) n.

(** Unfolding at the origin for complex partial sums. **)
// Proof in RealAnalysis2.1782828742.mg
ProofArchived complex_partial_sum_seq_0 :
  forall x : set -> set,
    complex_partial_sum_seq x 0 = 0.

(** Successor-step recursion for complex partial sums. **)
// Proof in RealAnalysis2.1782828742.mg
ProofArchived complex_partial_sum_seq_S :
  forall x : set -> set,
  forall n :e omega,
    complex_partial_sum_seq x (ordsucc n)
    =
    add_CSNo
      (complex_partial_sum_seq x n)
      (x n).

(** Complex-valued terms yield complex-valued partial sums. **)
// Proof in RealAnalysis2.1782828742.mg
ProofArchived complex_partial_sum_seq_in_complex :
  forall x : set -> set,
    (forall n :e omega, x n :e complex) ->
    forall n :e omega,
      complex_partial_sum_seq x n :e complex.

(** Extensionality of complex partial sums on an initial segment. **)
// Proof in RealAnalysis2.1782841407.mg
ProofArchived complex_partial_sum_seq_ext :
  forall x y : set -> set,
  forall n :e omega,
    (forall i :e n, x i = y i) ->
    complex_partial_sum_seq x n = complex_partial_sum_seq y n.

(** The zero-valued complex sequence has zero partial sums. **)
// Proof in RealAnalysis2.1782841407.mg
ProofArchived complex_partial_sum_seq_const_zero :
  forall n :e omega,
    complex_partial_sum_seq (fun i : set => 0) n = 0.

(** Note: moved below the real/imaginary projection lemmas so the proof can use
    `complex_Re_add_CSNo`, `complex_Im_add_CSNo`, `complex_partial_sum_seq_Re`,
    and `complex_partial_sum_seq_Im` without forward references. In `real2.tex`
    it still belongs with the basic finite-sum algebra for `complex_exp`. **)

(** Pulling out a fixed left complex factor from a complex partial sum. **)
// Proof in RealAnalysis2.1782828742.mg
ProofArchived complex_partial_sum_seq_mul_const_left :
  forall c :e complex,
  forall y : set -> set,
    (forall n :e omega, y n :e complex) ->
    forall n :e omega,
      complex_partial_sum_seq
        (fun j : set => mul_CSNo c (y j))
        n
      =
      mul_CSNo c (complex_partial_sum_seq y n).

(** Pulling out a fixed right complex factor from a complex partial sum. **)
// Proof in RealAnalysis2.1782836206.mg
ProofArchived complex_partial_sum_seq_mul_const_right :
  forall y : set -> set,
  forall c :e complex,
    (forall n :e omega, y n :e complex) ->
    forall n :e omega,
      complex_partial_sum_seq
        (fun j : set => mul_CSNo (y j) c)
        n
      =
      mul_CSNo
        (complex_partial_sum_seq y n)
        c.

(** Split a complex partial sum at an index `M` using the shifted tail series. **)
// Proof in RealAnalysis2.1782836751.mg
ProofArchived complex_partial_sum_seq_add_nat_split :
  forall x : set -> set,
    (forall k :e omega, x k :e complex) ->
    forall M :e omega,
    forall n :e omega,
      complex_partial_sum_seq x (add_nat M n)
      =
      add_CSNo
        (complex_partial_sum_seq x M)
        (complex_partial_sum_seq (tail_series x M) n).

(** Direct finite series-product theorem for complex partial sums. **)
// Proof in RealAnalysis2.1782828742.mg
ProofArchived complex_partial_sum_seq_product :
  forall x : set -> set,
  forall y : set -> set,
    (forall i :e omega, x i :e complex) ->
    (forall j :e omega, y j :e complex) ->
    forall m :e omega,
    forall n :e omega,
      mul_CSNo
        (complex_partial_sum_seq x m)
        (complex_partial_sum_seq y n)
      =
      complex_partial_sum_seq
        (fun i : set =>
          complex_partial_sum_seq
            (fun j : set => mul_CSNo (x i) (y j))
            n)
        m.

(** Real part of complex addition. **)
// Proof in RealAnalysis2.1782835299.mg
ProofArchived complex_Re_add_CSNo :
  forall z :e complex,
  forall w :e complex,
    Re (add_CSNo z w) = Re z + Re w.

(** Imaginary part of complex addition. **)
// Proof in RealAnalysis2.1782835299.mg
ProofArchived complex_Im_add_CSNo :
  forall z :e complex,
  forall w :e complex,
    Im (add_CSNo z w) = Im z + Im w.

(** Real part of a complex partial sum is the partial sum of real parts. **)
// Proof in RealAnalysis2.1782835299.mg
ProofArchived complex_partial_sum_seq_Re :
  forall x : set -> set,
    (forall n :e omega, x n :e complex) ->
    forall n :e omega,
      Re (complex_partial_sum_seq x n)
      =
      partial_sum_seq (fun k : set => Re (x k)) n.

(** Imaginary part of a complex partial sum is the partial sum of imaginary parts. **)
// Proof in RealAnalysis2.1782835299.mg
ProofArchived complex_partial_sum_seq_Im :
  forall x : set -> set,
    (forall n :e omega, x n :e complex) ->
    forall n :e omega,
      Im (complex_partial_sum_seq x n)
      =
      partial_sum_seq (fun k : set => Im (x k)) n.

(** Partial sums distribute over pointwise complex addition. **)
// Proof in RealAnalysis2.1782842193.mg
ProofArchived complex_partial_sum_seq_add_split :
  forall x y : set -> set,
    (forall n :e omega, x n :e complex) ->
    (forall n :e omega, y n :e complex) ->
    forall n :e omega,
      complex_partial_sum_seq
        (fun i : set => add_CSNo (x i) (y i))
        n
      =
      add_CSNo
        (complex_partial_sum_seq x n)
        (complex_partial_sum_seq y n).

(** Finite complex double sums can be swapped. **)
// Proof in RealAnalysis2.1782835299.mg
ProofArchived complex_partial_sum_seq_double_swap :
  forall a : set -> set -> set,
  forall n :e omega,
  forall m :e omega,
    (forall i :e omega, forall j :e omega, a i j :e complex) ->
    complex_partial_sum_seq
      (fun i : set => complex_partial_sum_seq (fun j : set => a i j) m)
      n
    =
    complex_partial_sum_seq
      (fun j : set => complex_partial_sum_seq (fun i : set => a i j) n)
      m.

// Proof in RealAnalysis2.1782837657.mg
ProofArchived complex_add_CSNo_cancel_L :
  forall x :e complex,
  forall y :e complex,
  forall z :e complex,
    add_CSNo x y = add_CSNo x z ->
    y = z.

(** Tail-series form of the complex offset split identity. **)
// Proof in RealAnalysis2.1782837657.mg
ProofArchived complex_partial_sum_seq_tail_series_eq :
  forall x : set -> set,
    (forall k :e omega, x k :e complex) ->
    forall M :e omega,
    forall n :e omega,
      complex_partial_sum_seq (tail_series x M) n
      =
      add_CSNo
        (complex_partial_sum_seq x (add_nat M n))
        (minus_CSNo (complex_partial_sum_seq x M)).

(** Pulling out a fixed left complex factor from a shifted tail partial sum. **)
// Proof in RealAnalysis2.1782838684.mg
ProofArchived complex_partial_sum_seq_mul_const_left_tail_series :
  forall c :e complex,
  forall y : set -> set,
    (forall n :e omega, y n :e complex) ->
    forall M :e omega,
    forall n :e omega,
      complex_partial_sum_seq
        (tail_series (fun j : set => mul_CSNo c (y j)) M)
        n
      =
      mul_CSNo
        c
        (complex_partial_sum_seq (tail_series y M) n).

(** Split a left-scaled complex partial sum at `M` into a scaled prefix and
    scaled shifted tail. **)
// Proof in RealAnalysis2.1782838684.mg
ProofArchived complex_partial_sum_seq_mul_const_left_add_nat_split :
  forall c :e complex,
  forall y : set -> set,
    (forall n :e omega, y n :e complex) ->
    forall M :e omega,
    forall n :e omega,
      complex_partial_sum_seq
        (fun j : set => mul_CSNo c (y j))
        (add_nat M n)
      =
      add_CSNo
        (complex_partial_sum_seq
          (fun j : set => mul_CSNo c (y j))
          M)
        (mul_CSNo
          c
          (complex_partial_sum_seq (tail_series y M) n)).

//LLM factorial : "the factorial of #1" | $#1 !$
Definition factorial : set -> set := fun n => nat_primrec 1 (fun i r => mul_SNo r (ordsucc i)) n.

(** Complex exponential e^z on complex. **)
//REAL2:412578 complex_exp : "the complex exponential of #1" | $e^{#1}$
//LLM complex_exp : "the complex exponential of #1" | $e^{#1}$
Definition complex_exp : set -> set :=
  fun z => ms_lim_seq complex dist_complex
               (complex_partial_sum_seq (fun n => div_CSNo (exp_CSNo_nat z n) (factorial n))).

(** Complex cosine on complex. **)
//REAL2:414851 complex_cos : "the complex cosine of #1" | $\cos(#1)$
//LLM complex_cos : "the complex cosine of #1" | $\cos(#1)$
Definition complex_cos : set -> set :=
  fun z => div_CSNo (add_CSNo (complex_exp (mul_CSNo Complex_i z)) (complex_exp (minus_CSNo (mul_CSNo Complex_i z)))) 2.

(** Complex sine on complex. **)
//REAL2:414919 complex_sin : "the complex sine of #1" | $\sin(#1)$
//LLM complex_sin : "the complex sine of #1" | $\sin(#1)$
Definition complex_sin : set -> set :=
  fun z => div_CSNo (add_CSNo (complex_exp (mul_CSNo Complex_i z)) (minus_CSNo (complex_exp (minus_CSNo (mul_CSNo Complex_i z))))) (mul_CSNo 2 Complex_i).

(** Pi as a real constant. **)
//REAL2:416403 pi : "the number $\pi$" | $\pi$
//LLM pi : "the number $\pi$" | $\pi$
Definition pi : set := 2 * Eps_i (fun y => y :e real /\ 0 < y /\ complex_cos y = 0 /\ forall z :e real, 0 < z -> complex_cos z = 0 -> y <= z).

(** Predicate picking out first positive real zeros of `complex_cos`. **)
//LLM complex_cos_first_positive_real_zero_pred : "#1 is the first positive real zero of the complex cosine" | $\mathrm{complex\_cos\_first\_positive\_real\_zero\_pred}(#1)$
Definition complex_cos_first_positive_real_zero_pred : set -> prop :=
  fun y =>
    y :e real
    /\
    0 < y
    /\
    complex_cos y = 0
    /\
    forall z :e real, 0 < z -> complex_cos z = 0 -> y <= z.

(** Repackaging the raw existence hypothesis into the named first-positive-zero predicate. **)
// Proof in RealAnalysis2.1783097458.mg
ProofArchived complex_cos_first_positive_real_zero_pred_exists_of_exists :
  (exists y,
    y :e real
    /\
    0 < y
    /\
    complex_cos y = 0
    /\
    forall z :e real, 0 < z -> complex_cos z = 0 -> y <= z) ->
  exists y,
    complex_cos_first_positive_real_zero_pred y.

(** Route-explicit self-source alias for the raw-to-predicate existence bridge. **)

(** Route-explicit alias for the raw-to-predicate existence bridge through the
    named-predicate existence route. **)

(** The `Eps_i` choice for the named first-positive-zero predicate satisfies that predicate. **)
// Proof in RealAnalysis2.1783097458.mg
ProofArchived complex_cos_first_positive_real_zero_choice_pred :
  (exists y, complex_cos_first_positive_real_zero_pred y) ->
  complex_cos_first_positive_real_zero_pred
    (Eps_i complex_cos_first_positive_real_zero_pred).

(** Route-explicit self-source alias for the named-predicate choice theorem. **)

(** Explicit source-name alias for the named-predicate choice theorem. **)

(** Route-explicit alias for the named-predicate choice theorem through the
    named-predicate existence route itself. **)

(** Raw existence feeds the named-predicate `Eps_i` choice directly. **)
// Proof in RealAnalysis2.1783098193.mg
ProofArchived complex_cos_first_positive_real_zero_choice_pred_of_exists :
  (exists y,
    y :e real
    /\
    0 < y
    /\
    complex_cos y = 0
    /\
    forall z :e real, 0 < z -> complex_cos z = 0 -> y <= z) ->
  complex_cos_first_positive_real_zero_pred
    (Eps_i complex_cos_first_positive_real_zero_pred).

(** Route-explicit self-source alias for the raw-source named-predicate choice theorem. **)

(** Route-explicit alias for the raw-source named-predicate choice theorem
    through the raw existence route itself. **)

(** Forget the named predicate layer back to the raw existential package. **)
// Proof in RealAnalysis2.1783097826.mg
ProofArchived complex_cos_first_positive_real_zero_exists_of_pred_exists :
  (exists y, complex_cos_first_positive_real_zero_pred y) ->
  exists y,
    y :e real
    /\
    0 < y
    /\
    complex_cos y = 0
    /\
    forall z :e real, 0 < z -> complex_cos z = 0 -> y <= z.

(** Route-explicit self-source alias for the predicate-to-raw existence bridge. **)

(** Route-explicit alias for the predicate-to-raw existence bridge through the
    raw existence route. **)

(** If a first positive real zero of `complex_cos` exists, then the `Eps_i`
    choice used in the definition of `pi` satisfies exactly that specification. **)
// Proof in RealAnalysis2.1783094799.mg
ProofArchived complex_cos_first_positive_real_zero_choice_spec :
  (exists y,
    y :e real
    /\
    0 < y
    /\
    complex_cos y = 0
    /\
    forall z :e real, 0 < z -> complex_cos z = 0 -> y <= z) ->
  (Eps_i
    (fun y =>
      y :e real
      /\
      0 < y
      /\
      complex_cos y = 0
      /\
      forall z :e real, 0 < z -> complex_cos z = 0 -> y <= z))
    :e real
  /\
  0 <
    (Eps_i
      (fun y =>
        y :e real
        /\
        0 < y
        /\
        complex_cos y = 0
        /\
        forall z :e real, 0 < z -> complex_cos z = 0 -> y <= z))
  /\
  complex_cos
    (Eps_i
      (fun y =>
        y :e real
        /\
        0 < y
        /\
        complex_cos y = 0
        /\
        forall z :e real, 0 < z -> complex_cos z = 0 -> y <= z))
  = 0
  /\
  forall z :e real,
    0 < z ->
    complex_cos z = 0 ->
    (Eps_i
      (fun y =>
        y :e real
        /\
        0 < y
        /\
        complex_cos y = 0
        /\
