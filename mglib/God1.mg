assume hG hz.
let n.
assume hn hind hf.
exact (god1_group_word_represented_mul_word_step
  G mul B z f n hG hn hz hind hf).
Qed.

Theorem god1_group_word_represented_mul_word :
  forall G, forall mul:set -> set -> set, forall B z,
