//GOD1:641088 endomorphism_coordinate_matrix : "the matrix of the endomorphism #9 relative to the basis #8" | $[#9]_{#8}$
Definition endomorphism_coordinate_matrix :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> (set -> set) -> (set -> set) -> set :=
