//GOD1:776192 relative_algebraic_closure : "the elements of #1 algebraic over the subfield #4" | $\overline{#4}^{#1}$
Definition relative_algebraic_closure :
  set -> (set -> set -> set) -> (set -> set -> set) -> set -> set :=
  fun L add mul K => {x :e L|algebraic_over L add mul K x}.

Theorem god1_s26_theorem2_algebraic_elements_form_subfield :
  forall L, forall add mul:set -> set -> set, forall K,
    field L add mul -> subfield L add mul K ->
    subfield L add mul (relative_algebraic_closure L add mul K).
let L add mul K.
assume hL hK.
//GOD1PRF:776385 Let $x, y$ be elements of L , algebraic over K . Then there exist integers $p, q$ such that every power of $x$ (resp. $y$ ) is a linear combination, with coefficients in K , of the powers
claim h_s26_t2_power_bounds : forall x y :e relative_algebraic_closure L add mul K,
  exists p q :e omega,
    finite_dimensional_vector_space K add mul
      (subring_generated_by L add mul K {x}) add mul
    /\ finite_dimensional_vector_space K add mul
      (subring_generated_by L add mul K {y}) add mul.
admit.
//GOD1PRF:776655 It follows immediately, by multiplication, that all the monomials $x^{r} y^{s}$ are linear combinations, with coefficients in K , of the $p q$ monomials
claim h_s26_t2_two_variable_monomial_span :
  forall x y :e relative_algebraic_closure L add mul K,
  exists p q :e omega,
    generating_family K add mul
      (subring_generated_by L add mul K {x,y}) add mul (p :*: q)
      (fun u => mul (ring_natural_power L mul x (u 0))
        (ring_natural_power L mul y (u 1))).
admit.
//GOD1PRF:776893 Hence the subring $\mathrm{K}[x, y]$ of L is finite-dimensional as a vector space over K . For every $z \in \mathrm{~K}[x, y]$, the subring $\mathrm{K}[z]$ is contained in $\mathrm{K}[x, y]$, hence a fortiori is finitedimensional over K . In particular, $x-y$ and $x y$ are algebraic over K , which shows already that $\overline{\mathrm{K}}$ is a subring of L .
claim h_s26_t2_closed_under_subtraction_and_product :
  forall x y :e relative_algebraic_closure L add mul K,
    add x (ring_negation L add y) :e relative_algebraic_closure L add mul K
    /\ mul x y :e relative_algebraic_closure L add mul K.
admit.
//GOD1PRF:777256 To complete the proof, we must show that if an element $x \neq 0$ of L is algebraic over K , then so is $x^{-1}$. For this, consider a relation
claim h_s26_t2_inverse_relation_start :
  forall x :e relative_algebraic_closure L add mul K,
    x <> ring_zero L add -> exists coeff:set -> set,
      algebraic_relation L add mul K 1 (fun i => x) coeff.
admit.
//GOD1PRF:777443 with coefficients in K ; then it is clear that $y=x^{-1}$ satisfies
claim h_s26_t2_reversed_relation :
  forall x :e relative_algebraic_closure L add mul K,
    x <> ring_zero L add ->
    algebraic_over L add mul K (ring_inverse L add mul x).
admit.
//GOD1PRF:777562 Hence $y=x^{-1}$ is algebraic over K , and the proof is complete.\\
claim h_s26_t2_subfield_conclusion :
  subfield L add mul (relative_algebraic_closure L add mul K).
admit.
Admitted.

(** § 27. Polynomial rings. **)

//GOD1:789896 multivariate_polynomial_ring : "the ring of polynomials in #4 indeterminates over #1" | $#1[X_1,\ldots,X_{#4}]$
Definition multivariate_polynomial_ring :
  set -> (set -> set -> set) -> set -> set :=
  fun K add n =>
    {f :e K :^: (omega :^: n)|
      almost_all_zero (omega :^: n) (ring_zero K add) (fun exponent => f exponent)}.

//GOD1:789896 polynomial_addition : "addition in the #4-variable polynomial ring over #1" | $#5+#6$
Definition polynomial_addition :
  set -> (set -> set -> set) -> set -> set -> set -> set :=
  fun K add n f g =>
    fun exponent :e omega :^: n => add (f exponent) (g exponent).

//GOD1:789896 polynomial_multiplication : "convolution multiplication in the #5-variable polynomial ring over #1" | $#6#7$
Definition polynomial_multiplication :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> set -> set -> set :=
  fun K add mul n f g =>
    fun exponent :e omega :^: n =>
      module_finitely_supported_sum K add
        {u :e (omega :^: n) :*: (omega :^: n)|
          forall i :e n, add_SNo (u 0 i) (u 1 i) = exponent i}
        (fun u => mul (f (u 0)) (g (u 1))).

//GOD1:797289 polynomial_constant : "the constant polynomial associated with #5" | $#5$
Definition polynomial_constant :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> set -> set :=
  fun K add mul n a =>
    fun exponent :e omega :^: n =>
      if exponent = (fun i :e n => 0) then a else ring_zero K add.

//GOD1:797289 polynomial_constant_subring : "the constant subring of the #4-variable polynomial ring" | $#1\subseteq #1[X_1,\ldots,X_{#4}]$
Definition polynomial_constant_subring :
  set -> (set -> set -> set) -> (set -> set -> set) -> set -> set :=
  fun K add mul n => {polynomial_constant K add mul n a|a :e K}.

//GOD1:798246 polynomial_standard_exponent : "the exponent tuple of indeterminate #2 among #1 indeterminates" | $e_{#2}$
Definition polynomial_standard_exponent : set -> set -> set :=
  fun n i => fun j :e n => if j = i then 1 else 0.

//GOD1:798246 polynomial_indeterminate : "indeterminate #5 in the #4-variable polynomial ring over #1" | $X_{#5}$
Definition polynomial_indeterminate :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> set -> set :=
  fun K add mul n i =>
    fun exponent :e omega :^: n =>
      if exponent = polynomial_standard_exponent n i
      then ring_one K mul else ring_zero K add.

Theorem god1_polynomial_ring_construction_properties :
  forall K, forall add mul:set -> set -> set,
  forall n :e omega, 0 :e n ->
    commutative_ring K add mul ->
    let P := multivariate_polynomial_ring K add n in
    let addP := polynomial_addition K add n in
    let mulP := polynomial_multiplication K add mul n in
    let C := polynomial_constant_subring K add mul n in
    commutative_ring P addP mulP
    /\ subring P addP mulP C
    /\ algebraically_independent P addP mulP C n
      (polynomial_indeterminate K add mul n)
    /\ subring_generated_by P addP mulP C
      {polynomial_indeterminate K add mul n i|i :e n} = P
    /\ bij K C (polynomial_constant K add mul n).
let K add mul.
let n.
assume hn hPositive hRing.
apply andI.
//GOD1PRF:789896 By definition, L will be the set of sequences
claim h_s27_construction_underlying_set :
  multivariate_polynomial_ring K add n
  = {f :e K :^: (omega :^: n)|almost_all_zero (omega :^: n) (ring_zero K add) (fun e => f e)}.
admit.
//GOD1PRF:791709 from the previous section. To justify these definitions, we must show that the sequences ( $c_{n}$ ) and ( $d_{n}$ ) defined by (2) and (3) are again polynomials, i.e., that $c_{n}=d_{n}=0$ for all sufficiently large $n$. Let $p, q$ be the degrees of $f, g$ respectively; if $n>\max (p, q)$ we have $a_{n}=b_{n}=0$ and therefore $c_{n}=0$; so that $f+g$ is a polynomial, and its degree satisfies the inequality
claim h_s27_construction_operations_closed : forall f g :e multivariate_polynomial_ring K add n,
  polynomial_addition K add n f g :e multivariate_polynomial_ring K add n
  /\ polynomial_multiplication K add mul n f g :e multivariate_polynomial_ring K add n.
admit.
//GOD1PRF:792579 We must now verify that the set L , endowed with the laws of composition which have just been defined, is a commutative ring. The calculations which have to be performed are in principle trivial, and of the same order as those in § 9, section 3. We shall therefore leave it to the reader to verify most of the axioms, and we shall limit ourselves here to proving that the multiplication is associative.
claim h_s27_construction_s9_section3_formal_call :
  forall K0, forall add0 mul0:set -> set -> set, forall d0 :e K0,
    commutative_ring K0 add0 mul0 ->
    commutative_ring
      (quadratic_extension K0)
      (quadratic_extension_addition K0 add0)
      (quadratic_extension_multiplication K0 add0 mul0 d0).
apply god1_quadratic_extension_is_commutative_ring.
claim h_s27_construction_commutative_ring :
  commutative_ring (multivariate_polynomial_ring K add n)
    (polynomial_addition K add n) (polynomial_multiplication K add mul n).
admit.
//GOD1PRF:793526 thus we have to establish that the expressions (6) and (7) are equal for all $n$. Now $u_{p}$ is the sum of the products $a_{i} b_{j}$ for which $i+j=p$, and therefore (6) is the sum of all products
claim h_s27_construction_associative_coefficients :
  forall f g h :e multivariate_polynomial_ring K add n,
    polynomial_multiplication K add mul n
      (polynomial_multiplication K add mul n f g) h
    = polynomial_multiplication K add mul n f
      (polynomial_multiplication K add mul n g h).
admit.
//GOD1PRF:793997 It is now obvious that (6) and (7) are equal.
claim h_s27_construction_multiplication_associative :
  forall f g h :e multivariate_polynomial_ring K add n,
    polynomial_multiplication K add mul n
      (polynomial_multiplication K add mul n f g) h
    = polynomial_multiplication K add mul n f
      (polynomial_multiplication K add mul n g h).
admit.
//GOD1PRF:794230 We shall now show that we may identify K with a subring of L . To do this, we define a mapping
claim h_s27_construction_constant_embedding :
  forall a :e K, polynomial_constant K add mul n a
  :e polynomial_constant_subring K add mul n.
admit.
//GOD1PRF:794413 for all $a \in \mathrm{~K}$. Clearly $j$ is injective, and it is a trivial matter to verify, with the help of the formulae (2) and (3) of section 2, that
claim h_s27_construction_section2_operation_calls : forall a b :e K,
  polynomial_addition K add n
    (polynomial_constant K add mul n a)
    (polynomial_constant K add mul n b)
    = polynomial_constant K add mul n (add a b)
  /\ polynomial_multiplication K add mul n
    (polynomial_constant K add mul n a)
    (polynomial_constant K add mul n b)
