      SetAdjoin (SetAdjoin beta {1}) {2} = SetAdjoin gamma {1})) ->
    (SetAdjoin u {2} :e (SNoLev x :\/: SNoLev y)
      \/
    (exists gamma :e (SNoLev x :\/: SNoLev y), SetAdjoin u {2} = SetAdjoin gamma {1})).

