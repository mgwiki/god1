      n
      (fun i => fun x :e L => right_module_dual_basis_vector
        K addK mulK L addL smulR n a i x)
    /\ forall i j :e n,
      right_module_dual_basis_vector
        K addK mulK L addL smulR n a i (a j)
      = if i = j then ring_one K mulK else ring_zero K addK.
