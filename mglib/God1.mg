      (matrix_multiplication K addK mulK n n n
        (matrix_of_right_linear_map
          K addK mulK M addM smulR M addM smulR n n a1 a1 f)
        (matrix_inverse K addK mulK n
          (transition_matrix K addK mulK M addM smulR n a1 a2))).
