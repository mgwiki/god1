    (trilinear_mapping K addK mulK
      X addX smulX Y addY smulY Z addZ smulZ M addM smulM f
    <-> exists coeff:set -> set -> set -> set,
      (forall i :e m, forall j :e n, forall k :e p, coeff i j k :e M)
