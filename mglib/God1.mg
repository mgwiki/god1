(** Further basic consequences of ordered-field properties on R. **)

Section form17.

(** If x is positive then -x is negative, and conversely. **)

// Proof in 1777388823.mg
ProofArchived R_pos_implies_minus_neg : forall x :e R, 0 < x -> - x < 0.

// Proof in 1777388823.mg
ProofArchived R_neg_implies_minus_pos : forall x :e R, x < 0 -> 0 < - x.

(** Product of positive numbers is positive. **)

// Proof in 1777388823.mg
ProofArchived R_pos_mul_pos : forall x y :e R, 0 < x -> 0 < y -> 0 < x * y.

(** If 0 < x < y then x^2 < y^2 (written as xx < yy). **)

// Proof in 1777388823.mg
ProofArchived R_sqr_lt_sqr : forall x y :e R, 0 < x -> x < y -> x * x < y * y.

(** If x <= y and z <= w then x+z <= y+w. **)

// Proof in 1777388823.mg
ProofArchived R_add_Le_compat2 : forall x y z w :e R, x <= y -> z <= w -> x + z <= y + w.

End form17.

Section form18.

(** The least-upper-bound property for R, and a total supremum into ext_real. **)

//LLM lub_property_R : "the lub property r associated to #1" | $\mathrm{lub\_property\_R}$
Definition lub_property_R : prop :=
  forall S, S c= R -> nonempty S -> bounded_above S -> exists x :e R, is_lub S x.

// Proof in 1777388823.mg
ProofArchived R_has_lub_property : lub_property_R.

//LLM sup_ext : "the sup ext associated to #1" | $\sup #1$
Definition sup_ext : set -> set := fun S => Eps_i (fun x => x :e ext_real /\ is_lub S x).

// Proof in 1777388823.mg
ProofArchived sup_ext_spec : forall S, S c= R -> sup_ext S :e ext_real /\ is_lub S (sup_ext S).

End form18.

Section form19.

(** Archimedean property and density results on R (wrappers around trusted theorems for real). **)

// Proof in 1777388823.mg
ProofArchived R_Archimedean :
  forall x y :e R, 0 < x -> 0 <= y -> exists n :e omega, y <= n * x.

// Proof in 1777388823.mg
ProofArchived R_Archimedean_strict :
  forall x y :e R, 0 < x -> exists n :e omega, y < n * x.

// Proof in 1777388823.mg
ProofArchived SNoS_omega_dense_R :
  forall x y :e R, x < y -> exists q :e SNoS_ omega, x < q /\ q < y.

// Proof in 1777388823.mg
ProofArchived rational_dense_R :
  forall x y :e R, x < y -> exists q :e rational, x < q /\ q < y.

End form19.

Section form20.

(** Basic set operations on subsets of R: translation, scaling, and negation. **)

//LLM add_const_set : "the add const set associated to #1" | $#1 + #2$
Definition add_const_set : set -> set -> set := fun x S => {x + s|s :e S}.

//LLM mul_const_set : "the mul const set associated to #1" | $#1 \cdot #2$
Definition mul_const_set : set -> set -> set := fun x S => {x * s|s :e S}.

//LLM neg_set : "the neg set associated to #1" | $-#1$
Definition neg_set : set -> set := fun S => {- s|s :e S}.

// Proof in 1777388823.mg
ProofArchived add_const_set_subq_R : forall x :e R, forall S, S c= R -> add_const_set x S c= R.

// Proof in 1777388823.mg
ProofArchived mul_const_set_subq_R : forall x :e R, forall S, S c= R -> mul_const_set x S c= R.

// Proof in 1777388823.mg
ProofArchived neg_set_subq_R : forall S, S c= R -> neg_set S c= R.

// Proof in 1777388823.mg
ProofArchived nonempty_add_const_set : forall x :e R, forall S, nonempty S -> nonempty (add_const_set x S).

// Proof in 1777388823.mg
ProofArchived nonempty_mul_const_set : forall x :e R, forall S, nonempty S -> nonempty (mul_const_set x S).

// Proof in 1777388823.mg
ProofArchived nonempty_neg_set : forall S, nonempty S -> nonempty (neg_set S).

End form20.

Section form21.

(** Supremum under translation: sup (x + A) = x + sup A (when the sup exists). **)

// Proof in 1777388823.mg
ProofArchived is_lub_add_const_set :
  forall A, A c= R -> forall b x :e R, is_lub A b -> is_lub (add_const_set x A) (x + b).

// Proof in 1777388823.mg
ProofArchived sup_add_const_set :
  forall A, A c= R -> forall x :e R, has_lub A -> sup (add_const_set x A) = x + sup A.

End form21.

Section form22.

(** Infimum under translation: inf (x + A) = x + inf A (when the inf exists). **)

// Proof in 1777388823.mg
ProofArchived is_glb_add_const_set :
  forall A, A c= R -> forall b x :e R, is_glb A b -> is_glb (add_const_set x A) (x + b).

// Proof in 1777388823.mg
ProofArchived inf_add_const_set :
  forall A, A c= R -> forall x :e R, has_glb A -> inf (add_const_set x A) = x + inf A.

End form22.

Section form23.

(** Supremum under scaling by a positive constant. **)

// Proof in 100thms_12b.mg
ProofArchived R_recip_closed : forall x :e R, recip_SNo x :e R.

// Proof in 1777388823.mg
ProofArchived recip_SNo_square :
  forall x :e R, x <> 0 ->
    recip_SNo (x * x) = (recip_SNo x) * (recip_SNo x).

// Proof in 1777388823.mg
ProofArchived is_lub_mul_const_set_pos :
  forall A, A c= R -> forall b x :e R, 0 < x -> is_lub A b -> is_lub (mul_const_set x A) (x * b).

// Proof in 1777388823.mg
ProofArchived sup_mul_const_set_pos :
  forall A, A c= R -> forall x :e R, 0 < x -> has_lub A -> sup (mul_const_set x A) = x * sup A.

End form23.

Section form24.

(** Infimum under scaling by a positive constant. **)

// Proof in 1777388823.mg
ProofArchived is_glb_mul_const_set_pos :
  forall A, A c= R -> forall b x :e R, 0 < x -> is_glb A b -> is_glb (mul_const_set x A) (x * b).

// Proof in 1777388823.mg
ProofArchived inf_mul_const_set_pos :
  forall A, A c= R -> forall x :e R, 0 < x -> has_glb A -> inf (mul_const_set x A) = x * inf A.

End form24.

Section form25.

(** Sup/inf under negation of a set. **)

// Proof in 1777388823.mg
ProofArchived is_lub_neg_set_of_is_glb :
  forall A, A c= R -> forall b :e R, is_glb A b -> is_lub (neg_set A) (- b).

// Proof in 1777388823.mg
ProofArchived is_glb_neg_set_of_is_lub :
  forall A, A c= R -> forall b :e R, is_lub A b -> is_glb (neg_set A) (- b).

// Proof in 1777388823.mg
ProofArchived sup_neg_set_of_has_glb :
  forall A, A c= R -> has_glb A -> sup (neg_set A) = - inf A.

// Proof in 1777388823.mg
ProofArchived inf_neg_set_of_has_lub :
  forall A, A c= R -> has_lub A -> inf (neg_set A) = - sup A.

End form25.

Section form26.

(** Sup/inf under scaling by a negative constant. **)

// Proof in 1777388823.mg
ProofArchived R_mul_minus_L : forall a b :e R, (- a) * b = - (a * b).

// Proof in 1777388823.mg
ProofArchived mul_const_set_minus :
  forall A, A c= R -> forall x :e R, mul_const_set (- x) A = neg_set (mul_const_set x A).

// Proof in 1777388823.mg
ProofArchived mul_const_set_neg_const :
  forall A, A c= R -> forall x :e R, mul_const_set x A = neg_set (mul_const_set (- x) A).

// Proof in 1777388823.mg
ProofArchived sup_mul_const_set_neg :
  forall A, A c= R -> forall x :e R, x < 0 -> has_glb A -> sup (mul_const_set x A) = x * inf A.

// Proof in 1777388823.mg
ProofArchived inf_mul_const_set_neg :
  forall A, A c= R -> forall x :e R, x < 0 -> has_lub A -> inf (mul_const_set x A) = x * sup A.

End form26.

Section form27.

(** Infsup inequality: if every x in A is <= every y in B, then sup A <= inf B. **)

// Proof in 1777388823.mg
ProofArchived sup_le_inf_of_forall_Le :
  forall A B,
    A c= R -> B c= R ->
    nonempty A -> nonempty B ->
    (forall x :e A, forall y :e B, x <= y) ->
    has_lub A /\ has_glb B /\ sup A <= inf B.

End form27.

Section form28.

(** For ε > 0, there exists a point of S within ε of sup S from below. **)

// Proof in 1777388823.mg
ProofArchived exists_x_eps_from_sup :
  forall S, S c= R -> has_lub S ->
  forall eps :e R, 0 < eps ->
  exists x :e S, sup S + (- eps) < x /\ x <= sup S.

End form28.

Section form29.

(** Maxima and minima: sup/inf that are elements of the set. **)

//LLM is_max : "#1 is max" | $\mathrm{is\_max}(#1,#2)$
Definition is_max : set -> set -> prop := fun A m => m :e A /\ upper_bound A m.

//LLM is_min : "#1 is min" | $\mathrm{is\_min}(#1,#2)$
Definition is_min : set -> set -> prop := fun A m => m :e A /\ lower_bound A m.

//LLM has_max : "the has max associated to #1" | $\mathrm{has\_max}(#1)$
Definition has_max : set -> prop := fun A => exists m :e R, is_max A m.

//LLM has_min : "the has min associated to #1" | $\mathrm{has\_min}(#1)$
Definition has_min : set -> prop := fun A => exists m :e R, is_min A m.

//REAL1:88267 max : "the maximum of #1" | $\max #1$
//LLM max : "the maximum of #1" | $\max #1$
Definition max : set -> set := fun A => Eps_i (fun m => m :e R /\ is_max A m).

//REAL1:88446 min : "the minimum of #1" | $\min #1$
//LLM min : "the minimum of #1" | $\min #1$
Definition min : set -> set := fun A => Eps_i (fun m => m :e R /\ is_min A m).

// Proof in 1777388823.mg
ProofArchived max_spec : forall A, has_max A -> max A :e R /\ is_max A (max A).

// Proof in 1777388823.mg
ProofArchived min_spec : forall A, has_min A -> min A :e R /\ is_min A (min A).

// Proof in 1777388823.mg
ProofArchived has_lub_of_has_max : forall A, has_max A -> has_lub A.

// Proof in 1777388823.mg
ProofArchived has_glb_of_has_min : forall A, has_min A -> has_glb A.

// Proof in 1777388823.mg
ProofArchived max_eq_sup : forall A, has_max A -> has_lub A -> max A = sup A.

// Proof in 1777388823.mg
ProofArchived min_eq_inf : forall A, has_min A -> has_glb A -> min A = inf A.

End form29.

Section form30.

(** Absolute value basics on R (using abs_SNo). **)

// Proof in 1777388823.mg
ProofArchived abs_R_nonneg : forall x :e R, 0 <= abs_SNo x.

// Proof in 1777388823.mg
ProofArchived abs_R_eq_0_iff : forall x :e R, abs_SNo x = 0 <-> x = 0.

// Proof in 1777388823.mg
ProofArchived abs_R_minus : forall x :e R, abs_SNo (- x) = abs_SNo x.

// Proof in 1777388823.mg
ProofArchived abs_R_bounds : forall x :e R, - (abs_SNo x) <= x /\ x <= abs_SNo x.

End form30.

Section form31.

(** More absolute value facts: characterization and triangle inequality. **)

// Proof in 1777388823.mg
ProofArchived abs_R_closed : forall x :e R, abs_SNo x :e R.

// Proof in 1777388823.mg
ProofArchived abs_R_Le_iff :
  forall x y :e R, abs_SNo x <= y <-> (- y <= x /\ x <= y).

// Proof in 1777388823.mg
ProofArchived R_minus_add_distr : forall a b :e R, - (a + b) = (- a) + (- b).

// Proof in 1777388823.mg
ProofArchived abs_R_triangle : forall x y :e R, abs_SNo (x + y) <= abs_SNo x + abs_SNo y.

End form31.

Section form32.

(** Corollaries of the triangle inequality. **)

// Proof in 1777388823.mg
ProofArchived abs_R_sub : forall x y :e R, abs_SNo (x + (- y)) <= abs_SNo x + abs_SNo y.

// Proof in 1777388823.mg
ProofArchived abs_R_rev_triangle :
  forall x y :e R, abs_SNo (abs_SNo x + (- (abs_SNo y))) <= abs_SNo (x + (- y)).

// Proof in 1777388823.mg
ProofArchived abs_R_mul :
  forall x y :e R, abs_SNo (x * y) = abs_SNo x * abs_SNo y.

End form32.

Section form33.

(** Countability / uncountability wrappers for later use. **)

// Proof in 100thms_12b.mg
ProofArchived rational_countable : equip omega rational.

// Proof in 100thms_12b.mg
ProofArchived R_uncountable : atleastp omega R /\ ~equip R omega.

// Proof in 100thms_12b.mg
ProofArchived R_not_equip_omega : ~equip R omega.

End form33.

Section form34.

(** Bounded functions and sup/inf over a domain. **)

//LLM fimage : "the fimage associated to #1" | $#2[#1]$
Definition fimage : (set -> set) -> set -> set := fun f D => {f x|x :e D}.

//LLM R_fun : "the r fun associated to #1" | $\mathrm{R\_fun}(#1,#2)$
Definition R_fun : set -> (set -> set) -> prop :=
  fun D f => forall x :e D, f x :e R.

//LLM bounded_fun : "the bounded fun associated to #1" | $\mathrm{bounded\_fun}(#1,#2)$
Definition bounded_fun : set -> (set -> set) -> prop :=
  fun D f => R_fun D f /\ exists M :e R, forall x :e D, abs_SNo (f x) <= M.

// Proof in 1777388823.mg
ProofArchived fimage_subq_R : forall D, forall f : set -> set, R_fun D f -> fimage f D c= R.

(** moved below after ex_intro is available **)

// Proof in 1777388823.mg
ProofArchived bounded_above_fimage_of_bounded_fun :
  forall D, forall f : set -> set, bounded_fun D f -> nonempty D -> bounded_above (fimage f D).

// Proof in 1777388823.mg
ProofArchived bounded_below_fimage_of_bounded_fun :
  forall D, forall f : set -> set, bounded_fun D f -> nonempty D -> bounded_below (fimage f D).

//LLM sup_on : "the sup on associated to #1" | $\sup #1$
Definition sup_on : (set -> set) -> set -> set := fun f D => sup (fimage f D).

//LLM inf_on : "the inf on associated to #1" | $\inf #1$
Definition inf_on : (set -> set) -> set -> set := fun f D => inf (fimage f D).

// Proof in 1777388823.mg
ProofArchived sup_on_spec :
  forall D, forall f : set -> set, nonempty D -> bounded_fun D f -> sup_on f D :e R /\ is_lub (fimage f D) (sup_on f D).

// Proof in 1777388823.mg
ProofArchived inf_on_spec :
  forall D, forall f : set -> set, nonempty D -> bounded_fun D f -> inf_on f D :e R /\ is_glb (fimage f D) (inf_on f D).

(** Monotonicity of sup/inf under pointwise inequality (Prop. funcsupinf). **)

// Proof in 1777388823.mg
ProofArchived sup_on_Le_of_pointwise_Le :
  forall D, forall f g : set -> set,
    nonempty D ->
    bounded_fun D f -> bounded_fun D g ->
    (forall x :e D, f x <= g x) ->
    sup_on f D <= sup_on g D.

// Proof in 1777388823.mg
ProofArchived inf_on_Le_of_pointwise_Le :
  forall D, forall f g : set -> set,
    nonempty D ->
    bounded_fun D f -> bounded_fun D g ->
    (forall x :e D, f x <= g x) ->
    inf_on f D <= inf_on g D.

End form34.

Section form35.

(** Standard intervals as subsets of R. **)

//LLM Icc : "the icc associated to #1" | $[#1,#2]$
Definition Icc : set -> set -> set := fun a b => {x :e R| a <= x /\ x <= b}.
//LLM Ioo : "the ioo associated to #1" | $(#1,#2)$
Definition Ioo : set -> set -> set := fun a b => {x :e R| a < x /\ x < b}.
//LLM Ioc : "the ioc associated to #1" | $(#1,#2]$
Definition Ioc : set -> set -> set := fun a b => {x :e R| a < x /\ x <= b}.
//LLM Ico : "the ico associated to #1" | $[#1,#2)$
Definition Ico : set -> set -> set := fun a b => {x :e R| a <= x /\ x < b}.

//LLM Ici : "the ici associated to #1" | $[#1,\infty)$
Definition Ici : set -> set := fun a => {x :e R| a <= x}.
//LLM Ioi : "the ioi associated to #1" | $(#1,\infty)$
Definition Ioi : set -> set := fun a => {x :e R| a < x}.
//LLM Iic : "the iic associated to #1" | $(-\infty,#1]$
Definition Iic : set -> set := fun b => {x :e R| x <= b}.
//LLM Iio : "the iio associated to #1" | $(-\infty,#1)$
Definition Iio : set -> set := fun b => {x :e R| x < b}.

// Proof in 1777388823.mg
ProofArchived Icc_subq_R : forall a b, Icc a b c= R.

// Proof in 1777388823.mg
ProofArchived Ioo_subq_R : forall a b, Ioo a b c= R.

// Proof in 1777388823.mg
ProofArchived Ioc_subq_R : forall a b, Ioc a b c= R.

// Proof in 1777388823.mg
ProofArchived Ico_subq_R : forall a b, Ico a b c= R.

// Proof in 1777388823.mg
ProofArchived Ici_subq_R : forall a, Ici a c= R.

// Proof in 1777388823.mg
ProofArchived Ioi_subq_R : forall a, Ioi a c= R.

// Proof in 1777388823.mg
ProofArchived Iic_subq_R : forall b, Iic b c= R.

// Proof in 1777388823.mg
ProofArchived Iio_subq_R : forall b, Iio b c= R.

End form35.

Section form36.

(** Decimal representation of the reals is optional in real1.tex. **)
(** For now we only add minimal placeholders (to avoid blocking later sections). **)

//LLM digit_p : "the digit p associated to #1" | $\mathrm{digit\_p}(#1)$
Definition digit_p : set -> prop := fun d => d :e 10.

//LLM digit_seq : "the digit seq associated to #1" | $\mathrm{digit\_seq}(#1)$
Definition digit_seq : (set -> set) -> prop :=
  fun d => forall n :e omega, digit_p (d n).

//LLM decimal_val : "the decimal val associated to #1" | $\mathrm{decimal\_val}(#1)$
Definition decimal_val : (set -> set) -> set := fun d => 0.

// Proof in 1777388823.mg
ProofArchived decimal_val_spec :
  forall d : set -> set, digit_seq d -> decimal_val d :e Icc 0 1.

End form36.

Section form37.

(** Sequences and limits. **)

//LLM dist_R : "the dist r associated to #1" | $|#1 - #2|$
Definition dist_R : set -> set -> set := fun x y => abs_SNo (x + (- y)).

// Proof in 1777388823.mg
ProofArchived dist_R_sym : forall x y :e R, dist_R x y = dist_R y x.

// Proof in 1777388823.mg
ProofArchived dist_R_triangle :
  forall x y z :e R, dist_R x z <= dist_R x y + dist_R y z.

// Proof in 1777388823.mg
ProofArchived dist_R_add_right :
  forall x y z :e R, dist_R (x + z) (y + z) = dist_R x y.

// Proof in 1777388823.mg
ProofArchived dist_R_neg :
  forall x y :e R, dist_R (- x) (- y) = dist_R x y.

//LLM R_seq : "#1 is a real sequence" | $\mathrm{R\_seq}(#1)$
Definition R_seq : (set -> set) -> prop :=
  fun x => forall n :e omega, x n :e R.

(** The dyadic epsilons are real numbers. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived eps_n_in_R :
  forall n :e omega, eps_ n :e R.

// Proof in 100thms_12b.mg
ProofArchived eps_n_SNo :
  forall n :e omega, SNo (eps_ n).

//LLM eventually_omega : "the eventually omega associated to #1" | $\mathrm{eventually\_omega}(#1)$
Definition eventually_omega : (set -> prop) -> prop :=
  fun P => exists N :e omega, forall n :e omega, N <= n -> P n.

//LLM seq_limit : "the seq limit associated to #1" | $\mathrm{seq\_limit}(#1,#2)$
Definition seq_limit : (set -> set) -> set -> prop :=
  fun x l =>
    R_seq x
    /\ l :e R
    /\ forall eps :e R, 0 < eps ->
         exists N :e omega, forall n :e omega, N <= n -> dist_R (x n) l < eps.

// Proof in 1777388823.mg
ProofArchived seq_limit_choose :
  forall x y : set -> set, forall l,
    seq_limit x l ->
    seq_limit y l ->
    forall p : set -> prop,
      seq_limit (fun n => if p n then x n else y n) l.

// Proof in RealAnalysis1May042026a.mg
ProofArchived seq_limit_eq_subst :
  forall x : set -> set, forall l1 l2,
    seq_limit x l1 ->
    l1 = l2 ->
    seq_limit x l2.

//LLM convergent_seq : "the convergent seq associated to #1" | $\mathrm{convergent\_seq}(#1)$
Definition convergent_seq : (set -> set) -> prop :=
  fun x => exists l :e R, seq_limit x l.

//LLM lim_seq : "the lim seq associated to #1" | $\lim #1$
Definition lim_seq : (set -> set) -> set :=
  fun x => Eps_i (fun l => seq_limit x l).

// Proof in 1777388823.mg
ProofArchived lim_seq_spec :
  forall x : set -> set, convergent_seq x -> seq_limit x (lim_seq x).

// Proof in 1777388823.mg
ProofArchived seq_limit_unique :
  forall x : set -> set, forall l1 l2, seq_limit x l1 -> seq_limit x l2 -> l1 = l2.

//LLM bounded_seq : "the bounded seq associated to #1" | $\mathrm{bounded\_seq}(#1)$
Definition bounded_seq : (set -> set) -> prop :=
  fun x => exists B :e R, forall n :e omega, abs_SNo (x n) <= B.

// Proof in 1777388823.mg
ProofArchived seq_limit_imp_bounded :
  forall x : set -> set, forall l, seq_limit x l -> bounded_seq x.

//LLM const_seq : "the const seq associated to #1" | $\mathrm{const\_seq}(#1)$
Definition const_seq : set -> (set -> set) := fun c => fun n => c.

// Proof in 1777388823.mg
ProofArchived seq_limit_const : forall c :e R, seq_limit (const_seq c) c.

//LLM seq_add : "the seq add associated to #1" | $#1 + #2$
Definition seq_add : (set -> set) -> (set -> set) -> (set -> set) :=
  fun x y => fun n => x n + y n.

//LLM seq_mul : "the seq mul associated to #1" | $#1 \cdot #2$
Definition seq_mul : (set -> set) -> (set -> set) -> (set -> set) :=
  fun x y => fun n => x n * y n.

//LLM seq_neg : "the seq neg associated to #1" | $-#1$
Definition seq_neg : (set -> set) -> (set -> set) :=
  fun x => fun n => - (x n).

//LLM seq_sub : "the seq sub associated to #1" | $#1 - #2$
Definition seq_sub : (set -> set) -> (set -> set) -> (set -> set) :=
  fun x y => fun n => x n + (- (y n)).

//LLM seq_scale : "the seq scale associated to #1" | $#1\,#2$
Definition seq_scale : set -> (set -> set) -> (set -> set) :=
  fun a x => fun n => a * (x n).

// Proof in 1777388823.mg
ProofArchived seq_limit_add :
  forall x y : set -> set, forall a b, seq_limit x a -> seq_limit y b -> seq_limit (seq_add x y) (a + b).

// Proof in 1777388823.mg
ProofArchived seq_limit_neg :
  forall x : set -> set, forall a, seq_limit x a -> seq_limit (seq_neg x) (- a).

// Proof in 1777388823.mg
ProofArchived seq_limit_sub :
  forall x y : set -> set, forall a b, seq_limit x a -> seq_limit y b -> seq_limit (seq_sub x y) (a + (- b)).

// Proof in 1777388823.mg
ProofArchived seq_limit_scale :
  forall a, forall x : set -> set, forall l, a :e R -> seq_limit x l -> seq_limit (seq_scale a x) (a * l).

// Proof in 1777388823.mg
ProofArchived seq_limit_mul :
  forall x y : set -> set, forall a b, seq_limit x a -> seq_limit y b -> seq_limit (seq_mul x y) (a * b).

// Proof in 1777388823.mg
ProofArchived seq_limit_recip :
  forall x : set -> set, forall l,
    seq_limit x l ->
    l <> 0 ->
    (forall n :e omega, x n <> 0) ->
    seq_limit (fun n => recip_SNo (x n)) (recip_SNo l).

//LLM eventually_le : "the eventually le associated to #1" | $\mathrm{eventually\_le}(#1,#2)$
Definition eventually_le : (set -> set) -> (set -> set) -> prop :=
  fun x y => eventually_omega (fun n => x n <= y n).

(** Monotone sequences. **)

//LLM monotone_inc : "the monotone inc associated to #1" | $\mathrm{monotone\_inc}(#1)$
Definition monotone_inc : (set -> set) -> prop :=
  fun x => forall m :e omega, forall n :e omega, m <= n -> x m <= x n.

//LLM monotone_dec : "the monotone dec associated to #1" | $\mathrm{monotone\_dec}(#1)$
Definition monotone_dec : (set -> set) -> prop :=
  fun x => forall m :e omega, forall n :e omega, m <= n -> x n <= x m.

(** Reverse direction of seq_limit_neg (useful for monotone decreasing sequences). **)

// Proof in 1777388823.mg
ProofArchived monotone_inc_bounded_limit_sup :
  forall x : set -> set,
    R_seq x -> bounded_seq x -> monotone_inc x -> seq_limit x (sup (fimage x omega)).

// Proof in 1777388823.mg
ProofArchived monotone_dec_bounded_convergent :
  forall x : set -> set,
    R_seq x -> bounded_seq x -> monotone_dec x -> convergent_seq x.

End form37.

Section form38.

(** Facts about limits of sequences. **)

//LLM between_seq : "the between seq associated to #1" | $\mathrm{between\_seq}(#1,#2,#3)$
Definition between_seq : (set -> set) -> (set -> set) -> (set -> set) -> prop :=
  fun a x b =>
    R_seq a /\ R_seq x /\ R_seq b
    /\ forall n :e omega, a n <= x n /\ x n <= b n.

// Proof in 1777388823.mg
ProofArchived SNoLe_eq_substL38 :
  forall x y z, SNo x -> SNo y -> SNo z -> x = y -> x <= z -> y <= z.

// Proof in 1777436708.mg
ProofArchived SNoLe_eq_substR38 :
  forall x y z, SNo x -> SNo y -> SNo z -> x = y -> z <= x -> z <= y.

// Proof in RealAnalysis1May042026a.mg
ProofArchived dist_R_lt_imp_bounds :
  forall u v eps :e R,
    dist_R u v < eps ->
    v + (- eps) <= u /\ u <= v + eps.

// Proof in RealAnalysis1May042026a.mg
ProofArchived bounds_imp_dist_R_Le :
  forall u v eps :e R,
    v + (- eps) <= u ->
    u <= v + eps ->
    dist_R u v <= eps.

// Proof in 1777388823.mg
ProofArchived squeeze_lemma :
  forall a b x : set -> set, forall l,
    between_seq a x b ->
    seq_limit a l ->
    seq_limit b l ->
    seq_limit x l.

End form38.

Section form39.

(** Subsequences. **)

//LLM subseq_fun : "the subseq fun associated to #1" | $\mathrm{subseq\_fun}(#1)$
Definition subseq_fun : (set -> set) -> prop :=
  fun f =>
    (forall n :e omega, f n :e omega)
    /\ (forall n :e omega, n <= f n)
    /\ (forall n :e omega, f n < f (ordsucc n)).

//LLM subseq_of : "the subseq of associated to #1" | $\mathrm{subseq\_of}(#1,#2)$
Definition subseq_of : (set -> set) -> (set -> set) -> prop :=
  fun x y => exists f : set -> set, subseq_fun f /\ forall n :e omega, y n = x (f n).

// Proof in 1777388823.mg
ProofArchived seq_limit_subseq :
  forall x y : set -> set, forall l, subseq_of x y -> seq_limit x l -> seq_limit y l.

// Proof in 1777388823.mg
ProofArchived omega_lt_ordsucc :
  forall n :e omega, n < ordsucc n.

// Proof in 1777388823.mg
ProofArchived ordsucc_subseq_fun :
  subseq_fun (fun n => ordsucc n).

End form39.

Section form40.

(** Limit superior and limit inferior (bounded-sequence version). **)

//LLM tail_set : "the tail set associated to #1" | $\mathrm{tail\_set}(#1,#2)$
Definition tail_set : (set -> set) -> set -> set :=
  fun x n => {x k|k :e omega, n <= k}.

//LLM sup_tail_seq : "the sup tail seq associated to #1" | $\sup #1$
Definition sup_tail_seq : (set -> set) -> (set -> set) :=
  fun x => fun n => sup (tail_set x n).

//LLM inf_tail_seq : "the inf tail seq associated to #1" | $\inf #1$
Definition inf_tail_seq : (set -> set) -> (set -> set) :=
  fun x => fun n => inf (tail_set x n).

//LLM limsup_seq : "the limsup seq associated to #1" | $\limsup #1$
Definition limsup_seq : (set -> set) -> set :=
  fun x => lim_seq (sup_tail_seq x).

//LLM liminf_seq : "the liminf seq associated to #1" | $\liminf #1$
Definition liminf_seq : (set -> set) -> set :=
  fun x => lim_seq (inf_tail_seq x).

// Proof in 1777388823.mg
ProofArchived tail_set_sub :
  forall x : set -> set, forall m n :e omega, m <= n -> tail_set x n c= tail_set x m.

// Proof in 1777388823.mg
ProofArchived tail_set_subq_R :
  forall x : set -> set, R_seq x -> forall n :e omega, tail_set x n c= R.

// Proof in 1777388823.mg
ProofArchived tail_set_nonempty :
  forall x : set -> set, forall n :e omega, nonempty (tail_set x n).

// Proof in 1777388823.mg
ProofArchived tail_set_bounded_above :
  forall x : set -> set, R_seq x -> bounded_seq x ->
  forall n :e omega, bounded_above (tail_set x n).

// Proof in 1777388823.mg
ProofArchived tail_set_has_lub :
  forall x : set -> set, R_seq x -> bounded_seq x ->
  forall n :e omega, has_lub (tail_set x n).

// Proof in 1777388823.mg
ProofArchived tail_set_bounded_below :
  forall x : set -> set, R_seq x -> bounded_seq x ->
  forall n :e omega, bounded_below (tail_set x n).

// Proof in 1777388823.mg
ProofArchived tail_set_has_glb :
  forall x : set -> set, R_seq x -> bounded_seq x ->
  forall n :e omega, has_glb (tail_set x n).

// Proof in 1777388823.mg
ProofArchived sup_tail_seq_R_seq :
  forall x : set -> set, R_seq x -> bounded_seq x -> R_seq (sup_tail_seq x).

// Proof in 1777388823.mg
ProofArchived inf_tail_seq_R_seq :
  forall x : set -> set, R_seq x -> bounded_seq x -> R_seq (inf_tail_seq x).

// Proof in 1777388823.mg
ProofArchived sup_tail_seq_monotone_dec :
  forall x : set -> set, R_seq x -> bounded_seq x -> monotone_dec (sup_tail_seq x).

// Proof in 1777388823.mg
ProofArchived inf_tail_seq_monotone_inc :
  forall x : set -> set, R_seq x -> bounded_seq x -> monotone_inc (inf_tail_seq x).

// Proof in 1777388823.mg
ProofArchived sup_tail_seq_bounded_seq :
  forall x : set -> set, R_seq x -> bounded_seq x -> bounded_seq (sup_tail_seq x).

// Proof in 1777388823.mg
ProofArchived inf_tail_seq_bounded_seq :
  forall x : set -> set, R_seq x -> bounded_seq x -> bounded_seq (inf_tail_seq x).

// Proof in 1777388823.mg
ProofArchived sup_tail_seq_convergent :
  forall x : set -> set, R_seq x -> bounded_seq x -> convergent_seq (sup_tail_seq x).

// Proof in 1777388823.mg
ProofArchived inf_tail_seq_convergent :
  forall x : set -> set, R_seq x -> bounded_seq x -> convergent_seq (inf_tail_seq x).

// Proof in 1777388823.mg
ProofArchived limsup_seq_spec :
  forall x : set -> set, R_seq x -> bounded_seq x -> seq_limit (sup_tail_seq x) (limsup_seq x).

// Proof in 1777388823.mg
ProofArchived liminf_seq_spec :
  forall x : set -> set, R_seq x -> bounded_seq x -> seq_limit (inf_tail_seq x) (liminf_seq x).

// Proof in 1777388823.mg
ProofArchived liminf_le_limsup :
  forall x : set -> set, R_seq x -> bounded_seq x -> liminf_seq x <= limsup_seq x.

// Proof in 1777388823.mg
ProofArchived liminfsup_eq_imp_limit :
  forall x : set -> set, R_seq x -> bounded_seq x ->
    liminf_seq x = limsup_seq x -> seq_limit x (limsup_seq x).

// Proof in 1777388823.mg
ProofArchived limsup_seq_eq_of_seq_limit :
  forall x : set -> set, forall l, seq_limit x l -> limsup_seq x = l.

// Proof in 1777388823.mg
ProofArchived liminf_seq_eq_of_seq_limit :
  forall x : set -> set, forall l, seq_limit x l -> liminf_seq x = l.

// Proof in 1777388823.mg
ProofArchived liminfsup_eq_of_seq_limit :
  forall x : set -> set, forall l, seq_limit x l -> liminf_seq x = limsup_seq x.

// Proof in 1777388823.mg
ProofArchived exists_eps_n_lt :
  forall eps :e R, 0 < eps -> exists n :e omega, eps_ n < eps.

// Proof in 1777388823.mg
ProofArchived eps_decr_Le :
  forall m n :e omega, m <= n -> eps_ n <= eps_ m.

// Proof in 1777388823.mg
ProofArchived eps_seq_limit_0 :
  seq_limit (fun n => eps_ n) 0.

// Proof in 1777388823.mg
ProofArchived exists_k_tail_sup_close :
  forall x : set -> set, R_seq x -> bounded_seq x ->
  forall n :e omega, forall eps :e R, 0 < eps ->
    exists k :e omega,
      n <= k
      /\ (sup_tail_seq x n) + (- eps) < x k
      /\ x k <= sup_tail_seq x n.

(** For ε > 0, there exists a tail element within ε of inf S from above. **)
// Proof in 1777388823.mg
ProofArchived exists_k_tail_inf_close :
  forall x : set -> set, R_seq x -> bounded_seq x ->
  forall n :e omega, forall eps :e R, 0 < eps ->
    exists k :e omega,
      n <= k
      /\ inf_tail_seq x n <= x k
      /\ x k < (inf_tail_seq x n) + eps.

// Proof in 1777388823.mg
ProofArchived subseq_limsup_seq :
  forall x : set -> set, R_seq x -> bounded_seq x ->
    exists y : set -> set, subseq_of x y /\ seq_limit y (limsup_seq x).

// Proof in 1777388823.mg
ProofArchived subseq_liminf_seq :
  forall x : set -> set, R_seq x -> bounded_seq x ->
    exists y : set -> set, subseq_of x y /\ seq_limit y (liminf_seq x).

// Proof in 1777388823.mg
ProofArchived liminfsupconv :
  forall x : set -> set, R_seq x -> bounded_seq x ->
    (convergent_seq x <-> liminf_seq x = limsup_seq x).

End form40.

Section form41.

(** limsup/liminf behavior under subsequences, and Bolzano-Weierstrass for sequences in R. **)

// Proof in 1777388823.mg
ProofArchived R_seq_subseq_of :
  forall x y : set -> set, subseq_of x y -> R_seq x -> R_seq y.

// Proof in 1777388823.mg
ProofArchived bounded_seq_subseq_of :
  forall x y : set -> set, subseq_of x y -> bounded_seq x -> bounded_seq y.

// Proof in 1777388823.mg
ProofArchived tail_set_subseq_sub :
  forall x y : set -> set, subseq_of x y ->
  forall n :e omega, tail_set y n c= tail_set x n.

// Proof in 1777388823.mg
ProofArchived limsup_seq_subseq_le :
  forall x y : set -> set,
    R_seq x -> bounded_seq x ->
    subseq_of x y ->
    limsup_seq y <= limsup_seq x.

// Proof in 1777388823.mg
ProofArchived liminf_seq_subseq_ge :
  forall x y : set -> set,
    R_seq x -> bounded_seq x ->
    subseq_of x y ->
    liminf_seq x <= liminf_seq y.

// Proof in 1777388823.mg
ProofArchived subseq_liminf_limsup_chain :
  forall x y : set -> set,
    R_seq x -> bounded_seq x ->
    subseq_of x y ->
    liminf_seq x <= liminf_seq y
    /\ liminf_seq y <= limsup_seq y
    /\ limsup_seq y <= limsup_seq x.

// Proof in 1777388823.mg
ProofArchived bolzano_weierstrass_seq :
  forall x : set -> set, R_seq x -> bounded_seq x ->
    exists y : set -> set, subseq_of x y /\ convergent_seq y.

End form41.

Section form42.

(** Cauchy sequences. **)

//LLM cauchy_seq : "the cauchy seq associated to #1" | $\mathrm{cauchy\_seq}(#1)$
Definition cauchy_seq : (set -> set) -> prop :=
  fun x =>
    R_seq x
    /\ forall eps :e R, 0 < eps ->
         exists N :e omega,
           forall m n :e omega, N <= m -> N <= n -> dist_R (x m) (x n) < eps.

// Proof in 1777388823.mg
ProofArchived cauchy_seq_subseq_of :
  forall x y : set -> set, cauchy_seq x -> subseq_of x y -> cauchy_seq y.

// Proof in 100thms_12b.mg
ProofArchived mem_singleton : forall x:set, x :e {x}.

// Proof in 100thms_12b.mg
ProofArchived mem_singleton_eq : forall x y:set, y :e {x} -> y = x.

// Proof in 1777388823.mg
ProofArchived finite_abs_bounded :
  forall x : set -> set, R_seq x ->
  forall X, X c= omega -> finite X ->
    exists B :e R, 0 <= B /\ forall n :e X, abs_SNo (x n) <= B.

// Proof in 1777388823.mg
ProofArchived seq_limit_imp_cauchy :
  forall x : set -> set, forall l, seq_limit x l -> cauchy_seq x.

// Proof in 1777388823.mg
ProofArchived cauchy_seq_imp_bounded :
  forall x : set -> set, cauchy_seq x -> bounded_seq x.

// Proof in 1777388823.mg
ProofArchived cauchy_subseq_limit_imp_limit :
  forall x y : set -> set, forall l,
    cauchy_seq x ->
    subseq_of x y ->
    seq_limit y l ->
    seq_limit x l.

// Proof in 1777388823.mg
ProofArchived convergent_seq_iff_cauchy_seq :
  forall x : set -> set, convergent_seq x <-> cauchy_seq x.

// Proof in 1777388823.mg
ProofArchived cauchy_seq_imp_convergent :
  forall x : set -> set, cauchy_seq x -> convergent_seq x.

End form42.

Section form43.

(** Series. **)

//LLM partial_sum_seq : "the partial sum seq associated to #1" | $\sum_{k \le n} #1_k$
Definition partial_sum_seq : (set -> set) -> (set -> set) :=
  fun x => fun n => nat_primrec 0 (fun i r => r + x i) n.

//LLM convergent_series : "the convergent series associated to #1" | $\mathrm{convergent\_series}(#1)$
Definition convergent_series : (set -> set) -> prop :=
  fun x => convergent_seq (partial_sum_seq x).

//LLM cauchy_series : "the cauchy series associated to #1" | $\mathrm{cauchy\_series}(#1)$
Definition cauchy_series : (set -> set) -> prop :=
  fun x => cauchy_seq (partial_sum_seq x).

//LLM sum_series : "the sum series associated to #1" | $\mathrm{sum\_series}(#1)$
Definition sum_series : (set -> set) -> set :=
  fun x => lim_seq (partial_sum_seq x).

// Proof in 1777388823.mg
ProofArchived convergent_series_iff_cauchy_series :
  forall x : set -> set, convergent_series x <-> cauchy_series x.

// Proof in 1777388823.mg
ProofArchived cauchy_series_imp_convergent_series :
  forall x : set -> set, cauchy_series x -> convergent_series x.

// Proof in 1777388823.mg
ProofArchived cauchy_series_imp_bounded_partial_sums :
  forall x : set -> set, cauchy_series x -> bounded_seq (partial_sum_seq x).

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_0 :
  forall x : set -> set, partial_sum_seq x 0 = 0.

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_S :
  forall x : set -> set, forall n :e omega,
    partial_sum_seq x (ordsucc n) = partial_sum_seq x n + x n.

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_eq_of_eq_on :
  forall x y : set -> set,
    forall n :e omega,
      (forall k :e n, x k = y k) ->
      partial_sum_seq x n = partial_sum_seq y n.

(** A weaker closedness lemma for partial sums: it suffices that x k is real for k < n. **)
// Proof in 1777388823.mg
ProofArchived partial_sum_seq_closed_of_R_on :
  forall x : set -> set,
    forall n :e omega,
      (forall k :e n, x k :e R) ->
      partial_sum_seq x n :e R.

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_Le_of_term_Le_on :
  forall x y : set -> set,
    forall n :e omega,
      (forall k :e n, x k :e R) ->
      (forall k :e n, y k :e R) ->
      (forall k :e n, x k <= y k) ->
      partial_sum_seq x n <= partial_sum_seq y n.

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_closed :
  forall x : set -> set, R_seq x -> forall n :e omega, partial_sum_seq x n :e R.

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_R_seq :
  forall x : set -> set, R_seq x -> R_seq (partial_sum_seq x).

// Proof in 1777388823.mg
ProofArchived omega_SNoLe_Subq :
  forall m n :e omega, m <= n -> m c= n.

// Proof in 1777388823.mg
ProofArchived seq_limit_tail_imp_limit :
  forall x : set -> set, R_seq x ->
  forall M :e omega, forall l,
    seq_limit (fun n => x (add_nat M n)) l -> seq_limit x l.

// Proof in 1777388823.mg
ProofArchived convergent_series_imp_cauchy_series :
  forall x : set -> set, convergent_series x -> cauchy_series x.

// Proof in 1777388823.mg
ProofArchived convergent_series_imp_term_limit_0 :
  forall x : set -> set, R_seq x -> convergent_series x -> seq_limit x 0.

// Proof in 1777388823.mg
ProofArchived cauchy_series_imp_term_limit_0 :
  forall x : set -> set, R_seq x -> cauchy_series x -> seq_limit x 0.

// Proof in 1777388823.mg
ProofArchived convergent_series_imp_bounded_partial_sums :
  forall x : set -> set, convergent_series x -> bounded_seq (partial_sum_seq x).

//LLM tail_series : "the tail series associated to #1" | $\mathrm{tail\_series}(#1,#2)$
Definition tail_series : (set -> set) -> set -> (set -> set) :=
  fun x M => fun n => x (add_nat M n).

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_tail_series_eq :
  forall x : set -> set, R_seq x ->
  forall M :e omega, forall n :e omega,
    partial_sum_seq (tail_series x M) n =
      partial_sum_seq x (add_nat M n) + (- (partial_sum_seq x M)).

(** Absolute value preserves limits. **)
// Proof in 1777388823.mg
ProofArchived seq_limit_abs :
  forall x : set -> set, forall a, seq_limit x a ->
    seq_limit (fun n => abs_SNo (x n)) (abs_SNo a).

// Proof in 1777388823.mg
ProofArchived Ioo_nonempty : forall a b :e R, a < b -> nonempty (Ioo a b).

// Proof in 1777388823.mg
ProofArchived Icc_nonempty : forall a b :e R, a <= b -> nonempty (Icc a b).

// Proof in 1777388823.mg
ProofArchived nonempty_fimage : forall D, forall f : set -> set, nonempty D -> nonempty (fimage f D).

// Proof in RealAnalysis1May042026a.mg
ProofArchived exists_x_eps_from_inf :
  forall S, S c= R -> nonempty S -> has_glb S ->
  forall eps :e R, 0 < eps ->
  exists x :e S, inf S <= x /\ x < inf S + eps.

(** Transport boundedness across pointwise equality on the same domain. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived bounded_fun_of_pointwise_eq :
  forall D, forall f g : set -> set,
    bounded_fun D f ->
    (forall x :e D, f x = g x) ->
    bounded_fun D g.

(** Split partial sums at an index M using the tail series. **)
// Proof in 1777388823.mg
ProofArchived partial_sum_seq_add_nat_split :
  forall x : set -> set, R_seq x ->
  forall M :e omega, forall n :e omega,
    partial_sum_seq x (add_nat M n) =
      partial_sum_seq x M + partial_sum_seq (tail_series x M) n.

(** A prefix-only variant of `partial_sum_seq_add_nat_split` (avoids assuming `R_seq x` globally). **)
// Proof in 1777388823.mg
ProofArchived partial_sum_seq_add_nat_split_prefix :
  forall x : set -> set,
    forall M n :e omega,
      (forall k :e add_nat M n, x k :e R) ->
      partial_sum_seq x (add_nat M n) =
        partial_sum_seq x M + partial_sum_seq (tail_series x M) n.

// Proof in 1777388823.mg
ProofArchived add_nat_const_subseq_fun :
  forall M :e omega, subseq_fun (fun n => add_nat M n).

// Proof in 1777388823.mg
ProofArchived tail_series_subseq_of :
  forall x : set -> set, forall M :e omega, subseq_of x (tail_series x M).

// Proof in 1777388823.mg
ProofArchived seq_limit_of_eq_on_omega :
  forall x y : set -> set, forall l,
    (forall n :e omega, x n = y n) ->
    seq_limit x l -> seq_limit y l.

// Proof in 1777388823.mg
ProofArchived convergent_series_tail_iff :
  forall x : set -> set, R_seq x ->
  forall M :e omega, convergent_series x <-> convergent_series (tail_series x M).

End form43.

Section form44.

(** Basic properties of series: linearity, positivity, absolute convergence. **)

//LLM bounded_above_seq : "the bounded above seq associated to #1" | $\mathrm{bounded\_above\_seq}(#1)$
Definition bounded_above_seq : (set -> set) -> prop :=
  fun x => exists B :e R, forall n :e omega, x n <= B.

//LLM nonneg_seq : "the nonneg seq associated to #1" | $\mathrm{nonneg\_seq}(#1)$
Definition nonneg_seq : (set -> set) -> prop :=
  fun x => forall n :e omega, 0 <= x n.

//LLM abs_seq : "the abs seq associated to #1" | $|#1|$
Definition abs_seq : (set -> set) -> (set -> set) :=
  fun x => fun n => abs_SNo (x n).

//LLM absolutely_convergent_series : "the absolutely convergent series associated to #1" | $\mathrm{absolutely\_convergent\_series}(#1)$
Definition absolutely_convergent_series : (set -> set) -> prop :=
  fun x => convergent_series (abs_seq x).

// Proof in 1777388823.mg
ProofArchived R_seq_scale :
  forall a :e R, forall x : set -> set, R_seq x -> R_seq (seq_scale a x).

// Proof in 1777388823.mg
ProofArchived R_seq_add :
  forall x y : set -> set, R_seq x -> R_seq y -> R_seq (seq_add x y).

// Proof in 1777388823.mg
ProofArchived R_seq_abs :
  forall x : set -> set, R_seq x -> R_seq (abs_seq x).

// Proof in RealAnalysis1May042026a.mg
ProofArchived abs_partial_sum_seq_le :
  forall x : set -> set, R_seq x ->
  forall n :e omega,
    abs_SNo (partial_sum_seq x n) <= partial_sum_seq (abs_seq x) n.

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_scale_eq :
  forall a :e R, forall x : set -> set, R_seq x ->
  forall n :e omega, partial_sum_seq (seq_scale a x) n = a * (partial_sum_seq x n).

// Proof in 1777388844.mg
ProofArchived partial_sum_seq_scale_eq_on :
  forall a :e R, forall x : set -> set,
  forall n :e omega,
    (forall k :e n, x k :e R) ->
    partial_sum_seq (seq_scale a x) n = a * (partial_sum_seq x n).

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_add_eq :
  forall x y : set -> set, R_seq x -> R_seq y ->
  forall n :e omega,
    partial_sum_seq (seq_add x y) n = partial_sum_seq x n + partial_sum_seq y n.

// Proof in 1777388823.mg
ProofArchived convergent_series_scale :
  forall a :e R, forall x : set -> set,
    R_seq x -> convergent_series x -> convergent_series (seq_scale a x).

// Proof in 1777388823.mg
ProofArchived sum_series_scale :
  forall a :e R, forall x : set -> set,
    R_seq x -> convergent_series x ->
    sum_series (seq_scale a x) = a * sum_series x.

// Proof in 1777388823.mg
ProofArchived convergent_series_add :
  forall x y : set -> set,
    R_seq x -> R_seq y ->
    convergent_series x -> convergent_series y ->
    convergent_series (seq_add x y).

// Proof in 1777388823.mg
ProofArchived sum_series_add :
  forall x y : set -> set,
    R_seq x -> R_seq y ->
    convergent_series x -> convergent_series y ->
    sum_series (seq_add x y) = sum_series x + sum_series y.

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_nonneg :
  forall x : set -> set, R_seq x -> nonneg_seq x ->
  forall n :e omega, 0 <= partial_sum_seq x n.

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_monotone_inc_nonneg :
  forall x : set -> set, R_seq x -> nonneg_seq x -> monotone_inc (partial_sum_seq x).

// Proof in 1777388823.mg
ProofArchived convergent_series_nonneg_iff_bounded_above :
  forall x : set -> set, R_seq x -> nonneg_seq x ->
    (convergent_series x <-> bounded_above_seq (partial_sum_seq x)).

// Proof in 1777388823.mg
ProofArchived tail_series_R_seq :
  forall x : set -> set, R_seq x -> forall M :e omega, R_seq (tail_series x M).

// Proof in 1777388823.mg
ProofArchived abs_partial_sum_tail_le :
  forall x : set -> set, R_seq x ->
  forall M :e omega, forall n :e omega,
    abs_SNo (partial_sum_seq (tail_series x M) n)
      <= partial_sum_seq (tail_series (abs_seq x) M) n.

// Proof in 1777388823.mg
ProofArchived dist_R_refl :
  forall x :e R, dist_R x x = 0.

// Proof in 1777388823.mg
ProofArchived dist_partial_sum_seq_le_abs_partial_sum_seq_le :
  forall x : set -> set, R_seq x ->
  forall m :e omega, forall n :e omega, m <= n ->
    dist_R (partial_sum_seq x n) (partial_sum_seq x m)
      <= dist_R (partial_sum_seq (abs_seq x) n) (partial_sum_seq (abs_seq x) m).

// Proof in 1777388823.mg
ProofArchived dist_partial_sum_seq_le_abs_partial_sum_seq :
  forall x : set -> set, R_seq x ->
  forall m :e omega, forall n :e omega,
    dist_R (partial_sum_seq x m) (partial_sum_seq x n)
      <= dist_R (partial_sum_seq (abs_seq x) m) (partial_sum_seq (abs_seq x) n).

// Proof in 1777388823.mg
ProofArchived absolutely_convergent_series_imp_convergent_series :
  forall x : set -> set, R_seq x ->
    absolutely_convergent_series x -> convergent_series x.

End form44.

Section form45.

(** Comparison test for series. **)

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_Le_of_term_Le_aux :
  forall x y : set -> set,
    R_seq x -> R_seq y ->
    (forall n :e omega, x n <= y n) ->
    forall n :e omega, partial_sum_seq x n <= partial_sum_seq y n.

// Proof in 1777388823.mg
ProofArchived partial_sum_seq_Le_of_term_Le_nonneg :
  forall x y : set -> set,
    R_seq x -> R_seq y ->
    nonneg_seq x ->
    (forall n :e omega, x n <= y n) ->
    forall n :e omega, partial_sum_seq x n <= partial_sum_seq y n.

(** Termwise comparison implies partial-sum comparison (no nonnegativity assumption needed). **)
// Proof in 1777388823.mg
ProofArchived partial_sum_seq_Le_of_term_Le :
  forall x y : set -> set,
    R_seq x -> R_seq y ->
    (forall n :e omega, x n <= y n) ->
    forall n :e omega, partial_sum_seq x n <= partial_sum_seq y n.

// Proof in 1777388823.mg
ProofArchived comparison_test_conv :
  forall x y : set -> set,
    R_seq x -> R_seq y ->
    nonneg_seq x ->
    (forall n :e omega, x n <= y n) ->
    convergent_series y -> convergent_series x.

// Proof in 1777388823.mg
ProofArchived comparison_test_div :
  forall x y : set -> set,
    R_seq x -> R_seq y ->
    nonneg_seq x ->
    (forall n :e omega, x n <= y n) ->
    ~ convergent_series x -> ~ convergent_series y.

End form45.

Section form46.

(** Powers and the geometric sequence. **)

//LLM pow_seq : "the pow seq associated to #1" | $#1^{#2}$
Definition pow_seq : set -> (set -> set) :=
  fun c => fun n => c ^ n.

// Proof in 1777388823.mg
ProofArchived R_exp_nat_closed :
  forall c :e R, forall n :e omega, c ^ n :e R.

// Proof in 1777388823.mg
ProofArchived R_seq_pow_seq :
  forall c :e R, R_seq (pow_seq c).

// Proof in 1777388823.mg
ProofArchived pow_seq_limit_0_lt1 :
  forall c :e R, 0 < c -> c < 1 -> seq_limit (pow_seq c) 0.

End form46.

Section form47.

(** Finite geometric sum identity: (1-r)  (sum_{i=0}^{k-1} r^i) = 1 - r^k. **)
// Proof in 1777388823.mg
ProofArchived geom_partial_sum_mul :
  forall r :e R, forall k :e omega,
    (1 + (- r)) * (partial_sum_seq (pow_seq r) k) = 1 + (- (r ^ k)).

End form47.

Section form48.

(** Geometric series. **)

// Proof in 1777388823.mg
ProofArchived omega_ge_1_ne0 :
  forall n :e omega, 1 <= n -> n <> 0.

// Proof in 1777388823.mg
ProofArchived pow_zero_ge1 :
  forall n :e omega, 1 <= n -> 0 ^ n = 0.

// Proof in 1777388823.mg
ProofArchived pow_seq_limit_zero :
  seq_limit (pow_seq 0) 0.

// Proof in 1777388823.mg
ProofArchived abs_pow_seq :
  forall r :e R, forall n :e omega,
    abs_SNo (r ^ n) = (abs_SNo r) ^ n.

// Proof in 1777388823.mg
ProofArchived pow_seq_limit_between_m1_1 :
  forall r :e R, - 1 < r -> r < 1 -> seq_limit (pow_seq r) 0.

// Proof in 1777388823.mg
ProofArchived geom_partial_sum_limit :
  forall r :e R, - 1 < r -> r < 1 ->
    seq_limit (partial_sum_seq (pow_seq r)) (1 :/: (1 + (- r))).

// Proof in 1777388823.mg
ProofArchived geometric_series_convergent :
  forall r :e R, - 1 < r -> r < 1 -> convergent_series (pow_seq r).

// Proof in 1777388823.mg
ProofArchived geometric_series_sum :
  forall r :e R, - 1 < r -> r < 1 ->
    sum_series (pow_seq r) = 1 :/: (1 + (- r)).

End form48.

Section form49.

(** Divergence of the geometric series when |r| >= 1 (term test). **)

// Proof in 1777388823.mg
ProofArchived pow_ge_1 :
  forall r :e R, 1 <= r -> forall n :e omega, 1 <= r ^ n.

// Proof in 1777388823.mg
ProofArchived not_pow_seq_limit_0_ge1 :
  forall r :e R, 1 <= r -> ~ seq_limit (pow_seq r) 0.

// Proof in 1777388823.mg
ProofArchived not_pow_seq_limit_0_le_m1 :
  forall r :e R, r <= - 1 -> ~ seq_limit (pow_seq r) 0.

// Proof in 1777388823.mg
ProofArchived geometric_series_diverge_ge1 :
  forall r :e R, 1 <= r -> ~ convergent_series (pow_seq r).

// Proof in 1777388823.mg
ProofArchived geometric_series_diverge_le_m1 :
  forall r :e R, r <= - 1 -> ~ convergent_series (pow_seq r).

End form49.

Section form50.

(** Ratio test for series. **)

//LLM ratio_abs_seq : "the ratio abs seq associated to #1" | $\mathrm{ratio\_abs\_seq}(#1)$
Definition ratio_abs_seq : (set -> set) -> (set -> set) :=
  fun x => fun n => (abs_SNo (x (ordsucc n))) :/: (abs_SNo (x n)).

// Proof in 1777388823.mg
ProofArchived abs_pos_of_nonzero :
  forall x :e R, x <> 0 -> 0 < abs_SNo x.

// Proof in 1777388823.mg
ProofArchived ratio_abs_seq_pos :
  forall x : set -> set, R_seq x ->
    (forall n :e omega, x n <> 0) ->
    forall n :e omega, 0 < ratio_abs_seq x n.

// Proof in 1777388823.mg
ProofArchived ratio_abs_seq_nonneg :
  forall x : set -> set, R_seq x ->
    (forall n :e omega, x n <> 0) ->
    forall n :e omega, 0 <= ratio_abs_seq x n.

// Proof in 1777388823.mg
ProofArchived ratio_eventually_Le_of_limit_Lt :
  forall x : set -> set, R_seq x ->
    (forall n :e omega, x n <> 0) ->
    forall L r :e R,
      seq_limit (ratio_abs_seq x) L ->
      L < r ->
      exists N :e omega,
        forall n :e omega, N <= n -> ratio_abs_seq x n <= r.

// Proof in 1777388823.mg
ProofArchived ratio_eventually_Le_of_limit_Gt :
  forall x : set -> set, R_seq x ->
    (forall n :e omega, x n <> 0) ->
    forall L r :e R,
      seq_limit (ratio_abs_seq x) L ->
      r < L ->
      exists N :e omega,
        forall n :e omega, N <= n -> r <= ratio_abs_seq x n.

(** Strong ratio test: if eventually ratio <= r < 1, then absolute convergence. **)
// Proof in 1777388823.mg
ProofArchived ratio_test_strong_conv :
  forall x : set -> set, R_seq x ->
    (forall n :e omega, x n <> 0) ->
    forall r :e R, 0 < r -> r < 1 ->
      (exists M :e omega, forall n :e omega, M <= n -> ratio_abs_seq x n <= r) ->
      absolutely_convergent_series x.

// Proof in 1777388823.mg
ProofArchived ratio_test_strong_div :
  forall x : set -> set, R_seq x ->
    (forall n :e omega, x n <> 0) ->
    forall r :e R, 1 < r ->
      (exists M :e omega, forall n :e omega, M <= n -> r <= ratio_abs_seq x n) ->
      ~ convergent_series x.

(** Standard ratio test via existence of the limit. **)
// Proof in 1777388823.mg
ProofArchived ratio_test_conv :
  forall x : set -> set, R_seq x ->
    (forall n :e omega, x n <> 0) ->
    forall L :e R,
      seq_limit (ratio_abs_seq x) L ->
      L < 1 ->
      absolutely_convergent_series x.

// Proof in 1777388823.mg
ProofArchived ratio_test_div :
  forall x : set -> set, R_seq x ->
    (forall n :e omega, x n <> 0) ->
    forall L :e R,
      seq_limit (ratio_abs_seq x) L ->
      1 < L ->
      ~ convergent_series x.

End form50.

Section form51.

(** More on series: alternating series test. **)

//LLM alt_sign_seq : "the alt sign seq associated to #1" | $\mathrm{alt\_sign\_seq}(#1)$
Definition alt_sign_seq : set -> set :=
  fun n => (- 1) ^ (ordsucc n).

//LLM alt_seq : "the alt seq associated to #1" | $\mathrm{alt\_seq}(#1)$
Definition alt_seq : (set -> set) -> (set -> set) :=
  fun x => fun n => (alt_sign_seq n) * (x n).

// Proof in 1777388823.mg
ProofArchived pow_m1_two : (- 1) ^ 2 = 1.

// Proof in 1777388823.mg
ProofArchived pow_m1_SS :
  forall n :e omega, (- 1) ^ (ordsucc (ordsucc n)) = (- 1) ^ n.

// Proof in 1777388823.mg
ProofArchived pow_test_rewrite :
  (- 1) ^ (2 * 0) = (- 1) ^ 0.

// Proof in 1777388823.mg
ProofArchived mul2_ordsucc :
  forall k :e omega, 2 * (ordsucc k) = ordsucc (ordsucc (2 * k)).

// Proof in 1777388823.mg
ProofArchived pow_m1_even_0 : (- 1) ^ (2 * 0) = 1.

// Proof in 1777388823.mg
ProofArchived pow_m1_even :
  forall k :e omega, (- 1) ^ (2 * k) = 1.

// Proof in 1777388823.mg
ProofArchived pow_m1_odd :
  forall k :e omega, (- 1) ^ (ordsucc (2 * k)) = - 1.

// Proof in 1777388823.mg
ProofArchived omega_even_or_odd :
  forall n :e omega, exists k :e omega, n = 2 * k \/ n = ordsucc (2 * k).

// Proof in 1777388823.mg
ProofArchived alt_sign_even :
  forall k :e omega, alt_sign_seq (2 * k) = - 1.

// Proof in 1777388823.mg
ProofArchived alt_sign_odd :
  forall k :e omega, alt_sign_seq (ordsucc (2 * k)) = 1.

// Proof in 1777388823.mg
ProofArchived alt_sign_seq_R_seq : R_seq alt_sign_seq.

// Proof in 1777388823.mg
ProofArchived alt_seq_R_seq :
  forall x : set -> set, R_seq x -> R_seq (alt_seq x).

// Proof in 1777388823.mg
ProofArchived alt_seq_even_term :
  forall x : set -> set, R_seq x ->
  forall k :e omega, (alt_seq x) (2 * k) = - (x (2 * k)).

// Proof in 1777388823.mg
ProofArchived alt_seq_odd_term :
  forall x : set -> set, R_seq x ->
  forall k :e omega, (alt_seq x) (ordsucc (2 * k)) = x (ordsucc (2 * k)).

// Proof in 1777388823.mg
ProofArchived omega_le_mul2 :
  forall k :e omega, k <= 2 * k.

// Proof in 1777388823.mg
ProofArchived alt_partial_sum_even_step :
  forall x : set -> set,
    R_seq x ->
    (forall n :e omega, 0 <= x n) ->
    monotone_dec x ->
    forall k :e omega,
      partial_sum_seq (alt_seq x) (2 * (ordsucc k))
        <= partial_sum_seq (alt_seq x) (2 * k).

// Proof in 1777388823.mg
ProofArchived alt_partial_sum_odd_step :
  forall x : set -> set,
    R_seq x ->
    (forall n :e omega, 0 <= x n) ->
    monotone_dec x ->
    forall k :e omega,
      partial_sum_seq (alt_seq x) (ordsucc (2 * k))
        <= partial_sum_seq (alt_seq x) (ordsucc (2 * (ordsucc k))).

// Proof in 1777388823.mg
ProofArchived alt_partial_sum_odd_le_even :
  forall x : set -> set,
    R_seq x ->
    (forall n :e omega, 0 <= x n) ->
    forall k :e omega,
      partial_sum_seq (alt_seq x) (ordsucc (2 * k))
        <= partial_sum_seq (alt_seq x) (2 * k).

// Proof in 1777388823.mg
ProofArchived alt_partial_sum_even_decrease :
  forall x : set -> set,
    R_seq x ->
    (forall n :e omega, 0 <= x n) ->
    monotone_dec x ->
    forall k :e omega, forall j :e omega,
      partial_sum_seq (alt_seq x) (2 * (add_nat k j))
        <= partial_sum_seq (alt_seq x) (2 * k).

// Proof in 1777388823.mg
ProofArchived alt_partial_sum_odd_increase :
  forall x : set -> set,
    R_seq x ->
    (forall n :e omega, 0 <= x n) ->
    monotone_dec x ->
    forall k :e omega, forall j :e omega,
      partial_sum_seq (alt_seq x) (ordsucc (2 * k))
        <= partial_sum_seq (alt_seq x) (ordsucc (2 * (add_nat k j))).

// Proof in 1777388823.mg
ProofArchived add_nat_mul2_distr :
  forall k j :e omega, add_nat (2 * k) (2 * j) = 2 * (add_nat k j).

// Proof in 1777388823.mg
ProofArchived add_nat_mul2_succ :
  forall k j :e omega,
    add_nat (ordsucc (2 * k)) (2 * j) = ordsucc (2 * (add_nat k j)).

// Proof in 1777388823.mg
ProofArchived alt_partial_sum_tail_bounds :
  forall x : set -> set,
    R_seq x ->
    (forall n :e omega, 0 <= x n) ->
    monotone_dec x ->
    forall k :e omega, forall n :e omega, 2 * k <= n ->
      partial_sum_seq (alt_seq x) (ordsucc (2 * k))
        <= partial_sum_seq (alt_seq x) n
      /\ partial_sum_seq (alt_seq x) n
           <= partial_sum_seq (alt_seq x) (2 * k).

// Proof in 1777388823.mg
ProofArchived alternating_series_convergent :
  forall x : set -> set,
    R_seq x ->
    (forall n :e omega, 0 <= x n) ->
    monotone_dec x ->
    seq_limit x 0 ->
    convergent_series (alt_seq x).

End form51.

Section form52.

(** Continuous functions: limits of functions. **)

//LLM cluster_point : "the cluster point associated to #1" | $\mathrm{cluster\_point}(#1,#2)$
Definition cluster_point : set -> set -> prop :=
  fun S x =>
    x :e R
    /\ forall eps :e R, 0 < eps ->
         exists y :e S, y <> x /\ dist_R y x < eps.

// Proof in 1777388823.mg
ProofArchived cluster_point_iff_seq :
  forall S x : set,
    S c= R ->
    (cluster_point S x <->
      exists a : set -> set,
        (forall n :e omega, a n :e S /\ a n <> x)
        /\ seq_limit a x).

//LLM func_limit : "the func limit associated to #1" | $\mathrm{func\_limit}(#1,#2,#3,#4)$
Definition func_limit : (set -> set) -> set -> set -> set -> prop :=
  fun f S c L =>
    S c= R
    /\ cluster_point S c
    /\ (forall x :e S, f x :e R)
    /\ L :e R
    /\ forall eps :e R, 0 < eps ->
         exists delta :e R, 0 < delta
           /\ forall x :e S, x <> c -> dist_R x c < delta -> dist_R (f x) L < eps.

// Proof in 1777388823.mg
ProofArchived func_limit_unique :
  forall f : set -> set, forall S c L1 L2 : set,
    func_limit f S c L1 ->
    func_limit f S c L2 ->
    L1 = L2.

// Proof in 1777388823.mg
ProofArchived func_limit_imp_seq_limit :
  forall f : set -> set, forall S c L : set,
    func_limit f S c L ->
    forall a : set -> set,
      (forall n :e omega, a n :e S /\ a n <> c) ->
      seq_limit a c ->
      seq_limit (fun n => f (a n)) L.
(** cluster_point_iff_seq proof moved next to its statement. **)

//LLM seq_func_limit : "the seq func limit associated to #1" | $\mathrm{seq\_func\_limit}(#1,#2,#3,#4)$
Definition seq_func_limit : (set -> set) -> set -> set -> set -> prop :=
  fun f S c L =>
    S c= R
    /\ cluster_point S c
    /\ (forall x :e S, f x :e R)
    /\ L :e R
    /\ forall a : set -> set,
        (forall n :e omega, a n :e S /\ a n <> c) ->
        seq_limit a c ->
        seq_limit (fun n => f (a n)) L.

// Proof in 1777388823.mg
ProofArchived seq_func_limit_elim_Sc :
  forall f : set -> set, forall S c L,
    seq_func_limit f S c L -> S c= R.

// Proof in 1777388823.mg
ProofArchived seq_func_limit_elim_cluster :
  forall f : set -> set, forall S c L,
    seq_func_limit f S c L -> cluster_point S c.

// Proof in 1777388823.mg
ProofArchived seq_func_limit_elim_fR :
  forall f : set -> set, forall S c L,
    seq_func_limit f S c L -> forall x :e S, f x :e R.

// Proof in 1777388823.mg
ProofArchived seq_func_limit_elim_LR :
  forall f : set -> set, forall S c L,
    seq_func_limit f S c L -> L :e R.

// Proof in 1777388823.mg
ProofArchived seq_func_limit_elim_seq :
  forall f : set -> set, forall S c L,
    seq_func_limit f S c L ->
    forall a : set -> set,
      (forall n :e omega, a n :e S /\ a n <> c) ->
      seq_limit a c ->
      seq_limit (fun n => f (a n)) L.

(** Uniqueness of sequential function limits. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived seq_func_limit_unique :
  forall f : set -> set, forall S c L1 L2,
    seq_func_limit f S c L1 ->
    seq_func_limit f S c L2 ->
    L1 = L2.

// Proof in 1777388823.mg
ProofArchived ms_seqflimit_lemma :
  forall f : set -> set, forall S c L : set,
    S c= R ->
    cluster_point S c ->
    (forall x :e S, f x :e R) ->
    L :e R ->
    ((forall eps :e R, 0 < eps ->
        exists delta :e R, 0 < delta
          /\ forall x :e S, x <> c -> dist_R x c < delta -> dist_R (f x) L < eps)
     <->
     (forall a : set -> set,
        (forall n :e omega, a n :e S /\ a n <> c) ->
        seq_limit a c ->
        seq_limit (fun n => f (a n)) L)).

// Proof in 1777388823.mg
ProofArchived func_limit_imp_seq_func_limit :
  forall f : set -> set, forall S c L : set,
    func_limit f S c L ->
    seq_func_limit f S c L.

// Proof in 1777388823.mg
ProofArchived seq_func_limit_imp_func_limit :
  forall f : set -> set, forall S c L : set,
    seq_func_limit f S c L ->
    func_limit f S c L.

// Proof in 1777388823.mg
ProofArchived func_limit_iff_seq_func_limit :
  forall f : set -> set, forall S c L : set,
    func_limit f S c L <-> seq_func_limit f S c L.

End form52.

Section form53.

(** Continuity. **)

//REAL1:320489 continuous_at : "#1 is continuous at #3 on #2" | $#1 \text{ is continuous at } #3 \text{ on } #2$
//LLM continuous_at : "#1 is continuous at #3 on #2" | $#1 \text{ is continuous at } #3 \text{ on } #2$
Definition continuous_at : (set -> set) -> set -> set -> prop :=
  fun f S c =>
    S c= R
    /\ c :e S
    /\ (forall x :e S, f x :e R)
    /\ forall eps :e R, 0 < eps ->
         exists delta :e R, 0 < delta
           /\ forall x :e S, dist_R x c < delta -> dist_R (f x) (f c) < eps.

//REAL1:321336 continuous_on : "#1 is continuous on #2" | $#1 \text{ is continuous on } #2$
//LLM continuous_on : "#1 is continuous on #2" | $#1 \text{ is continuous on } #2$
Definition continuous_on : (set -> set) -> set -> prop :=
  fun f S => forall c :e S, continuous_at f S c.

// Proof in 1777388823.mg
ProofArchived continuous_at_imp_func_limit :
  forall f : set -> set, forall S c,
    continuous_at f S c ->
    cluster_point S c ->
    func_limit f S c (f c).

// Proof in 1777388823.mg
ProofArchived func_limit_imp_continuous_at :
  forall f : set -> set, forall S c,
    func_limit f S c (f c) ->
    c :e S ->
    continuous_at f S c.

// Proof in 1777388823.mg
ProofArchived continuous_at_imp_seq_limit :
  forall f : set -> set, forall S c,
    continuous_at f S c ->
    forall a : set -> set,
      (forall n :e omega, a n :e S) ->
      seq_limit a c ->
      seq_limit (fun n => f (a n)) (f c).

(** Sequential continuity. **)

//LLM seq_continuous_at : "the seq continuous at associated to #1" | $\mathrm{seq\_continuous\_at}(#1,#2,#3)$
Definition seq_continuous_at : (set -> set) -> set -> set -> prop :=
  fun f S c =>
    S c= R
    /\ c :e S
    /\ (forall x :e S, f x :e R)
    /\ forall a : set -> set,
         (forall n :e omega, a n :e S) ->
         seq_limit a c ->
         seq_limit (fun n => f (a n)) (f c).

// Proof in 1777388823.mg
ProofArchived continuous_at_imp_seq_continuous_at :
  forall f : set -> set, forall S c, continuous_at f S c -> seq_continuous_at f S c.

// Proof in 1777388823.mg
ProofArchived seq_continuous_at_imp_continuous_at :
  forall f : set -> set, forall S c, seq_continuous_at f S c -> continuous_at f S c.

// Proof in 1777388823.mg
ProofArchived continuous_at_iff_seq_continuous_at :
  forall f : set -> set, forall S c, continuous_at f S c <-> seq_continuous_at f S c.

// Proof in RealAnalysis1May042026a.mg
ProofArchived continuous_at_minus :
  forall f : set -> set, forall S c,
    continuous_at f S c ->
    continuous_at (fun x => - (f x)) S c.

// Proof in RealAnalysis1May042026a.mg
ProofArchived continuous_at_nbhd_nonzero :
  forall f : set -> set, forall S c,
    continuous_at f S c ->
    f c <> 0 ->
    exists delta :e R, 0 < delta
      /\ forall x :e S, dist_R x c < delta -> f x <> 0.

End form53.

Section form54.

(** Links between continuity and func_limit / seq_func_limit. **)

// Proof in 1777388823.mg
ProofArchived continuous_at_iff_func_limit :
  forall f : set -> set, forall S c,
    cluster_point S c ->
    c :e S ->
    (continuous_at f S c <-> func_limit f S c (f c)).

// Proof in 1777388823.mg
ProofArchived continuous_at_imp_seq_func_limit :
  forall f : set -> set, forall S c,
    continuous_at f S c ->
    cluster_point S c ->
    seq_func_limit f S c (f c).

// Proof in 1777388823.mg
ProofArchived seq_func_limit_imp_continuous_at :
  forall f : set -> set, forall S c,
    seq_func_limit f S c (f c) ->
    c :e S ->
    continuous_at f S c.

End form54.

Section form55.

(** Uniform continuity. **)

//REAL1:365416 uniformly_continuous_on : "#1 is uniformly continuous on #2" | $#1 \text{ is uniformly continuous on } #2$
//LLM uniformly_continuous_on : "#1 is uniformly continuous on #2" | $#1 \text{ is uniformly continuous on } #2$
Definition uniformly_continuous_on : (set -> set) -> set -> prop :=
  fun f S =>
    S c= R
    /\ (forall x :e S, f x :e R)
    /\ forall eps :e R, 0 < eps ->
         exists delta :e R, 0 < delta
           /\ forall x :e S, forall y :e S,
                dist_R x y < delta -> dist_R (f x) (f y) < eps.

// Proof in 1777388823.mg
ProofArchived uniformly_continuous_on_imp_continuous_on :
  forall f : set -> set, forall S, uniformly_continuous_on f S -> continuous_on f S.

End form55.

Section form56.

(** Lipschitz continuity. **)

//REAL1:374871 lipschitz_continuous_on : "#1 is Lipschitz continuous on #2" | $#1 \text{ is Lipschitz on } #2$
//LLM lipschitz_continuous_on : "#1 is Lipschitz continuous on #2" | $#1 \text{ is Lipschitz on } #2$
Definition lipschitz_continuous_on : (set -> set) -> set -> prop :=
  fun f S =>
    S c= R
    /\ (forall x :e S, f x :e R)
    /\ exists K :e R, 0 < K
         /\ forall x :e S, forall y :e S, dist_R (f x) (f y) <= K * dist_R x y.

// Proof in 1777388823.mg
ProofArchived lipschitz_continuous_on_imp_uniformly_continuous_on :
  forall f : set -> set, forall S,
    lipschitz_continuous_on f S -> uniformly_continuous_on f S.

// Proof in 1777388823.mg
ProofArchived uniformly_continuous_on_imp_preserve_cauchy :
  forall f : set -> set, forall S, forall x : set -> set,
    uniformly_continuous_on f S ->
    (forall n :e omega, x n :e S) ->
    cauchy_seq x ->
    cauchy_seq (fun n => f (x n)).

// Proof in 1777388823.mg
ProofArchived seq_limit_dist_0_of_same_limit :
  forall x y : set -> set, forall l,
    seq_limit x l ->
    seq_limit y l ->
    seq_limit (fun n : set => dist_R (x n) (y n)) 0.

// Proof in 1777388823.mg
ProofArchived continuous_on_Icc_imp_uniformly_continuous_on :
  forall f : set -> set, forall a b :e R,
    continuous_on f (Icc a b) -> uniformly_continuous_on f (Icc a b).

End form56.

Section form57.

(** Boundedness on closed intervals. **)

// Proof in 1777388823.mg
ProofArchived abs_Icc_le_abs_sum :
  forall a b :e R, forall x,
    x :e Icc a b -> abs_SNo x <= abs_SNo a + abs_SNo b.

// Proof in 1777388823.mg
ProofArchived Icc_seq_bounded :
  forall a b :e R, forall x : set -> set,
    (forall n :e omega, x n :e Icc a b) -> bounded_seq x.

End form57.

Section form58.

(** Closedness / compactness of Icc for sequences. **)

// Proof in 1777388823.mg
ProofArchived Icc_closed_seq_limit :
  forall a b :e R, forall x : set -> set, forall l,
    (forall n :e omega, x n :e Icc a b) ->
    seq_limit x l ->
    l :e Icc a b.

(** seq_limit_dist_0_of_same_limit is proved in form56. **)

End form58.

Section form59.

(** Sequential compactness in a general metric space (X,d) via sequences. **)

//LLM ms_seq_limit : "the ms seq limit associated to #1" | $\mathrm{ms\_seq\_limit}(#1,#2,#3,#4)$
Definition ms_seq_limit : set -> (set -> set -> set) -> (set -> set) -> set -> prop :=
  fun X d x l =>
    (forall n :e omega, x n :e X)
    /\ l :e X
    /\ forall eps :e R, 0 < eps ->
         exists N :e omega, forall n :e omega, N <= n -> d (x n) l < eps.

//LLM ms_lim_seq : "the ms lim seq associated to #1" | $\mathrm{ms\_lim\_seq}(#1,#2,#3)$
Definition ms_lim_seq : set -> (set -> set -> set) -> (set -> set) -> set :=
  fun X d x => Eps_i (fun l => ms_seq_limit X d x l).

//LLM ms_seq_compact : "the ms seq compact associated to #1" | $\mathrm{ms\_seq\_compact}(#1,#2,#3)$
Definition ms_seq_compact : set -> (set -> set -> set) -> set -> prop :=
  fun X d K =>
    K c= X
    /\ forall x : set -> set,
         (forall n :e omega, x n :e K) ->
         exists xs : set -> set,
           subseq_of x xs
           /\ exists l :e K, ms_seq_limit X d xs l.

(** Sequential continuity on K (stated directly, without epsilon-delta continuity). **)
//LLM ms_seq_continuous_on : "the ms seq continuous on associated to #1" | $\mathrm{ms\_seq\_continuous\_on}(#1,#2,#3,#4,#5,#6)$
Definition ms_seq_continuous_on :
  (set -> set) -> set -> (set -> set -> set) -> set -> (set -> set -> set) -> set -> prop :=
  fun f X dX Y dY K =>
    (forall x :e K, f x :e Y)
    /\ forall c :e K, forall a0 : set -> set,
         (forall n :e omega, a0 n :e K) ->
         ms_seq_limit X dX a0 c ->
         ms_seq_limit Y dY (fun n : set => f (a0 n)) (f c).

// Proof in 1777388823.mg
ProofArchived ms_seq_continuous_on_imp_image_seq_compact :
  forall X Y, forall dX dY : set -> set -> set, forall f : set -> set, forall K,
    ms_seq_compact X dX K ->
    ms_seq_continuous_on f X dX Y dY K ->
    ms_seq_compact Y dY {f x|x :e K}.

End form59.

Section form60.

(** Epsilon-delta continuity in a metric space implies sequential continuity. **)

//LLM ms_continuous_at : "the ms continuous at associated to #1" | $\mathrm{ms\_continuous\_at}(#1,#2,#3,#4,#5,#6)$
Definition ms_continuous_at :
  (set -> set) -> set -> (set -> set -> set) -> set -> (set -> set -> set) -> set -> prop :=
  fun f X dX Y dY c =>
    c :e X
    /\ (forall x :e X, f x :e Y)
    /\ forall eps :e R, 0 < eps ->
         exists delta :e R, 0 < delta
           /\ forall x :e X, dX x c < delta -> dY (f x) (f c) < eps.

//LLM ms_continuous_on : "the ms continuous on associated to #1" | $\mathrm{ms\_continuous\_on}(#1,#2,#3,#4,#5,#6)$
Definition ms_continuous_on :
  (set -> set) -> set -> (set -> set -> set) -> set -> (set -> set -> set) -> set -> prop :=
  fun f X dX Y dY K =>
    K c= X
    /\ forall c :e K, ms_continuous_at f X dX Y dY c.

// Proof in 1777388823.mg
ProofArchived ms_continuous_at_imp_ms_seq_continuous :
  forall f : set -> set, forall X Y, forall dX dY : set -> set -> set, forall c,
    ms_continuous_at f X dX Y dY c ->
    forall a0 : set -> set,
      (forall n :e omega, a0 n :e X) ->
      ms_seq_limit X dX a0 c ->
      ms_seq_limit Y dY (fun n : set => f (a0 n)) (f c).

// Proof in 1777388823.mg
ProofArchived ms_continuous_on_imp_ms_seq_continuous_on :
  forall f : set -> set, forall X Y, forall dX dY : set -> set -> set, forall K,
    ms_continuous_on f X dX Y dY K ->
    ms_seq_continuous_on f X dX Y dY K.

End form60.

Section form61.

(** Continuous image of a sequentially compact set is sequentially compact. **)

// Proof in 1777388823.mg
ProofArchived ms_continuous_on_imp_image_seq_compact :
  forall X Y, forall dX dY : set -> set -> set, forall f : set -> set, forall K,
    ms_seq_compact X dX K ->
    ms_continuous_on f X dX Y dY K ->
    ms_seq_compact Y dY {f x|x :e K}.

End form61.

Section form62.

(** Sequential compactness of closed intervals in R (as metric spaces with dist_R). **)

// Proof in 1777388823.mg
ProofArchived Icc_ms_seq_compact :
  forall a b :e R, ms_seq_compact (Icc a b) dist_R (Icc a b).

End form62.

Section form63.

(** Bridge: real-line continuity on a domain S implies metric-space continuity on X := S. **)

// Proof in 1777388823.mg
ProofArchived continuous_at_imp_ms_continuous_at :
  forall f : set -> set, forall S, forall c,
    continuous_at f S c ->
    ms_continuous_at f S dist_R R dist_R c.

// Proof in 1777388823.mg
ProofArchived continuous_on_imp_ms_continuous_on_self :
  forall f : set -> set, forall S,
    continuous_on f S ->
    ms_continuous_on f S dist_R R dist_R S.

// Proof in 1777388823.mg
ProofArchived continuous_on_Icc_imp_fimage_ms_seq_compact :
  forall f : set -> set, forall a b :e R,
    continuous_on f (Icc a b) ->
    ms_seq_compact R dist_R {f x|x :e Icc a b}.

End form63.

Section form64.

(** Extreme value theorem (pending): sequentially compact subsets of R attain max/min. **)

// Proof in 1777388823.mg
ProofArchived ms_seq_compact_R_has_maxmin :
  forall A,
    ms_seq_compact R dist_R A ->
    nonempty A ->
    has_max A /\ has_min A.

// Proof in 1777388823.mg
ProofArchived continuous_on_Icc_attains_maxmin :
  forall f : set -> set, forall a b :e R,
    a <= b ->
    continuous_on f (Icc a b) ->
    (exists x :e Icc a b, is_max (fimage f (Icc a b)) (f x))
    /\ (exists y :e Icc a b, is_min (fimage f (Icc a b)) (f y)).

End form64.

Section form65.

(** Bolzano's intermediate value theorem (IVT), 0-crossing lemma. **)

// Proof in 1777388823.mg
ProofArchived continuous_on_Icc_IVT :
  forall f : set -> set, forall a b :e R, forall y :e R,
    a < b ->
    continuous_on f (Icc a b) ->
    (f a < y /\ y < f b) \/ (f b < y /\ y < f a) ->
    exists c :e Ioo a b, f c = y.

// Proof in 1777388823.mg
ProofArchived continuous_on_Icc_IVT0 :
  forall f : set -> set, forall a b :e R,
    a < b ->
    continuous_on f (Icc a b) ->
    f a < 0 ->
    0 < f b ->
    exists c :e Ioo a b, f c = 0.

End form65.

Section form66.

(** Corollary: image of an interval under a continuous function is an interval (possibly degenerate). **)
// Proof in 1777388823.mg
ProofArchived continuous_on_Icc_fimage_interval :
  forall f : set -> set, forall a b :e R,
    a <= b ->
    continuous_on f (Icc a b) ->
    exists m :e R, exists M :e R, fimage f (Icc a b) = Icc m M.

End form66.

Section form67.

(** Fixed point theorem (contraction mapping principle / Banach fixed point theorem). **)

(** Basic closedness facts for 0 and 1 as reals. **)

// Proof in 100thms_12b.mg
ProofArchived zero_in_R : 0 :e R.

// Proof in 100thms_12b.mg
ProofArchived one_in_R : 1 :e R.

// Proof in RealAnalysis1.1778394101.mg
ProofArchived nonempty_R : nonempty R.

//LLM is_metric : "#1 is metric" | $\mathrm{is\_metric}(#1,#2)$
Definition is_metric : set -> (set -> set -> set) -> prop :=
  fun X d =>
    (forall x :e X, forall y :e X, d x y :e R)
    /\ ((forall x :e X, forall y :e X, 0 <= d x y)
        /\ ((forall x :e X, d x x = 0)
            /\ ((forall x :e X, forall y :e X, d x y = d y x)
                /\ ((forall x :e X, forall y :e X, forall z :e X, d x z <= d x y + d y z)
                    /\ (forall x :e X, forall y :e X, d x y = 0 -> x = y))))).

// Proof in 1777388823.mg
ProofArchived is_metric_dR :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    forall x :e X, forall y :e X, d x y :e R.

// Proof in 1777388823.mg
ProofArchived is_metric_nonneg :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    forall x :e X, forall y :e X, 0 <= d x y.

// Proof in 1777388823.mg
ProofArchived is_metric_sep :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    forall x :e X, forall y :e X, d x y = 0 -> x = y.

// Proof in 1777388823.mg
ProofArchived is_metric_diag0 :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    forall x :e X, d x x = 0.

// Proof in 1777388823.mg
ProofArchived is_metric_sym :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    forall x :e X, forall y :e X, d x y = d y x.

// Proof in 1777388823.mg
ProofArchived is_metric_tri :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    forall x :e X, forall y :e X, forall z :e X, d x z <= d x y + d y z.

// real1.tex: ms:chapter, sec:mettop (Open and closed sets).

//LLM ms_ball : "the ms ball associated to #1" | $\mathrm{ms\_ball}(#1,#2,#3,#4)$
Definition ms_ball : set -> (set -> set -> set) -> set -> set -> set :=
  fun X d x delta =>
    {y :e X | d x y < delta}.

//LLM ms_closed_ball : "the ms closed ball associated to #1" | $\mathrm{ms\_closed\_ball}(#1,#2,#3,#4)$
Definition ms_closed_ball : set -> (set -> set -> set) -> set -> set -> set :=
  fun X d x delta =>
    {y :e X | d x y <= delta}.

//LLM ms_open : "the ms open associated to #1" | $\mathrm{ms\_open}(#1,#2,#3)$
Definition ms_open : set -> (set -> set -> set) -> set -> prop :=
  fun X d V =>
    V c= X
    /\ forall x :e V, exists delta :e R,
         0 < delta /\ forall y :e X, d x y < delta -> y :e V.

//LLM ms_closed : "#1 is closed under ms" | $\mathrm{ms\_closed}(#1,#2,#3)$
Definition ms_closed : set -> (set -> set -> set) -> set -> prop :=
  fun X d E =>
    E c= X /\ ms_open X d (X :\: E).

// Proof in RealAnalysis1.1778396412.mg
ProofArchived ms_open_Empty :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    ms_open X d Empty.

// Proof in RealAnalysis1.1778396412.mg
ProofArchived ms_open_X :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    ms_open X d X.

// Proof in RealAnalysis1.1778396412.mg
ProofArchived ms_open_binintersect :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    forall V W,
      ms_open X d V ->
      ms_open X d W ->
      ms_open X d (V :/\: W).

// Proof in RealAnalysis1.1778396412.mg
ProofArchived ms_open_Union :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    forall V,
      (forall U :e V, ms_open X d U) ->
      ms_open X d (Union V).

// Proof in RealAnalysis1.1778397627.mg
ProofArchived setminus_self_eq_Empty :
  forall X, X :\: X = Empty.

// Proof in RealAnalysis1.1778397627.mg
ProofArchived setminus_Empty_eq :
  forall X, X :\: Empty = X.

// Proof in RealAnalysis1.1778397627.mg
ProofArchived ms_closed_Empty :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    ms_closed X d Empty.

// Proof in RealAnalysis1.1778397627.mg
ProofArchived ms_closed_X :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    ms_closed X d X.

// Proof in RealAnalysis1.1778400234.mg
ProofArchived setminus_binunion_eq_binintersect_setminus :
  forall X A B, X :\: (A :\/: B) = (X :\: A) :/\: (X :\: B).

// Proof in RealAnalysis1.1778400234.mg
ProofArchived ms_closed_binunion :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    forall A B,
      ms_closed X d A ->
      ms_closed X d B ->
      ms_closed X d (A :\/: B).

// real1.tex: prop:topology:ballsopenclosed (open ball is open).
// Proof in RealAnalysis1.1778400234.mg
ProofArchived ms_open_ball :
  forall X, forall d : set -> set -> set,
    is_metric X d ->
    forall x :e X, forall delta :e R,
      0 < delta ->
      ms_open X d (ms_ball X d x delta).

// Proof in RealAnalysis1.1778390155.mg
ProofArchived is_metric_R_dist_R :
  is_metric R dist_R.

//LLM ms_cauchy_seq : "the ms cauchy seq associated to #1" | $\mathrm{ms\_cauchy\_seq}(#1,#2,#3)$
Definition ms_cauchy_seq : set -> (set -> set -> set) -> (set -> set) -> prop :=
  fun X d x =>
    (forall n :e omega, x n :e X)
    /\ forall eps :e R, 0 < eps ->
         exists N :e omega,
           forall m :e omega, forall n :e omega, N <= m -> N <= n -> d (x m) (x n) < eps.

//LLM ms_complete : "the ms complete associated to #1" | $\mathrm{ms\_complete}(#1,#2)$
Definition ms_complete : set -> (set -> set -> set) -> prop :=
  fun X d =>
    forall x : set -> set, ms_cauchy_seq X d x -> exists l :e X, ms_seq_limit X d x l.

// Proof in RealAnalysis1.1778391763.mg
ProofArchived ms_complete_R_dist_R :
  ms_complete R dist_R.

//LLM ms_contraction : "the ms contraction associated to #1" | $\mathrm{ms\_contraction}(#1,#2,#3)$
Definition ms_contraction : (set -> set) -> set -> (set -> set -> set) -> prop :=
  fun phi X d =>
    exists k :e R, (0 <= k /\ k < 1) /\ forall x :e X, forall y :e X, d (phi x) (phi y) <= k * d x y.

// real1.tex: ms:chapter exercise: discrete metric contraction is constant.
//LLM dist_discrete : "the dist discrete associated to #1" | $d(#1,#2)$
Definition dist_discrete : set -> set -> set :=
  fun x y => if x = y then 0 else 1.

// Proof in RealAnalysis1.1778383598.mg
ProofArchived dist_discrete_def :
  forall x y, dist_discrete x y = if x = y then 0 else 1.

// real1.tex: ms:chapter exercise: the discrete metric is a metric.
// Proof in RealAnalysis1.1778383598.mg
ProofArchived dist_discrete_is_metric :
  forall X, is_metric X dist_discrete.

// Proof in RealAnalysis1.1778381345.mg
ProofArchived ms_contraction_discrete_constant :
  forall X,
    nonempty X ->
  forall f : set -> set,
    (forall x :e X, f x :e X) ->
    ms_contraction f X dist_discrete ->
    exists c :e X, forall x :e X, f x = c.

//LLM ms_fixed_point : "the ms fixed point associated to #1" | $\mathrm{ms\_fixed\_point}(#1,#2)$
Definition ms_fixed_point : (set -> set) -> set -> prop :=
  fun phi x => phi x = x.

//LLM ms_has_unique_fixed_point : "the ms has unique fixed point associated to #1" | $\mathrm{ms\_has\_unique\_fixed\_point}(#1,#2)$
Definition ms_has_unique_fixed_point : (set -> set) -> set -> prop :=
  fun phi X =>
    exists x :e X, ms_fixed_point phi x /\ forall y :e X, ms_fixed_point phi y -> y = x.

//LLM ms_iter_seq : "the ms iter seq associated to #1" | $\mathrm{ms\_iter\_seq}(#1,#2)$
Definition ms_iter_seq : (set -> set) -> set -> (set -> set) :=
  fun phi x0 => fun n => nat_primrec x0 (fun _ r => phi r) n.

// Proof in 1777388823.mg
ProofArchived ms_iter_seq_0 : forall phi : set -> set, forall x0, ms_iter_seq phi x0 0 = x0.

// Proof in 1777388823.mg
ProofArchived ms_iter_seq_S : forall phi : set -> set, forall x0, forall n :e omega,
  ms_iter_seq phi x0 (ordsucc n) = phi (ms_iter_seq phi x0 n).

// Proof in 1777388823.mg
ProofArchived ms_iter_seq_inX :
  forall X, forall phi : set -> set, forall x0,
    x0 :e X ->
    (forall x :e X, phi x :e X) ->
    forall n :e omega, ms_iter_seq phi x0 n :e X.

// Proof in 1777388823.mg
ProofArchived ms_contraction_fixed_point_exists_k0 :
  forall X, forall d : set -> set -> set, forall phi : set -> set,
    nonempty X ->
    is_metric X d ->
    (forall x :e X, phi x :e X) ->
    (forall x :e X, forall y :e X, d (phi x) (phi y) <= 0) ->
    exists c :e X, phi c = c.

// Proof in 1777388823.mg
ProofArchived ms_contraction_fixed_point_unique :
  forall X, forall d : set -> set -> set, forall phi : set -> set,
    is_metric X d ->
    (forall x :e X, phi x :e X) ->
    ms_contraction phi X d ->
    forall x :e X, phi x = x ->
    forall y :e X, phi y = y ->
    x = y.

// Proof in 1777388823.mg
ProofArchived ms_contraction_fixed_point_unique2 :
  forall X, forall d : set -> set -> set, forall phi : set -> set,
    is_metric X d ->
    (forall x :e X, phi x :e X) ->
    ms_contraction phi X d ->
    forall x :e X, ms_fixed_point phi x ->
    forall y :e X, ms_fixed_point phi y ->
    x = y.

// Proof in 1777388823.mg
ProofArchived SNoLe_eq_substL :
  forall x y z, SNo x -> SNo y -> SNo z -> x = y -> x <= z -> y <= z.

(** Substitute an equality on the right side of <= (early copy). **)
// Proof in 1777436708.mg
ProofArchived SNoLe_eq_substR0 :
  forall x y z,
    SNo x ->
    SNo y ->
    SNo z ->
    x = y ->
    z <= x ->
    z <= y.

(** Contraction mapping principle (strong form): existence + uniqueness of the fixed point. **)
// Proof in 1777388823.mg
ProofArchived ms_contraction_mapping_principle :
  forall X, forall d : set -> set -> set, forall phi : set -> set,
    nonempty X ->
    is_metric X d ->
    ms_contraction phi X d ->
    ms_complete X d ->
    (forall x :e X, phi x :e X) ->
    exists x :e X, phi x = x /\ forall y :e X, phi y = y -> y = x.

(** Contraction mapping principle: existence of a fixed point. **)
// Proof in 1777388823.mg
ProofArchived ms_contraction_fixed_point_exists :
  forall X, forall d : set -> set -> set, forall phi : set -> set,
    nonempty X ->
    is_metric X d ->
    ms_contraction phi X d ->
    ms_complete X d ->
    (forall x :e X, phi x :e X) ->
    exists x :e X, phi x = x.

// real1.tex: ms:chapter exercise: if the iterates f^(n+1) are Lipschitz with summable constants, then f has a unique fixed point.

// Proof in RealAnalysis1.1778385666.mg
ProofArchived ms_iter_seq_succ_arg :
  forall phi : set -> set, forall x, forall n, nat_p n ->
    ms_iter_seq phi (phi x) n = phi (ms_iter_seq phi x n).

// Proof in RealAnalysis1.1778385666.mg
ProofArchived ms_iter_seq_of_fixed_point :
  forall phi : set -> set, forall x,
    phi x = x ->
    forall n, nat_p n -> ms_iter_seq phi x n = x.

// Proof in RealAnalysis1.1778385666.mg
ProofArchived ms_summable_iterates_unique_fixed_point :
  forall X, forall d : set -> set -> set, forall f : set -> set, forall k : set -> set,
    nonempty X ->
    is_metric X d ->
    ms_complete X d ->
    (forall x :e X, f x :e X) ->
    R_seq k ->
    nonneg_seq k ->
    convergent_series k ->
    (forall n :e omega, forall x :e X, forall y :e X,
        d (ms_iter_seq f x (ordsucc n)) (ms_iter_seq f y (ordsucc n)) <= k n * d x y) ->
    ms_has_unique_fixed_point f X.

// real1.tex: ms:chapter exercise: contraction iteration error bound.
// Proof in RealAnalysis1.1778404487.mg
ProofArchived ms_contraction_iter_dist_fixed_point_le :
  forall X, forall d : set -> set -> set, forall f : set -> set,
    is_metric X d ->
    forall k :e R,
      0 <= k ->
      k < 1 ->
      (forall x :e X, forall y :e X, d (f x) (f y) <= k * d x y) ->
      (forall x :e X, f x :e X) ->
      forall x0 :e X, forall x :e X,
        f x = x ->
        forall n :e omega,
          d (ms_iter_seq f x0 n) x <= (k ^ n) * d x0 x.

// real1.tex: ms:chapter exercise: bound the initial gap to a fixed point.
// Proof in RealAnalysis1.1778404487.mg
ProofArchived ms_contraction_fixed_point_gap_le :
  forall X, forall d : set -> set -> set, forall f : set -> set,
    is_metric X d ->
    forall k :e R,
      0 <= k ->
      k < 1 ->
      (forall x :e X, forall y :e X, d (f x) (f y) <= k * d x y) ->
      (forall x :e X, f x :e X) ->
      forall x0 :e X, forall x :e X,
        f x = x ->
        d x0 x <= (d (f x0) x0) :/: (1 + (- k)).

// real1.tex: ms:chapter exercise: combine the fixed-point gap bound with the iterate bound.
// Proof in RealAnalysis1.1778404487.mg
ProofArchived ms_contraction_iter_dist_fixed_point_le_gap :
  forall X, forall d : set -> set -> set, forall f : set -> set,
    is_metric X d ->
    forall k :e R,
      0 <= k ->
      k < 1 ->
      (forall x :e X, forall y :e X, d (f x) (f y) <= k * d x y) ->
      (forall x :e X, f x :e X) ->
      forall x0 :e X, forall x :e X,
        f x = x ->
        forall n :e omega,
          d (ms_iter_seq f x0 n) x <= (k ^ n) * ((d (f x0) x0) :/: (1 + (- k))).

// real1.tex: Picard exercises: affine contractions on R.

// Proof in RealAnalysis1.1778390155.mg
ProofArchived ms_contraction_affine_R :
  forall k b :e R,
    0 <= k ->
    k < 1 ->
    ms_contraction (fun x : set => k * x + b) R dist_R.

// Proof in RealAnalysis1.1778390155.mg
ProofArchived ms_fixed_point_affine_R_unique :
  forall k b :e R,
    0 <= k ->
    k < 1 ->
    forall x :e R, (k * x + b) = x ->
    forall y :e R, (k * y + b) = y ->
    x = y.

// real1.tex: Picard exercise: affine contractions on R have a unique fixed point.
// Proof in RealAnalysis1.1778394101.mg
ProofArchived ms_has_unique_fixed_point_affine_R :
  forall k b :e R,
    0 <= k ->
    k < 1 ->
    ms_has_unique_fixed_point (fun x : set => k * x + b) R.

End form67.

Section form68.

(** Derivative: definition and basic properties (differentiability implies continuity, linearity). **)

//REAL1:414414 diffquot : "the difference quotient of #1 at #2" | $\frac{#1(x)-#1(#2)}{x-#2}$
//LLM diffquot : "the difference quotient of #1 at #2" | $\frac{#1(x)-#1(#2)}{x-#2}$
Definition diffquot : (set -> set) -> set -> (set -> set) :=
  fun f c =>
    fun x => (f x + (- (f c))) :/: (x + (- c)).

//REAL1:414094 deriv_at : "#1 has derivative #4 at #3 on #2" | $#1'(#3)=#4$
//LLM deriv_at : "#1 has derivative #4 at #3 on #2" | $#1'(#3)=#4$
Definition deriv_at : (set -> set) -> set -> set -> set -> prop :=
  fun f I c L =>
    I c= R
    /\ c :e I
    /\ (forall x :e I, f x :e R)
    /\ seq_func_limit (diffquot f c) I c L.

// Proof in 1777388823.mg
ProofArchived deriv_at_elim_Ic :
  forall f : set -> set, forall I c L,
    deriv_at f I c L ->
    I c= R /\ c :e I /\ (forall x :e I, f x :e R).

// Proof in 1777388823.mg
ProofArchived deriv_at_elim_seq :
  forall f : set -> set, forall I c L,
    deriv_at f I c L ->
    seq_func_limit (diffquot f c) I c L.

//LLM differentiable_at : "the differentiable at associated to #1" | $\mathrm{differentiable\_at}(#1,#2,#3)$
Definition differentiable_at : (set -> set) -> set -> set -> prop :=
  fun f I c => exists L :e R, deriv_at f I c L.

// Proof in 1777388823.mg
ProofArchived deriv_at_unique :
  forall f : set -> set, forall I c L1 L2,
    deriv_at f I c L1 -> deriv_at f I c L2 -> L1 = L2.

// Proof in 1777388823.mg
ProofArchived deriv_at_imp_continuous_at :
  forall f : set -> set, forall I c L,
    deriv_at f I c L -> continuous_at f I c.

// Proof in 1777388823.mg
ProofArchived deriv_at_scale :
  forall f : set -> set, forall I c L, deriv_at f I c L ->
  forall alpha :e R, deriv_at (fun x => alpha * (f x)) I c (alpha * L).

// Proof in 1777388823.mg
ProofArchived deriv_at_add :
  forall f g : set -> set, forall I c Lf Lg,
    deriv_at f I c Lf -> deriv_at g I c Lg ->
    deriv_at (fun x => f x + g x) I c (Lf + Lg).

End form68.

Section form69.

(** Book: Chapter "The Derivative", Section "The derivative". **)
(** Next major results are product / quotient / chain rules.  The first two are **)
(** stated in the book as propositions whose proofs are left as exercises. **)

(** Basic eliminators for `seq_limit` placed here (>= RealAnalysis1) to avoid editing earlier parts. **)
// Proof in 1777486372.mg
ProofArchived seq_limit_elim_R_seq :
  forall x : set -> set, forall l,
    seq_limit x l ->
    R_seq x.

// Proof in 1777486372.mg
ProofArchived seq_limit_elim_l_in_R :
  forall x : set -> set, forall l,
    seq_limit x l ->
    l :e R.

// Proof in 1777486372.mg
ProofArchived seq_limit_elim_eps :
  forall x : set -> set, forall l,
    seq_limit x l ->
    forall eps :e R, 0 < eps ->
      exists N :e omega, forall n :e omega, N <= n -> dist_R (x n) l < eps.

// Proof in 1777388823.mg
ProofArchived deriv_at_mul :
  forall f g : set -> set, forall I c Lf Lg,
    deriv_at f I c Lf -> deriv_at g I c Lg ->
    deriv_at (fun x => (f x) * (g x)) I c ((f c) * Lg + Lf * (g c)).

// Proof in 1777388823.mg
ProofArchived deriv_at_const :
  forall I : set, forall c k :e R,
    I c= R ->
    c :e I ->
    cluster_point I c ->
    deriv_at (fun x : set => k) I c 0.

// Proof in 1777388823.mg
ProofArchived deriv_at_id :
  forall I : set, forall c :e R,
    I c= R ->
    c :e I ->
    cluster_point I c ->
    deriv_at (fun x : set => x) I c 1.

// Proof in 1777388823.mg
ProofArchived div_cancel_mul_left :
  forall x y z,
    SNo x -> SNo y -> SNo z ->
    y <> 0 ->
    (x * y) :/: (y * z) = x :/: z.

// Proof in 1777393974.mg
ProofArchived seq_limit_div :
  forall x y : set -> set, forall a b,
    seq_limit x a ->
    seq_limit y b ->
    b <> 0 ->
    (forall n :e omega, y n <> 0) ->
    seq_limit (fun n => (x n) :/: (y n)) (a :/: b).

// Proof in 1777394319.mg
ProofArchived mul_SNo_eq_0_imp_L_eq_0 :
  forall x y,
    SNo x ->
    SNo y ->
    y <> 0 ->
    x * y = 0 ->
    x = 0.

// Proof in 1777394319.mg
ProofArchived mul_SNo_eq_0_imp_R_eq_0 :
  forall x y,
    SNo x ->
    SNo y ->
    x <> 0 ->
    x * y = 0 ->
    y = 0.

// Proof in 1777394495.mg
ProofArchived recip_SNo_sub_eq :
  forall u v,
    SNo u ->
    SNo v ->
    u <> 0 ->
    v <> 0 ->
    recip_SNo u + (- (recip_SNo v)) = (v + (- u)) :/: (u * v).

// Proof in 1777394624.mg
ProofArchived div_SNo_minus_num :
  forall x y,
    SNo x ->
    SNo y ->
    (- x) :/: y = - (x :/: y).

// Proof in 1777394665.mg
ProofArchived add_SNo_neg_swap :
  forall u v,
    SNo u ->
    SNo v ->
    v + (- u) = - (u + (- v)).

// Proof in 1777397067.mg
ProofArchived deriv_at_recip_comp :
  forall g : set -> set, forall I c Lg,
    (forall x :e I, g x <> 0) ->
    deriv_at g I c Lg ->
    deriv_at (fun x => recip_SNo (g x)) I c ((- Lg) :/: ((g c) * (g c))).

// Proof in 1777388823.mg
ProofArchived deriv_at_div :
  forall f g : set -> set, forall I c Lf Lg,
    (forall x :e I, g x <> 0) ->
    deriv_at f I c Lf -> deriv_at g I c Lg ->
    deriv_at (fun x => (f x) :/: (g x)) I c
      ((Lf * (g c) + (- ((f c) * Lg))) :/: ((g c) * (g c))).

// Proof in 1777388823.mg
ProofArchived deriv_at_chain :
  forall f : set -> set, forall I2 d Lf,
    deriv_at f I2 d Lf ->
  forall g : set -> set, forall I1 c Lg,
    deriv_at g I1 c Lg ->
    (forall x :e I1, g x :e I2) ->
    g c = d ->
    deriv_at (fun x => f (g x)) I1 c (Lf * Lg).

End form69.

Section form70.

(** Book: Chapter "The Derivative": Rolle's theorem and mean value theorem. **)

//LLM differentiable_on : "the differentiable on associated to #1" | $\mathrm{differentiable\_on}(#1,#2)$
Definition differentiable_on : (set -> set) -> set -> prop :=
  fun f I => forall c :e I, differentiable_at f I c.

// Proof in 1777388823.mg
ProofArchived R_two : 2 :e R.

(** Helper lemmas for Rolle/MVT. **)

// Proof in 1777388823.mg
ProofArchived Ioo_subq_Icc :
  forall a b :e R, Ioo a b c= Icc a b.

// Proof in 1777388823.mg
ProofArchived Icc_boundary_or_Ioo :
  forall a b :e R, forall x :e Icc a b,
    x :e Ioo a b \/ x = a \/ x = b.

// Proof in 1777388823.mg
ProofArchived continuous_at_elim_fR :
  forall f : set -> set, forall S c,
    continuous_at f S c ->
    forall x :e S, f x :e R.

// Proof in 1777388823.mg
ProofArchived continuous_on_elim_fR :
  forall f : set -> set, forall S,
    continuous_on f S ->
    forall x :e S, f x :e R.

// Proof in 1777388823.mg
ProofArchived deriv_at_Ioo_imp_Icc_of_continuous_on :
  forall f : set -> set, forall a b :e R, forall c L,
    a < b ->
    continuous_on f (Icc a b) ->
    c :e Ioo a b ->
    deriv_at f (Ioo a b) c L ->
    deriv_at f (Icc a b) c L.

// Proof in 1777388823.mg
ProofArchived omega_le_add_nat_L :
  forall n m :e omega, n <= add_nat n m.

// Proof in 1777388823.mg
ProofArchived omega_le_add_nat_R :
  forall n m :e omega, m <= add_nat n m.

// Proof in 1777388823.mg
ProofArchived div_SNo_minus_minus :
  forall x y, SNo x -> SNo y -> (- x) :/: (- y) = x :/: y.

// Proof in 1777388823.mg
ProofArchived fermat_max_Icc :
  forall f : set -> set, forall a b :e R, forall c L,
    a < b ->
    c :e Ioo a b ->
deriv_at f (Icc a b) c L ->
(forall x :e Icc a b, f x <= f c) ->
L = 0.

// Proof in 1777388823.mg
ProofArchived fermat_min_Icc :
  forall f : set -> set, forall a b :e R, forall c L,
    a < b ->
    c :e Ioo a b ->
    deriv_at f (Icc a b) c L ->
    (forall x :e Icc a b, f c <= f x) ->
    L = 0.

// Proof in 1777388823.mg
ProofArchived Rolle_choose_extremum :
  forall f : set -> set, forall a b :e R,
    a < b ->
    continuous_on f (Icc a b) ->
    f a = f b ->
    exists c :e Ioo a b,
      is_max (fimage f (Icc a b)) (f c)
      \/ is_min (fimage f (Icc a b)) (f c).

// Proof in 1777388823.mg
ProofArchived Rolle_thm :
  forall f : set -> set, forall a b :e R,
    a < b ->
    continuous_on f (Icc a b) ->
    differentiable_on f (Ioo a b) ->
    f a = f b ->
    exists c :e (Ioo a b), deriv_at f (Icc a b) c 0.

// Proof in 1777388823.mg
ProofArchived mean_value_thm :
  forall f : set -> set, forall a b :e R,
    a < b ->
    continuous_on f (Icc a b) ->
    differentiable_on f (Ioo a b) ->
    exists c :e (Ioo a b), exists L :e R,
      deriv_at f (Icc a b) c L /\ f b + (- (f a)) = L * (b + (- a)).

// Proof in 1777388823.mg
ProofArchived cauchy_mean_value_thm :
  forall f phi : set -> set, forall a b :e R,
    a < b ->
    continuous_on f (Icc a b) ->
    continuous_on phi (Icc a b) ->
    differentiable_on f (Ioo a b) ->
    differentiable_on phi (Ioo a b) ->
    exists c :e (Ioo a b), exists Lf Lphi :e R,
      deriv_at f (Icc a b) c Lf
      /\ deriv_at phi (Icc a b) c Lphi
      /\ (f b + (- (f a))) * Lphi = Lf * (phi b + (- (phi a))).

End form70.

Section form71.

(** Book: Chapter "The Derivative": Applications of the mean value theorem. **)

// Proof in 1777388823.mg
ProofArchived deriv_zero_endpoints_eq_Icc :
  forall f : set -> set, forall a b :e R,
    a < b ->
    continuous_on f (Icc a b) ->
    differentiable_on f (Ioo a b) ->
    (forall c :e Ioo a b, deriv_at f (Icc a b) c 0) ->
    f a = f b.

(** Some general-purpose infrastructure for working with subintervals. **)

// Proof in 1777388823.mg
ProofArchived Ioo_subinterval_subq :
  forall a b :e R, forall x y :e R,
    a <= x -> y <= b -> Ioo x y c= Ioo a b.

// Proof in 1777388823.mg
ProofArchived Icc_subinterval_subq :
  forall a b :e R, forall x y :e R,
    a <= x -> y <= b -> Icc x y c= Icc a b.

// Proof in RealAnalysis1May042026a.mg
ProofArchived Icc_subq_Ioo_of_inner_bounds :
  forall a b x y :e R,
    a < x ->
    y < b ->
    Icc x y c= Ioo a b.

// Proof in 1777388823.mg
ProofArchived continuous_at_subq :
  forall f : set -> set, forall S T c,
    T c= S ->
    c :e T ->
    continuous_at f S c ->
    continuous_at f T c.

// Proof in 1777388823.mg
ProofArchived continuous_on_subq :
  forall f : set -> set, forall S T,
    T c= S ->
    continuous_on f S ->
    continuous_on f T.

// Proof in RealAnalysis1May042026a.mg
ProofArchived continuous_on_Ioo_imp_continuous_on_Icc_inner :
  forall f : set -> set, forall a b x y :e R,
    a < x ->
    y < b ->
    continuous_on f (Ioo a b) ->
    continuous_on f (Icc x y).

// Proof in 1777388823.mg
ProofArchived cluster_point_Ioo :
  forall a b :e R, forall c :e Ioo a b,
    cluster_point (Ioo a b) c.

(** Cluster points are monotone with respect to set inclusion. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived cluster_point_superset :
  forall S T c,
    T c= S ->
    cluster_point T c ->
    cluster_point S c.

(** Endpoints of a nondegenerate closed interval are cluster points. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived cluster_point_Icc_left :
  forall a b :e R, a < b ->
    cluster_point (Icc a b) a.

// Proof in RealAnalysis1May042026a.mg
ProofArchived cluster_point_Icc_right :
  forall a b :e R, a < b ->
    cluster_point (Icc a b) b.

// Proof in RealAnalysis1May042026a.mg
ProofArchived cluster_point_Icc :
  forall a b :e R, a < b ->
  forall c :e Icc a b,
    cluster_point (Icc a b) c.

(** Next application: derivative zero implies constant. **)

// Proof in 1777388823.mg
ProofArchived seq_func_limit_subq :
  forall g : set -> set, forall S T c L,
    T c= S ->
    seq_func_limit g S c L ->
    cluster_point T c ->
    seq_func_limit g T c L.

// Proof in RealAnalysis1May042026a.mg
ProofArchived seq_func_limit_congr :
  forall f g : set -> set, forall S c L,
    (forall x :e S, g x = f x) ->
    seq_func_limit f S c L ->
    seq_func_limit g S c L.

// Proof in RealAnalysis1May042026a.mg
ProofArchived deriv_at_congr :
  forall f g : set -> set, forall I c L,
    (forall x :e I, g x = f x) ->
    deriv_at f I c L ->
    deriv_at g I c L.

// Proof in 1777388823.mg
ProofArchived deriv_at_subq :
  forall f : set -> set, forall S T c L,
    T c= S ->
    c :e T ->
    cluster_point T c ->
    deriv_at f S c L ->
    deriv_at f T c L.

// Proof in 1777388823.mg
ProofArchived differentiable_on_subinterval_Ioo :
  forall f : set -> set, forall a b :e R, forall x y :e R,
    a <= x -> y <= b ->
    differentiable_on f (Ioo a b) ->
    differentiable_on f (Ioo x y).

// Proof in 1777388823.mg
ProofArchived deriv_zero_const_Icc :
  forall f : set -> set, forall a b :e R,
    a < b ->
    continuous_on f (Icc a b) ->
    differentiable_on f (Ioo a b) ->
    (forall c :e Ioo a b, deriv_at f (Ioo a b) c 0) ->
    forall x y :e Icc a b, f x = f y.

End form71.

Section form72.

(** Monotonicity on subsets of R (for functions f : set -> set). **)

//LLM increasing_on : "the increasing on associated to #1" | $\mathrm{increasing\_on}(#1,#2)$
Definition increasing_on : (set -> set) -> set -> prop :=
  fun f I => forall x :e I, forall y :e I, x < y -> f x <= f y.

//LLM decreasing_on : "the decreasing on associated to #1" | $\mathrm{decreasing\_on}(#1,#2)$
Definition decreasing_on : (set -> set) -> set -> prop :=
  fun f I => forall x :e I, forall y :e I, x < y -> f y <= f x.

//LLM strictly_increasing_on : "the strictly increasing on associated to #1" | $\mathrm{strictly\_increasing\_on}(#1,#2)$
Definition strictly_increasing_on : (set -> set) -> set -> prop :=
  fun f I => forall x :e I, forall y :e I, x < y -> f x < f y.

//LLM strictly_decreasing_on : "the strictly decreasing on associated to #1" | $\mathrm{strictly\_decreasing\_on}(#1,#2)$
Definition strictly_decreasing_on : (set -> set) -> set -> prop :=
  fun f I => forall x :e I, forall y :e I, x < y -> f y < f x.

// Proof in 1777388823.mg
ProofArchived deriv_nonneg_imp_increasing_Icc :
  forall f : set -> set, forall a b :e R,
    a < b ->
    continuous_on f (Icc a b) ->
    differentiable_on f (Ioo a b) ->
    (forall x y :e Icc a b, x < y ->
      forall c :e Ioo x y, forall L :e R,
        deriv_at f (Icc x y) c L -> 0 <= L) ->
    increasing_on f (Icc a b).

// Proof in 1777388823.mg
ProofArchived deriv_nonpos_imp_decreasing_Icc :
  forall f : set -> set, forall a b :e R,
    a < b ->
    continuous_on f (Icc a b) ->
    differentiable_on f (Ioo a b) ->
    (forall x y :e Icc a b, x < y ->
      forall c :e Ioo x y, forall L :e R,
        deriv_at f (Icc x y) c L -> L <= 0) ->
    decreasing_on f (Icc a b).

End form72.

Section form73.

// Proof in 1777391151.mg
ProofArchived deriv_pos_imp_strictly_increasing_Icc :
  forall f : set -> set, forall a b :e R,
    a < b ->
    continuous_on f (Icc a b) ->
    differentiable_on f (Ioo a b) ->
    (forall x y :e Icc a b, x < y ->
      forall c :e Ioo x y, forall L :e R,
        deriv_at f (Icc x y) c L -> 0 < L) ->
    strictly_increasing_on f (Icc a b).

// Proof in 1777388823.mg
ProofArchived deriv_neg_imp_strictly_decreasing_Icc :
  forall f : set -> set, forall a b :e R,
    a < b ->
    continuous_on f (Icc a b) ->
    differentiable_on f (Ioo a b) ->
    (forall x y :e Icc a b, x < y ->
      forall c :e Ioo x y, forall L :e R,
        deriv_at f (Icc x y) c L -> L < 0) ->
    strictly_decreasing_on f (Icc a b).

End form73.

Section form74.

(** First-derivative-test style fact from monotonicity hypotheses. **)
(** (Matches real1.tex Prop firstderminmaxtest, but stated directly for Icc a b.) **)

// Proof in 1777388823.mg
ProofArchived dec_inc_min_Icc :
  forall f : set -> set, forall a b c :e R,
    a <= c -> c <= b ->
    decreasing_on f (Icc a c) ->
    increasing_on f (Icc c b) ->
    forall x :e Icc a b, f c <= f x.

// Proof in RealAnalysis1May042026a.mg
ProofArchived inc_dec_max_Icc :
  forall f : set -> set, forall a b c :e R,
    a <= c -> c <= b ->
    increasing_on f (Icc a c) ->
    decreasing_on f (Icc c b) ->
    forall x :e Icc a b, f x <= f c.

// Proof in RealAnalysis1May042026a.mg
ProofArchived first_derivative_test_min_Icc :
  forall f : set -> set, forall a b c :e R,
    a < c ->
    c < b ->
    continuous_on f (Icc a c) ->
    continuous_on f (Icc c b) ->
    differentiable_on f (Ioo a c) ->
    differentiable_on f (Ioo c b) ->
    (forall x y :e Icc a c, x < y ->
      forall d :e Ioo x y, forall L :e R,
        deriv_at f (Icc x y) d L -> L <= 0) ->
    (forall x y :e Icc c b, x < y ->
      forall d :e Ioo x y, forall L :e R,
        deriv_at f (Icc x y) d L -> 0 <= L) ->
    forall x :e Icc a b, f c <= f x.

// Proof in RealAnalysis1May042026a.mg
ProofArchived first_derivative_test_max_Icc :
  forall f : set -> set, forall a b c :e R,
    a < c ->
    c < b ->
    continuous_on f (Icc a c) ->
    continuous_on f (Icc c b) ->
    differentiable_on f (Ioo a c) ->
    differentiable_on f (Ioo c b) ->
    (forall x y :e Icc a c, x < y ->
      forall d :e Ioo x y, forall L :e R,
        deriv_at f (Icc x y) d L -> 0 <= L) ->
    (forall x y :e Icc c b, x < y ->
      forall d :e Ioo x y, forall L :e R,
        deriv_at f (Icc x y) d L -> L <= 0) ->
    forall x :e Icc a b, f x <= f c.

End form74.

Section form75.

(** Book: Chapter "The Derivative": Continuity of derivatives and the intermediate value theorem. **)
(** real1.tex: Theorem [Darboux] (thm:darboux). **)

// Proof in 1777388823.mg
ProofArchived differentiable_on_imp_continuous_on :
  forall f : set -> set, forall I : set,
    differentiable_on f I ->
    continuous_on f I.

(** Endpoint derivative sign lemmas (used in Darboux). **)

// Proof in RealAnalysis1May042026a.mg
ProofArchived eps_shift_seq_limit_0 :
  forall M :e omega, seq_limit (fun n => eps_ (add_nat M n)) 0.

// Proof in 1777388823.mg
ProofArchived deriv_at_pos_exists_right_Icc :
  forall f : set -> set, forall a b :e R, forall L :e R,
    a < b ->
    deriv_at f (Icc a b) a L ->
    0 < L ->
    exists x :e Icc a b, a < x /\ f a < f x.

// Proof in 1777388823.mg
ProofArchived deriv_at_neg_exists_left_Icc :
  forall f : set -> set, forall a b :e R, forall L :e R,
    a < b ->
    deriv_at f (Icc a b) b L ->
    L < 0 ->
    exists x :e Icc a b, x < b /\ f b < f x.

// Proof in 1777388823.mg
ProofArchived darboux_thm_Icc :
  forall f : set -> set, forall a b :e R, forall y :e R,
    a < b ->
    differentiable_on f (Icc a b) ->
    forall La Lb :e R,
      deriv_at f (Icc a b) a La ->
      deriv_at f (Icc a b) b Lb ->
      (La < y /\ y < Lb) \/ (y < La /\ Lb < y) ->
      exists c :e Ioo a b, deriv_at f (Icc a b) c y.

End form75.

Section form76.

(** Book: Chapter "The Integral": starting infrastructure for Darboux/Riemann integration. **)
(** real1.tex: around "Darboux sums and not tagged partitions". **)

(** real1.tex: boundedness of continuous functions on Icc. **)
(** Placed here because it uses `ex_intro` (introduced at the start of form76). **)
// Proof in 1777503893.mg
ProofArchived continuous_on_Icc_imp_bounded_fun :
  forall f : set -> set, forall a b :e R,
a <= b ->
continuous_on f (Icc a b) ->
bounded_fun (Icc a b) f.

(** If two sequences agree pointwise on omega, they have the same limit. **)
// Proof in 1777494119.mg
ProofArchived seq_limit_of_pointwise_eq :
  forall x y : set -> set, forall l,
    seq_limit x l ->
    (forall n :e omega, y n = x n) ->
    seq_limit y l.

(** Sequence lemma moved here since it uses `ex_intro` (introduced in this section). **)
(** If x_n -> l and m < l then eventually m <= x_n. **)
// Proof in 1777488299.mg
ProofArchived seq_limit_eventually_ge_of_lt_limit :
  forall x : set -> set, forall l m :e R,
    seq_limit x l ->
    m < l ->
    exists N :e omega, forall n :e omega, N <= n -> m <= x n.

(** If x_n -> l and l < m then eventually x_n <= m. **)
// Proof in 1777488992.mg
ProofArchived seq_limit_eventually_le_of_limit_lt :
  forall x : set -> set, forall l m :e R,
    seq_limit x l ->
    l < m ->
    exists N :e omega, forall n :e omega, N <= n -> x n <= m.

(** If two sequences agree on a tail, they have the same limit. **)
// Proof in 1777388823.mg
ProofArchived seq_limit_of_eq_on_tail :
  forall x y : set -> set, forall l,
    seq_limit x l ->
    R_seq y ->
    (exists N0 :e omega, forall n :e omega, N0 <= n -> y n = x n) ->
    seq_limit y l.

(** Reverse direction of `seq_limit_neg`. **)
// Proof in 1777388823.mg
ProofArchived seq_limit_neg_rev :
  forall x : set -> set, forall a, R_seq x -> seq_limit (seq_neg x) a -> seq_limit x (- a).

(** If x_n -> a and y_n -> b and eventually x_n <= y_n then a <= b. **)
// Proof in 1777388823.mg
ProofArchived seq_limit_le :
  forall x y : set -> set, forall a b,
    seq_limit x a ->
    seq_limit y b ->
    eventually_le x y ->
    a <= b.

(** Pointwise order implies eventual order. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived eventually_le_of_pointwise_le :
  forall x y : set -> set,
    (forall n :e omega, x n <= y n) ->
    eventually_le x y.

(** If x_n -> a and y_n -> b and x_n <= y_n for all n then a <= b. **)
// Proof in 1777388823.mg
ProofArchived seq_limit_le_all :
  forall x y : set -> set, forall a b,
    seq_limit x a ->
    seq_limit y b ->
    (forall n :e omega, x n <= y n) ->
    a <= b.

(** If x_n -> a and 0 <= x_n for all n then 0 <= a. **)
// Proof in 1777388823.mg
ProofArchived seq_limit_nonneg :
  forall x : set -> set, forall a, seq_limit x a ->
    (forall n :e omega, 0 <= x n) -> 0 <= a.

(** A local "inverse-by-choice" eliminator for `inv`: **)
(** if you exhibit a witness `u :e X` with `f u = y`, then `inv X f y` lies in X and maps to y. **)
// Proof in 1777473693.mg
ProofArchived inv_spec_of_witness :
  forall X, forall f : set -> set, forall y u,
    u :e X ->
    f u = y ->
    inv X f y :e X /\ f (inv X f y) = y.

(** Basic fact about `inv` on the image of a function. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived inv_spec_of_mem_fimage :
  forall f : set -> set, forall I,
  forall y :e fimage f I,
    inv I f y :e I /\ f (inv I f y) = y.

(** Intro lemma for membership in `Icc` (unfolds the Sep definition). **)
// Proof in 1777451203.mg
ProofArchived IccI :
  forall a b x :e R,
    a <= x ->
    x <= b ->
    x :e Icc a b.

//LLM is_partition_Icc : "#1 is partition icc" | $\mathrm{is\_partition\_Icc}(#1,#2,#3)$
Definition is_partition_Icc : set -> set -> set -> prop :=
  fun a b P =>
    a :e R
    /\ b :e R
    /\ a <= b
    /\ finite P
    /\ P c= Icc a b
    /\ a :e P
    /\ b :e P.

// Proof in 1777388823.mg
ProofArchived partition_Icc_nonempty :
  forall a b P, is_partition_Icc a b P -> nonempty P.

// Proof in 1777388823.mg
ProofArchived partition_Icc_subq :
  forall a b P, is_partition_Icc a b P -> P c= Icc a b.

// Proof in 1777388823.mg
ProofArchived partition_Icc_elim_memR :
  forall a b P, is_partition_Icc a b P -> forall x :e P, x :e R.

// Proof in 1777388823.mg
ProofArchived partition_Icc_elim_finite :
  forall a b P, is_partition_Icc a b P -> finite P.

// Proof in 1777388823.mg
ProofArchived partition_Icc_adjoin :
  forall a b P, is_partition_Icc a b P ->
  forall x :e Icc a b, is_partition_Icc a b (P :\/: {x}).

(** Partition sequences (closer to the book's x0 < x1 < ... < xn presentation). **)
(** real1.tex: Definition of a partition of [a,b]. **)
//LLM is_partition_seq_Icc : "#1 is partition seq icc" | $\mathrm{is\_partition\_seq\_Icc}(#1,#2,#3,#4)$
Definition is_partition_seq_Icc : set -> set -> set -> (set -> set) -> prop :=
  fun a b n p =>
    nat_p n
    /\ a :e R
    /\ b :e R
    /\ a <= b
    /\ (forall i :e ordsucc n, p i :e R)
    /\ p 0 = a
    /\ p n = b
    /\ (forall i :e n, p i < p (ordsucc i)).

(** Constructor lemma for `is_partition_seq_Icc` (avoids repeatedly rebuilding the left-associated /\ chain). **)
// Proof in 1777459873.mg
ProofArchived is_partition_seq_IccI_components :
  forall a b n, forall p : set -> set,
    nat_p n ->
    a :e R ->
    b :e R ->
    a <= b ->
    (forall i :e ordsucc n, p i :e R) ->
    p 0 = a ->
    p n = b ->
    (forall i :e n, p i < p (ordsucc i)) ->
    is_partition_seq_Icc a b n p.

(** Endpoints of a partition sequence. **)
// Proof in 1777388844.mg
ProofArchived partition_seq_endpoints :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    p 0 = a /\ p n = b.

(** Eliminators for the left-associated conjunction in `is_partition_seq_Icc`. **)
// Proof in 1777471902.mg
ProofArchived is_partition_seq_Icc_elim_nat_p :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    nat_p n.

// Proof in 1777435952.mg
ProofArchived is_partition_seq_Icc_elim_valsR :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall i :e ordsucc n, p i :e R.

// Proof in 1777471902.mg
ProofArchived is_partition_seq_Icc_elim_strict :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall i :e n, p i < p (ordsucc i).

(** Natural subtraction witness (ordinal-style): if n c= m, this picks some k with m = k + n. **)
(** This is used later when building concatenated partition sequences. **)
//LLM nat_sub_witness : "the nat sub witness associated to #1" | $\mathrm{nat\_sub\_witness}(#1,#2)$
Definition nat_sub_witness : set -> set -> set :=
  fun n m => Eps_i (fun k => nat_p k /\ m = add_nat k n).

// Proof in 1777417625.mg
ProofArchived nat_sub_witness_spec :
  forall n, nat_p n ->
  forall m, nat_p m ->
    n c= m ->
    nat_p (nat_sub_witness n m) /\ m = add_nat (nat_sub_witness n m) n.

// Proof in 1777418051.mg
ProofArchived nat_sub_witness_self_eq_0 :
  forall n, nat_p n -> nat_sub_witness n n = 0.

// Proof in 1777418210.mg
ProofArchived nat_sub_witness_eq_of_add :
  forall n k, nat_p n -> nat_p k ->
  nat_sub_witness n (add_nat k n) = k.

(** Shift lemma: n + (k+1) = k + (n+1) (all additions are nat additions here). **)
// Proof in 1777418273.mg
ProofArchived add_nat_succ_swap :
  forall n k, nat_p n -> nat_p k ->
    add_nat n (ordsucc k) = add_nat k (ordsucc n).

(** Specialized computation: n + 1 = (n+1). **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived add_nat_succ_0R :
  forall n, nat_p n ->
    add_nat n (ordsucc 0) = ordsucc n.

(** Specialized computation for the concatenation map: subtracting (n+1) from n+(k+1) yields k. **)
// Proof in 1777418273.mg
ProofArchived nat_sub_witness_shift_succ :
  forall n k, nat_p n -> nat_p k ->
    nat_sub_witness (ordsucc n) (add_nat n (ordsucc k)) = k.

(** Index inequality: n+(k+1) is not <= n (i.e. not a member of ordsucc n). **)
// Proof in 1777418434.mg
ProofArchived add_nat_succ_not_in_ordsucc :
  forall n k, nat_p n -> nat_p k ->
    ~ (add_nat n (ordsucc k) :e ordsucc n).

(** If n+(k+1) is within ordsucc(n+m), then k is within m. **)
// Proof in 1777421072.mg
ProofArchived add_nat_succ_mem_ordsucc_imp_mem :
  forall n k m,
    nat_p n ->
    nat_p k ->
    nat_p m ->
    add_nat n (ordsucc k) :e ordsucc (add_nat n m) ->
    k :e m.

// Proof in 1777417708.mg
ProofArchived nat_sub_witness_in_omega :
  forall n m, nat_p n -> nat_p m -> n c= m -> nat_sub_witness n m :e omega.

(** Concatenation of two partition sequences (used for interval additivity). **)
(** The indices 0..n come from p, and the indices n+1..n+m come from q (skipping q 0 = c). **)
//LLM concat_partition_seq_fun : "the concat partition seq fun associated to #1" | $\mathrm{concat\_partition\_seq\_fun}(#1,#2,#3,#4)$
Definition concat_partition_seq_fun :
  set -> (set -> set) -> set -> (set -> set) -> (set -> set) :=
  fun n p m q =>
    fun i =>
      if i :e ordsucc n then p i
      else q (ordsucc (nat_sub_witness (ordsucc n) i)).

(** Evaluation of the concatenation map on the left part. **)
// Proof in 1777422590.mg
ProofArchived concat_partition_seq_fun_left :
  forall n m, nat_p n -> nat_p m ->
  forall p q : set -> set,
  forall i :e ordsucc n,
    concat_partition_seq_fun n p m q i = p i.

// Proof in 1777417809.mg
ProofArchived concat_partition_seq_fun_0 :
  forall n, nat_p n ->
  forall m, nat_p m ->
  forall p q : set -> set,
    concat_partition_seq_fun n p m q 0 = p 0.

// Proof in 1777417920.mg
ProofArchived concat_partition_seq_fun_n :
  forall n, nat_p n ->
  forall m, nat_p m ->
  forall p q : set -> set,
    concat_partition_seq_fun n p m q n = p n.

// Proof in 1777418076.mg
ProofArchived concat_partition_seq_fun_succ_n :
  forall n, nat_p n ->
  forall m, nat_p m ->
  forall p q : set -> set,
    concat_partition_seq_fun n p m q (ordsucc n)
      = q (ordsucc 0).

// Proof in 1777418471.mg
ProofArchived concat_partition_seq_fun_shift_succ :
  forall n k, nat_p n -> nat_p k ->
  forall m, nat_p m ->
  forall p q : set -> set,
    concat_partition_seq_fun n p m q (add_nat n (ordsucc k))
      = q (ordsucc k).

(** Index decomposition for ordsucc(n+m): every index is either on the left part (<= n) **)
(** or of the form n+(k+1) with k < m. **)
// Proof in 1777444204.mg
ProofArchived mem_ordsucc_add_nat_decomp :
  forall n m, nat_p n -> nat_p m ->
  forall i :e ordsucc (add_nat n m),
    i :e ordsucc n \/ exists k :e m, i = add_nat n (ordsucc k).

(** If i is a valid index in ordsucc(n+m) and not on the left part, then the nat-subtraction witness is < m. **)
// Proof in 1777422590.mg
ProofArchived nat_sub_witness_mem_m_of_index :
  forall n m,
    nat_p n ->
    nat_p m ->
    forall i :e ordsucc (add_nat n m),
      ~ (i :e ordsucc n) ->
      nat_sub_witness (ordsucc n) i :e m.

(** Convenience: on the left part, the concatenation map agrees with p at successor indices too. **)
// Proof in 1777425791.mg
ProofArchived concat_partition_seq_fun_left_succ :
  forall n, nat_p n ->
  forall m, nat_p m ->
  forall p q : set -> set,
  forall i :e n,
    concat_partition_seq_fun n p m q (ordsucc i) = p (ordsucc i).

(** Convenience: on the right part, successors correspond to successor indices in q. **)
// Proof in 1777425850.mg
ProofArchived concat_partition_seq_fun_shift_succ_succ :
  forall n k, nat_p n -> nat_p k ->
  forall m, nat_p m ->
  forall p q : set -> set,
    concat_partition_seq_fun n p m q (ordsucc (add_nat n (ordsucc k)))
      = q (ordsucc (ordsucc k)).

(** real1.tex: concatenation of partition sequences (used in Darboux/Riemann additivity lemmas). **)
// Proof in 1777445160.mg
ProofArchived concat_is_partition_seq_Icc :
  forall a b c :e R, a <= b -> b <= c ->
  forall n m, nat_p n -> nat_p m ->
  forall p q : set -> set,
    is_partition_seq_Icc a b n p ->
    is_partition_seq_Icc b c m q ->
    is_partition_seq_Icc a c (add_nat n m) (concat_partition_seq_fun n p m q).

(** Subinterval and width corresponding to the i-th step of a partition sequence. **)
//LLM part_Icc : "the part icc associated to #1" | $\mathrm{part\_Icc}(#1,#2)$
Definition part_Icc : (set -> set) -> set -> set :=
  fun p i => Icc (p i) (p (ordsucc i)).

//LLM delta_part : "the delta part associated to #1" | $\mathrm{delta\_part}(#1,#2)$
Definition delta_part : (set -> set) -> set -> set :=
  fun p i => (p (ordsucc i)) + (- (p i)).

(** Lower/upper Darboux terms and sums for a partition sequence (n,p). **)
(** Note: `inf_on`/`sup_on` are defined unconditionally; their specs require boundedness + nonemptiness. **)
//LLM darboux_term_lower : "the darboux term lower associated to #1" | $\mathrm{darboux\_term\_lower}(#1,#2,#3)$
Definition darboux_term_lower : (set -> set) -> (set -> set) -> set -> set :=
  fun f p i => (inf_on f (part_Icc p i)) * (delta_part p i).

//LLM darboux_term_upper : "the darboux term upper associated to #1" | $\mathrm{darboux\_term\_upper}(#1,#2,#3)$
Definition darboux_term_upper : (set -> set) -> (set -> set) -> set -> set :=
  fun f p i => (sup_on f (part_Icc p i)) * (delta_part p i).

//LLM darboux_sum_lower_seq : "the darboux sum lower seq associated to #1" | $\mathrm{darboux\_sum\_lower\_seq}(#1,#2,#3)$
Definition darboux_sum_lower_seq : (set -> set) -> set -> (set -> set) -> set :=
  fun f n p => partial_sum_seq (fun i:set => darboux_term_lower f p i) n.

//LLM darboux_sum_upper_seq : "the darboux sum upper seq associated to #1" | $\mathrm{darboux\_sum\_upper\_seq}(#1,#2,#3)$
Definition darboux_sum_upper_seq : (set -> set) -> set -> (set -> set) -> set :=
  fun f n p => partial_sum_seq (fun i:set => darboux_term_upper f p i) n.

(** Darboux terms for a concatenated partition: left part agrees with the left partition sequence. **)
// Proof in 1777425940.mg
ProofArchived darboux_term_lower_concat_left :
  forall n, nat_p n ->
  forall m, nat_p m ->
  forall f : set -> set,
  forall p q : set -> set,
  forall i :e n,
    darboux_term_lower f (concat_partition_seq_fun n p m q) i
      = darboux_term_lower f p i.

// Proof in 1777425940.mg
ProofArchived darboux_term_upper_concat_left :
  forall n, nat_p n ->
  forall m, nat_p m ->
  forall f : set -> set,
  forall p q : set -> set,
  forall i :e n,
    darboux_term_upper f (concat_partition_seq_fun n p m q) i
      = darboux_term_upper f p i.

(** Darboux terms for a concatenated partition: right part agrees with q on shifted indices. **)
// Proof in 1777426195.mg
ProofArchived darboux_term_lower_concat_shift_succ :
  forall n k, nat_p n -> nat_p k ->
  forall m, nat_p m ->
  forall f : set -> set,
  forall p q : set -> set,
    darboux_term_lower f (concat_partition_seq_fun n p m q) (add_nat n (ordsucc k))
      = darboux_term_lower f q (ordsucc k).

// Proof in 1777426195.mg
ProofArchived darboux_term_upper_concat_shift_succ :
  forall n k, nat_p n -> nat_p k ->
  forall m, nat_p m ->
  forall f : set -> set,
  forall p q : set -> set,
    darboux_term_upper f (concat_partition_seq_fun n p m q) (add_nat n (ordsucc k))
      = darboux_term_upper f q (ordsucc k).

(** Darboux terms at the boundary index n: this corresponds to the first term of q when p n = q 0. **)
// Proof in 1777426628.mg
ProofArchived darboux_term_lower_concat_n :
  forall n, nat_p n ->
  forall m, nat_p m ->
  forall f : set -> set,
  forall p q : set -> set,
    p n = q 0 ->
    darboux_term_lower f (concat_partition_seq_fun n p m q) n
      = darboux_term_lower f q 0.

// Proof in 1777426628.mg
ProofArchived darboux_term_upper_concat_n :
  forall n, nat_p n ->
  forall m, nat_p m ->
  forall f : set -> set,
  forall p q : set -> set,
    p n = q 0 ->
    darboux_term_upper f (concat_partition_seq_fun n p m q) n
      = darboux_term_upper f q 0.

(** Unified right-side Darboux-term computation: for any j< m, term at n+j equals term of q at j. **)
// Proof in 1777426628.mg
ProofArchived darboux_term_lower_concat_add_nat :
  forall n m, nat_p n -> nat_p m ->
  forall f : set -> set,
  forall p q : set -> set,
    p n = q 0 ->
    forall j :e m,
      darboux_term_lower f (concat_partition_seq_fun n p m q) (add_nat n j)
        = darboux_term_lower f q j.

// Proof in 1777426628.mg
ProofArchived darboux_term_upper_concat_add_nat :
  forall n m, nat_p n -> nat_p m ->
  forall f : set -> set,
  forall p q : set -> set,
    p n = q 0 ->
    forall j :e m,
      darboux_term_upper f (concat_partition_seq_fun n p m q) (add_nat n j)
        = darboux_term_upper f q j.

(** Darboux terms are real on valid indices of a partition sequence. **)
// Proof in 1777388844.mg
ProofArchived darboux_term_lower_closed :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall i :e n, darboux_term_lower f p i :e R.

// Proof in 1777388844.mg
ProofArchived darboux_term_upper_closed :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall i :e n, darboux_term_upper f p i :e R.

(** real1.tex: splitting Darboux sums along a concatenated partition sequence. **)
(** This lemma is a key step for the additivity of Darboux/Riemann integrals. **)
// Proof in 1777445189.mg
ProofArchived darboux_sum_lower_seq_concat_split :
  forall a b c :e R, a <= b -> b <= c ->
  forall n m, nat_p n -> nat_p m ->
  forall f : set -> set,
  forall p q : set -> set,
    bounded_fun (Icc a c) f ->
    is_partition_seq_Icc a b n p ->
    is_partition_seq_Icc b c m q ->
    darboux_sum_lower_seq f (add_nat n m) (concat_partition_seq_fun n p m q)
      = darboux_sum_lower_seq f n p + darboux_sum_lower_seq f m q.

// Proof in 1777445189.mg
ProofArchived darboux_sum_upper_seq_concat_split :
  forall a b c :e R, a <= b -> b <= c ->
  forall n m, nat_p n -> nat_p m ->
  forall f : set -> set,
  forall p q : set -> set,
    bounded_fun (Icc a c) f ->
    is_partition_seq_Icc a b n p ->
    is_partition_seq_Icc b c m q ->
    darboux_sum_upper_seq f (add_nat n m) (concat_partition_seq_fun n p m q)
      = darboux_sum_upper_seq f n p + darboux_sum_upper_seq f m q.

(** Book: Prop. sumulbound + refinement monotonicity will be proved for these `_seq` Darboux sums. **)
(** For now we record the key statements as theorems (possibly to be proved later). **)

(** Note: `darboux_sum_lower_Le_upper_seq` is proved later in this file (after the **)
(** auxiliary `part_Icc_` lemmas and `inf_on_Le_sup_on`), to avoid forward references. **)

(** real1.tex: Darboux sums are monotone under refinement. **)
(** The theorem `darboux_sum_refinement_monotone_seq` is stated later (after the **)
(** refinement infrastructure `partition_seq_refines_Icc` and auxiliary `inf_on`/`sup_on` **)
(** subset-monotonicity lemmas), to avoid forward references. **)

(** Refinements of (set-based) partitions. **)
(** real1.tex: Definition of refinement (P ⊂ \tilde P). **)
//LLM partition_refines_Icc : "the partition refines icc associated to #1" | $\mathrm{partition\_refines\_Icc}(#1,#2,#3,#4)$
Definition partition_refines_Icc : set -> set -> set -> set -> prop :=
  fun a b P Q =>
    is_partition_Icc a b P /\ is_partition_Icc a b Q /\ P c= Q.

// Proof in 1777388823.mg
ProofArchived partition_refines_Icc_refl :
  forall a b P, is_partition_Icc a b P -> partition_refines_Icc a b P P.

// Proof in 1777388823.mg
ProofArchived partition_refines_Icc_adjoin :
  forall a b P, is_partition_Icc a b P ->
  forall x :e Icc a b, partition_refines_Icc a b P (P :\/: {x}).

// Proof in 1777388823.mg
ProofArchived partition_refines_Icc_trans :
  forall a b P Q R,
    partition_refines_Icc a b P Q ->
    partition_refines_Icc a b Q R ->
    partition_refines_Icc a b P R.

(** Basic helper lemmas for Darboux sums. **)

// Proof in 1777388823.mg
ProofArchived bounded_fun_Subq :
  forall D E, forall f : set -> set, E c= D -> bounded_fun D f -> bounded_fun E f.

// Proof in 1777434293.mg
ProofArchived bounded_fun_Icc_subinterval :
  forall a b x y :e R,
    a <= x ->
    y <= b ->
    forall f : set -> set,
      bounded_fun (Icc a b) f ->
      bounded_fun (Icc x y) f.

(** Reflexivity of <= on reals (used for subinterval arguments). **)
// Proof in 1777436708.mg
ProofArchived R_Le_refl :
  forall x :e R, x <= x.

// Proof in 1777388823.mg
ProofArchived inf_on_le_value :
  forall D, forall f : set -> set,
    nonempty D -> bounded_fun D f ->
    forall x :e D, inf_on f D <= f x.

// Proof in 1777388823.mg
ProofArchived value_le_sup_on :
  forall D, forall f : set -> set,
    nonempty D -> bounded_fun D f ->
    forall x :e D, f x <= sup_on f D.

// Proof in 1777388823.mg
ProofArchived delta_part_pos :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall i :e n, 0 < delta_part p i.

// Proof in 1777388823.mg
ProofArchived partition_seq_elim_basic :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    nat_p n
    /\ (forall j :e ordsucc n, p j :e R)
    /\ (forall j :e n, p j < p (ordsucc j)).

// Proof in 1777435952.mg
ProofArchived partition_seq_points_in_R :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall i :e ordsucc n, p i :e R.

// Proof in 1777435952.mg
ProofArchived concat_partition_seq_fun_closed :
  forall a b c :e R, a <= b -> b <= c ->
  forall n m, nat_p n -> nat_p m ->
  forall p q : set -> set,
    is_partition_seq_Icc a b n p ->
    is_partition_seq_Icc b c m q ->
    forall i :e ordsucc (add_nat n m), concat_partition_seq_fun n p m q i :e R.

// Proof in 1777388844.mg
ProofArchived delta_part_real :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall i :e n, delta_part p i :e R.

(** Telescoping partial sums of partition widths: sum_{i<k} (q(i+1)-q(i)) = q(k)-q(0). **)
// Proof in 1777388823.mg
ProofArchived partial_sum_seq_delta_part_eq :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall k :e ordsucc n,
      partial_sum_seq (fun i => delta_part p i) k =
        p k + (- (p 0)).

// Proof in 1777388844.mg
ProofArchived partial_sum_seq_tail_delta_part_eq :
  forall a b m, forall q : set -> set,
    is_partition_seq_Icc a b m q ->
    forall j0 j1 :e ordsucc m,
      j0 :e j1 ->
      forall k :e omega,
        j1 = add_nat j0 k ->
        partial_sum_seq (tail_series (fun t => delta_part q t) j0) k =
          q j1 + (- (q j0)).

(** Decompose a strict index inclusion j0 :e j1 as an add_nat step: j1 = j0 + k. **)
// Proof in 1777388823.mg
ProofArchived nat_add_decomp_of_mem :
  forall m, nat_p m ->
  forall j0 j1 :e ordsucc m,
    j0 :e j1 ->
    exists k :e omega, j1 = add_nat j0 k.

// Proof in 1777388823.mg
ProofArchived part_Icc_nonempty :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall i :e n, nonempty (part_Icc p i).

(** Strictly-increasing finite sequences preserve strict order of indices: **)
(** if i :e j then p i < p j. **)
// Proof in 1777388823.mg
ProofArchived strict_finseq_mem_imp_lt :
  forall n, nat_p n ->
  forall p : set -> set,
    (forall j :e ordsucc n, p j :e R) ->
    (forall j :e n, p j < p (ordsucc j)) ->
    forall i j :e ordsucc n, i :e j -> p i < p j.

(** Strictly-increasing finite sequences: first/last bounds. **)
// Proof in 1777388823.mg
ProofArchived strict_finseq_0_Le :
  forall n, nat_p n ->
  forall p : set -> set,
    (forall j :e ordsucc n, p j :e R) ->
    (forall j :e n, p j < p (ordsucc j)) ->
    forall i :e ordsucc n, p 0 <= p i.

// Proof in 1777388823.mg
ProofArchived strict_finseq_Le_last :
  forall n, nat_p n ->
  forall p : set -> set,
    (forall j :e ordsucc n, p j :e R) ->
    (forall j :e n, p j < p (ordsucc j)) ->
    forall i :e ordsucc n, p i <= p n.

(** Strictly-increasing finite sequences are injective on ordsucc n. **)
// Proof in 1777388823.mg
ProofArchived strict_finseq_inj :
  forall n, nat_p n ->
  forall p : set -> set,
    (forall j :e ordsucc n, p j :e R) ->
    (forall j :e n, p j < p (ordsucc j)) ->
    forall i j :e ordsucc n, p i = p j -> i = j.

(** Reverse direction: strict increase implies index-order reflects value-order. **)
// Proof in 1777388823.mg
ProofArchived strict_finseq_lt_imp_mem :
  forall n, nat_p n ->
  forall p : set -> set,
    (forall j :e ordsucc n, p j :e R) ->
    (forall j :e n, p j < p (ordsucc j)) ->
    forall i j :e ordsucc n, p i < p j -> i :e j.

// Proof in 1777388823.mg
ProofArchived part_Icc_subq_Icc :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall i :e n, part_Icc p i c= Icc a b.

// Proof in 1777388823.mg
ProofArchived inf_on_ge_of_pointwise_ge :
  forall D, forall f : set -> set, forall m :e R,
    nonempty D ->
    bounded_fun D f ->
    (forall x :e D, m <= f x) ->
    m <= inf_on f D.

// Proof in 1777388823.mg
ProofArchived sup_on_le_of_pointwise_le :
  forall D, forall f : set -> set, forall M :e R,
    nonempty D ->
    bounded_fun D f ->
    (forall x :e D, f x <= M) ->
    sup_on f D <= M.

// Proof in 1777388823.mg
ProofArchived inf_on_Le_sup_on :
  forall D, forall f : set -> set,
    nonempty D ->
    bounded_fun D f ->
    inf_on f D <= sup_on f D.

// Proof in RealAnalysis1May042026a.mg
ProofArchived sup_on_le_of_pointwise_abs_le :
  forall D, forall f : set -> set, forall M :e R,
    nonempty D ->
    bounded_fun D f ->
    (forall x :e D, abs_SNo (f x) <= M) ->
    sup_on f D <= M.

// Proof in RealAnalysis1May042026a.mg
ProofArchived neg_bound_le_inf_on_of_pointwise_abs_le :
  forall D, forall f : set -> set, forall M :e R,
    nonempty D ->
    bounded_fun D f ->
    (forall x :e D, abs_SNo (f x) <= M) ->
    (- M) <= inf_on f D.

// Proof in RealAnalysis1May042026a.mg
ProofArchived osc_on_Le_of_pointwise_abs_le :
  forall D, forall f : set -> set, forall M :e R,
    nonempty D ->
    bounded_fun D f ->
    (forall x :e D, abs_SNo (f x) <= M) ->
    (sup_on f D) + (- (inf_on f D)) <= M + M.

(** Monotonicity of inf/sup under domain inclusion. **)
// Proof in 1777388823.mg
ProofArchived inf_on_mono_Subq :
  forall D E, forall f : set -> set,
    nonempty D ->
    nonempty E ->
    D c= E ->
    bounded_fun E f ->
    inf_on f E <= inf_on f D.

// Proof in 1777388823.mg
ProofArchived sup_on_mono_Subq :
  forall D E, forall f : set -> set,
    nonempty D ->
    nonempty E ->
    D c= E ->
    bounded_fun E f ->
    sup_on f D <= sup_on f E.

(** Pointwise equality on a domain induces equality of fimages and sup_on/inf_on values. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived fimage_eq_of_pointwise_eq :
  forall D, forall f g : set -> set,
    (forall x :e D, f x = g x) ->
    fimage f D = fimage g D.

// Proof in RealAnalysis1May042026a.mg
ProofArchived sup_on_eq_of_pointwise_eq :
  forall D, forall f g : set -> set,
    (forall x :e D, f x = g x) ->
    sup_on f D = sup_on g D.

// Proof in RealAnalysis1May042026a.mg
ProofArchived inf_on_eq_of_pointwise_eq :
  forall D, forall f g : set -> set,
    (forall x :e D, f x = g x) ->
    inf_on f D = inf_on g D.

(** Darboux terms satisfy lower <= upper (pointwise). **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived darboux_term_lower_Le_upper :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall i :e n, darboux_term_lower f p i <= darboux_term_upper f p i.

(** Darboux term gaps are nonnegative. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived darboux_term_gap_nonneg :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall i :e n,
      0 <= (darboux_term_upper f p i) + (- (darboux_term_lower f p i)).

(** real1.tex: Darboux sums satisfy lower <= upper. **)
// Proof in 1777388823.mg
ProofArchived darboux_sum_lower_Le_upper_seq :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    darboux_sum_lower_seq f n p <= darboux_sum_upper_seq f n p.

(** Refinements of partition sequences: the point-set of (n,p) is included in the point-set of (m,q). **)
//LLM partition_seq_refines_Icc : "the partition seq refines icc associated to #1" | $\mathrm{partition\_seq\_refines\_Icc}(#1,#2,#3,#4,#5,#6)$
Definition partition_seq_refines_Icc : set -> set -> set -> (set -> set) -> set -> (set -> set) -> prop :=
  fun a b n p m q =>
    is_partition_seq_Icc a b n p
    /\ is_partition_seq_Icc a b m q
    /\ (forall i :e ordsucc n, exists j :e ordsucc m, p i = q j).

(** If (m,q) refines (n,p), then each coarse subinterval endpoint occurs in q in the correct order. **)
// Proof in 1777388823.mg
ProofArchived partition_seq_refines_endpoints_order :
  forall a b n m, forall p q : set -> set,
    partition_seq_refines_Icc a b n p m q ->
    forall i :e n,
      exists j0 :e ordsucc m, exists j1 :e ordsucc m,
        p i = q j0 /\ p (ordsucc i) = q j1 /\ j0 :e j1.

(** If j is within the refinement block [j0, j1), then the fine subinterval lies in the coarse one. **)
// Proof in 1777388823.mg
ProofArchived part_Icc_refine_block_subq :
  forall a b n m, forall p q : set -> set,
    is_partition_seq_Icc a b n p ->
    is_partition_seq_Icc a b m q ->
    forall i :e n,
    forall j0 :e ordsucc m, forall j1 :e ordsucc m,
      p i = q j0 ->
      p (ordsucc i) = q j1 ->
      j0 :e j1 ->
      forall j :e m,
        j0 :e ordsucc j ->
        ordsucc j :e ordsucc j1 ->
        part_Icc q j c= part_Icc p i.

// Proof in 1777388823.mg
ProofArchived inf_on_refine_block_Le :
  forall a b n m, forall f p q : set -> set,
    is_partition_seq_Icc a b n p ->
    is_partition_seq_Icc a b m q ->
    bounded_fun (Icc a b) f ->
    forall i :e n,
    forall j0 :e ordsucc m, forall j1 :e ordsucc m,
      p i = q j0 ->
      p (ordsucc i) = q j1 ->
      j0 :e j1 ->
      forall j :e m,
        j0 :e ordsucc j ->
        ordsucc j :e ordsucc j1 ->
        inf_on f (part_Icc p i) <= inf_on f (part_Icc q j).

// Proof in 1777388823.mg
ProofArchived sup_on_refine_block_Le :
  forall a b n m, forall f p q : set -> set,
    is_partition_seq_Icc a b n p ->
    is_partition_seq_Icc a b m q ->
    bounded_fun (Icc a b) f ->
    forall i :e n,
    forall j0 :e ordsucc m, forall j1 :e ordsucc m,
      p i = q j0 ->
      p (ordsucc i) = q j1 ->
      j0 :e j1 ->
      forall j :e m,
        j0 :e ordsucc j ->
        ordsucc j :e ordsucc j1 ->
        sup_on f (part_Icc q j) <= sup_on f (part_Icc p i).

// Proof in 1777388823.mg
ProofArchived partition_seq_refines_points_Subq :
  forall a b n m, forall p q : set -> set,
    partition_seq_refines_Icc a b n p m q ->
    {p i | i :e ordsucc n} c= {q j | j :e ordsucc m}.

// Proof in 1777388823.mg
ProofArchived partition_seq_refines_Icc_refl :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    partition_seq_refines_Icc a b n p n p.

// Proof in 1777388823.mg
ProofArchived partition_seq_refines_Icc_trans :
  forall a b n m k, forall p q r : set -> set,
    partition_seq_refines_Icc a b n p m q ->
    partition_seq_refines_Icc a b m q k r ->
    partition_seq_refines_Icc a b n p k r.

(** real1.tex: Proposition (Refinement monotonicity of Darboux sums) for partition sequences. **)
// Proof in 1777388844.mg
ProofArchived darboux_term_lower_refine_block_Le :
  forall a b n m, forall f p q : set -> set,
    partition_seq_refines_Icc a b n p m q ->
    bounded_fun (Icc a b) f ->
    forall i :e n,
    forall j0 :e ordsucc m, forall j1 :e ordsucc m,
      p i = q j0 ->
      p (ordsucc i) = q j1 ->
      j0 :e j1 ->
      forall k :e omega,
        j1 = add_nat j0 k ->
        darboux_term_lower f p i <=
          partial_sum_seq (tail_series (fun t => darboux_term_lower f q t) j0) k.

// Proof in 1777388844.mg
ProofArchived darboux_term_upper_refine_block_Le :
  forall a b n m, forall f p q : set -> set,
    partition_seq_refines_Icc a b n p m q ->
    bounded_fun (Icc a b) f ->
    forall i :e n,
    forall j0 :e ordsucc m, forall j1 :e ordsucc m,
      p i = q j0 ->
      p (ordsucc i) = q j1 ->
      j0 :e j1 ->
      forall k :e omega,
        j1 = add_nat j0 k ->
        partial_sum_seq (tail_series (fun t => darboux_term_upper f q t) j0) k <=
          darboux_term_upper f p i.

// Proof in 1777388844.mg
ProofArchived darboux_sum_refinement_monotone_seq :
  forall a b n m, forall f p q : set -> set,
    partition_seq_refines_Icc a b n p m q ->
    bounded_fun (Icc a b) f ->
    darboux_sum_lower_seq f n p <= darboux_sum_lower_seq f m q
    /\ darboux_sum_upper_seq f m q <= darboux_sum_upper_seq f n p.

(** real1.tex (Integral chapter): lower/upper Darboux integrals are defined right after `sumulbound:prop`, **)
(** but in this file we place them here after the concrete `_seq` Darboux sum definitions. **)
//LLM lower_darboux_sums_Icc : "the lower darboux sums icc associated to #1" | $\mathrm{lower\_darboux\_sums\_Icc}(#1,#2,#3)$
Definition lower_darboux_sums_Icc : set -> set -> (set -> set) -> set :=
  fun a b f =>
    {s :e R |
      exists n :e omega, exists p : set -> set,
        is_partition_seq_Icc a b n p /\ s = darboux_sum_lower_seq f n p}.

//LLM upper_darboux_sums_Icc : "the upper darboux sums icc associated to #1" | $\mathrm{upper\_darboux\_sums\_Icc}(#1,#2,#3)$
Definition upper_darboux_sums_Icc : set -> set -> (set -> set) -> set :=
  fun a b f =>
    {s :e R |
      exists n :e omega, exists p : set -> set,
        is_partition_seq_Icc a b n p /\ s = darboux_sum_upper_seq f n p}.

//LLM lower_darboux_integral_Icc : "the lower darboux integral icc associated to #1" | $\int #1$
Definition lower_darboux_integral_Icc : set -> set -> (set -> set) -> set :=
  fun a b f => sup (lower_darboux_sums_Icc a b f).

//LLM upper_darboux_integral_Icc : "the upper darboux integral icc associated to #1" | $\int #1$
Definition upper_darboux_integral_Icc : set -> set -> (set -> set) -> set :=
  fun a b f => inf (upper_darboux_sums_Icc a b f).

//LLM riemann_integrable_Icc : "#1 is Riemann integrable on the closed interval from #2 to #3" | $\mathrm{riemann\_integrable\_Icc}(#1,#2,#3)$
Definition riemann_integrable_Icc : set -> set -> (set -> set) -> prop :=
  fun a b f =>
    bounded_fun (Icc a b) f
    /\ lower_darboux_integral_Icc a b f = upper_darboux_integral_Icc a b f.

(** By convention we take the Riemann integral (when it exists) to be this value; **)
(** for `riemann_integrable_Icc a b f` it will later be proved equal to both integrals. **)
//LLM riemann_integral_Icc : "the Riemann integral of #1 on the closed interval from #2 to #3" | $\int #1$
Definition riemann_integral_Icc : set -> set -> (set -> set) -> set :=
  fun a b f => lower_darboux_integral_Icc a b f.

(** The underlying point-set of a partition sequence (n,p). **)
//LLM partition_seq_points : "the partition seq points associated to #1" | $\mathrm{partition\_seq\_points}(#1,#2)$
Definition partition_seq_points : set -> (set -> set) -> set :=
  fun n p => {p i | i :e ordsucc n}.

(** Basic intro/elim lemmas for `partition_seq_points` (unfolds the `Repl` definition). **)
// Proof in 1777451057.mg
ProofArchived partition_seq_pointsI :
  forall n, forall p : set -> set,
  forall i :e ordsucc n,
    p i :e partition_seq_points n p.

// Proof in 1777451057.mg
ProofArchived partition_seq_pointsE :
  forall n, forall p : set -> set, forall y,
    y :e partition_seq_points n p ->
    exists i :e ordsucc n, y = p i.

(** Predecessor lemma inside a natural number: if j :e n and j <> 0, then j is a successor. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived nat_mem_ne0_imp_succ :
  forall n, nat_p n ->
  forall j :e n, j <> 0 ->
    exists j0 :e n, j = ordsucc j0.

(** Partition endpoints belong to their corresponding subinterval. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived part_Icc_mem_left_endpoint :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall i :e n, p i :e part_Icc p i.

// Proof in RealAnalysis1May042026a.mg
ProofArchived part_Icc_mem_right_endpoint :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall i :e n, p (ordsucc i) :e part_Icc p i.

(** If the left endpoint p 0 lies in part i, then i must be 0. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived part_Icc_mem_of_left_endpoint_imp_eq0 :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall i :e n,
      p 0 :e part_Icc p i ->
      i = 0.

(** If the right endpoint p n lies in part i, then i is the last index (ordsucc i = n). **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived part_Icc_mem_of_right_endpoint_imp_eq_last :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall i :e n,
      p n :e part_Icc p i ->
      ordsucc i = n.

(** If u and v are partition points with u < v, then their indices satisfy i_u :e i_v. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived partition_seq_points_lt_imp_exists_indices_mem :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall u v,
      u :e partition_seq_points n p ->
      v :e partition_seq_points n p ->
      u < v ->
      exists i0 :e ordsucc n, exists i1 :e ordsucc n,
        p i0 = u /\ p i1 = v /\ i0 :e i1.

(** If the point-set of (n,p) is included in the point-set of (m,q), then (m,q) refines (n,p). **)
// Proof in 1777454828.mg
ProofArchived partition_seq_refines_of_points_Subq :
  forall a b n m, forall p q : set -> set,
    is_partition_seq_Icc a b n p ->
    is_partition_seq_Icc a b m q ->
    partition_seq_points n p c= partition_seq_points m q ->
    partition_seq_refines_Icc a b n p m q.

(** If (m,q) refines (n,p), then every partition point of p also occurs in q. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived partition_seq_points_Subq_of_refines :
  forall a b n m, forall p q : set -> set,
    partition_seq_refines_Icc a b n p m q ->
    partition_seq_points n p c= partition_seq_points m q.

(** If x is a partition point with index in ordsucc n but x is not the right endpoint p n,
    then its index must lie in n. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived partition_seq_pointsE_in_n_of_neq_right_endpoint :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall x,
      x :e partition_seq_points n p ->
      x <> p n ->
      exists i :e n, x = p i.

(** If x is a partition point and x is not the left endpoint, then it has a nonzero index in ordsucc n. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived partition_seq_pointsE_index_ne0_of_neq_left_endpoint :
  forall n, forall p : set -> set,
    forall x,
      x :e partition_seq_points n p ->
      x <> p 0 ->
      exists i :e ordsucc n, x = p i /\ i <> 0.

(** If x is a partition point distinct from both endpoints p 0 and p n, then it has a nonzero index in n. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived partition_seq_pointsE_in_n_ne0_of_neq_endpoints :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall x,
      x :e partition_seq_points n p ->
      x <> p 0 ->
      x <> p n ->
      exists i :e n, x = p i /\ i <> 0.

(** Eliminator/constructor lemmas for Darboux-sum sets. **)
(** Placed immediately after the definitions so later proofs can use them without forward references. **)

(** Closedness: Darboux sums along a valid partition are real. **)
// Proof in 1777388844.mg
ProofArchived darboux_sum_lower_seq_closed :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    darboux_sum_lower_seq f n p :e R.

// Proof in 1777388844.mg
ProofArchived darboux_sum_upper_seq_closed :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    darboux_sum_upper_seq f n p :e R.

(** Eliminator for membership in the lower Darboux-sum set. **)
// Proof in 1777402252.mg
ProofArchived lower_darboux_sums_IccE :
  forall a b :e R, a <= b -> forall f : set -> set,
    forall s :e lower_darboux_sums_Icc a b f,
      exists n :e omega, exists p : set -> set,
        is_partition_seq_Icc a b n p /\ s = darboux_sum_lower_seq f n p.

(** Introduction lemma: a concrete lower Darboux sum lies in the lower-sum set. **)
// Proof in 1777404313.mg
ProofArchived lower_darboux_sums_IccI :
  forall a b :e R, a <= b -> forall f : set -> set,
    bounded_fun (Icc a b) f ->
    forall n :e omega, forall p : set -> set,
      is_partition_seq_Icc a b n p ->
      darboux_sum_lower_seq f n p :e lower_darboux_sums_Icc a b f.

(** Eliminator for membership in the upper Darboux-sum set. **)
// Proof in 1777404226.mg
ProofArchived upper_darboux_sums_IccE :
  forall a b :e R, a <= b -> forall f : set -> set,
    forall s :e upper_darboux_sums_Icc a b f,
      exists n :e omega, exists p : set -> set,
        is_partition_seq_Icc a b n p /\ s = darboux_sum_upper_seq f n p.

(** Introduction lemma: a concrete upper Darboux sum lies in the upper-sum set. **)
// Proof in 1777404278.mg
ProofArchived upper_darboux_sums_IccI :
  forall a b :e R, a <= b -> forall f : set -> set,
    bounded_fun (Icc a b) f ->
    forall n :e omega, forall p : set -> set,
      is_partition_seq_Icc a b n p ->
      darboux_sum_upper_seq f n p :e upper_darboux_sums_Icc a b f.

(** Darboux data is invariant under pointwise equality on Icc a b. **)

// Proof in RealAnalysis1May042026a.mg
ProofArchived darboux_term_lower_eq_of_pointwise_eq_Icc :
  forall a b n, forall f g p : set -> set,
    is_partition_seq_Icc a b n p ->
    (forall x :e Icc a b, f x = g x) ->
    forall i :e n,
      darboux_term_lower f p i = darboux_term_lower g p i.

(** A variant: if f=g on Icc a b except possibly at c, and c is not in the subinterval,
    then the Darboux term agrees. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived darboux_term_lower_eq_of_eq_off_singleton_Icc :
  forall a b n, forall f g p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall c :e Icc a b,
      (forall x :e Icc a b, x <> c -> f x = g x) ->
      forall i :e n,
        c /:e part_Icc p i ->
        darboux_term_lower f p i = darboux_term_lower g p i.

// Proof in RealAnalysis1May042026a.mg
ProofArchived darboux_term_upper_eq_of_pointwise_eq_Icc :
  forall a b n, forall f g p : set -> set,
    is_partition_seq_Icc a b n p ->
    (forall x :e Icc a b, f x = g x) ->
    forall i :e n,
      darboux_term_upper f p i = darboux_term_upper g p i.

// Proof in RealAnalysis1May042026a.mg
ProofArchived darboux_term_upper_eq_of_eq_off_singleton_Icc :
  forall a b n, forall f g p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall c :e Icc a b,
      (forall x :e Icc a b, x <> c -> f x = g x) ->
      forall i :e n,
        c /:e part_Icc p i ->
        darboux_term_upper f p i = darboux_term_upper g p i.

// Proof in RealAnalysis1May042026a.mg
ProofArchived darboux_sum_lower_seq_eq_of_pointwise_eq_Icc :
  forall a b n, forall f g p : set -> set,
    is_partition_seq_Icc a b n p ->
    (forall x :e Icc a b, f x = g x) ->
    darboux_sum_lower_seq f n p = darboux_sum_lower_seq g n p.

// Proof in RealAnalysis1May042026a.mg
ProofArchived darboux_sum_upper_seq_eq_of_pointwise_eq_Icc :
  forall a b n, forall f g p : set -> set,
    is_partition_seq_Icc a b n p ->
    (forall x :e Icc a b, f x = g x) ->
    darboux_sum_upper_seq f n p = darboux_sum_upper_seq g n p.

// Proof in RealAnalysis1May042026a.mg
ProofArchived lower_darboux_sums_Icc_eq_of_pointwise_eq :
  forall a b :e R, a <= b -> forall f g : set -> set,
    bounded_fun (Icc a b) f ->
    (forall x :e Icc a b, f x = g x) ->
    lower_darboux_sums_Icc a b f = lower_darboux_sums_Icc a b g.

// Proof in RealAnalysis1May042026a.mg
ProofArchived upper_darboux_sums_Icc_eq_of_pointwise_eq :
  forall a b :e R, a <= b -> forall f g : set -> set,
    bounded_fun (Icc a b) f ->
    (forall x :e Icc a b, f x = g x) ->
    upper_darboux_sums_Icc a b f = upper_darboux_sums_Icc a b g.

// Proof in RealAnalysis1May042026a.mg
ProofArchived lower_darboux_integral_Icc_eq_of_pointwise_eq :
  forall a b :e R, a <= b -> forall f g : set -> set,
    bounded_fun (Icc a b) f ->
    (forall x :e Icc a b, f x = g x) ->
    lower_darboux_integral_Icc a b f = lower_darboux_integral_Icc a b g.

// Proof in RealAnalysis1May042026a.mg
ProofArchived upper_darboux_integral_Icc_eq_of_pointwise_eq :
  forall a b :e R, a <= b -> forall f g : set -> set,
    bounded_fun (Icc a b) f ->
    (forall x :e Icc a b, f x = g x) ->
    upper_darboux_integral_Icc a b f = upper_darboux_integral_Icc a b g.

// Proof in RealAnalysis1May042026a.mg
ProofArchived riemann_integrable_Icc_of_pointwise_eq :
  forall a b :e R, a <= b -> forall f g : set -> set,
    riemann_integrable_Icc a b f ->
    (forall x :e Icc a b, f x = g x) ->
    riemann_integrable_Icc a b g
    /\ riemann_integral_Icc a b g = riemann_integral_Icc a b f.

// Proof in 1777388823.mg
ProofArchived partition_seq_points_finite :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    finite (partition_seq_points n p).

// Proof in 1777388823.mg
ProofArchived partition_seq_points_mem_0 :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    p 0 :e partition_seq_points n p.

// Proof in 1777388823.mg
ProofArchived partition_seq_points_mem_n :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    p n :e partition_seq_points n p.

(** Endpoint of a concatenated partition sequence: the last point is the last point of q. **)
// Proof in 1777418860.mg
ProofArchived concat_partition_seq_fun_last :
  forall a b c :e R,
  forall n m, forall p q : set -> set,
    is_partition_seq_Icc a c n p ->
    is_partition_seq_Icc c b m q ->
    concat_partition_seq_fun n p m q (add_nat n m) = b.

// Proof in 1777388844.mg
ProofArchived partition_seq_points_subq_Icc :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    partition_seq_points n p c= Icc a b.

// Proof in 1777388844.mg
ProofArchived partition_seq_points_is_partition_Icc :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    is_partition_Icc a b (partition_seq_points n p).

(** Adjoining an interior point to the point-set of a partition sequence yields a set-partition. **)
// Proof in 1777451098.mg
ProofArchived partition_seq_points_adjoin_is_partition_Icc :
  forall a c n, forall p : set -> set,
    is_partition_seq_Icc a c n p ->
    forall b :e Icc a c,
      is_partition_Icc a c (partition_seq_points n p :\/: {b}).

// Proof in 1777388844.mg
ProofArchived partition_Icc_mem_bounds :
  forall a b P, is_partition_Icc a b P ->
  forall x :e P, a <= x /\ x <= b.

// Proof in 1777388844.mg
ProofArchived partition_Icc_all_SNo :
  forall a b P, is_partition_Icc a b P ->
  forall x :e P, SNo x.

// Proof in 1777388844.mg
ProofArchived partition_Icc_a_is_min_of :
  forall a b P, is_partition_Icc a b P ->
  SNo_min_of P a.

// Proof in 1777388844.mg
ProofArchived partition_Icc_b_is_max_of :
  forall a b P, is_partition_Icc a b P ->
  SNo_max_of P b.

// Proof in 1777388844.mg
ProofArchived partition_Icc_min_eq_a :
  forall a b P, is_partition_Icc a b P ->
  forall x, SNo_min_of P x -> x = a.

// Proof in 1777388844.mg
ProofArchived partition_Icc_max_eq_b :
  forall a b P, is_partition_Icc a b P ->
  forall x, SNo_max_of P x -> x = b.

// Proof in 1777388844.mg
ProofArchived partition_Icc_min_exists :
  forall a b P, is_partition_Icc a b P ->
  exists x, SNo_min_of P x.

// Proof in 1777388844.mg
ProofArchived partition_Icc_max_exists :
  forall a b P, is_partition_Icc a b P ->
  exists x, SNo_max_of P x.

// Proof in 1777388844.mg
ProofArchived equip_SNo_set_strict_enum :
  forall n, nat_p n ->
  forall X,
    (forall x :e X, SNo x) ->
    equip X (ordsucc n) ->
    X <> 0 ->
    exists p : set -> set,
      ((forall i :e ordsucc n, p i :e X)
       /\ (forall i :e n, p i < p (ordsucc i))
       /\ (forall x :e X, exists i :e ordsucc n, p i = x))
      /\ SNo_min_of X (p 0)
      /\ SNo_max_of X (p n).

// Proof in 1777391384.mg
ProofArchived exists_partition_seq_of_partition_Icc :
  forall a b P,
    is_partition_Icc a b P ->
    exists n :e omega, exists p : set -> set,
      is_partition_seq_Icc a b n p /\ partition_seq_points n p = P.

(** From a partition sequence, adjoin a point and convert back to a refining partition sequence. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived exists_partition_seq_Icc_refining_adjoin_point :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall c :e Icc a b,
      exists m :e omega, exists q : set -> set,
        partition_seq_refines_Icc a b n p m q
        /\ c :e partition_seq_points m q.

(** A convenience wrapper: adjoin two points to a partition sequence, producing a common refinement that contains both. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived exists_partition_seq_Icc_refining_adjoin_two_points :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall c1 :e Icc a b,
    forall c2 :e Icc a b,
      exists m :e omega, exists q : set -> set,
        partition_seq_refines_Icc a b n p m q
        /\ c1 :e partition_seq_points m q
        /\ c2 :e partition_seq_points m q.

End form76.

Section form77.

(** Restrict an R-valued function to a subset. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived R_fun_subq :
  forall D E, forall f : set -> set,
    R_fun D f ->
    E c= D ->
    R_fun E f.

(** Restrict a bounded function to a subset. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived bounded_fun_subq :
  forall D E, forall f : set -> set,
    bounded_fun D f ->
    E c= D ->
    bounded_fun E f.

(** Restrict boundedness to a partition subinterval. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived bounded_fun_part_Icc :
  forall a b n, forall p : set -> set, forall f : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall i :e n,
      bounded_fun (part_Icc p i) f.

// Proof in 1777388844.mg
ProofArchived bounded_fun_add :
  forall D, forall f g : set -> set,
    bounded_fun D f ->
    bounded_fun D g ->
    bounded_fun D (fun x => (f x) + (g x)).

// Proof in 1777388844.mg
ProofArchived bounded_fun_scale :
  forall D, forall f : set -> set, bounded_fun D f ->
  forall alpha :e R,
    bounded_fun D (fun x => alpha * (f x)).

// Proof in 1777388844.mg
ProofArchived inf_on_add_Le :
  forall D, nonempty D ->
  forall f g : set -> set,
    bounded_fun D f ->
    bounded_fun D g ->
    (inf_on f D) + (inf_on g D) <= inf_on (fun x => (f x) + (g x)) D.

// Proof in 1777388844.mg
ProofArchived sup_on_add_Le :
  forall D, nonempty D ->
  forall f g : set -> set,
    bounded_fun D f ->
    bounded_fun D g ->
    sup_on (fun x => (f x) + (g x)) D <= (sup_on f D) + (sup_on g D).

(** Minkowski sum of two sets of reals (used in integral additivity/linearity proofs). **)
//LLM add_set : "the add set associated to #1" | $#1 + #2$
Definition add_set : set -> set -> set :=
  fun A B => (\/_ a :e A, add_const_set a B).

(** Substitute an equality on the right side of <=. **)
// Proof in 1777436708.mg
ProofArchived SNoLe_eq_substR :
  forall x y z,
    SNo x ->
    SNo y ->
    SNo z ->
    x = y ->
    z <= x ->
    z <= y.

// Proof in 1777398192.mg
ProofArchived sup_add_set :
  forall A B,
    A c= R ->
    B c= R ->
    has_lub A ->
    has_lub B ->
    sup (add_set A B) = (sup A) + (sup B).

(** Infimum of a Minkowski sum: inf(A+B) = inf(A)+inf(B), assuming both infima exist. **)
// Proof in 1777420733.mg
ProofArchived inf_add_set :
  forall A B,
    A c= R ->
    B c= R ->
    nonempty A ->
    nonempty B ->
    has_glb A ->
    has_glb B ->
    inf (add_set A B) = (inf A) + (inf B).

// Proof in 1777434587.mg
ProofArchived sup_mono_Subq :
  forall S T,
    S c= T ->
    has_lub S ->
    has_lub T ->
    sup S <= sup T.

// Proof in 1777434587.mg
ProofArchived inf_mono_Subq :
  forall S T,
    S c= T ->
    has_glb S ->
    has_glb T ->
    inf T <= inf S.

(** real1.tex: exercise:dominatingb (supremum/infimum under domination by a subset). **)
// Proof in 1777448505.mg
ProofArchived sup_eq_of_dominating_subset :
  forall A B,
    A c= R ->
    B c= A ->
    has_lub A ->
    has_lub B ->
    (forall x :e A, exists y :e B, x <= y) ->
    sup B = sup A.

// Proof in 1777448505.mg
ProofArchived inf_eq_of_dominating_subset :
  forall A B,
    A c= R ->
    B c= A ->
    has_glb A ->
    has_glb B ->
    (forall x :e A, exists y :e B, y <= x) ->
    inf B = inf A.

(** Scaling lemmas for Darboux sums along a fixed partition sequence. **)
(** These are used to relate lower/upper sums under negation when proving additivity. **)
// Proof in 1777407807.mg
ProofArchived darboux_sum_lower_seq_scale_neg :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall alpha :e R, alpha < 0 ->
      darboux_sum_lower_seq (fun x => alpha * (f x)) n p
        = alpha * (darboux_sum_upper_seq f n p).

// Proof in 1777407807.mg
ProofArchived darboux_sum_upper_seq_scale_neg :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall alpha :e R, alpha < 0 ->
      darboux_sum_upper_seq (fun x => alpha * (f x)) n p
        = alpha * (darboux_sum_lower_seq f n p).

(** real1.tex: lower/upper Darboux sums on adjacent intervals combine by concatenating partitions. **)
(** This is one direction needed for additivity of Darboux integrals via `sup_add_set`/`inf_add_set`. **)
// Proof in 1777447215.mg
ProofArchived lower_darboux_sums_Icc_add_set_Subq_concat :
  forall a b c :e R, a <= b -> b <= c ->
  forall f : set -> set,
    bounded_fun (Icc a c) f ->
    add_set (lower_darboux_sums_Icc a b f) (lower_darboux_sums_Icc b c f)
      c= lower_darboux_sums_Icc a c f.

(** If a partition sequence q of [a,c] contains b among its points, then its lower Darboux sum **)
(** is in the Minkowski sum of lower Darboux sums on [a,b] and [b,c]. **)
// Proof in 1777462086.mg
ProofArchived lower_darboux_sum_lower_seq_mem_add_set_of_contains_b :
  forall a b c :e R, a <= b -> b <= c ->
  forall f : set -> set,
    bounded_fun (Icc a c) f ->
    forall m :e omega, forall q : set -> set,
      is_partition_seq_Icc a c m q ->
      b :e partition_seq_points m q ->
      darboux_sum_lower_seq f m q
        :e add_set (lower_darboux_sums_Icc a b f) (lower_darboux_sums_Icc b c f).

(** Upper-sum analogue of `lower_darboux_sum_lower_seq_mem_add_set_of_contains_b`. **)
(** If a partition sequence q of [a,c] contains b among its points, then its upper Darboux sum **)
(** is in the Minkowski sum of upper Darboux sums on [a,b] and [b,c]. **)
// Proof in 1777467005.mg
ProofArchived upper_darboux_sum_upper_seq_mem_add_set_of_contains_b :
  forall a b c :e R, a <= b -> b <= c ->
  forall f : set -> set,
    bounded_fun (Icc a c) f ->
    forall m :e omega, forall q : set -> set,
      is_partition_seq_Icc a c m q ->
      b :e partition_seq_points m q ->
      darboux_sum_upper_seq f m q
        :e add_set (upper_darboux_sums_Icc a b f) (upper_darboux_sums_Icc b c f).

(** Reverse-direction ingredient for the other inequality in Darboux additivity: **)
(** the add_set-sums (i.e. partitions that contain b) dominate all lower Darboux sums on [a,c] **)
(** via refinement by adjoining b. **)
// Proof in 1777462191.mg
ProofArchived lower_darboux_sums_Icc_dominated_by_add_set_adjoin :
  forall a b c :e R, a <= b -> b <= c ->
  forall f : set -> set,
    bounded_fun (Icc a c) f ->
    forall s :e lower_darboux_sums_Icc a c f,
      exists t :e add_set (lower_darboux_sums_Icc a b f) (lower_darboux_sums_Icc b c f),
        s <= t.

// Proof in 1777447307.mg
ProofArchived upper_darboux_sums_Icc_add_set_Subq_concat :
  forall a b c :e R, a <= b -> b <= c ->
  forall f : set -> set,
    bounded_fun (Icc a c) f ->
    add_set (upper_darboux_sums_Icc a b f) (upper_darboux_sums_Icc b c f)
      c= upper_darboux_sums_Icc a c f.

(** Dual domination property for upper sums: adjoining b refines a partition and decreases U(Q,f), **)
(** so the add_set-sums dominate all upper Darboux sums from below. **)
// Proof in 1777467368.mg
ProofArchived upper_darboux_sums_Icc_dominated_by_add_set_adjoin :
  forall a b c :e R, a <= b -> b <= c ->
  forall f : set -> set,
    bounded_fun (Icc a c) f ->
    forall s :e upper_darboux_sums_Icc a c f,
      exists t :e add_set (upper_darboux_sums_Icc a b f) (upper_darboux_sums_Icc b c f),
        t <= s.

(** Basic closure properties of Minkowski sums (used when applying the lub/glb property of R). **)
// Proof in 1777423595.mg
ProofArchived add_set_subq_R :
  forall A B,
    A c= R ->
    B c= R ->
    add_set A B c= R.

// Proof in 1777424172.mg
ProofArchived add_set_nonempty :
  forall A B,
    nonempty A ->
    nonempty B ->
    nonempty (add_set A B).

// Proof in 1777424484.mg
ProofArchived add_set_bounded_above :
  forall A B,
    A c= R ->
    B c= R ->
    bounded_above A ->
    bounded_above B ->
    bounded_above (add_set A B).

// Proof in 1777424745.mg
ProofArchived add_set_bounded_below :
  forall A B,
    A c= R ->
    B c= R ->
    bounded_below A ->
    bounded_below B ->
    bounded_below (add_set A B).

// Proof in 1777424799.mg
ProofArchived has_lub_add_set :
  forall A B,
    A c= R ->
    B c= R ->
    nonempty A ->
    nonempty B ->
    bounded_above A ->
    bounded_above B ->
    has_lub (add_set A B).

// Proof in 1777424799.mg
ProofArchived has_glb_add_set :
  forall A B,
    A c= R ->
    B c= R ->
    nonempty A ->
    nonempty B ->
    bounded_below A ->
    bounded_below B ->
    has_glb (add_set A B).

(** Scaling of images and sup/inf-on (used for Riemann integral scaling later). **)
(** Note: these lemmas logically belong near form34 (bounded functions), but are placed here to avoid **)
(** editing earlier parts of the file. **)

// Proof in 1777406882.mg
ProofArchived fimage_scale :
  forall D, forall f : set -> set, forall alpha :e R,
    fimage (fun x => alpha * (f x)) D = mul_const_set alpha (fimage f D).

// Proof in 1777406882.mg
ProofArchived sup_on_scale_pos :
  forall D, nonempty D ->
  forall f : set -> set, bounded_fun D f ->
  forall alpha :e R, 0 < alpha ->
    sup_on (fun x => alpha * (f x)) D = alpha * (sup_on f D).

// Proof in 1777406882.mg
ProofArchived inf_on_scale_pos :
  forall D, nonempty D ->
  forall f : set -> set, bounded_fun D f ->
  forall alpha :e R, 0 < alpha ->
    inf_on (fun x => alpha * (f x)) D = alpha * (inf_on f D).

// Proof in 1777406882.mg
ProofArchived sup_on_scale_neg :
  forall D, nonempty D ->
  forall f : set -> set, bounded_fun D f ->
  forall alpha :e R, alpha < 0 ->
    sup_on (fun x => alpha * (f x)) D = alpha * (inf_on f D).

// Proof in 1777406882.mg
ProofArchived inf_on_scale_neg :
  forall D, nonempty D ->
  forall f : set -> set, bounded_fun D f ->
  forall alpha :e R, alpha < 0 ->
    inf_on (fun x => alpha * (f x)) D = alpha * (sup_on f D).

(** Scaling Darboux terms along a partition (uses the `sup_on`/`inf_on` scaling lemmas above). **)
// Proof in 1777407214.mg
ProofArchived darboux_term_lower_scale_pos :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall alpha :e R, 0 < alpha ->
    forall i :e n,
      darboux_term_lower (fun x => alpha * (f x)) p i = alpha * (darboux_term_lower f p i).

// Proof in 1777407214.mg
ProofArchived darboux_term_upper_scale_pos :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall alpha :e R, 0 < alpha ->
    forall i :e n,
      darboux_term_upper (fun x => alpha * (f x)) p i = alpha * (darboux_term_upper f p i).

// Proof in 1777407214.mg
ProofArchived darboux_term_lower_scale_neg :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall alpha :e R, alpha < 0 ->
    forall i :e n,
      darboux_term_lower (fun x => alpha * (f x)) p i = alpha * (darboux_term_upper f p i).

// Proof in 1777407214.mg
ProofArchived darboux_term_upper_scale_neg :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall alpha :e R, alpha < 0 ->
    forall i :e n,
      darboux_term_upper (fun x => alpha * (f x)) p i = alpha * (darboux_term_lower f p i).

// Proof in 1777388844.mg
ProofArchived riemann_integrable_Icc_imp_bounded_fun :
  forall a b, forall f : set -> set,
    riemann_integrable_Icc a b f ->
    bounded_fun (Icc a b) f.

// Proof in 1777388844.mg
ProofArchived riemann_integrable_Icc_imp_integral_eq_upper :
  forall a b, forall f : set -> set,
    riemann_integrable_Icc a b f ->
    riemann_integral_Icc a b f = upper_darboux_integral_Icc a b f.

// Proof in 1777388844.mg
ProofArchived exists_partition_seq_Icc :
  forall a b :e R, a <= b ->
  exists n :e omega, exists p : set -> set, is_partition_seq_Icc a b n p.

(** Basic facts about Darboux sums and the Darboux-sum sets. **)

// Proof in 1777388844.mg
ProofArchived lower_darboux_sums_Icc_subq_R :
  forall a b, forall f : set -> set,
    lower_darboux_sums_Icc a b f c= R.

// Proof in 1777388844.mg
ProofArchived upper_darboux_sums_Icc_subq_R :
  forall a b, forall f : set -> set,
    upper_darboux_sums_Icc a b f c= R.

(** Scaling Darboux sums for a fixed partition sequence. **)
(** These are used later to scale the Darboux-sum sets and hence the Darboux integrals. **)

// Proof in 1777407807.mg
ProofArchived darboux_sum_lower_seq_scale_pos :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall alpha :e R, 0 < alpha ->
      darboux_sum_lower_seq (fun x => alpha * (f x)) n p
        = alpha * (darboux_sum_lower_seq f n p).

// Proof in 1777407807.mg
ProofArchived darboux_sum_upper_seq_scale_pos :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall alpha :e R, 0 < alpha ->
      darboux_sum_upper_seq (fun x => alpha * (f x)) n p
        = alpha * (darboux_sum_upper_seq f n p).

// Proof in 1777388844.mg
ProofArchived darboux_sum_lower_seq_Le_of_pointwise_Le :
  forall a b n, forall f g p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
bounded_fun (Icc a b) g ->
(forall x :e Icc a b, f x <= g x) ->
darboux_sum_lower_seq f n p <= darboux_sum_lower_seq g n p.

(** Additivity inequalities for Darboux sums (fixed partition sequence). **)
(** These are the basic ingredients for integral linearity. **)

// Proof in 1777400108.mg
ProofArchived darboux_sum_lower_seq_add_Le :
  forall a b n, forall f g p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    bounded_fun (Icc a b) g ->
    darboux_sum_lower_seq f n p + darboux_sum_lower_seq g n p
      <= darboux_sum_lower_seq (fun x => (f x) + (g x)) n p.

// Proof in 1777400108.mg
ProofArchived darboux_sum_upper_seq_add_Le :
  forall a b n, forall f g p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    bounded_fun (Icc a b) g ->
    darboux_sum_upper_seq (fun x => (f x) + (g x)) n p
      <= darboux_sum_upper_seq f n p + darboux_sum_upper_seq g n p.

(** Helper lemmas for the lower Darboux-sum set (needed for integral monotonicity). **)

// Proof in 1777388844.mg
ProofArchived lower_darboux_sums_Icc_nonempty :
  forall a b :e R, a <= b -> forall f : set -> set,
    bounded_fun (Icc a b) f ->
    nonempty (lower_darboux_sums_Icc a b f).

(** Nonemptiness of the upper Darboux-sum set (parallel to `lower_darboux_sums_Icc_nonempty`). **)

// Proof in 1777388844.mg
ProofArchived upper_darboux_sums_Icc_nonempty :
  forall a b :e R, a <= b -> forall f : set -> set,
    bounded_fun (Icc a b) f ->
    nonempty (upper_darboux_sums_Icc a b f).

(** A (currently admitted) common-refinement lemma for partition sequences. **)
(** real1.tex: used implicitly when comparing Darboux sums from two different partitions. **)

// Proof in 1777391384.mg
ProofArchived exists_partition_seq_common_refinement_Icc :
  forall a b :e R, a <= b ->
  forall n m, forall p q : set -> set,
    is_partition_seq_Icc a b n p ->
    is_partition_seq_Icc a b m q ->
    exists k :e omega, exists r : set -> set,
      partition_seq_refines_Icc a b n p k r
      /\ partition_seq_refines_Icc a b m q k r.

(** Any lower Darboux sum is <= any upper Darboux sum (via a common refinement). **)

// Proof in 1777391384.mg
ProofArchived lower_darboux_sums_Icc_Le_upper_darboux_sums_Icc :
  forall a b :e R, a <= b -> forall f : set -> set,
    bounded_fun (Icc a b) f ->
    forall s :e lower_darboux_sums_Icc a b f,
    forall t :e upper_darboux_sums_Icc a b f,
      s <= t.

(** Boundedness-below and existence of an infimum for upper Darboux-sum sets. **)
(** We obtain a glb by applying the lub property to the negated set. **)

// Proof in 1777400808.mg
ProofArchived upper_darboux_sums_Icc_has_glb :
  forall a b :e R, a <= b -> forall f : set -> set,
    bounded_fun (Icc a b) f ->
    has_glb (upper_darboux_sums_Icc a b f).

// Proof in 1777400808.mg
ProofArchived upper_darboux_sums_Icc_bounded_below :
  forall a b :e R, a <= b -> forall f : set -> set,
    bounded_fun (Icc a b) f ->
    bounded_below (upper_darboux_sums_Icc a b f).

(** Upper Darboux integral is a real number under the standard boundedness hypotheses. **)
// Proof in 1777482864.mg
ProofArchived upper_darboux_integral_Icc_in_R :
  forall a b :e R, a <= b -> forall f : set -> set,
    bounded_fun (Icc a b) f ->
    upper_darboux_integral_Icc a b f :e R.

(** Existence of a lub for the lower Darboux-sum set (used for the lower Darboux integral). **)
// Proof in 1777388844.mg
ProofArchived lower_darboux_sums_Icc_has_lub :
  forall a b :e R, a <= b -> forall f : set -> set,
    bounded_fun (Icc a b) f ->
    has_lub (lower_darboux_sums_Icc a b f).

(** As a corollary, lower Darboux integral is <= upper Darboux integral (for any bounded function). **)

// Proof in 1777391415.mg
ProofArchived lower_darboux_integral_Icc_Le_upper_darboux_integral_Icc :
  forall a b :e R, a <= b -> forall f : set -> set,
    bounded_fun (Icc a b) f ->
    lower_darboux_integral_Icc a b f <= upper_darboux_integral_Icc a b f.

// Proof in 1777388844.mg
ProofArchived lower_darboux_sums_Icc_bounded_above :
  forall a b :e R, a <= b -> forall f : set -> set,
    bounded_fun (Icc a b) f ->
    bounded_above (lower_darboux_sums_Icc a b f).

(** Lower Darboux integral is a real number under the standard boundedness hypotheses. **)
// Proof in 1777482864.mg
ProofArchived lower_darboux_integral_Icc_in_R :
  forall a b :e R, a <= b -> forall f : set -> set,
    bounded_fun (Icc a b) f ->
    lower_darboux_integral_Icc a b f :e R.

(** If f is Riemann integrable on [a,b] (with a<=b), then the integral value is a real. **)
// Proof in 1777482780.mg
ProofArchived riemann_integrable_Icc_imp_integral_in_R :
  forall a b :e R, a <= b ->
  forall f : set -> set,
    riemann_integrable_Icc a b f ->
    riemann_integral_Icc a b f :e R.

(** Convenience: under integrability, both Darboux integrals are real numbers. **)
// Proof in 1777482982.mg
ProofArchived riemann_integrable_Icc_imp_darboux_integrals_in_R :
  forall a b :e R, a <= b ->
  forall f : set -> set,
    riemann_integrable_Icc a b f ->
    lower_darboux_integral_Icc a b f :e R
    /\ upper_darboux_integral_Icc a b f :e R.

(** Scaling of Darboux-sum sets (positive/negative scalar cases). **)
// Proof in 1777408132.mg
ProofArchived lower_darboux_sums_Icc_scale_pos :
forall a b :e R, a <= b ->
forall f : set -> set, bounded_fun (Icc a b) f ->
forall alpha :e R, 0 < alpha ->
lower_darboux_sums_Icc a b (fun x => alpha * (f x))
= mul_const_set alpha (lower_darboux_sums_Icc a b f).

// Proof in 1777408132.mg
ProofArchived upper_darboux_sums_Icc_scale_pos :
  forall a b :e R, a <= b ->
  forall f : set -> set, bounded_fun (Icc a b) f ->
  forall alpha :e R, 0 < alpha ->
    upper_darboux_sums_Icc a b (fun x => alpha * (f x))
      = mul_const_set alpha (upper_darboux_sums_Icc a b f).

// Proof in 1777408780.mg
ProofArchived lower_darboux_sums_Icc_scale_neg :
  forall a b :e R, a <= b ->
  forall f : set -> set, bounded_fun (Icc a b) f ->
  forall alpha :e R, alpha < 0 ->
    lower_darboux_sums_Icc a b (fun x => alpha * (f x))
      = mul_const_set alpha (upper_darboux_sums_Icc a b f).

// Proof in 1777408780.mg
ProofArchived upper_darboux_sums_Icc_scale_neg :
  forall a b :e R, a <= b ->
  forall f : set -> set, bounded_fun (Icc a b) f ->
  forall alpha :e R, alpha < 0 ->
    upper_darboux_sums_Icc a b (fun x => alpha * (f x))
      = mul_const_set alpha (lower_darboux_sums_Icc a b f).

(** Helper: bounded_below S implies bounded_above (neg_set S) for subsets of R. **)
// Proof in 1777404483.mg
ProofArchived bounded_above_neg_set_of_bounded_below :
  forall S,
    S c= R ->
    bounded_below S ->
    bounded_above (neg_set S).

(** Helper: if S has a glb and is nonempty, then neg_set S has a lub. **)
// Proof in 1777404574.mg
ProofArchived has_lub_neg_set_of_has_glb :
  forall S,
    S c= R ->
    nonempty S ->
    has_glb S ->
    has_lub (neg_set S).

(** Lower Darboux integrals are superadditive: L(f)+L(g) <= L(f+g). **)
// Proof in 1777402252.mg
ProofArchived lower_darboux_integral_Icc_add_Le :
  forall a b :e R, a <= b -> forall f g : set -> set,
    bounded_fun (Icc a b) f ->
bounded_fun (Icc a b) g ->
lower_darboux_integral_Icc a b f + lower_darboux_integral_Icc a b g
<= lower_darboux_integral_Icc a b (fun x => (f x) + (g x)).

(** Upper Darboux integrals are subadditive: U(f+g) <= U(f)+U(g). **)
(** real1.tex: this is the upper-integral counterpart needed for Riemann integral linearity. **)
// Proof in 1777405516.mg
ProofArchived upper_darboux_integral_Icc_add_Le :
  forall a b :e R, a <= b -> forall f g : set -> set,
    bounded_fun (Icc a b) f ->
    bounded_fun (Icc a b) g ->
    upper_darboux_integral_Icc a b (fun x => (f x) + (g x))
      <= upper_darboux_integral_Icc a b f + upper_darboux_integral_Icc a b g.

(** Riemann integrability is closed under addition (uses Darboux integral inequalities). **)
// Proof in 1777405562.mg
ProofArchived riemann_integrable_Icc_add :
  forall a b :e R, a <= b -> forall f g : set -> set,
    riemann_integrable_Icc a b f ->
    riemann_integrable_Icc a b g ->
    riemann_integrable_Icc a b (fun x => (f x) + (g x)).

(** Riemann integral additivity on a fixed interval (derived from `riemann_integrable_Icc_add`). **)
// Proof in 1777406322.mg
ProofArchived riemann_integral_Icc_add :
  forall a b :e R, a <= b -> forall f g : set -> set,
    riemann_integrable_Icc a b f ->
    riemann_integrable_Icc a b g ->
    riemann_integral_Icc a b (fun x => (f x) + (g x))
      = riemann_integral_Icc a b f + riemann_integral_Icc a b g.

(** Partial sums of the constant-zero sequence. **)
// Proof in 1777412226.mg
ProofArchived partial_sum_seq_const0 :
  forall n, nat_p n -> partial_sum_seq (fun _ : set => 0) n = 0.

(** Basic numeric inequality used frequently: 1/2 < 1. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived recip_SNo_2_lt_1 : recip_SNo 2 < 1.

(** For x>0, we have x/2 < x. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived half_lt_self_pos :
  forall x :e R, 0 < x -> x :/: 2 < x.

(** For x<0, we have x < x/2. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived half_gt_self_neg :
  forall x :e R, x < 0 -> x < x :/: 2.

// Proof in RealAnalysis1May042026a.mg
ProofArchived continuous_at_nbhd_pos :
  forall f : set -> set, forall S c,
    continuous_at f S c ->
    0 < f c ->
    exists delta :e R, 0 < delta
      /\ forall x :e S, dist_R x c < delta -> 0 < f x.

// Proof in RealAnalysis1May042026a.mg
ProofArchived continuous_at_nbhd_neg :
  forall f : set -> set, forall S c,
    continuous_at f S c ->
    f c < 0 ->
    exists delta :e R, 0 < delta
      /\ forall x :e S, dist_R x c < delta -> f x < 0.

(** If a real sequence converges to a nonzero limit, then it is eventually nonzero. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived seq_limit_eventually_nonzero_of_limit_ne0 :
  forall x : set -> set, forall l,
    seq_limit x l ->
    l <> 0 ->
    exists N :e omega, forall n :e omega, N <= n -> x n <> 0.

(** A finite real-valued function image is bounded in absolute value. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived finite_R_fun_abs_bounded :
  forall S, finite S ->
  forall g : set -> set,
    R_fun S g ->
    exists M :e R,
      0 <= M
      /\ forall x :e S, abs_SNo (g x) <= M.

(** Cluster point infrastructure for open domains (used to restrict derivatives). **)

// Proof in 1777497924.mg
ProofArchived cluster_point_R :
  forall c :e R, cluster_point R c.

// Proof in 1777497924.mg
ProofArchived cluster_point_Ioi0 :
  forall c :e Ioi 0, cluster_point (Ioi 0) c.

(** Derivative of the identity function on (0,∞). **)
// Proof in 1777497924.mg
ProofArchived deriv_at_id_Ioi0 :
  forall c :e Ioi 0, deriv_at (fun x : set => x) (Ioi 0) c 1.

(** Derivative and continuity of reciprocal on (0,∞). **)
// Proof in 1777497924.mg
ProofArchived deriv_at_recip_SNo_Ioi0 :
  forall c :e Ioi 0, deriv_at (fun x => recip_SNo x) (Ioi 0) c ((- 1) :/: (c * c)).

// Proof in 1777497924.mg
ProofArchived recip_SNo_continuous_at_Ioi0 :
  forall c :e Ioi 0, continuous_at (fun x => recip_SNo x) (Ioi 0) c.

// Proof in 1777414988.mg
ProofArchived sup_Sing_eq : forall x :e R, sup {x} = x.

// Proof in 1777414988.mg
ProofArchived inf_Sing_eq : forall x :e R, inf {x} = x.

(** Degenerate intervals: all Darboux sums are 0, so all integrals over [a,a] are 0. **)
// Proof in 1777471902.mg
ProofArchived lower_darboux_sums_Icc_self_eq_Sing0 :
  forall a :e R, forall f : set -> set,
    lower_darboux_sums_Icc a a f = {0}.

// Proof in 1777471902.mg
ProofArchived upper_darboux_sums_Icc_self_eq_Sing0 :
  forall a :e R, forall f : set -> set,
    upper_darboux_sums_Icc a a f = {0}.

// Proof in 1777471902.mg
ProofArchived riemann_integral_Icc_self_eq_0 :
  forall a :e R, forall f : set -> set,
    riemann_integral_Icc a a f = 0.

// Proof in 1777471902.mg
ProofArchived upper_darboux_integral_Icc_self_eq_0 :
  forall a :e R, forall f : set -> set,
    upper_darboux_integral_Icc a a f = 0.

(** Infimum/supremum on a nonempty domain for a pointwise-zero function. **)

// Proof in 1777415049.mg
ProofArchived inf_on_eq_0_of_pointwise_eq_0 :
  forall D, nonempty D ->
  forall f : set -> set,
    bounded_fun D f ->
    (forall x :e D, f x = 0) ->
    inf_on f D = 0.

// Proof in 1777415049.mg
ProofArchived sup_on_eq_0_of_pointwise_eq_0 :
  forall D, nonempty D ->
  forall f : set -> set,
    bounded_fun D f ->
    (forall x :e D, f x = 0) ->
    sup_on f D = 0.

(** Riemann integrability under scaling, for a nonzero scalar. **)
// Proof in 1777411982.mg
ProofArchived riemann_integrable_Icc_scale_ne0 :
  forall a b :e R, a <= b -> forall f : set -> set, forall alpha :e R,
    alpha <> 0 ->
riemann_integrable_Icc a b f ->
riemann_integrable_Icc a b (fun x => alpha * (f x)).

(** Riemann integral scaling, for a nonzero scalar. **)
// Proof in 1777411982.mg
ProofArchived riemann_integral_Icc_scale_ne0 :
  forall a b :e R, a <= b -> forall f : set -> set, forall alpha :e R,
    alpha <> 0 ->
    riemann_integrable_Icc a b f ->
    riemann_integral_Icc a b (fun x => alpha * (f x))
      = alpha * (riemann_integral_Icc a b f).

(** Riemann integrability under scaling (needed for full linearity statement). **)
// Proof in 1777417069.mg
ProofArchived riemann_integrable_Icc_scale :
  forall a b :e R, a <= b -> forall f : set -> set, forall alpha :e R,
    riemann_integrable_Icc a b f ->
    riemann_integrable_Icc a b (fun x => alpha * (f x)).

(** Riemann integral scaling (needed for full linearity statement). **)
// Proof in 1777417069.mg
ProofArchived riemann_integral_Icc_scale :
  forall a b :e R, a <= b -> forall f : set -> set, forall alpha :e R,
    riemann_integrable_Icc a b f ->
    riemann_integral_Icc a b (fun x => alpha * (f x))
      = alpha * (riemann_integral_Icc a b f).

(** Main linearity properties. **)

(** Riemann-integral additivity is proved later (in form78), after Darboux additivity. **)

// Proof in 1777417169.mg
ProofArchived riemann_integral_Icc_linearity :
  forall a b :e R, a <= b -> forall f g : set -> set, forall alpha :e R,
    riemann_integrable_Icc a b f ->
    riemann_integrable_Icc a b g ->
    riemann_integrable_Icc a b (fun x => (f x) + (g x))
    /\ riemann_integral_Icc a b (fun x => (f x) + (g x))
        = riemann_integral_Icc a b f + riemann_integral_Icc a b g
    /\ riemann_integrable_Icc a b (fun x => alpha * (f x))
    /\ riemann_integral_Icc a b (fun x => alpha * (f x))
        = alpha * (riemann_integral_Icc a b f).

// Proof in 1777388844.mg
ProofArchived riemann_integral_Icc_monotone :
  forall a b :e R, a <= b -> forall f g : set -> set,
    (forall x :e Icc a b, f x <= g x) ->
    riemann_integrable_Icc a b f ->
    riemann_integrable_Icc a b g ->
    riemann_integral_Icc a b f <= riemann_integral_Icc a b g.

End form77.

Section form78.

(** real1.tex: Lemma `lemma:darbouxadd` (additivity of lower/upper Darboux integrals). **)
(** Note: the book states it for a < b < c, but we use a <= b <= c. **)

// Proof in 1777462247.mg
ProofArchived lower_darboux_integral_Icc_additivity :
  forall a b c :e R, a <= b -> b <= c ->
  forall f : set -> set,
    bounded_fun (Icc a c) f ->
    lower_darboux_integral_Icc a c f
      = lower_darboux_integral_Icc a b f + lower_darboux_integral_Icc b c f.

(** real1.tex: Riemann-integral additivity (placed here because the proof uses Darboux additivity). **)
// Proof in 1777462247.mg
ProofArchived riemann_integral_Icc_additivity :
  forall a b c, forall f : set -> set,
    a :e R -> b :e R -> c :e R ->
    a <= c -> c <= b ->
    riemann_integrable_Icc a b f ->
    riemann_integrable_Icc a c f ->
    riemann_integrable_Icc c b f ->
    riemann_integral_Icc a b f
      = riemann_integral_Icc a c f + riemann_integral_Icc c b f.

// Proof in 1777467368.mg
ProofArchived upper_darboux_integral_Icc_additivity :
  forall a b c :e R, a <= b -> b <= c ->
  forall f : set -> set,
    bounded_fun (Icc a c) f ->
    upper_darboux_integral_Icc a c f
      = upper_darboux_integral_Icc a b f + upper_darboux_integral_Icc b c f.

(** Riemann-integral counterpart (derived from the Darboux additivity lemma once proved). **)
// Proof in 1777462527.mg
ProofArchived riemann_integral_Icc_additivity' :
  forall a b c :e R, a <= b -> b <= c ->
  forall f : set -> set,
    riemann_integrable_Icc a c f ->
    riemann_integrable_Icc a b f ->
    riemann_integrable_Icc b c f ->
    riemann_integral_Icc a c f
      = riemann_integral_Icc a b f + riemann_integral_Icc b c f.

(** Useful rearrangement of additivity: solve for the tail integral. **)
// Proof in 1777506238.mg
ProofArchived riemann_integral_Icc_tail_eq :
  forall a b c :e R, a <= b -> b <= c ->
  forall f : set -> set,
    riemann_integrable_Icc a c f ->
    riemann_integrable_Icc a b f ->
    riemann_integrable_Icc b c f ->
    riemann_integral_Icc b c f
      = (- (riemann_integral_Icc a b f)) + riemann_integral_Icc a c f.

(** Integrability on a tail subinterval [b,c] from integrability on [a,b] and [a,c]. **)
(** This is a standard consequence of Darboux additivity. **)
// Proof in 1777482204.mg
ProofArchived riemann_integrable_Icc_tail :
  forall a b c :e R, a <= b -> b <= c ->
  forall f : set -> set,
    riemann_integrable_Icc a c f ->
    riemann_integrable_Icc a b f ->
    riemann_integrable_Icc b c f.

(** Integrability on the head subinterval [a,b] from integrability on [a,c] and [b,c]. **)
(** (The symmetric companion of `riemann_integrable_Icc_tail`.) **)
// Proof in 1777482657.mg
ProofArchived riemann_integrable_Icc_head :
  forall a b c :e R, a <= b -> b <= c ->
  forall f : set -> set,
    riemann_integrable_Icc a c f ->
    riemann_integrable_Icc b c f ->
    riemann_integrable_Icc a b f.

(** Riemann integrability is inherited by subintervals. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived riemann_integrable_Icc_split :
  forall a c b :e R, a <= c -> c <= b ->
  forall f : set -> set,
    riemann_integrable_Icc a b f ->
    riemann_integrable_Icc a c f /\ riemann_integrable_Icc c b f.

End form78.

Section form79.

// Proof in RealAnalysis1May042026a.mg
ProofArchived upper_minus_lower_darboux_integral_Icc_Le_abs_bound :
  forall a b :e R, a < b ->
  forall f : set -> set,
    bounded_fun (Icc a b) f ->
    forall M :e R,
      (forall x :e Icc a b, abs_SNo (f x) <= M) ->
      upper_darboux_integral_Icc a b f + (- (lower_darboux_integral_Icc a b f))
        <= (M * (b + (- a))) + (M * (b + (- a))).

// Proof in RealAnalysis1May042026a.mg
ProofArchived abs_lower_darboux_integral_Icc_Le_abs_bound :
  forall a b :e R, a < b ->
  forall f : set -> set,
    bounded_fun (Icc a b) f ->
    forall M :e R,
      (forall x :e Icc a b, abs_SNo (f x) <= M) ->
      abs_SNo (lower_darboux_integral_Icc a b f) <= M * (b + (- a)).

// Proof in RealAnalysis1May042026a.mg
ProofArchived abs_riemann_integral_Icc_Le_abs_bound :
  forall a b :e R, a < b ->
  forall f : set -> set,
    bounded_fun (Icc a b) f ->
    forall M :e R,
      (forall x :e Icc a b, abs_SNo (f x) <= M) ->
      abs_SNo (riemann_integral_Icc a b f) <= M * (b + (- a)).

End form79.

Section form80.

(** real1.tex: Lemma `lemma:boundedimpriemann` (extend integrability from inner intervals to endpoints). **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived riemann_integrable_Icc_of_integrable_on_inner_intervals :
  forall a b :e R, a < b ->
  forall f : set -> set,
    bounded_fun (Icc a b) f ->
    forall an bn : set -> set,
      R_seq an ->
      R_seq bn ->
      (forall n :e omega, a < an n /\ an n < bn n /\ bn n < b) ->
      seq_limit an a ->
      seq_limit bn b ->
      (forall n :e omega, riemann_integrable_Icc (an n) (bn n) f) ->
      riemann_integrable_Icc a b f
      /\ seq_limit
           (fun n:set => riemann_integral_Icc (an n) (bn n) f)
           (riemann_integral_Icc a b f).

End form80.

Section form81.

(** real1.tex: "bounded function with finitely many discontinuities is Riemann integrable". **)

//LLM finitely_many_discontinuities_Icc : "the finitely many discontinuities icc associated to #1" | $\mathrm{finitely\_many\_discontinuities\_Icc}(#1,#2,#3)$
Definition finitely_many_discontinuities_Icc : set -> set -> (set -> set) -> prop :=
  fun a b f =>
    exists S,
      finite S
      /\ S c= Icc a b
      /\ forall x :e Icc a b, x /:e S -> continuous_at f (Icc a b) x.

(** Continuous functions have finitely many discontinuities (take S = Empty). **)
// Proof in 1777504021.mg
ProofArchived finitely_many_discontinuities_Icc_of_continuous_on :
  forall a b :e R, forall f : set -> set,
    continuous_on f (Icc a b) ->
    finitely_many_discontinuities_Icc a b f.

(** real1.tex: changing finitely many values does not change integrability or the integral. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived bounded_fun_Icc_of_eq_off_finite_set :
  forall a b :e R, a <= b ->
  forall f g : set -> set,
    bounded_fun (Icc a b) f ->
    R_fun (Icc a b) g ->
    forall S,
      finite S ->
      S c= Icc a b ->
      (forall x :e Icc a b, x /:e S -> f x = g x) ->
      bounded_fun (Icc a b) g.

// Proof in RealAnalysis1May042026a.mg
ProofArchived riemann_integrable_Icc_exists_partition_gap_lt :
  forall a b :e R, a <= b ->
  forall f : set -> set,
    riemann_integrable_Icc a b f ->
    forall eps :e R, 0 < eps ->
      exists n :e omega,
      exists p : set -> set,
        is_partition_seq_Icc a b n p
        /\ (darboux_sum_upper_seq f n p + (- (darboux_sum_lower_seq f n p))) < eps.

// Proof in RealAnalysis1May042026a.mg
ProofArchived riemann_integrable_Icc_of_exists_partition_gap_lt :
  forall a b :e R, a <= b ->
  forall f : set -> set,
    bounded_fun (Icc a b) f ->
    (forall eps :e R, 0 < eps ->
      exists n :e omega,
      exists p : set -> set,
        is_partition_seq_Icc a b n p
        /\ (darboux_sum_upper_seq f n p + (- (darboux_sum_lower_seq f n p))) < eps) ->
    riemann_integrable_Icc a b f.

// Proof in RealAnalysis1May042026a.mg
ProofArchived not_mem_singleton_imp_neq :
  forall x c, x /:e {c} -> x <> c.

// Proof in RealAnalysis1May042026a.mg
ProofArchived neq_imp_not_mem_singleton :
  forall x c, x <> c -> x /:e {c}.

// Proof in 100thms_12b.mg
ProofArchived finite_Sing :
  forall x, finite {x}.

// Proof in RealAnalysis1May042026a.mg
ProofArchived point_not_in_two_parts_of_succ_mem :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall c :e Icc a b,
    forall i j :e n,
      ordsucc i :e j ->
      ~(c :e part_Icc p i /\ c :e part_Icc p j).

// Proof in RealAnalysis1May042026a.mg
ProofArchived point_in_two_parts_imp_adjacent :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall c :e Icc a b,
    forall i j :e n,
      c :e part_Icc p i ->
      c :e part_Icc p j ->
      i <> j ->
      j = ordsucc i \/ i = ordsucc j.

(** If c is a partition point p j (with j <> 0), then any subinterval containing c is either j or its predecessor. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived part_Icc_mem_of_partition_point_imp_eq_or_pred :
  forall a b n, forall p : set -> set,
    is_partition_seq_Icc a b n p ->
    forall c :e Icc a b,
    forall j :e n, p j = c ->
    j <> 0 ->
    forall i :e n,
      c :e part_Icc p i ->
      i = j \/ j = ordsucc i.

// Proof in RealAnalysis1May042026a.mg
ProofArchived darboux_term_gap_Le_abs_bound_part :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    forall i :e n,
    forall M :e R,
      (forall x :e part_Icc p i, abs_SNo (f x) <= M) ->
      (darboux_term_upper f p i) + (- (darboux_term_lower f p i))
        <= (delta_part p i) * (M + M).

// Proof in RealAnalysis1May042026a.mg
ProofArchived bounded_fun_Icc_of_eq_off_singleton :
  forall a b :e R, a <= b ->
  forall f g : set -> set,
    bounded_fun (Icc a b) f ->
    R_fun (Icc a b) g ->
    forall c :e Icc a b,
      (forall x :e Icc a b, x <> c -> f x = g x) ->
      bounded_fun (Icc a b) g.

// Proof in RealAnalysis1May042026a.mg
ProofArchived riemann_integrable_Icc_of_eq_off_singleton_self :
  forall a :e R,
  forall f g : set -> set,
    riemann_integrable_Icc a a f ->
    R_fun (Icc a a) g ->
    forall c :e Icc a a,
      (forall x :e Icc a a, x <> c -> f x = g x) ->
      riemann_integrable_Icc a a g
      /\ riemann_integral_Icc a a g = riemann_integral_Icc a a f.

// Proof in RealAnalysis1May042026a.mg
ProofArchived riemann_integrable_Icc_exists_partition_gap_lt_with_point :
  forall a b :e R, a <= b ->
  forall f : set -> set,
    riemann_integrable_Icc a b f ->
    forall eps :e R, 0 < eps ->
    forall c :e Icc a b,
      exists n :e omega,
      exists p : set -> set,
        is_partition_seq_Icc a b n p
        /\ c :e partition_seq_points n p
        /\ (darboux_sum_upper_seq f n p + (- (darboux_sum_lower_seq f n p))) < eps.

(** Partial sums of a sequence with exactly one nonzero term. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived partial_sum_seq_singleton_term :
  forall n, nat_p n ->
  forall i :e n, forall x :e R,
    partial_sum_seq (fun k : set => if k = i then x else 0) n = x.

// Proof in RealAnalysis1May042026a.mg
ProofArchived partial_sum_seq_add_two_singletons :
  forall n, nat_p n ->
  forall i :e n, forall j :e n,
  forall x y :e R,
    partial_sum_seq
      (seq_add
         (fun k : set => if k = i then x else 0)
         (fun k : set => if k = j then y else 0))
      n
      = x + y.

// Proof in RealAnalysis1May042026a.mg
ProofArchived partial_sum_seq_Le_of_term_Le_add_two_singletons :
  forall z : set -> set,
  forall n, nat_p n ->
    (forall k :e n, z k :e R) ->
    forall i :e n, forall j :e n,
    forall x y :e R,
      (forall k :e n,
        z k
          <= (seq_add
                (fun t : set => if t = i then x else 0)
                (fun t : set => if t = j then y else 0)) k) ->
      partial_sum_seq z n <= x + y.

// Proof in RealAnalysis1May042026a.mg
ProofArchived partial_sum_seq_sub_eq :
  forall x y : set -> set,
    forall n, nat_p n ->
      (forall k :e n, x k :e R) ->
      (forall k :e n, y k :e R) ->
      partial_sum_seq (seq_sub x y) n
        = partial_sum_seq x n + (- (partial_sum_seq y n)).

(** Prefix-only additivity of partial sums: no global `R_seq` hypothesis needed. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived partial_sum_seq_add_eq_on :
  forall x y : set -> set,
    forall n, nat_p n ->
      (forall k :e n, x k :e R) ->
      (forall k :e n, y k :e R) ->
      partial_sum_seq (seq_add x y) n
        = partial_sum_seq x n + partial_sum_seq y n.

// Proof in RealAnalysis1May042026a.mg
ProofArchived darboux_sum_gap_eq_partial_sum_seq_sub :
  forall a b n, forall f p : set -> set,
    is_partition_seq_Icc a b n p ->
    bounded_fun (Icc a b) f ->
    darboux_sum_upper_seq f n p + (- (darboux_sum_lower_seq f n p))
      = partial_sum_seq
          (seq_sub (fun i => darboux_term_upper f p i)
                   (fun i => darboux_term_lower f p i))
          n.

// Proof in RealAnalysis1May042026a.mg
ProofArchived exists_two_points_around_interior_Icc_small_width :
  forall a b :e R, a < b ->
  forall c :e Ioo a b,
  forall delta :e R, 0 < delta ->
    exists u :e Ioo a b, exists v :e Ioo a b,
      u < c /\ c < v /\ v + (- u) < delta.

// Proof in RealAnalysis1May042026a.mg
ProofArchived exists_point_right_of_left_Icc_small_width :
  forall a b :e R, a < b ->
  forall delta :e R, 0 < delta ->
    exists v :e Ioo a b, v + (- a) < delta.

// Proof in RealAnalysis1May042026a.mg
ProofArchived exists_point_left_of_right_Icc_small_width :
  forall a b :e R, a < b ->
  forall delta :e R, 0 < delta ->
    exists u :e Ioo a b, b + (- u) < delta.

// Proof in RealAnalysis1May042026a.mg
ProofArchived riemann_integrable_Icc_const0_integral_eq_0 :
  forall a b :e R, a <= b ->
    riemann_integrable_Icc a b (fun _ : set => 0)
    /\ riemann_integral_Icc a b (fun _ : set => 0) = 0.

// Proof in RealAnalysis1May042026a.mg
ProofArchived R_fun_Icc_spike :
  forall a b :e R, a <= b ->
  forall c :e Icc a b,
  forall d :e R,
    R_fun (Icc a b) (fun x => if x = c then d else 0).

