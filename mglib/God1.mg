claim h_s30_t7_multiplicity_factorization :
  polynomial_root_multiplicity K add mul f a = r ->
  polynomial_divides K add mul
    (ring_nat_power
      (multivariate_polynomial_ring K add 1)
      (polynomial_addition K add 1)
      (polynomial_multiplication K add mul 1)
      (polynomial_addition K add 1
        (polynomial_indeterminate K add mul 1 0)
        (ring_negation
          (multivariate_polynomial_ring K add 1)
          (polynomial_addition K add 1)
          (polynomial_constant K add mul 1 a))) r) f.
admit.
//GOD1PRF:922651 where $g(a) \neq 0$; for otherwise (Theorem 5) $g(\mathrm{~T})$ would be divisible by $\mathrm{T}-a$, and hence $f(\mathrm{~T})$ would be divisible by $(\mathrm{T}-a)^{r+1}$. Now if we differentiate (16) $k$ times we shall clearly get a relation of the form
claim h_s30_t7_theorem5_formal_call :
  forall K0, forall add0 mul0:set -> set -> set,
  forall f0 :e multivariate_polynomial_ring K0 add0 1, forall a0 :e K0,
    commutative_ring K0 add0 mul0 ->
    (polynomial_zero K0 add0 mul0 K0 add0 mul0 1 f0 (fun i => a0)
    <-> polynomial_divides K0 add0 mul0
      (polynomial_addition K0 add0 1
        (polynomial_indeterminate K0 add0 mul0 1 0)
        (ring_negation
          (multivariate_polynomial_ring K0 add0 1)
          (polynomial_addition K0 add0 1)
          (polynomial_constant K0 add0 mul0 1 a0))) f0).
apply god1_s30_theorem5_root_iff_linear_factor.
claim h_s30_t7_cofactor_nonzero_at_root :
  polynomial_root_multiplicity K add mul f a = r ->
  exists g :e multivariate_polynomial_ring K add 1,
    polynomial_evaluation K add mul K add mul 1 g (fun i => a)
      <> ring_zero K add.
admit.
//GOD1PRF:922913 f^{(k)}(\mathrm{T})=r(r-1) \ldots(r-k+1)(\mathrm{T}-a)^{r-k} g(\mathrm{~T})+(\mathrm{T}-a)^{r-k+1} q_{k}(\mathrm{~T}),
claim h_s30_t7_iterated_derivative_form : forall k :e ordsucc r,
