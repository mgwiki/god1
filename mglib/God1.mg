    ~(exists m :e omega, k = nat_pair 0 m) ->
    ~(exists m :e omega, k = nat_pair 1 m) ->
    null_set_binunion_cseq n cseq1 cseq2 k = cseq1 0.

// Proof in RealAnalysis2.1780535583.mg
ProofArchived null_set_binunion_cseq_mem :
  forall n :e omega,
