Theorem god1_group_word_represented_mul_word_step :
  forall G, forall mul:set -> set -> set, forall B z,
  forall f:set -> set, forall n,
    group G mul -> nat_p n ->
    group_word_represented G mul B z ->
    ((forall i :e n, group_word_letter G mul B (f i)) ->
