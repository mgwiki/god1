            (determinant_3 K addK mulK
              (basis_triple_coordinate_matrix
                K addK mulK X addX smulX n a
                (t 0) (t 1 0) (t 1 1) x y z))
            (f (trilinear_tuple (a (t 0)) (a (t 1 0)) (a (t 1 1)))))).
