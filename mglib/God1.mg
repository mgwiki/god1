      matrix_determinant K add mul (ordsucc n) A
      = ring_finite_sum K add (ordsucc n)
        (fun i => mul (matrix_entry A i j)
          (matrix_cofactor K add mul n i j A)))
    /\ forall i :e ordsucc n,
      matrix_determinant K add mul (ordsucc n) A
      = ring_finite_sum K add (ordsucc n)
        (fun j => mul (matrix_entry A i j)
          (matrix_cofactor K add mul n i j A)).
