ProofArchived mul_SNo_minus_distrL : forall x y, SNo x -> SNo y -> (- x) * y = - x * y.

// Proof in 100thms_12b.mg
ProofArchived mul_SNo_minus_distrR: forall x y, SNo x -> SNo y -> x * (- y) = - (x * y).

