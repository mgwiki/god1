    /\ module_endomorphism K add mul X addX smulX u
    /\ module_endomorphism K add mul X addX smulX v
    /\ basis_coordinate_matrix K add mul X addX smulX p a
      (fun j => u (a j)) = A
    /\ basis_coordinate_matrix K add mul X addX smulX p a
      (fun j => v (a j)) = B
    /\ basis_coordinate_matrix K add mul X addX smulX p a
      (fun j => u (v (a j)))
