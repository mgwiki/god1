Qed.

Theorem god1_group_word_product_in_subgroup :
  forall G, forall mul:set -> set -> set, forall B H,
  forall f:set -> set, forall p,
    subgroup G mul H -> B c= H -> nat_p p ->
    (forall i :e p, group_word_letter G mul B (f i)) ->
