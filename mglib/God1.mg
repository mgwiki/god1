Section God1.

(** § 6. Laws of composition. **)

//GOD1:3155 law_of_composition : "#2 is a law of composition on #1" | $#2 : #1 \times #1 \longrightarrow #1$
Definition law_of_composition : set -> (set -> set -> set) -> prop :=
  fun X op => forall x y :e X, op x y :e X.

//GOD1:3773 associative_on : "#2 is associative on #1" | $\forall x,y,z\in #1,\ #2(x,#2(y,z))=#2(#2(x,y),z)$
Definition associative_on : set -> (set -> set -> set) -> prop :=
  fun X op => forall x y z :e X, op x (op y z) = op (op x y) z.

//GOD1:5327 commutative_on : "#2 is commutative on #1" | $\forall x,y\in #1,\ #2(x,y)=#2(y,x)$
Definition commutative_on : set -> (set -> set -> set) -> prop :=
  fun X op => forall x y :e X, op x y = op y x.

//GOD1:8221 neutral_element : "#3 is a neutral element for #2 on #1" | $\forall x\in #1,\ #2(x,#3)=#2(#3,x)=x$
Definition neutral_element : set -> (set -> set -> set) -> set -> prop :=
  fun X op e =>
    e :e X /\ forall x :e X, op x e = x /\ op e x = x.

//GOD1:11796 left_reflection : "#5 is a left reflection of #4 for #2 on #1 with neutral element #3" | $#2(#5,#4)=#3$
Definition left_reflection :
  set -> (set -> set -> set) -> set -> set -> set -> prop :=
  fun X op e x r => r :e X /\ op r x = e.

//GOD1:11796 right_reflection : "#5 is a right reflection of #4 for #2 on #1 with neutral element #3" | $#2(#4,#5)=#3$
Definition right_reflection :
  set -> (set -> set -> set) -> set -> set -> set -> prop :=
  fun X op e x r => r :e X /\ op x r = e.

//GOD1:12077 reflection : "#5 is a reflection of #4 for #2 on #1 with neutral element #3" | $#2(#5,#4)=#2(#4,#5)=#3$
Definition reflection :
  set -> (set -> set -> set) -> set -> set -> set -> prop :=
  fun X op e x r =>
    r :e X /\ op r x = e /\ op x r = e.

//GOD1:12271 reflexible : "#4 is reflexible for #2 on #1 with neutral element #3" | $#4\text{ is reflexible}$
Definition reflexible :
  set -> (set -> set -> set) -> set -> set -> prop :=
  fun X op e x =>
    x :e X /\ exists r :e X, reflection X op e x r.

Theorem god1_s6_theorem1_neutral_element_unique :
  forall X, forall op:set -> set -> set,
    law_of_composition X op ->
    forall e1 e2,
      neutral_element X op e1 ->
      neutral_element X op e2 ->
      e1 = e2.
let X op.
assume hop.
let e1 e2.
assume he1 he2.
//GOD1PRF:8596 Suppose that $e^{\prime}, e^{\prime \prime}$ are neutral elements.
//GOD1PRF:8663 Then the formula $e^{\prime} \perp x=x$ applied to $x=e^{\prime \prime}$ gives $e^{\prime} \perp e^{\prime \prime}=e^{\prime \prime}$; and the formula $x \perp e^{\prime \prime}=x$ applied to $x=e^{\prime}$ gives $e^{\prime} \perp e^{\prime \prime} =e^{\prime}$.
apply (eq_i_tra e1 (op e1 e2) e2).
//GOD1PRF:8926 Hence $e^{\prime}=e^{\prime \prime}$.
Admitted.

Theorem god1_s6_theorem2_reflection_characterization :
  forall X, forall op:set -> set -> set, forall e x,
    law_of_composition X op ->
    associative_on X op ->
    neutral_element X op e ->
    x :e X ->
    (reflexible X op e x <->
      ((exists l :e X, left_reflection X op e x l) /\
       (exists r :e X, right_reflection X op e x r)))
    /\
    (((exists l :e X, left_reflection X op e x l) /\
      (exists r :e X, right_reflection X op e x r)) ->
      exists u :e X,
        reflection X op e x u
        /\ (forall v :e X, reflection X op e x v -> v = u)
        /\ (forall v :e X, left_reflection X op e x v -> v = u)
        /\ (forall v :e X, right_reflection X op e x v -> v = u)).
