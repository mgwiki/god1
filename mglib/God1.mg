    ms_ball (Rn n) (Rn_dist n) (cseq2 k) (rseq2 k)
    =
    ms_ball
      (Rn n)
      (Rn_dist n)
      ((fun j :e omega => null_set_binunion_cseq n cseq1 cseq2 j) (nat_pair 1 k))
      ((fun j :e omega => null_set_binunion_rseq rseq1 rseq2 j) (nat_pair 1 k)).

// Proof in RealAnalysis2.1780533286.mg
ProofArchived null_set_binunion_cover_subq :
  forall n :e omega,
  forall cseq1 :e setexp (Rn n) omega,
  forall cseq2 :e setexp (Rn n) omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    (((\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq1 k) (rseq1 k))
      :\/:
      (\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq2 k) (rseq2 k)))
     c=
     (\/_ k :e omega,
       ms_ball
         (Rn n)
         (Rn_dist n)
         ((fun k :e omega => null_set_binunion_cseq n cseq1 cseq2 k) k)
         ((fun k :e omega => null_set_binunion_rseq rseq1 rseq2 k) k))).

// Proof in RealAnalysis2.1780535583.mg
ProofArchived null_set_binunion_cover_merge :
  forall n :e omega,
  forall cseq1 :e setexp (Rn n) omega,
  forall cseq2 :e setexp (Rn n) omega,
  forall rseq1 :e setexp R omega,
  forall rseq2 :e setexp R omega,
    (forall k :e omega, 0 < rseq1 k) ->
    (forall k :e omega, 0 < rseq2 k) ->
    exists cseq :e setexp (Rn n) omega,
    exists rseq :e setexp R omega,
      (forall k :e omega, 0 < rseq k)
      /\ (((\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq1 k) (rseq1 k))
           :\/:
           (\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq2 k) (rseq2 k)))
          c=
          (\/_ k :e omega, ms_ball (Rn n) (Rn_dist n) (cseq k) (rseq k))).

(** Doubling on omega is injective. This supports a fallback-free even/odd merge for null-set unions. **)
// Proof in RealAnalysis2.1780536433.mg
ProofArchived mul2_cancel_omega :
  forall m :e omega,
  forall n :e omega,
    2 * m = 2 * n ->
    m = n.

(** Odd naturals of this coded form are never even coded terms. **)
// Proof in RealAnalysis2.1780536433.mg
ProofArchived not_eq_mul2_ordsucc_mul2 :
  forall m :e omega,
  forall n :e omega,
    ordsucc (2 * n) <> 2 * m.

(** These odd codes are injective. **)
// Proof in RealAnalysis2.1780536433.mg
ProofArchived ordsucc_mul2_cancel_omega :
  forall m :e omega,
  forall n :e omega,
    ordsucc (2 * m) = ordsucc (2 * n) ->
    m = n.

(** Fallback-free even/odd merge of center sequences for null-set unions.
    This belongs to `sec:outermeasure`; it is placed here to support the remaining merge blocker. **)
//LLM null_set_evenodd_cseq : "the even-odd split of the null-set sequence #1" | $\mathrm{null\_set\_evenodd\_cseq}(#1,#2,#3,#4)$
Definition null_set_evenodd_cseq :
  set ->
  set ->
  set ->
  set ->
  set :=
  fun n cseq1 cseq2 k =>
    if exists m :e omega, k = 2 * m
    then cseq1
           (Eps_i
             (fun m : set =>
                m :e omega /\ k = 2 * m))
    else if exists m :e omega, k = ordsucc (2 * m)
    then cseq2
           (Eps_i
             (fun m : set =>
                m :e omega /\ k = ordsucc (2 * m)))
    else cseq1 0.

(** Fallback-free even/odd merge of radius sequences for null-set unions. **)
//LLM null_set_evenodd_rseq : "the even-odd split of the real-indexed null-set sequence #1" | $\mathrm{null\_set\_evenodd\_rseq}(#1,#2,#3)$
Definition null_set_evenodd_rseq :
  set ->
  set ->
  set ->
  set :=
  fun rseq1 rseq2 k =>
    if exists m :e omega, k = 2 * m
    then rseq1
           (Eps_i
             (fun m : set =>
                m :e omega /\ k = 2 * m))
    else if exists m :e omega, k = ordsucc (2 * m)
    then rseq2
           (Eps_i
             (fun m : set =>
                m :e omega /\ k = ordsucc (2 * m)))
    else 1.

// Proof in RealAnalysis2.1780538786.mg
ProofArchived null_set_evenodd_cseq_even_witness :
  forall n,
  forall cseq1,
  forall cseq2,
  forall k,
  forall m :e omega,
    k = 2 * m ->
    null_set_evenodd_cseq n cseq1 cseq2 k = cseq1 m.

