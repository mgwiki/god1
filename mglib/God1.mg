//LLM bij : "#1 is a bijection from #2 to #3" | $#3 : #1 \xrightarrow{\sim} #2$
Definition bij : set->set->(set->set)->prop :=
  fun X Y f =>
  (forall u :e X, f u :e Y)
  /\
  (forall u v :e X, f u = f v -> u = v)
  /\
  (forall w :e Y, exists u :e X, f u = w).

