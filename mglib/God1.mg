let I.
assume hI.
exact (god1_subgroups_of_integers_classification_unique I hI).
Qed.

Theorem god1_field_characteristic_zero_or_prime_and_scalar_criterion :
  forall K, forall add mul:set -> set -> set,
    field K add mul ->
    (field_characteristic K add mul = 0
      \/ prime_nat (field_characteristic K add mul))
    /\ forall r :e int,
      (group_int_power K add (ring_one K mul) r = ring_zero K add
      <-> exists z :e int,
        r = mul_SNo (field_characteristic K add mul) z).
let K add mul.
assume hField.
apply andI.
//GOD1PRF:915139 Hence, under the assumption that K is a field, we are led to consider the set I of integers $r$ such that
claim h_s30_characteristic_kernel_set :
  {r :e int|group_int_power K add (ring_one K mul) r = ring_zero K add}
    :e Power int.
admit.
//GOD1PRF:915262 this set I contains 0 , and if it contains integers $r, s$ it clearly contains $r-s$; it is therefore a subgroup of the additive group $\mathbf{Z}$, and hence (§ 7, Example 8) there exists a unique integer $p \geqslant 0$ such that $\mathrm{I}=p \mathrm{Z}$. This integer $p$ is called the characteristic of the field K .
claim h_s30_characteristic_s7_example8_formal_call :
  forall I,
    subgroup int add_SNo I ->
    exists p :e omega,
      I = {mul_SNo p z|z :e int}
      /\ forall q :e omega,
        I = {mul_SNo q z|z :e int} -> q = p.
apply god1_s7_example8_subgroups_of_integers_interface.
claim h_s30_characteristic_kernel_subgroup :
  subgroup int add_SNo
    {r :e int|group_int_power K add (ring_one K mul) r = ring_zero K add}.
admit.
//GOD1PRF:915586 The characteristic $p$ of a field K may also be defined as follows: if the relation $r .1=0$ implies $r=0$, then $p=0$; if not, then $p$ is the smallest strictly positive integer such that $p .1=0$. In all cases, the relation $r .1=0$ means that $r$ is a multiple of $p$, or again : for $r .1$ to be non-zero it is necessary and sufficient that $r$ is not divisible by the characteristic of K .
claim h_s30_characteristic_scalar_criterion : forall r :e int,
  (group_int_power K add (ring_one K mul) r = ring_zero K add
  <-> exists z :e int, r = mul_SNo (field_characteristic K add mul) z).
admit.
//GOD1PRF:915982 It is important to observe that the characteristic of a field is always either 0 or a prime number. For suppose that the field K is of characteristic $p \neq 0$, and let $r, s$ be two integers such that
claim h_s30_characteristic_prime_goal :
  field_characteristic K add mul = 0
  \/ prime_nat (field_characteristic K add mul).
admit.
//GOD1PRF:916199 then we have
claim h_s30_characteristic_product_scalar : forall r s :e int,
  group_int_power K add (ring_one K mul) (mul_SNo r s)
  = mul
    (group_int_power K add (ring_one K mul) r)
    (group_int_power K add (ring_one K mul) s).
admit.
//GOD1PRF:916256 and since a field is an integral domain, it follows that either $r .1=0$ (in which case $p$ divides $r$ ) or $s .1=0$ (in which case $p$ divides $s$ ). This proves our assertion.
claim h_s30_characteristic_zero_or_prime :
  field_characteristic K add mul = 0
  \/ prime_nat (field_characteristic K add mul).
admit.
Admitted.

//GOD1:920202 polynomial_divides : "polynomial #4 divides polynomial #5" | $#4\mid #5$
Definition polynomial_divides :
  set -> (set -> set -> set) -> (set -> set -> set) -> set -> set -> prop :=
  fun K add mul g f =>
    exists q :e multivariate_polynomial_ring K add 1,
      f = polynomial_multiplication K add mul 1 g q.

//GOD1:920883 polynomial_root_multiplicity : "the multiplicity of #5 as a root of polynomial #4" | $\operatorname{mult}_{#5}(#4)$
Definition polynomial_root_multiplicity :
  set -> (set -> set -> set) -> (set -> set -> set) -> set -> set -> set :=
  fun K add mul f a =>
    if f = (fun exponent :e omega :^: 1 => ring_zero K add)
    then omega
    else Eps_i (fun r => r :e omega
      /\ polynomial_divides K add mul
        (ring_nat_power
          (multivariate_polynomial_ring K add 1)
          (polynomial_addition K add 1)
          (polynomial_multiplication K add mul 1)
          (polynomial_addition K add 1
            (polynomial_indeterminate K add mul 1 0)
            (ring_negation
              (multivariate_polynomial_ring K add 1)
              (polynomial_addition K add 1)
              (polynomial_constant K add mul 1 a))) r) f
      /\ forall s :e omega,
        polynomial_divides K add mul
          (ring_nat_power
            (multivariate_polynomial_ring K add 1)
            (polynomial_addition K add 1)
            (polynomial_multiplication K add mul 1)
            (polynomial_addition K add 1
              (polynomial_indeterminate K add mul 1 0)
              (ring_negation
                (multivariate_polynomial_ring K add 1)
                (polynomial_addition K add 1)
                (polynomial_constant K add mul 1 a))) s) f -> s c= r).

Theorem god1_s30_theorem5_root_iff_linear_factor :
  forall K, forall add mul:set -> set -> set,
  forall f :e multivariate_polynomial_ring K add 1, forall a :e K,
    commutative_ring K add mul ->
    (polynomial_zero K add mul K add mul 1 f (fun i => a)
    <-> polynomial_divides K add mul
      (polynomial_addition K add 1
        (polynomial_indeterminate K add mul 1 0)
        (ring_negation
          (multivariate_polynomial_ring K add 1)
          (polynomial_addition K add 1)
          (polynomial_constant K add mul 1 a))) f).
let K add mul f.
assume hf.
let a.
assume ha hRing.
apply iffI.
//GOD1PRF:920023 where $q \in \mathrm{~K}[\mathrm{~T}]$. If $g$, $h$ are polynomials with coefficients in K , we say that $h$ is divisible by $g$ if there exists a polynomial $q$, with coefficients in K , such that $h=g q$. The result just obtained leads immediately to the following proposition (which was already established in § 28, Lemma 1):\\
claim h_s30_t5_s28_lemma1_formal_call :
  forall K0, forall add0 mul0:set -> set -> set,
  forall f0 :e multivariate_polynomial_ring K0 add0 1, forall a0 :e K0,
    commutative_ring K0 add0 mul0 ->
    (polynomial_zero K0 add0 mul0 K0 add0 mul0 1 f0 (fun i => a0)
    <-> exists g0 :e multivariate_polynomial_ring K0 add0 1,
      f0 = polynomial_multiplication K0 add0 mul0 1
        (polynomial_addition K0 add0 1
          (polynomial_indeterminate K0 add0 mul0 1 0)
          (ring_negation
            (multivariate_polynomial_ring K0 add0 1)
            (polynomial_addition K0 add0 1)
            (polynomial_constant K0 add0 mul0 1 a0))) g0).
apply god1_s28_lemma1_factor_theorem.
claim h_s30_t5_divisibility_definition_call : forall g h,
  (polynomial_divides K add mul g h <->
    exists q :e multivariate_polynomial_ring K add 1,
      h = polynomial_multiplication K add mul 1 g q).
admit.
//GOD1PRF:920355 theorem 5. Let $f$ be a polynomial in one indeterminate with coefficients in a commutative ring K . For an element a of K to be a root (or zero) of $f$, it is necessary and sufficient that the polynomial $f(\mathrm{X})$ should be divisible by the polynomial $\mathrm{X}-a$.
claim h_s30_t5_statement :
  polynomial_zero K add mul K add mul 1 f (fun i => a)
  <-> polynomial_divides K add mul
    (polynomial_addition K add 1
      (polynomial_indeterminate K add mul 1 0)
      (ring_negation
        (multivariate_polynomial_ring K add 1)
        (polynomial_addition K add 1)
        (polynomial_constant K add mul 1 a))) f.
admit.
//GOD1PRF:920630 For if $a$ is a root of $f$, we have $f(a)=0$, and Taylor's formula then shows that
claim h_s30_t5_taylor_formula_formal_call :
  forall K0, forall add0 mul0:set -> set -> set,
  forall f0 :e multivariate_polynomial_ring K0 add0 1,
  forall n0 :e omega,
    commutative_ring K0 add0 mul0 ->
    polynomial_total_degree K0 add0 1 f0 = n0 ->
    (forall x0 y0 :e K0,
      polynomial_evaluation K0 add0 mul0 K0 add0 mul0 1 f0
        (fun i => add0 x0 y0)
      = ring_finite_sum K0 add0 (ordsucc n0)
        (fun k => mul0
          (polynomial_evaluation K0 add0 mul0 K0 add0 mul0 1
            (polynomial_taylor_coefficient K0 add0 f0 k) (fun i => x0))
          (ring_nat_power K0 add0 mul0 y0 k)))
    /\ forall k :e ordsucc n0,
      polynomial_multiplication K0 add0 mul0 1
        (polynomial_constant K0 add0 mul0 1
          (ring_nat_multiple K0 add0 (factorial k) (ring_one K0 mul0)))
        (polynomial_taylor_coefficient K0 add0 f0 k)
      = iterated_polynomial_derivative K0 add0 f0 k.
apply god1_s30_theorem4_taylor_formula.
claim h_s30_t5_root_implies_factor :
  polynomial_zero K add mul K add mul 1 f (fun i => a) ->
  polynomial_divides K add mul
    (polynomial_addition K add 1
      (polynomial_indeterminate K add mul 1 0)
      (ring_negation
        (multivariate_polynomial_ring K add 1)
        (polynomial_addition K add 1)
        (polynomial_constant K add mul 1 a))) f.
admit.
//GOD1PRF:920775 Conversely, it follows from this relation that
claim h_s30_t5_factor_implies_root :
  polynomial_divides K add mul
    (polynomial_addition K add 1
      (polynomial_indeterminate K add mul 1 0)
      (ring_negation
        (multivariate_polynomial_ring K add 1)
        (polynomial_addition K add 1)
        (polynomial_constant K add mul 1 a))) f ->
  polynomial_zero K add mul K add mul 1 f (fun i => a).
admit.
//GOD1PRF:920854 and the theorem is proved.\\
claim h_s30_t5_conclusion :
  polynomial_zero K add mul K add mul 1 f (fun i => a)
  <-> polynomial_divides K add mul
    (polynomial_addition K add 1
      (polynomial_indeterminate K add mul 1 0)
      (ring_negation
        (multivariate_polynomial_ring K add 1)
        (polynomial_addition K add 1)
        (polynomial_constant K add mul 1 a))) f.
admit.
Admitted.

Theorem god1_s30_theorem6_simple_root_derivative_criterion :
  forall K, forall add mul:set -> set -> set,
  forall f :e multivariate_polynomial_ring K add 1, forall a :e K,
    commutative_ring K add mul ->
    (polynomial_root_multiplicity K add mul f a = 1
    <-> polynomial_evaluation K add mul K add mul 1 f (fun i => a)
          = ring_zero K add
      /\ polynomial_evaluation K add mul K add mul 1
          (polynomial_derived K add f) (fun i => a)
          <> ring_zero K add).
let K add mul f.
assume hf.
let a.
assume ha hRing.
