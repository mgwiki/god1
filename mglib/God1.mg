//LLM surj : "#1 is a surjection from #2 to #3" | $#3 : #1 \twoheadrightarrow #2$
Definition surj : set->set->(set->set)->prop :=
  fun X Y f =>
  (forall u :e X, f u :e Y)
  /\
  (forall w :e Y, exists u :e X, f u = w).

