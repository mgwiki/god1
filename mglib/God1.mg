(* Parameter Eps_i "174b78e53fc239e8c2aab4ab5a996a27e3e5741e88070dad186e05fb13f275e5" *)
//LLM Eps_i : "the epsilon-choice operator for the predicate #1" | $\mathrm{Eps\_i}(#1)$
Parameter Eps_i : (set->prop)->set.
Axiom Eps_i_ax : forall P:set->prop, forall x:set, P x -> P (Eps_i P).
//LLM True : "the true proposition" | $\top$
Definition True : prop := forall p:prop, p -> p.
//LLM False : "the false proposition" | $\bot$
Definition False : prop := forall p:prop, p.
//LLM not : "the negation of proposition #1" | $\neg #1$
Definition not : prop -> prop := fun A:prop => A -> False.
(* Unicode ~ "00ac" *)
Prefix ~ 700 := not.
//LLM and : "the conjunction of propositions #1 and #2" | $#1 \land #2$
Definition and : prop -> prop -> prop := fun A B:prop => forall p:prop, (A -> B -> p) -> p.
(* Unicode /\ "2227" *)
Infix /\ 780 left := and.
//LLM or : "the disjunction of propositions #1 and #2" | $#1 \lor #2$
Definition or : prop -> prop -> prop := fun A B:prop => forall p:prop, (A -> p) -> (B -> p) -> p.
(* Unicode \/ "2228" *)
Infix \/ 785 left := or.
//LLM iff : "the equivalence of propositions #1 and #2" | $#1 \leftrightarrow #2$
Definition iff : prop -> prop -> prop := fun A B:prop => and (A -> B) (B -> A).
(* Unicode <-> "2194" *)
Infix <-> 805 := iff.
Section Eq.
Variable A:SType.
//LLM eq : "the equality of #1 and #2" | $#1 = #2$
Definition eq : A->A->prop := fun x y:A => forall Q:A->A->prop, Q x y -> Q y x.
//LLM neq : "the inequality of #1 and #2" | $#1 \neq #2$
Definition neq : A->A->prop := fun x y:A => ~ eq x y.
End Eq.
Infix = 502 := eq.
(* Unicode <> "2260" *)
Infix <> 502 := neq.
Section FE.
Variable A B : SType.
Axiom func_ext : forall f g : A -> B , (forall x : A , f x = g x) -> f = g.
End FE.
Section Ex.
Variable A:SType.
//LLM ex : "the existential proposition over #1" | $\exists #1$
Definition ex : (A->prop)->prop := fun Q:A->prop => forall P:prop, (forall x:A, Q x -> P) -> P.
End Ex.
(* Unicode exists "2203" *)
Binder+ exists , := ex.
Axiom prop_ext : forall p q:prop, iff p q -> p = q.
//LLM In : "#1 is an element of #2" | $#1 \in #2$
Parameter In:set->set->prop.
//LLM Subq : "#1 is a subset of #2" | $#1 \subseteq #2$
Definition Subq : set -> set -> prop := fun A B => forall x :e A, x :e B.
Axiom set_ext : forall X Y:set, X c= Y -> Y c= X -> X = Y.
Axiom In_ind : forall P:set->prop, (forall X:set, (forall x :e X, P x) -> P X) -> forall X:set, P X.
Binder+ exists , := ex; and.
//LLM Empty : "the empty set" | $\emptyset$
Parameter Empty : set.
Axiom EmptyAx : ~exists x:set, x :e Empty.
(* Unicode Union "22C3" *)
//LLM Union : "the union of #1" | $\bigcup #1$
Parameter Union : set->set.
Axiom UnionEq : forall X x, x :e Union X <-> exists Y, x :e Y /\ Y :e X.
(* Unicode Power "1D4AB" *)
//LLM Power : "the powerset of #1" | $\wp #1$
Parameter Power : set->set.
Axiom PowerEq : forall X Y:set, Y :e Power X <-> Y c= X.
//LLM Repl : "the replacement of #1 along #2" | $\mathrm{Repl}(#1,#2)$
Parameter Repl : set -> (set -> set) -> set.
Notation Repl Repl.
Axiom ReplEq : forall A:set, forall F:set->set, forall y:set, y :e {F x|x :e A} <-> exists x :e A, y = F x.
//LLM TransSet : "#1 is transitive" | $\mathrm{TransSet}(#1)$
Definition TransSet : set->prop := fun U:set => forall x :e U, x c= U.
//LLM Union_closed : "#1 is closed under unions" | $\mathrm{Union\_closed}(#1)$
Definition Union_closed : set->prop := fun U:set => forall X:set, X :e U -> Union X :e U.
//LLM Power_closed : "#1 is closed under powersets" | $\mathrm{Power\_closed}(#1)$
Definition Power_closed : set->prop := fun U:set => forall X:set, X :e U -> Power X :e U.
//LLM Repl_closed : "#1 is closed under replacement" | $\mathrm{Repl\_closed}(#1)$
Definition Repl_closed : set->prop := fun U:set => forall X:set, X :e U -> forall F:set->set,
   (forall x:set, x :e X -> F x :e U) -> {F x|x :e X} :e U.
//LLM ZF_closed : "#1 is closed under the ZF operations" | $\mathrm{ZF\_closed}(#1)$
Definition ZF_closed : set->prop := fun U:set =>
   Union_closed U
/\ Power_closed U
/\ Repl_closed U.
//LLM UnivOf : "the universe generated by #1" | $\mathrm{UnivOf}(#1)$
Parameter UnivOf : set->set.
Axiom UnivOf_In : forall N:set, N :e UnivOf N.
Axiom UnivOf_TransSet : forall N:set, TransSet (UnivOf N).
Axiom UnivOf_ZF_closed : forall N:set, ZF_closed (UnivOf N).
Axiom UnivOf_Min : forall N U:set, N :e U
  -> TransSet U
  -> ZF_closed U
  -> UnivOf N c= U.

