//GOD1:694957 matrix_adjugate : "the adjugate matrix of #5" | $\widetilde{#5}$
Definition matrix_adjugate :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> set -> set :=
  fun K add mul n A =>
    fun u :e ordsucc n :*: ordsucc n =>
      matrix_cofactor K add mul n (u 1) (u 0) A.

