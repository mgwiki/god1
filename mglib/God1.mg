(** real2.tex: sec:complexnums (Complex numbers) [scaffolding, moved early for dependencies].
    The underlying construction of `complex` and basic algebra is already available earlier in this file.
    We place the metric-space view here because Arzelà–Ascoli later refers to a metric on `complex`. **)

Let Re : set -> set := CSNo_Re.
Let Im : set -> set := CSNo_Im.

(** Embed a complex number into R^2 via its real and imaginary parts. **)
//LLM complex_vec2 : "the complex vector corresponding to #1" | $\mathrm{complex\_vec2}(#1)$
Definition complex_vec2 : set -> set :=
  fun z =>
    (fun i :e 2 => if i = 0 then Re z else Im z).

(** Euclidean distance on C induced by the R^2 embedding `complex_vec2`. **)
//LLM dist_complex : "the distance between complex numbers #1 and #2" | $|#1 - #2|$
Definition dist_complex : set -> set -> set :=
  fun z w => Rn_dist 2 (complex_vec2 z) (complex_vec2 w).

(** Unfolding lemma for `dist_complex`. **)
// Proof in RealAnalysis2.1780484148.mg
ProofArchived dist_complex_unfold :
  forall z w,
    dist_complex z w = Rn_dist 2 (complex_vec2 z) (complex_vec2 w).

Transparent abs_sqr_CSNo.
Transparent modulus_CSNo.

(** Unfolding lemma for `abs_sqr_CSNo` (used to relate `modulus_CSNo` to `dist_complex`). **)
// Proof in RealAnalysis2.1780330045.mg
ProofArchived abs_sqr_CSNo_unfold :
  forall z,
    abs_sqr_CSNo z = (Re z ^ 2) + (Im z ^ 2).

(** Unfolding lemma for `modulus_CSNo`. **)
// Proof in RealAnalysis2.1780330045.mg
ProofArchived modulus_CSNo_unfold :
  forall z,
    modulus_CSNo z = sqrt_SNo_nonneg (abs_sqr_CSNo z).

Opaque abs_sqr_CSNo modulus_CSNo.

// Proof in RealAnalysis2.1779321830.mg
ProofArchived complex_vec2_mem :
  forall z :e complex, complex_vec2 z :e Rn 2.

// Proof in RealAnalysis2.1779321830.mg
ProofArchived complex_vec2_ap0 :
  forall z :e complex, (complex_vec2 z) 0 = Re z.

// Proof in RealAnalysis2.1779321830.mg
ProofArchived complex_vec2_ap1 :
  forall z :e complex, (complex_vec2 z) 1 = Im z.

(** complex_vec2 agrees with the canonical R^2 pairing. **)
// Proof in RealAnalysis2.1780330045.mg
ProofArchived complex_vec2_eq_R2_pair :
  forall z :e complex,
    complex_vec2 z = R2_pair (Re z) (Im z).

(** The complex zero maps to the zero vector in R^2. **)
// Proof in RealAnalysis2.1780330045.mg
ProofArchived complex_vec2_0_eq_Rn_zero2 :
  complex_vec2 0 = Rn_zero 2.

(** Dot product in R^2 for a pair vector: (a,b)·(a,b) = a^2 + b^2. **)
// Proof in RealAnalysis2.1780330045.mg
ProofArchived Rn_dot_R2_pair_self :
  forall a :e R,
  forall b :e R,
    Rn_dot 2 (R2_pair a b) (R2_pair a b) = (a ^ 2) + (b ^ 2).

(** The complex Euclidean distance to 0 matches the complex modulus. **)
// Proof in RealAnalysis2.1780330045.mg
ProofArchived dist_complex_zero_eq_modulus :
  forall z :e complex,
    dist_complex z 0 = modulus_CSNo z.

(** complex_vec2 respects the algebra of subtraction: vec(z-w)=vec(z)+(-vec(w)). **)
// Proof in RealAnalysis2.1779321830.mg
ProofArchived complex_vec2_add_minus :
  forall z :e complex,
  forall w :e complex,
    complex_vec2 (add_CSNo z (minus_CSNo w))
    =
    Rn_add 2 (complex_vec2 z) (Rn_neg 2 (complex_vec2 w)).

(** The embedding complex -> R^2 is injective. **)
// Proof in RealAnalysis2.1779335539.mg
ProofArchived complex_vec2_inj :
  forall z :e complex,
  forall w :e complex,
    complex_vec2 z = complex_vec2 w ->
    z = w.

(** Moved earlier from the later translation-combine block because the
    `sec:complexexp` majorant route uses these generic translation identities
    for `dist_complex` before the FTA-side normalization work. In `real2.tex`
    they belong with the basic complex/Euclidean metric interaction. **)
// Proof in RealAnalysis2.1780644227.mg
ProofArchived complex_vec2_add_CSNo_right :
  forall w :e complex,
  forall z0 :e complex,
    complex_vec2 (add_CSNo w z0)
    =
    Rn_add 2 (complex_vec2 z0) (complex_vec2 w).

(** Translating by a complex base point preserves distance from the origin. **)
// Proof in RealAnalysis2.1780644227.mg
ProofArchived dist_complex_add_CSNo_right_eq_dist0 :
  forall w :e complex,
  forall z0 :e complex,
    dist_complex (add_CSNo w z0) z0 = dist_complex w 0.

(** Any bound `dist_complex w 0 < eps` transports to the translated point
    `add_CSNo w z0` around the original base point. **)
// Proof in RealAnalysis2.1780644227.mg
ProofArchived dist_complex_add_CSNo_right_lt_eps :
  forall w :e complex,
  forall z0 :e complex,
  forall eps :e R,
    dist_complex w 0 < eps ->
    dist_complex (add_CSNo w z0) z0 < eps.

(** dist_complex is a metric on complex (statement stub). **)
// Proof in RealAnalysis2.1779337911.mg
ProofArchived dist_complex_is_metric :
  is_metric complex dist_complex.

(** The complex modulus is a real number (derived from `dist_complex`). **)
// Proof in RealAnalysis2.1780335268.mg
ProofArchived modulus_CSNo_mem_R :
  forall z :e complex,
    modulus_CSNo z :e R.

(** Triangle-type bound for modulus via the metric triangle inequality. **)
// Proof in RealAnalysis2.1780335268.mg
ProofArchived modulus_CSNo_Le_dist_complex_add :
  forall u :e complex,
  forall v :e complex,
    modulus_CSNo u <= dist_complex u v + modulus_CSNo v.

Section form82.

(** real2.tex: sec:arzelaascoli (Arzelà–Ascoli) [scaffolding, added early]. **)

(** Projections for `ms_seq_compact`. **)
// Proof in RealAnalysis2.1780156947.mg
ProofArchived ms_seq_compact_subq :
  forall X,
  forall d : set -> set -> set,
  forall K,
    ms_seq_compact X d K ->
    K c= X.

// Proof in RealAnalysis2.1780156947.mg
ProofArchived ms_seq_compact_elim :
  forall X,
  forall d : set -> set -> set,
  forall K,
    ms_seq_compact X d K ->
    forall x : set -> set,
      (forall n :e omega, x n :e K) ->
      exists xs : set -> set,
        subseq_of x xs
        /\ exists l :e K, ms_seq_limit X d xs l.

(** A set is countable if it injects into omega (at most countable). **)
//LLM countable : "#1 is countable" | $\mathrm{countable}(#1)$
Definition countable : set -> prop :=
  fun A => atleastp A omega.

(** Finite sets are countable. **)
// Proof in RealAnalysis2.1780259525.mg
ProofArchived finite_imp_countable :
  forall A,
    finite A ->
    countable A.

(** A nonempty countable set admits an omega-indexed enumerating sequence. **)
// Proof in RealAnalysis2.1780482097.mg
ProofArchived countable_nonempty_imp_exists_omega_enum :
  forall D,
    countable D ->
    nonempty D ->
    exists e : set -> set,
      (forall n :e omega, e n :e D)
      /\ (forall x :e D, exists n :e omega, e n = x).

(** Density in a metric space: every ball around x meets D. **)
//LLM ms_dense : "#1 is dense in #2" | $\mathrm{ms\_dense}(#1,#2,#3)$
Definition ms_dense :
  set ->
  (set -> set -> set) ->
  set ->
  prop :=
  fun X d D =>
    D c= X
    /\ forall x :e X,
         forall eps :e R,
           0 < eps ->
           exists y :e D, d x y < eps.

(** Equality substitution in the right argument of a binary function inside a strict inequality. **)
// Proof in RealAnalysis2.1780482522.mg
ProofArchived binfun_lt_eq_substR :
  forall f : set -> set -> set,
  forall x y z eps,
    y = z ->
    f x y < eps ->
    f x z < eps.

(** A nonempty countable dense subset yields an omega-indexed dense sequence. **)
// Proof in RealAnalysis2.1780482522.mg
ProofArchived ms_dense_countable_nonempty_imp_exists_dense_seq :
  forall X,
  forall d : set -> set -> set,
  forall D,
    ms_dense X d D ->
    countable D ->
    nonempty D ->
    exists e : set -> set,
      (forall n :e omega, e n :e D)
      /\ (forall x :e X,
            forall eps :e R,
              0 < eps ->
              exists n :e omega, d x (e n) < eps).

(** Total boundedness: for every eps>0 there is a finite eps-net. **)
//LLM ms_totally_bounded : "#1 is totally bounded" | $\mathrm{ms\_totally\_bounded}(#1,#2)$
Definition ms_totally_bounded :
  set ->
  (set -> set -> set) ->
  prop :=
  fun X d =>
    forall eps :e R,
      0 < eps ->
      exists F,
        F c= X
        /\ finite F
        /\ forall x :e X,
             x :e (\/_ c :e F, ms_ball X d c eps).

(** The empty set is totally bounded for any pseudo-distance (vacuously). **)
// Proof in RealAnalysis2.1780280861.mg
ProofArchived ms_totally_bounded_Empty :
  forall d : set -> set -> set,
    ms_totally_bounded Empty d.

(** If a set is not nonempty, it is equal to Empty. **)
// Megalodon reports this proposition is already known elsewhere; keep as an axiom to avoid reproving.
Axiom not_nonempty_imp_eq_Empty :
  forall X,
    ~nonempty X ->
    X = Empty.

(** If X is empty, it is totally bounded (via ms_totally_bounded_Empty). **)
// Megalodon reports this proposition is already known elsewhere; keep as an axiom to avoid reproving.
Axiom ms_totally_bounded_of_not_nonempty :
  forall X,
  forall d : set -> set -> set,
    ~nonempty X ->
    ms_totally_bounded X d.

(** If y is not in a union, then y is not in any member of the family. **)
// Megalodon reports this proposition is already known elsewhere; keep as an axiom to avoid reproving.
Axiom famunion_not_mem_imp :
  forall A,
  forall F : set -> set,
  forall y,
    y /:e (\/_ x :e A, F x) ->
    forall x :e A, y /:e F x.

(** Compact metric spaces are totally bounded (statement stub; used for Arzelà–Ascoli). **)
// Proof in RealAnalysis2.1780311312.mg
ProofArchived ms_no_finite_eps_net_imp_sep_seq :
  forall X,
  forall d : set -> set -> set,
  forall eps :e R,
    0 < eps ->
    is_metric X d ->
    (forall F,
      F c= X ->
      finite F ->
      exists x :e X, x /:e (\/_ c :e F, ms_ball X d c eps)) ->
    exists x : set -> set,
      (forall n :e omega, x n :e X)
      /\ forall n :e omega, forall m :e n, ~ (d (x m) (x n) < eps).

// Proof in RealAnalysis2.1780323467.mg
ProofArchived ms_seq_compact_imp_totally_bounded :
  forall X,
  forall d : set -> set -> set,
    is_metric X d ->
    ms_seq_compact X d X ->
    ms_totally_bounded X d.

// Proof sketch:
// - Fix eps>0. Assume no finite eps-net exists.
// - For each finite F ⊆ X, pick a point choose(F) ∈ X outside U(F):=⋃_{c∈F} B(c,eps).
// - Build an eps-separated sequence (x_n) by recursion: x_{n+1} = choose({x_0,...,x_n}).
// - Sequential compactness gives a convergent subsequence; convergence implies two far-out terms are within eps,
//   contradicting eps-separation.

(** Totally bounded metric spaces admit a countable dense subset (statement stub; used for Arzelà–Ascoli). **)
// Proof in RealAnalysis2.1780271147.mg
ProofArchived ms_totally_bounded_imp_exists_countable_dense :
  forall X,
  forall d : set -> set -> set,
    is_metric X d ->
    ms_totally_bounded X d ->
    exists D,
      countable D
      /\ ms_dense X d D.

(** A nonempty sequentially compact metric space admits an omega-indexed dense sequence. **)
// Proof in RealAnalysis2.1780482522.mg
ProofArchived ms_seq_compact_nonempty_imp_exists_dense_seq :
  forall X,
  forall d : set -> set -> set,
    is_metric X d ->
    ms_seq_compact X d X ->
    nonempty X ->
    exists e : set -> set,
      (forall n :e omega, e n :e X)
      /\ (forall x :e X,
            forall eps :e R,
              0 < eps ->
              exists n :e omega, d x (e n) < eps).

(** Pointwise bounded sequence of complex-valued functions on X. **)
//LLM pointwise_bounded_fun_seq : "#1 is a pointwise bounded sequence of functions" | $\mathrm{pointwise\_bounded\_fun\_seq}(#1,#2)$
Definition pointwise_bounded_fun_seq :
  set ->
  (set -> set) ->
  prop :=
  fun X fn =>
    (forall n :e omega, fn n :e setexp complex X)
    /\ forall x :e X,
         exists M :e R,
           forall n :e omega, modulus_CSNo ((fn n) x) <= M.

(** Projections for `pointwise_bounded_fun_seq`. **)
// Proof in RealAnalysis2.1780156947.mg
ProofArchived pointwise_bounded_fun_seq_maps_to :
  forall X,
  forall fn : set -> set,
    pointwise_bounded_fun_seq X fn ->
    forall n :e omega, fn n :e setexp complex X.

// Proof in RealAnalysis2.1780156947.mg
ProofArchived pointwise_bounded_fun_seq_bound :
  forall X,
  forall fn : set -> set,
    pointwise_bounded_fun_seq X fn ->
    forall x :e X,
      exists M :e R,
        forall n :e omega, modulus_CSNo ((fn n) x) <= M.

(** Uniformly bounded sequence of complex-valued functions on X. **)
//LLM uniformly_bounded_fun_seq : "#1 is a uniformly bounded sequence of functions" | $\mathrm{uniformly\_bounded\_fun\_seq}(#1,#2)$
Definition uniformly_bounded_fun_seq :
  set ->
  (set -> set) ->
  prop :=
  fun X fn =>
    (forall n :e omega, fn n :e setexp complex X)
    /\ exists M :e R,
         forall n :e omega, forall x :e X, modulus_CSNo ((fn n) x) <= M.

(** Projections for `uniformly_bounded_fun_seq`. **)
// Proof in RealAnalysis2.1780156947.mg
ProofArchived uniformly_bounded_fun_seq_maps_to :
  forall X,
  forall fn : set -> set,
    uniformly_bounded_fun_seq X fn ->
    forall n :e omega, fn n :e setexp complex X.

// Proof in RealAnalysis2.1780156947.mg
ProofArchived uniformly_bounded_fun_seq_bound :
  forall X,
  forall fn : set -> set,
    uniformly_bounded_fun_seq X fn ->
    exists M :e R,
      forall n :e omega, forall x :e X, modulus_CSNo ((fn n) x) <= M.

(** Uniform boundedness implies pointwise boundedness. **)
// Proof in RealAnalysis2.1780156947.mg
ProofArchived uniformly_bounded_fun_seq_imp_pointwise_bounded_fun_seq :
  forall X,
  forall fn : set -> set,
    uniformly_bounded_fun_seq X fn ->
    pointwise_bounded_fun_seq X fn.

(** If y is nonnegative then x <= x + y (right-addition monotonicity at 0). **)
// Proof in RealAnalysis2.1780335268.mg
ProofArchived R_Le_add_of_nonneg_right :
  forall x :e R,
  forall y :e R,
    0 <= y ->
    x <= x + y.

(** Coordinate bounds: real/imag parts are dominated by the modulus. **)
// Proof in RealAnalysis2.1780360004.mg
ProofArchived complex_Re_abs_le_modulus :
  forall z :e complex,
    abs_SNo (Re z) <= modulus_CSNo z.

// Proof in RealAnalysis2.1780360004.mg
ProofArchived complex_Im_abs_le_modulus :
  forall z :e complex,
    abs_SNo (Im z) <= modulus_CSNo z.

(** A modulus bound places a complex number inside the corresponding closed rectangle in `R^2`. **)
// Proof in RealAnalysis2.1780484148.mg
ProofArchived complex_modulus_bound_imp_vec_in_rect :
  forall z :e complex,
  forall M :e R,
    modulus_CSNo z <= M ->
    complex_vec2 z :e rect_Icc_R2 (- M) M (- M) M.

// Proof in RealAnalysis2.1780484148.mg
ProofArchived complex_seq_dist_lt_of_vec_dist_lt :
  forall x : set -> set,
  forall f : set -> set,
  forall vsub : set -> set,
  forall p,
  forall l,
  forall n :e omega,
    vsub n = complex_vec2 ((fun m : set => x (f m)) n) ->
    p = complex_vec2 l ->
    forall eps :e R,
      Rn_dist 2 (vsub n) p < eps ->
      dist_complex ((fun m : set => x (f m)) n) l < eps.

// Proof in RealAnalysis2.1780484148.mg
ProofArchived complex_vec2_of_SNo_pair :
  forall x :e R,
  forall y :e R,
    complex_vec2 (SNo_pair x y) = R2_pair x y.

// Proof in RealAnalysis2.1780484148.mg
ProofArchived complex_subseq_limit_from_vec_subseq_witness :
  forall x : set -> set,
  forall M :e R,
    (forall n :e omega, x n :e complex) ->
    forall vsub : set -> set,
    forall f : set -> set,
      subseq_fun f ->
      (forall n :e omega, vsub n = (fun n : set => complex_vec2 (x n)) (f n)) ->
      forall p :e rect_Icc_R2 (- M) M (- M) M,
        ms_seq_limit (Rn 2) (Rn_dist 2) vsub p ->
        exists y : set -> set,
          subseq_of x y
          /\ exists l :e complex, ms_seq_limit complex dist_complex y l.

// Proof in RealAnalysis2.1780484148.mg
ProofArchived complex_subseq_limit_from_vec_subseq_limit :
  forall x : set -> set,
  forall M :e R,
    (forall n :e omega, x n :e complex) ->
    forall vsub : set -> set,
      subseq_of (fun n : set => complex_vec2 (x n)) vsub ->
      (exists p :e rect_Icc_R2 (- M) M (- M) M,
        ms_seq_limit (Rn 2) (Rn_dist 2) vsub p) ->
      exists y : set -> set,
        subseq_of x y
        /\ exists l :e complex, ms_seq_limit complex dist_complex y l.

(** A uniformly modulus-bounded complex sequence admits a convergent subsequence
    in the metric space `(complex, dist_complex)`. **)
// Proof in RealAnalysis2.1780489106.mg
ProofArchived complex_seq_modulus_bounded_subseq_converges :
  forall x : set -> set,
  forall M :e R,
    (forall n :e omega, x n :e complex) ->
    (forall n :e omega, modulus_CSNo (x n) <= M) ->
    exists y : set -> set,
      subseq_of x y
      /\ exists l :e complex, ms_seq_limit complex dist_complex y l.

(** Evaluating a subsequence of functions at a fixed point gives a subsequence of the evaluated values. **)
// Proof in RealAnalysis2.1780484934.mg
ProofArchived subseq_of_eval_at_point :
  forall x y : set -> set,
    subseq_of x y ->
    forall c,
      subseq_of (fun n : set => (x n) c) (fun n : set => (y n) c).

(** At each fixed point c, a pointwise bounded sequence of complex-valued functions has a convergent subsequence of values. **)
// Proof in RealAnalysis2.1780489106.mg
ProofArchived pointwise_bounded_fun_seq_at_point_subseq_converges :
  forall X,
  forall fn : set -> set,
    pointwise_bounded_fun_seq X fn ->
    forall c :e X,
      exists y : set -> set,
        subseq_of (fun n : set => (fn n) c) y
        /\ exists l :e complex, ms_seq_limit complex dist_complex y l.

(** Fixed-point compactness, lifted back to a subsequence of functions. **)
// Proof in RealAnalysis2.1780490498.mg
ProofArchived pointwise_bounded_fun_seq_at_point_fun_subseq_converges :
  forall X,
  forall fn : set -> set,
    pointwise_bounded_fun_seq X fn ->
    forall c :e X,
      exists gn : set -> set,
        subseq_of fn gn
        /\ exists l :e complex,
             ms_seq_limit complex dist_complex (fun n : set => (gn n) c) l.

(** Transport a metric-space sequence limit across equality of the sampled evaluation point. **)
// Proof in RealAnalysis2.1780490498.mg
ProofArchived ms_seq_limit_eval_arg_eq_subst :
  forall e : set -> set,
  forall gn : set -> set,
  forall m,
  forall k,
  forall l,
    e m = e k ->
    ms_seq_limit complex dist_complex (fun n : set => (gn n) (e k)) l ->
    ms_seq_limit complex dist_complex (fun n : set => (gn n) (e m)) l.

(** Convergence at finitely many sample points is preserved by passing to a further subsequence. **)
// Proof in RealAnalysis2.1780490984.mg
ProofArchived pointwise_limits_on_initial_segment_subseq :
  forall e : set -> set,
  forall hn gn : set -> set,
  forall K :e omega,
    (forall m :e K,
      exists l :e complex,
        ms_seq_limit complex dist_complex (fun n : set => (hn n) (e m)) l) ->
    subseq_of hn gn ->
    forall m :e K,
      exists l :e complex,
        ms_seq_limit complex dist_complex (fun n : set => (gn n) (e m)) l.

(** Merge old convergence on an initial segment with convergence at the next sample point. **)
// Proof in RealAnalysis2.1780490984.mg
ProofArchived pointwise_limits_initial_segment_ordsucc_merge :
  forall e : set -> set,
  forall gn : set -> set,
  forall K :e omega,
    (forall m :e K,
      exists l :e complex,
        ms_seq_limit complex dist_complex (fun n : set => (gn n) (e m)) l) ->
    (exists l :e complex,
      ms_seq_limit complex dist_complex (fun n : set => (gn n) (e K)) l) ->
    forall m :e ordsucc K,
      exists l :e complex,
        ms_seq_limit complex dist_complex (fun n : set => (gn n) (e m)) l.

(** One-step extension for the diagonal process. **)
// Proof in RealAnalysis2.1780490984.mg
ProofArchived pointwise_bounded_fun_seq_extend_subseq_converges :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    forall hn : set -> set,
      subseq_of fn hn ->
      forall K :e omega,
        e K :e X ->
        (forall m :e K,
          exists l :e complex,
            ms_seq_limit complex dist_complex (fun n : set => (hn n) (e m)) l) ->
        exists gn : set -> set,
          subseq_of hn gn
          /\ forall m :e ordsucc K,
               exists l :e complex,
                 ms_seq_limit complex dist_complex (fun n : set => (gn n) (e m)) l.

(** Pointwise bounded complex-valued function sequences evaluate to complex numbers at each point. **)
// Proof in RealAnalysis2.1780484934.mg
ProofArchived pointwise_bounded_fun_seq_eval_in_complex :
  forall X,
  forall fn : set -> set,
    pointwise_bounded_fun_seq X fn ->
    forall c :e X,
    forall n :e omega,
      (fn n) c :e complex.

(** Uniformly bounded complex-valued function sequences evaluate to complex numbers at each point. **)
// Proof in RealAnalysis2.1780484934.mg
ProofArchived uniformly_bounded_fun_seq_eval_in_complex :
  forall X,
  forall fn : set -> set,
    uniformly_bounded_fun_seq X fn ->
    forall c :e X,
    forall n :e omega,
      (fn n) c :e complex.

(** Pointwise boundedness is preserved by passing to a subsequence of functions. **)
// Proof in RealAnalysis2.1780488319.mg
ProofArchived pointwise_bounded_fun_seq_subseq :
  forall X,
  forall fn gn : set -> set,
    pointwise_bounded_fun_seq X fn ->
    subseq_of fn gn ->
    pointwise_bounded_fun_seq X gn.

(** Uniform boundedness is preserved by passing to a subsequence of functions. **)
// Proof in RealAnalysis2.1780489106.mg
ProofArchived uniformly_bounded_fun_seq_subseq :
  forall X,
  forall fn gn : set -> set,
    uniformly_bounded_fun_seq X fn ->
    subseq_of fn gn ->
    uniformly_bounded_fun_seq X gn.

(** Passing to a subsequence preserves the property of landing in a fixed function space. **)
// Proof in RealAnalysis2.1780486688.mg
ProofArchived subseq_of_maps_to_setexp :
  forall X,
  forall Y,
  forall fn gn : set -> set,
    (forall n :e omega, fn n :e setexp Y X) ->
    subseq_of fn gn ->
    forall n :e omega, gn n :e setexp Y X.

(** Finite collections of pointwise bounds can be dominated by a single bound. **)
//LLM pointwise_bounds_uniformizable : "the pointwise bounds for #1 can be made uniform" | $\mathrm{pointwise\_bounds\_uniformizable}(#1,#2,#3)$
Definition pointwise_bounds_uniformizable :
  set ->
  (set -> set) ->
  set ->
  prop :=
  fun X fn S =>
    S c= X ->
    (forall c :e S,
      exists M :e R,
        forall n :e omega, modulus_CSNo ((fn n) c) <= M) ->
    exists B :e R,
      forall c :e S,
        forall n :e omega, modulus_CSNo ((fn n) c) <= B.

(** Base case for `pointwise_bounds_uniformizable` on Empty. **)
// Proof in RealAnalysis2.1780343770.mg
ProofArchived pointwise_bounds_uniformizable_Empty :
  forall X,
  forall fn : set -> set,
    pointwise_bounds_uniformizable X fn Empty.

(** Step case for `pointwise_bounds_uniformizable` under adjoining a point. **)
// Proof in RealAnalysis2.1780343770.mg
ProofArchived pointwise_bounds_uniformizable_adjoin :
  forall X,
  forall fn : set -> set,
  (forall n :e omega, fn n :e setexp complex X) ->
  forall S y,
    finite S ->
    y /:e S ->
    pointwise_bounds_uniformizable X fn S ->
    pointwise_bounds_uniformizable X fn (S :\/: {y}).

// Proof in RealAnalysis2.1780343770.mg
ProofArchived finite_pointwise_bounds_imp_uniform_bound :
  forall X,
  forall fn : set -> set,
  forall F,
    (forall n :e omega, fn n :e setexp complex X) ->
    F c= X ->
    finite F ->
    (forall c :e F,
      exists M :e R,
        forall n :e omega, modulus_CSNo ((fn n) c) <= M) ->
    exists B :e R,
      forall c :e F,
        forall n :e omega, modulus_CSNo ((fn n) c) <= B.

(** Equicontinuity on a subset K in a metric space (X,dX) for a sequence of maps X -> Y. **)
//LLM ms_equicontinuous_on : "#1 is equicontinuous on #2" | $\mathrm{ms\_equicontinuous\_on}(#1,#2,#3,#4,#5,#6)$
Definition ms_equicontinuous_on :
  set ->
  (set -> set -> set) ->
  set ->
  (set -> set -> set) ->
  set ->
  (set -> set) ->
  prop :=
  fun X dX Y dY K fn =>
    K c= X
    /\ (forall n :e omega, fn n :e setexp Y X)
    /\ forall eps :e R, 0 < eps ->
         exists delta :e R,
           0 < delta
           /\ forall n :e omega,
              forall x :e K,
              forall y :e K,
                dX x y < delta ->
                dY ((fn n) x) ((fn n) y) < eps.

(** Projections for `ms_equicontinuous_on`. **)
// Proof in RealAnalysis2.1780135428.mg
ProofArchived ms_equicontinuous_on_subq :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
    ms_equicontinuous_on X dX Y dY K fn ->
    K c= X.

// Proof in RealAnalysis2.1780135428.mg
ProofArchived ms_equicontinuous_on_maps_to :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
    ms_equicontinuous_on X dX Y dY K fn ->
    forall n :e omega, fn n :e setexp Y X.

(** Equicontinuity implies each `fn n` maps K into Y. **)
// Proof in RealAnalysis2.1780156947.mg
ProofArchived ms_equicontinuous_on_maps_to_on_K :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
    ms_equicontinuous_on X dX Y dY K fn ->
    forall n :e omega, forall x :e K, (fn n) x :e Y.

(** Equicontinuity is preserved by passing to a subsequence of functions. **)
// Proof in RealAnalysis2.1780489106.mg
ProofArchived ms_equicontinuous_on_subseq :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn gn : set -> set,
    ms_equicontinuous_on X dX Y dY K fn ->
    subseq_of fn gn ->
    ms_equicontinuous_on X dX Y dY K gn.

(** Equicontinuity implies the epsilon-delta condition for each fixed index n. **)
// Proof in RealAnalysis2.1780135428.mg
ProofArchived ms_equicontinuous_on_imp_eps_delta_each :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
    ms_equicontinuous_on X dX Y dY K fn ->
    forall n :e omega,
    forall eps :e R,
      0 < eps ->
      exists delta :e R,
        0 < delta
        /\ forall x :e K,
           forall y :e K,
             dX x y < delta ->
             dY ((fn n) x) ((fn n) y) < eps.

(** Equicontinuity implies continuity (for each fixed index) on K, viewed as a metric space in its own right. **)
// Proof in RealAnalysis2.1780149480.mg
ProofArchived ms_equicontinuous_on_imp_ms_continuous_on_each :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
    ms_equicontinuous_on X dX Y dY K fn ->
    forall n :e omega,
      ms_continuous_on (fun x : set => (fn n) x) K dX Y dY K.

(** Equicontinuity also yields uniform continuity for each fixed index on K. **)
// Proof in RealAnalysis2.1780149480.mg
ProofArchived ms_equicontinuous_on_imp_ms_uniformly_continuous_on_each :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
    ms_equicontinuous_on X dX Y dY K fn ->
    forall n :e omega,
      ms_uniformly_continuous_on (fun x : set => (fn n) x) K dX Y dY K.

(** Restriction: equicontinuity passes to subsets. **)
// Megalodon reports this proposition is already known elsewhere; keep as an axiom to avoid reproving it here.
Axiom ms_equicontinuous_on_restrict :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall K',
  forall fn : set -> set,
    K' c= K ->
    ms_equicontinuous_on X dX Y dY K fn ->
    ms_equicontinuous_on X dX Y dY K' fn.

(** Pointwise convergence of functions on K in a metric space (X,dX) -> (Y,dY). **)
//LLM ms_pointwise_converges_to : "#1 converges pointwise to #2" | $\mathrm{ms\_pointwise\_converges\_to}(#1,#2,#3,#4,#5,#6,#7)$
Definition ms_pointwise_converges_to :
  set ->
  (set -> set -> set) ->
  set ->
  (set -> set -> set) ->
  set ->
  (set -> set) ->
  set ->
  prop :=
  fun X dX Y dY K fn f =>
    K c= X
    /\ (forall n :e omega, fn n :e setexp Y X)
    /\ f :e setexp Y X
    /\ forall x :e K, ms_seq_limit Y dY (fun n : set => (fn n) x) (f x).

(** Projections for `ms_pointwise_converges_to`. **)
// Proof in RealAnalysis2.1780485840.mg
ProofArchived ms_pointwise_converges_to_subq :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_pointwise_converges_to X dX Y dY K fn f ->
    K c= X.

// Proof in RealAnalysis2.1780485840.mg
ProofArchived ms_pointwise_converges_to_maps_to :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_pointwise_converges_to X dX Y dY K fn f ->
    forall n :e omega, fn n :e setexp Y X.

// Proof in RealAnalysis2.1780485840.mg
ProofArchived ms_pointwise_converges_to_limit_in_setexp :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_pointwise_converges_to X dX Y dY K fn f ->
    f :e setexp Y X.

// Proof in RealAnalysis2.1780485840.mg
ProofArchived ms_pointwise_converges_to_imp_pointwise_seq_limit :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_pointwise_converges_to X dX Y dY K fn f ->
    forall x :e K, ms_seq_limit Y dY (fun n : set => (fn n) x) (f x).

// Proof in RealAnalysis2.1780485840.mg
ProofArchived ms_pointwise_converges_to_maps_to_on_K :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_pointwise_converges_to X dX Y dY K fn f ->
    forall n :e omega, forall x :e K, (fn n) x :e Y.

// Proof in RealAnalysis2.1780485840.mg
ProofArchived ms_pointwise_converges_to_limit_in_Y_on_K :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_pointwise_converges_to X dX Y dY K fn f ->
    forall x :e K, (f x) :e Y.

// Proof in RealAnalysis2.1780486688.mg
ProofArchived ms_pointwise_converges_to_subseq :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn gn : set -> set,
  forall f,
    ms_pointwise_converges_to X dX Y dY K fn f ->
    subseq_of fn gn ->
    ms_pointwise_converges_to X dX Y dY K gn f.

// Proof in RealAnalysis2.1780485840.mg
ProofArchived ms_pointwise_converges_to_restrict :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall K',
  forall fn : set -> set,
  forall f,
    K' c= K ->
    ms_pointwise_converges_to X dX Y dY K fn f ->
    ms_pointwise_converges_to X dX Y dY K' fn f.

(** Uniform convergence of functions on K in a metric space (X,dX) -> (Y,dY). **)
//LLM ms_uniformly_converges_to : "#1 converges uniformly to #2" | $\mathrm{ms\_uniformly\_converges\_to}(#1,#2,#3,#4,#5,#6,#7)$
Definition ms_uniformly_converges_to :
  set ->
  (set -> set -> set) ->
  set ->
  (set -> set -> set) ->
  set ->
  (set -> set) ->
  set ->
  prop :=
  fun X dX Y dY K fn f =>
    K c= X
    /\ ((forall n :e omega, fn n :e setexp Y X)
        /\ f :e setexp Y X
        /\ forall eps :e R, 0 < eps ->
             exists N :e omega,
               forall n :e omega, N <= n ->
                 forall x :e K, dY ((fn n) x) (f x) < eps).

(** Projections for `ms_uniformly_converges_to`. **)
// Proof in RealAnalysis2.1780156947.mg
ProofArchived ms_uniformly_converges_to_subq :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_uniformly_converges_to X dX Y dY K fn f ->
    K c= X.

// Proof in RealAnalysis2.1780156947.mg
ProofArchived ms_uniformly_converges_to_maps_to :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_uniformly_converges_to X dX Y dY K fn f ->
    forall n :e omega, fn n :e setexp Y X.

// Proof in RealAnalysis2.1780156947.mg
ProofArchived ms_uniformly_converges_to_limit_in_setexp :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_uniformly_converges_to X dX Y dY K fn f ->
    f :e setexp Y X.

// Proof in RealAnalysis2.1780156947.mg
ProofArchived ms_uniformly_converges_to_tail :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_uniformly_converges_to X dX Y dY K fn f ->
    forall eps :e R, 0 < eps ->
      exists N :e omega,
        forall n :e omega, N <= n ->
          forall x :e K, dY ((fn n) x) (f x) < eps.

(** Uniform convergence implies each fn n and f map K into Y. **)
// Proof in RealAnalysis2.1780154999.mg
ProofArchived ms_uniformly_converges_to_maps_to_on_K :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_uniformly_converges_to X dX Y dY K fn f ->
    (forall n :e omega, forall x :e K, (fn n) x :e Y)
    /\ (forall x :e K, (f x) :e Y).

(** The identity map on `omega` is a valid subsequence function. **)
// Proof in RealAnalysis2.1780489832.mg
ProofArchived subseq_fun_id :
  subseq_fun (fun n : set => n).

(** Every sequence is a subsequence of itself. **)
// Proof in RealAnalysis2.1780489832.mg
ProofArchived subseq_of_refl :
  forall x : set -> set,
    subseq_of x x.

(** Finite-stage diagonal extraction over an initial segment of sample points. **)
// Proof in RealAnalysis2.1780491950.mg
ProofArchived pointwise_bounded_fun_seq_finite_subseq_converges :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall N :e omega,
      exists gn : set -> set,
        subseq_of fn gn
        /\ forall m :e N,
             exists l :e complex,
               ms_seq_limit complex dist_complex (fun n : set => (gn n) (e m)) l.

(** Dense-sequence data plus finite-stage diagonal extraction on a nonempty sequentially compact metric space. **)
// Proof in RealAnalysis2.1780492436.mg
ProofArchived ms_seq_compact_nonempty_imp_dense_seq_finite_subseq_data :
  forall X,
  forall dX : set -> set -> set,
  forall fn : set -> set,
    is_metric X dX ->
    ms_seq_compact X dX X ->
    pointwise_bounded_fun_seq X fn ->
    nonempty X ->
    exists e : set -> set,
      (forall n :e omega, e n :e X)
      /\ (forall x :e X,
            forall eps :e R,
              0 < eps ->
              exists n :e omega, dX x (e n) < eps)
      /\ forall N :e omega,
           exists gn : set -> set,
             subseq_of fn gn
             /\ forall m :e N,
                  exists l :e complex,
                    ms_seq_limit complex dist_complex (fun n : set => (gn n) (e m)) l.

(** Re-encoding a subsequence as an `omega`-coded set preserves the subsequence relation. **)
// Proof in RealAnalysis2.1780493284.mg
ProofArchived subseq_of_omega_coding :
  forall fn gn : set -> set,
    subseq_of fn gn ->
    subseq_of fn (fun n : set => ((fun k :e omega => gn k) n)).

(** Re-encoding an `omega`-sequence as an `omega`-coded set preserves its metric-space limit. **)
// Proof in RealAnalysis2.1780493284.mg
ProofArchived ms_seq_limit_omega_coding :
  forall X,
  forall d : set -> set -> set,
  forall x : set -> set,
  forall l,
    ms_seq_limit X d x l ->
    ms_seq_limit X d (fun n : set => ((fun k :e omega => x k) n)) l.

(** Fixed-point compactness, packaged as a chosen `omega`-coded subsequence.
    Placed here because it depends on the omega-coding transport helpers above. **)
// Proof in RealAnalysis2.1780495516.mg
ProofArchived pointwise_bounded_fun_seq_at_point_fun_subseq_converges_coded :
  forall X,
  forall fn : set -> set,
    pointwise_bounded_fun_seq X fn ->
    forall c :e X,
      exists g,
        subseq_of fn (fun n : set => g n)
        /\ exists l :e complex,
             ms_seq_limit complex dist_complex (fun n : set => (g n) c) l.

(** One-step diagonal extension, packaged as a chosen `omega`-coded subsequence.
    Placed here because it depends on the omega-coding transport helpers above. **)
// Proof in RealAnalysis2.1780495516.mg
ProofArchived pointwise_bounded_fun_seq_extend_subseq_converges_coded :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    forall hn : set -> set,
      subseq_of fn hn ->
      forall K :e omega,
        e K :e X ->
        (forall m :e K,
          exists l :e complex,
            ms_seq_limit complex dist_complex (fun n : set => (hn n) (e m)) l) ->
        exists g,
          subseq_of fn (fun n : set => g n)
          /\ forall m :e ordsucc K,
               exists l :e complex,
                 ms_seq_limit complex dist_complex (fun n : set => (g n) (e m)) l.

(** Finite-stage diagonal extraction, packaged as a chosen `omega`-coded subsequence.
    Placed here because it depends on the omega-coding transport helpers above. **)
// Proof in RealAnalysis2.1780495516.mg
ProofArchived pointwise_bounded_fun_seq_finite_subseq_converges_coded :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall N :e omega,
      exists g,
        subseq_of fn (fun n : set => g n)
        /\ forall m :e N,
             exists l :e complex,
               ms_seq_limit complex dist_complex (fun n : set => (g n) (e m)) l.

(** One-step diagonal extension, packaged as a chosen `omega`-coded subsequence
    relative to the current subsequence `hn`. This is the nested form needed for
    a recursive diagonal family. **)
// Proof in RealAnalysis2.1780495822.mg
ProofArchived pointwise_bounded_fun_seq_extend_subseq_converges_coded_rel :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    forall hn : set -> set,
      subseq_of fn hn ->
      forall K :e omega,
        e K :e X ->
        (forall m :e K,
          exists l :e complex,
            ms_seq_limit complex dist_complex (fun n : set => (hn n) (e m)) l) ->
        exists g,
          subseq_of hn (fun n : set => g n)
          /\ forall m :e ordsucc K,
               exists l :e complex,
                 ms_seq_limit complex dist_complex (fun n : set => (g n) (e m)) l.

(** Predicate saying that a coded subsequence already converges on the first `N` dense sample points. **)
//LLM arzela_diag_step_pred : "the Arzelà diagonal step predicate for #1" | $\mathrm{arzela\_diag\_step\_pred}(#1,#2,#3,#4)$
Definition arzela_diag_step_pred :
  (set -> set) ->
  (set -> set) ->
  set ->
  set ->
  prop :=
  fun fn e N r =>
    subseq_of fn (fun n : set => r n)
    /\ forall m :e N,
         exists l :e complex,
           ms_seq_limit complex dist_complex (fun n : set => (r n) (e m)) l.

(** Choice target for the next coded diagonal refinement. **)
//LLM arzela_diag_step_choice : "a choice function for the Arzelà diagonal step predicate #1" | $\mathrm{arzela\_diag\_step\_choice}(#1,#2,#3)$
Definition arzela_diag_step_choice :
  (set -> set) ->
  set ->
  set ->
  set :=
  fun e N r =>
    Eps_i
      (fun g : set =>
        subseq_of (fun n : set => r n) (fun n : set => g n)
        /\ forall m :e ordsucc N,
             exists l :e complex,
               ms_seq_limit complex dist_complex (fun n : set => (g n) (e m)) l).

(** Recursive step for the diagonal family: if the current coded subsequence has the right
    prefix-convergence property, choose a coded refinement; otherwise leave it unchanged. **)
//LLM arzela_diag_step : "the Arzelà diagonal step associated to #1" | $\mathrm{arzela\_diag\_step}(#1,#2,#3,#4)$
Definition arzela_diag_step :
  (set -> set) ->
  (set -> set) ->
  set ->
  set ->
  set :=
  fun fn e N r =>
    if arzela_diag_step_pred fn e N r
    then arzela_diag_step_choice e N r
    else r.

(** The recursively generated coded diagonal family. **)
//LLM arzela_diag_family : "the Arzelà diagonal family associated to #1" | $\mathrm{arzela\_diag\_family}(#1,#2,#3)$
Definition arzela_diag_family :
  (set -> set) ->
  (set -> set) ->
  set ->
  set :=
  fun fn e =>
    nat_primrec
      (fun n :e omega => fn n)
      (arzela_diag_step fn e).

(** Target property for the recursive coded diagonal family. **)
//LLM arzela_diag_family_prop : "the defining property of the Arzelà diagonal family #1" | $\mathrm{arzela\_diag\_family\_prop}(#1,#2,#3)$
Definition arzela_diag_family_prop :
  (set -> set) ->
  (set -> set) ->
  set ->
  prop :=
  fun fn e K =>
    subseq_of fn (fun n : set => (arzela_diag_family fn e K) n)
    /\ (forall m :e K,
          exists l :e complex,
            ms_seq_limit complex dist_complex
              (fun n : set => ((arzela_diag_family fn e K) n) (e m)) l)
    /\ subseq_of
         (fun n : set => (arzela_diag_family fn e K) n)
         (fun n : set => (arzela_diag_family fn e (ordsucc K)) n)
    /\ forall m :e ordsucc K,
         exists l :e complex,
           ms_seq_limit complex dist_complex
             (fun n : set => ((arzela_diag_family fn e (ordsucc K)) n) (e m)) l.

(** If two coded sequences agree on `omega`, subsequencehood transports to the right-hand one. **)
// Proof in RealAnalysis2.1780497330.mg
ProofArchived subseq_of_eq_on_omega_substR :
  forall x y z : set -> set,
    subseq_of x y ->
    (forall n :e omega, z n = y n) ->
    subseq_of x z.

(** When the current coded subsequence has the diagonal prefix property, the chosen next step
    satisfies the expected refinement and convergence conclusion. **)
// Proof in RealAnalysis2.1780497330.mg
ProofArchived arzela_diag_step_choice_spec :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
  forall N,
  forall r,
    pointwise_bounded_fun_seq X fn ->
    N :e omega ->
    e N :e X ->
    arzela_diag_step_pred fn e N r ->
    subseq_of (fun n : set => r n) (fun n : set => (arzela_diag_step_choice e N r) n)
    /\ forall m :e ordsucc N,
         exists l :e complex,
           ms_seq_limit complex dist_complex
             (fun n : set => ((arzela_diag_step_choice e N r) n) (e m)) l.

(** Transport an existential complex sequence limit across pointwise equality on `omega`. **)
// Proof in RealAnalysis2.1780497330.mg
ProofArchived complex_seq_limit_exists_of_pointwise_eq :
  forall x y : set -> set,
    (forall n :e omega, y n = x n) ->
    (exists l :e complex, ms_seq_limit complex dist_complex x l) ->
    exists l :e complex, ms_seq_limit complex dist_complex y l.

(** Base step for the recursive coded diagonal family. **)
// Proof in RealAnalysis2.1780497330.mg
ProofArchived arzela_diag_family_base :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    arzela_diag_family_prop fn e 0.

(** Inductive step for the recursive coded diagonal family. **)
// Proof in RealAnalysis2.1780497330.mg
ProofArchived arzela_diag_family_step :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall K,
      nat_p K ->
      arzela_diag_family_prop fn e K ->
      arzela_diag_family_prop fn e (ordsucc K).

(** Full recursive coded diagonal family property on every finite initial segment. **)
// Proof in RealAnalysis2.1780497330.mg
ProofArchived arzela_diag_family_spec :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall N :e omega,
      arzela_diag_family_prop fn e N.

(** On a nonempty sequentially compact metric space, a dense sample sequence can be equipped
    with the recursive coded diagonal family on all finite initial segments. **)
// Proof in RealAnalysis2.1780497330.mg
ProofArchived ms_seq_compact_nonempty_imp_arzela_diag_family_data :
  forall X,
  forall dX : set -> set -> set,
  forall fn : set -> set,
    is_metric X dX ->
    ms_seq_compact X dX X ->
    pointwise_bounded_fun_seq X fn ->
    nonempty X ->
    exists e : set -> set,
      (forall n :e omega, e n :e X)
      /\ (forall x :e X,
            forall eps :e R,
              0 < eps ->
              exists n :e omega, dX x (e n) < eps)
      /\ forall N :e omega,
           arzela_diag_family_prop fn e N.

(** Reflexivity of `<=` on naturals. Useful for subsequence-index bookkeeping. **)
// Proof in RealAnalysis2.1780499137.mg
ProofArchived omega_Le_refl :
  forall n :e omega, n <= n.

(** Choose a specific subsequence witness map between two sequences. **)
// Proof in RealAnalysis2.1780501186.mg
ProofArchived subseq_fun_omega_coding :
  forall f : set -> set,
    subseq_fun f ->
    subseq_fun (fun n : set => ((fun k :e omega => f k) n)).

(** If two omega-indexed functions agree on omega, subsequencehood of the index map transports. **)
// Proof in RealAnalysis2.1780501186.mg
ProofArchived subseq_fun_eq_on_omega_substR :
  forall f g : set -> set,
    subseq_fun f ->
    (forall n :e omega, g n = f n) ->
    subseq_fun g.

//LLM subseq_index_choice : "a choice of subsequence indices for #1" | $\mathrm{subseq\_index\_choice}(#1,#2)$
Definition subseq_index_choice :
  (set -> set) ->
  (set -> set) ->
  (set -> set) :=
  fun x y =>
    fun n : set =>
      (Eps_i
        (fun f : set =>
          subseq_fun (fun k : set => f k)
          /\ forall k :e omega, y k = x (f k))) n.

(** The chosen subsequence witness satisfies the expected witness property. **)
// Proof in RealAnalysis2.1780501186.mg
ProofArchived subseq_index_choice_spec :
  forall x y : set -> set,
    subseq_of x y ->
    subseq_fun (subseq_index_choice x y)
    /\ forall n :e omega, y n = x ((subseq_index_choice x y) n).

(** Chosen witness map between consecutive levels of the recursive diagonal family. **)
//LLM arzela_diag_link : "the Arzelà diagonal link associated to #1" | $\mathrm{arzela\_diag\_link}(#1,#2,#3)$
Definition arzela_diag_link :
  (set -> set) ->
  (set -> set) ->
  set ->
  (set -> set) :=
  fun fn e N =>
    subseq_index_choice
      (fun n : set => (arzela_diag_family fn e N) n)
      (fun n : set => (arzela_diag_family fn e (ordsucc N)) n).

(** The chosen link map indeed witnesses the refinement from level `N` to `N+1`. **)
// Proof in RealAnalysis2.1780501186.mg
ProofArchived arzela_diag_link_spec :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall N :e omega,
      subseq_fun (arzela_diag_link fn e N)
      /\ forall k :e omega,
           (arzela_diag_family fn e (ordsucc N)) k
           = (arzela_diag_family fn e N) ((arzela_diag_link fn e N) k).

(** Recursive witness-family of subsequence indices for the coded diagonal family. **)
//LLM arzela_diag_index_family : "the index family associated to the Arzelà diagonal construction #1" | $\mathrm{arzela\_diag\_index\_family}(#1,#2,#3)$
Definition arzela_diag_index_family :
  (set -> set) ->
  (set -> set) ->
  set ->
  set :=
  fun fn e =>
    nat_primrec
      (fun n :e omega => n)
      (fun N a =>
        fun k :e omega =>
          a ((arzela_diag_link fn e N) k)).

(** Candidate global diagonal subsequence extracted from the witness-family. **)
//LLM arzela_diag_subseq : "the Arzelà diagonal subsequence associated to #1" | $\mathrm{arzela\_diag\_subseq}(#1,#2)$
Definition arzela_diag_subseq :
  (set -> set) ->
  (set -> set) ->
  (set -> set) :=
  fun fn e =>
    fun n : set =>
      (fn (((arzela_diag_index_family fn e n)) n)).

(** Recursive step identity for the coded diagonal index family. **)
// Proof in RealAnalysis2.1780501186.mg
ProofArchived arzela_diag_index_family_step_eq :
  forall fn : set -> set,
  forall e : set -> set,
    forall N :e omega,
    forall k :e omega,
      ((arzela_diag_index_family fn e (ordsucc N)) k)
      =
      ((arzela_diag_index_family fn e N) ((arzela_diag_link fn e N) k)).

(** Base step for the explicit coded diagonal index family witness. **)
// Proof in RealAnalysis2.1780501186.mg
ProofArchived arzela_diag_index_family_base :
  forall fn : set -> set,
  forall e : set -> set,
    subseq_fun (fun k : set => ((arzela_diag_index_family fn e 0) k))
    /\ forall k :e omega,
         (arzela_diag_family fn e 0) k
         = fn (((arzela_diag_index_family fn e 0) k)).

(** Inductive step for the explicit coded diagonal index family witness. **)
// Proof in RealAnalysis2.1780501186.mg
ProofArchived arzela_diag_index_family_step :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall M,
      nat_p M ->
      (subseq_fun (fun k : set => ((arzela_diag_index_family fn e M) k))
       /\ forall k :e omega,
            (arzela_diag_family fn e M) k
            = fn (((arzela_diag_index_family fn e M) k))) ->
      (subseq_fun (fun k : set => ((arzela_diag_index_family fn e (ordsucc M)) k))
       /\ forall k :e omega,
            (arzela_diag_family fn e (ordsucc M)) k
            = fn (((arzela_diag_index_family fn e (ordsucc M)) k))).

(** The recursively chosen coded index family explicitly witnesses each finite-stage diagonal subsequence. **)
// Proof in RealAnalysis2.1780501186.mg
ProofArchived arzela_diag_index_family_spec :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall N :e omega,
      subseq_fun (fun k : set => ((arzela_diag_index_family fn e N) k))
      /\ forall k :e omega,
           (arzela_diag_family fn e N) k
           = fn (((arzela_diag_index_family fn e N) k)).

(** The diagonal index map itself is a subsequence function. **)
// Proof in RealAnalysis2.1780501186.mg
ProofArchived arzela_diag_subseq_index_subseq_fun :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    subseq_fun (fun n : set => ((arzela_diag_index_family fn e n) n)).

(** The diagonal sequence is a subsequence of the original function sequence. **)
// Proof in RealAnalysis2.1780501186.mg
ProofArchived arzela_diag_subseq_subseq_of :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    subseq_of fn (arzela_diag_subseq fn e).

(** The diagonal sequence is the diagonal of the finite-stage coded family. **)
// Proof in RealAnalysis2.1780501186.mg
ProofArchived arzela_diag_subseq_eq_family_diag :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall n :e omega,
      (arzela_diag_subseq fn e) n
      =
      ((arzela_diag_family fn e n) n).

(** Later diagonal-family levels are subsequences of earlier ones, along a natural-number shift. **)
// Proof in RealAnalysis2.1780502813.mg
ProofArchived arzela_diag_family_subseq_shift :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall N :e omega,
    forall k :e omega,
      subseq_of
        (fun n : set => (arzela_diag_family fn e N) n)
        (fun n : set => (arzela_diag_family fn e (add_nat k N)) n).

(** Any later diagonal-family level is a subsequence of any earlier level. **)
// Proof in RealAnalysis2.1780502813.mg
ProofArchived arzela_diag_family_subseq_levels :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall N :e omega,
    forall M :e omega,
      N <= M ->
      subseq_of
        (fun n : set => (arzela_diag_family fn e N) n)
        (fun n : set => (arzela_diag_family fn e M) n).

(** Each sufficiently late diagonal term comes from an earlier fixed family level at a later index. **)
// Proof in RealAnalysis2.1780502813.mg
ProofArchived arzela_diag_subseq_term_from_level :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall N :e omega,
    forall n :e omega,
      N <= n ->
      exists j :e omega,
        n <= j
        /\ (arzela_diag_subseq fn e) n
             = (arzela_diag_family fn e N) j.

(** Equality of coded functions transports to equality after evaluation at a fixed point. **)
// Proof in RealAnalysis2.1780502813.mg
ProofArchived eval_fun_eq_subst :
  forall a,
  forall f g,
    f = g ->
    f a = g a.

(** A late diagonal value at a fixed sample point comes from the same sample point
    along an earlier family level at a later index. **)
// Proof in RealAnalysis2.1780504019.mg
ProofArchived arzela_diag_subseq_eval_from_level :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall N :e omega,
    forall n :e omega,
    forall m :e omega,
      N <= n ->
      exists j :e omega,
        n <= j
        /\ ((arzela_diag_subseq fn e) n) (e m)
             = ((arzela_diag_family fn e N) j) (e m).

(** The recursive family already converges at its designated dense sample point. **)
// Proof in RealAnalysis2.1780505709.mg
ProofArchived arzela_diag_family_sample_limit :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall m :e omega,
      exists l :e complex,
        ms_seq_limit complex dist_complex
          (fun n : set => ((arzela_diag_family fn e (ordsucc m)) n) (e m))
          l.

(** Every diagonal sample value stays in `complex`. **)
// Proof in RealAnalysis2.1780505709.mg
ProofArchived arzela_diag_subseq_eval_in_complex :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall n :e omega,
    forall m :e omega,
      ((arzela_diag_subseq fn e) n) (e m) :e complex.

(** A tail estimate for one family level transfers to the diagonal subsequence at the same sample point. **)
// Proof in RealAnalysis2.1780505709.mg
ProofArchived arzela_diag_subseq_eval_tail_from_family_tail :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall m :e omega,
    forall l :e complex,
    forall eps :e R,
    forall N1 :e omega,
      (forall j :e omega,
        N1 <= j ->
        dist_complex (((arzela_diag_family fn e (ordsucc m)) j) (e m)) l < eps) ->
      forall n :e omega,
        add_nat (ordsucc m) N1 <= n ->
        dist_complex (((arzela_diag_subseq fn e) n) (e m)) l < eps.

(** The explicit diagonal subsequence converges at each dense sample point. **)
// Proof in RealAnalysis2.1780505709.mg
ProofArchived arzela_diag_subseq_dense_point_converges :
  forall X,
  forall fn : set -> set,
  forall e : set -> set,
    pointwise_bounded_fun_seq X fn ->
    (forall n :e omega, e n :e X) ->
    forall m :e omega,
      exists l :e complex,
        ms_seq_limit complex dist_complex
          (fun n : set => ((arzela_diag_subseq fn e) n) (e m))
          l.

(** Package the dense sequence together with the explicit diagonal subsequence
    and its convergence on all dense sample points. **)
// Proof in RealAnalysis2.1780505709.mg
ProofArchived ms_seq_compact_nonempty_imp_arzela_diag_subseq_data :
  forall X,
  forall dX : set -> set -> set,
  forall fn : set -> set,
    is_metric X dX ->
    ms_seq_compact X dX X ->
    pointwise_bounded_fun_seq X fn ->
    nonempty X ->
    exists e : set -> set,
      (((forall n :e omega, e n :e X)
        /\ (forall x :e X,
              forall eps :e R,
                0 < eps ->
                exists n :e omega, dX x (e n) < eps))
       /\ subseq_of fn (arzela_diag_subseq fn e))
      /\ forall m :e omega,
           exists l :e complex,
             ms_seq_limit complex dist_complex
               (fun n : set => ((arzela_diag_subseq fn e) n) (e m))
               l.

(** If the domain is empty, uniform convergence on the whole domain is automatic. **)
// Proof in RealAnalysis2.1780489832.mg
ProofArchived ms_uniformly_converges_to_of_not_nonempty :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall fn : set -> set,
  forall f,
    ~nonempty X ->
    (forall n :e omega, fn n :e setexp Y X) ->
    f :e setexp Y X ->
    ms_uniformly_converges_to X dX Y dY X fn f.

(** The empty-domain branch of Arzelà–Ascoli is immediate. **)
// Proof in RealAnalysis2.1780489832.mg
ProofArchived arzela_ascoli_empty_branch :
  forall X,
  forall dX : set -> set -> set,
  forall fn : set -> set,
    ~nonempty X ->
    pointwise_bounded_fun_seq X fn ->
    exists gn : set -> set,
      subseq_of fn gn
      /\ exists f,
           ms_uniformly_converges_to X dX complex dist_complex X gn f.

(** Uniform convergence implies pointwise sequential convergence on K. **)
// Proof in RealAnalysis2.1780152852.mg
ProofArchived ms_uniformly_converges_to_imp_pointwise_seq_limit :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_uniformly_converges_to X dX Y dY K fn f ->
    forall x :e K,
      ms_seq_limit Y dY (fun n : set => (fn n) x) (f x).

// Proof in RealAnalysis2.1780188056.mg
ProofArchived ms_uniformly_converges_to_restrict :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall K',
  forall fn : set -> set,
  forall f,
    K' c= K ->
    ms_uniformly_converges_to X dX Y dY K fn f ->
    ms_uniformly_converges_to X dX Y dY K' fn f.

(** Uniform convergence is preserved by passing to a subsequence of indices. **)
// Proof in RealAnalysis2.1780189732.mg
ProofArchived ms_uniformly_converges_to_subseq :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    ms_uniformly_converges_to X dX Y dY K fn f ->
    forall g : set -> set,
      subseq_fun g ->
      ms_uniformly_converges_to X dX Y dY K (fun n : set => fn (g n)) f.

(** A convergent metric-space sequence has a pairwise-close tail. **)
// Proof in RealAnalysis2.1780512346.mg
ProofArchived ms_seq_limit_pairwise_tail :
  forall X,
  forall d : set -> set -> set,
  forall x : set -> set,
  forall l,
    is_metric X d ->
    ms_seq_limit X d x l ->
    forall eps :e R,
      0 < eps ->
      exists N :e omega,
        forall m :e omega,
        forall n :e omega,
          N <= m ->
          N <= n ->
          d (x m) (x n) < eps.

(** Equality substitution for metric-space sequence limits. **)
// Proof in RealAnalysis2.1780510898.mg
ProofArchived ms_seq_limit_eq_subst :
  forall X,
  forall d : set -> set -> set,
  forall x : set -> set,
  forall l1,
  forall l2,
    ms_seq_limit X d x l1 ->
    l1 = l2 ->
    ms_seq_limit X d x l2.

(** The epsilon-chosen pointwise limit lies in the codomain. **)
// Proof in RealAnalysis2.1780510898.mg
ProofArchived ms_pointwise_limit_choice_mem :
  forall X,
  forall Y,
  forall dY : set -> set -> set,
  forall fn : set -> set,
    (forall x :e X,
      exists l :e Y,
        ms_seq_limit Y dY (fun n : set => (fn n) x) l) ->
    forall x :e X,
      (Eps_i
        (fun l : set =>
          l :e Y
          /\ ms_seq_limit Y dY (fun n : set => (fn n) x) l)) :e Y.

(** The epsilon-chosen pointwise limit is indeed a sequence limit at each point. **)
// Proof in RealAnalysis2.1780510898.mg
ProofArchived ms_pointwise_limit_choice_seq_limit :
  forall X,
  forall Y,
  forall dY : set -> set -> set,
  forall fn : set -> set,
    (forall x :e X,
      exists l :e Y,
        ms_seq_limit Y dY (fun n : set => (fn n) x) l) ->
    forall x :e X,
      ms_seq_limit
        Y
        dY
        (fun n : set => (fn n) x)
        ((fun x :e X =>
          Eps_i
            (fun l : set =>
              l :e Y
              /\ ms_seq_limit Y dY (fun n : set => (fn n) x) l)) x).

(** The epsilon-chosen pointwise limit function lands in the codomain. **)
// Proof in RealAnalysis2.1780510898.mg
ProofArchived ms_pointwise_limit_choice_in_setexp :
  forall X,
  forall Y,
  forall dY : set -> set -> set,
  forall fn : set -> set,
    (forall x :e X,
      exists l :e Y,
        ms_seq_limit Y dY (fun n : set => (fn n) x) l) ->
    (fun x :e X =>
      Eps_i
        (fun l : set =>
          l :e Y
          /\ ms_seq_limit Y dY (fun n : set => (fn n) x) l))
      :e setexp Y X.

(** If each leg of a two-step path is shorter than eps/2, the total distance is shorter than eps. **)
// Proof in RealAnalysis2.1780513132.mg
ProofArchived ms_metric_two_step_half_lt :
  forall Y,
  forall dY : set -> set -> set,
  forall a,
  forall b,
  forall c,
  forall eps :e R,
    is_metric Y dY ->
    a :e Y ->
    b :e Y ->
    c :e Y ->
    dY a b < eps :/: 2 ->
    dY b c < eps :/: 2 ->
    dY a c < eps.

(** Three-step metric estimate: if each of three consecutive legs is shorter than `(eps/2)/2`,
    then the total endpoint distance is shorter than `eps`. **)
// Proof in RealAnalysis2.1780521415.mg
ProofArchived ms_metric_three_step_quarter_lt :
  forall Y,
  forall dY : set -> set -> set,
  forall a,
  forall b,
  forall c,
  forall z,
  forall eps :e R,
    is_metric Y dY ->
    a :e Y ->
    b :e Y ->
    c :e Y ->
    z :e Y ->
    dY a b < (eps :/: 2) :/: 2 ->
    dY b c < (eps :/: 2) :/: 2 ->
    dY c z < (eps :/: 2) :/: 2 ->
    0 < eps ->
    dY a z < eps.

(** Metric-space analogue of `cauchy_subseq_limit_imp_limit`:
    a Cauchy sequence converges to the limit of any convergent subsequence. **)
// Proof in RealAnalysis2.1780515373.mg
ProofArchived ms_cauchy_subseq_limit_imp_limit :
  forall X,
  forall d : set -> set -> set,
  forall x : set -> set,
  forall y : set -> set,
  forall l,
    is_metric X d ->
    ms_cauchy_seq X d x ->
    subseq_of x y ->
    ms_seq_limit X d y l ->
    ms_seq_limit X d x l.

(** A uniformly Cauchy pointwise bounded sequence of complex-valued functions
    has a pointwise limit at every sample point. **)
// Proof in RealAnalysis2.1780515373.mg
ProofArchived pointwise_bounded_fun_seq_point_limit_exists_of_uniform_cauchy :
  forall X,
  forall gn : set -> set,
    pointwise_bounded_fun_seq X gn ->
    (forall eps :e R,
      0 < eps ->
      exists N :e omega,
        forall m :e omega,
        forall n :e omega,
          N <= m ->
          N <= n ->
          forall x :e X,
            dist_complex ((gn m) x) ((gn n) x) < eps) ->
    forall x :e X,
      exists l :e complex,
        ms_seq_limit complex dist_complex (fun n : set => (gn n) x) l.

(** Fixed-point version of the uniformly Cauchy tail-to-limit upgrade. **)
// Proof in RealAnalysis2.1780514283.mg
ProofArchived ms_uniformly_cauchy_pointwise_limit_tail_at_point :
  forall X,
  forall Y,
  forall dY : set -> set -> set,
  forall fn : set -> set,
  forall f,
  forall x,
    is_metric Y dY ->
    (forall n :e omega, fn n :e setexp Y X) ->
    f :e setexp Y X ->
    x :e X ->
    (forall eps :e R,
      0 < eps ->
      exists N :e omega,
        forall m :e omega,
        forall n :e omega,
          N <= m ->
          N <= n ->
          forall y :e X, dY ((fn m) y) ((fn n) y) < eps) ->
    ms_seq_limit Y dY (fun n : set => (fn n) x) (f x) ->
    forall eps :e R,
      0 < eps ->
      exists N :e omega,
        forall n :e omega,
          N <= n ->
          dY ((fn n) x) (f x) < eps.

(** A uniformly Cauchy family with a given pointwise limit has a uniform tail to that limit. **)
// Current proof attempt preserved in scratch/ms_uniformly_cauchy_pointwise_limit_tail.proof.bck0591.mg
// Proof in RealAnalysis2.1780514283.mg
ProofArchived ms_uniformly_cauchy_pointwise_limit_tail :
  forall X,
  forall Y,
  forall dY : set -> set -> set,
  forall fn : set -> set,
  forall f,
    is_metric Y dY ->
    (forall n :e omega, fn n :e setexp Y X) ->
    f :e setexp Y X ->
    (forall eps :e R,
      0 < eps ->
      exists N :e omega,
        forall m :e omega,
        forall n :e omega,
          N <= m ->
          N <= n ->
          forall x :e X, dY ((fn m) x) ((fn n) x) < eps) ->
    (forall x :e X, ms_seq_limit Y dY (fun n : set => (fn n) x) (f x)) ->
    forall eps :e R,
      0 < eps ->
      exists N :e omega,
        forall n :e omega,
          N <= n ->
          forall x :e X, dY ((fn n) x) (f x) < eps.

(** On the full domain `X`, a uniformly Cauchy sequence of `Y`-valued functions with pointwise limits
    converges uniformly to the function of those pointwise limits. **)
// Current proof attempt preserved in scratch/ms_uniformly_cauchy_full_pointwise_limit_imp_uniform_limit.proof.bck0590.mg
// Proof in RealAnalysis2.1780514283.mg
ProofArchived ms_uniformly_cauchy_full_pointwise_limit_imp_uniform_limit :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall fn : set -> set,
    is_metric Y dY ->
    (forall n :e omega, fn n :e setexp Y X) ->
    (forall eps :e R,
      0 < eps ->
      exists N :e omega,
        forall m :e omega,
        forall n :e omega,
          N <= m ->
          N <= n ->
          forall x :e X, dY ((fn m) x) ((fn n) x) < eps) ->
    (forall x :e X,
      exists l :e Y,
        ms_seq_limit Y dY (fun n : set => (fn n) x) l) ->
    exists f,
      ms_uniformly_converges_to X dX Y dY X fn f.

(** Finite sets: unordered pairs are finite (used for taking minima of two positive reals). **)
// Proof in RealAnalysis2.1780194003.mg
ProofArchived finite_UPair :
  forall x y, finite {x,y}.

(** A finite family of uniformly continuous maps admits a common delta. **)
Axiom ms_uniformly_continuous_on_finite_initial_segment :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
    is_metric X dX ->
    K c= X ->
    forall N,
      nat_p N ->
      (forall n :e ordsucc N,
        ms_uniformly_continuous_on (fun x : set => (fn n) x) X dX Y dY K) ->
      forall eps :e R,
        0 < eps ->
        exists delta :e R,
          0 < delta
          /\ forall n :e ordsucc N,
               forall x :e K,
               forall y :e K,
                 dX x y < delta ->
                 dY ((fn n) x) ((fn n) y) < eps.
// Proof attempt sketch (not checked by Megalodon; kept for future proofing work):
// - Induction on N (using nat_ind).
// - Base N=0: take delta from uniform continuity of fn 0.
// - Step: combine delta for ordsucc n with delta for fn (ordsucc n) by taking the smaller one (via SNoLtLe_or).

(** Helper for the Arzelà–Ascoli equicontinuity proposition: the tail case n >= N. **)
// Proof in RealAnalysis2.1780234348.mg
ProofArchived ms_equicontinuity_tail_case_bound :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
  forall N :e omega,
  forall delta :e R,
  forall eps :e R,
  forall eps2 :e R,
  forall eps4 :e R,
  forall eps8 :e R,
    eps8 + eps8 = eps4 ->
    eps4 + eps4 = eps2 ->
    eps2 + eps2 = eps ->
    is_metric Y dY ->
    (forall x :e K, (f x) :e Y) ->
    (forall n :e omega, forall x :e K, (fn n) x :e Y) ->
    (forall n :e omega, N <= n ->
      forall x :e K, dY ((fn n) x) (f x) < eps8) ->
    (forall x :e K,
      forall y :e K,
        dX x y < delta ->
        dY ((fn N) x) ((fn N) y) < eps2) ->
    forall n :e omega,
      N <= n ->
      forall x :e K,
      forall y :e K,
        dX x y < delta ->
        dY ((fn n) x) ((fn n) y) < eps.

(** Uniform convergence of continuous functions on a compact metric space implies uniform equicontinuity.
    (real2.tex, sec:arzelaascoli, first proposition in the section). **)
// Proof in RealAnalysis2.1780234348.mg
ProofArchived ms_uniformly_converges_to_continuous_imp_equicontinuous_on :
  forall X,
  forall dX : set -> set -> set,
  forall Y,
  forall dY : set -> set -> set,
  forall K,
  forall fn : set -> set,
  forall f,
    is_metric X dX ->
    is_metric Y dY ->
    ms_seq_compact X dX K ->
    (forall n :e omega,
      ms_continuous_on (fun x : set => (fn n) x) X dX Y dY K) ->
    ms_uniformly_converges_to X dX Y dY K fn f ->
    ms_equicontinuous_on X dX Y dY K fn.

(** Pointwise boundedness for a sequence of maps X -> Y in a metric space (Y,dY), measured from a basepoint y0. **)
//LLM ms_pointwise_bounded_fun_seq : "#1 is a metric-space pointwise bounded sequence of functions" | $\mathrm{ms\_pointwise\_bounded\_fun\_seq}(#1,#2,#3,#4,#5)$
Definition ms_pointwise_bounded_fun_seq :
  set ->
  (set -> set -> set) ->
  set ->
  set ->
  (set -> set) ->
  prop :=
  fun Y dY X y0 fn =>
    y0 :e Y
    /\ (forall n :e omega, fn n :e setexp Y X)
    /\ forall x :e X,
         exists M :e R,
           forall n :e omega, dY ((fn n) x) y0 <= M.

(** Uniform boundedness for a sequence of maps X -> Y in a metric space (Y,dY), measured from a basepoint y0. **)
//LLM ms_uniformly_bounded_fun_seq : "#1 is a metric-space uniformly bounded sequence of functions" | $\mathrm{ms\_uniformly\_bounded\_fun\_seq}(#1,#2,#3,#4,#5)$
Definition ms_uniformly_bounded_fun_seq :
  set ->
  (set -> set -> set) ->
  set ->
  set ->
  (set -> set) ->
  prop :=
  fun Y dY X y0 fn =>
    y0 :e Y
    /\ (forall n :e omega, fn n :e setexp Y X)
    /\ exists M :e R,
         forall n :e omega, forall x :e X, dY ((fn n) x) y0 <= M.

(** Uniform boundedness implies pointwise boundedness (same basepoint). **)
Axiom ms_uniformly_bounded_fun_seq_imp_pointwise_bounded_fun_seq :
  forall Y,
  forall dY : set -> set -> set,
  forall X,
  forall y0,
  forall fn : set -> set,
    ms_uniformly_bounded_fun_seq Y dY X y0 fn ->
    ms_pointwise_bounded_fun_seq Y dY X y0 fn.

(** Arzelà–Ascoli theorem (real2.tex, Thm. thm:arzelaascoli).
    NOTE: Book statement is for complex-valued continuous functions; we use `dist_complex`.
    TODO: replace this admitted theorem with a proof and then retire `arzela_ascoli_stub`. **)

(** Arzelà–Ascoli (part 1): pointwise boundedness + equicontinuity on a sequentially compact metric space
    implies uniform boundedness.
    Megalodon reports this proposition is already known elsewhere; keep as an axiom to avoid reproving it here.
    Proof script preserved in `scratch/arzela_ascoli_uniform_boundedness.proof.bck0560.mg`. **)
Axiom arzela_ascoli_uniform_boundedness :
  forall X,
  forall dX : set -> set -> set,
  forall fn : set -> set,
    is_metric X dX ->
    ms_seq_compact X dX X ->
    pointwise_bounded_fun_seq X fn ->
    ms_equicontinuous_on X dX complex dist_complex X fn ->
    uniformly_bounded_fun_seq X fn.

(** A finite initial segment of pointwise convergent complex-valued sample sequences
    admits a common pairwise-close tail. **)
// Proof in RealAnalysis2.1780517061.mg
ProofArchived finite_sample_pairwise_tail_step :
  forall e : set -> set,
  forall gn : set -> set,
  forall K,
  forall M0 :e omega,
  forall M1 :e omega,
  forall eps,
    (forall m :e K,
      forall i :e omega,
      forall j :e omega,
        M0 <= i ->
        M0 <= j ->
        dist_complex ((gn i) (e m)) ((gn j) (e m)) < eps) ->
    (forall i :e omega,
      forall j :e omega,
        M1 <= i ->
        M1 <= j ->
        dist_complex ((gn i) (e K)) ((gn j) (e K)) < eps) ->
    exists M :e omega,
      forall m :e ordsucc K,
      forall i :e omega,
      forall j :e omega,
        M <= i ->
        M <= j ->
        dist_complex ((gn i) (e m)) ((gn j) (e m)) < eps.

(** A finite subset of `omega` is bounded above by some natural number. **)
// Proof in RealAnalysis2.1780518633.mg
ProofArchived finite_omega_bounded_above :
  forall F,
    F c= omega ->
    finite F ->
    exists N :e omega, forall n :e F, n <= N.

(** The image of a finite set under an omega-valued map is bounded above by some natural number. **)
// Proof in RealAnalysis2.1780518633.mg
ProofArchived finite_image_omega_bounded_above :
  forall F,
    finite F ->
    forall k : set -> set,
      (forall x :e F, k x :e omega) ->
      exists N :e omega, forall x :e F, k x <= N.

(** If one natural number is `<=` another, then it lies in the latter's successor ordinal. **)
// Proof in RealAnalysis2.1780520020.mg
ProofArchived omega_Le_imp_mem_ordsucc :
  forall m :e omega,
  forall n :e omega,
    m <= n ->
    m :e ordsucc n.

(** Any element of the successor of a natural number is itself a natural number. **)
// Proof in RealAnalysis2.1780522925.mg
ProofArchived omega_mem_of_mem_ordsucc_nat :
  forall K :e omega,
  forall k :e ordsucc K,
    k :e omega.

(** Choice of a dense-sequence index witnessing a prescribed radius. **)
//LLM dense_seq_choice_idx : "a choice index extracted from the dense sequence #1" | $\mathrm{dense\_seq\_choice\_idx}(#1,#2,#3,#4)$
Definition dense_seq_choice_idx :
  (set -> set -> set) ->
  (set -> set) ->
  set ->
  set ->
  set :=
  fun d e eps c =>
    Eps_i (fun n : set => n :e omega /\ d c (e n) < eps).

(** The chosen dense-sequence index lies in `omega` and witnesses the target radius. **)
// Proof in RealAnalysis2.1780520567.mg
ProofArchived dense_seq_choice_idx_spec :
  forall X,
  forall d : set -> set -> set,
  forall e : set -> set,
    (forall x :e X,
      forall eps :e R,
        0 < eps ->
        exists n :e omega, d x (e n) < eps) ->
    forall x :e X,
    forall eps :e R,
      0 < eps ->
      dense_seq_choice_idx d e eps x :e omega
      /\ d x (e (dense_seq_choice_idx d e eps x)) < eps.

(** For a finite family of points, the chosen dense-sequence witnesses all lie in one common finite prefix. **)
// Proof in RealAnalysis2.1780521415.mg
ProofArchived finite_dense_choice_prefix_bound :
  forall X,
  forall d : set -> set -> set,
  forall e : set -> set,
  forall F,
    finite F ->
    F c= X ->
    (forall x :e X,
      forall eps :e R,
        0 < eps ->
        exists n :e omega, d x (e n) < eps) ->
    forall eps :e R,
      0 < eps ->
      exists N :e omega,
        forall c :e F,
          dense_seq_choice_idx d e eps c :e ordsucc N
          /\ d c (e (dense_seq_choice_idx d e eps c)) < eps.

(** Total boundedness plus a dense omega-sequence yields a common finite dense prefix at every scale. **)
// Proof in RealAnalysis2.1780521415.mg
ProofArchived ms_totally_bounded_dense_seq_finite_prefix :
  forall X,
  forall d : set -> set -> set,
  forall e : set -> set,
    is_metric X d ->
    ms_totally_bounded X d ->
    (forall n :e omega, e n :e X) ->
    (forall x :e X,
      forall eps :e R,
        0 < eps ->
        exists n :e omega, d x (e n) < eps) ->
    forall eps :e R,
      0 < eps ->
      exists N :e omega,
        forall x :e X,
          exists m :e ordsucc N,
            d x (e m) < eps.

// Proof in RealAnalysis2.1780520020.mg
ProofArchived finite_sample_pairwise_tail_of_pointwise_limits :
  forall e : set -> set,
  forall gn : set -> set,
  forall N :e omega,
    (forall m :e N,
      exists l :e complex,
        ms_seq_limit complex dist_complex (fun n : set => (gn n) (e m)) l) ->
    forall eps :e R,
      0 < eps ->
      exists M :e omega,
        forall m :e N,
        forall i :e omega,
        forall j :e omega,
          M <= i ->
          M <= j ->
          dist_complex ((gn i) (e m)) ((gn j) (e m)) < eps.

(** The finite-tail estimate specialized to an initial segment `ordsucc K` of `omega`. **)
// Proof in RealAnalysis2.1780522925.mg
ProofArchived finite_sample_pairwise_tail_of_pointwise_limits_ordsucc_nat :
  forall e : set -> set,
  forall gn : set -> set,
  forall K :e omega,
    (forall m :e omega,
      exists l :e complex,
        ms_seq_limit complex dist_complex (fun n : set => (gn n) (e m)) l) ->
    forall eps :e R,
      0 < eps ->
      exists M :e omega,
        forall m :e ordsucc K,
        forall i :e omega,
        forall j :e omega,
          M <= i ->
          M <= j ->
          dist_complex ((gn i) (e m)) ((gn j) (e m)) < eps.

(** A dense finite prefix together with a common tail on that prefix yields a uniform Cauchy tail. **)
// Proof in RealAnalysis2.1780522925.mg
ProofArchived dense_prefix_pairwise_tail_imp_uniform_cauchy :
  forall X,
  forall dX : set -> set -> set,
  forall gn : set -> set,
  forall e : set -> set,
  forall K :e omega,
  forall M :e omega,
  forall delta :e R,
  forall eps :e R,
    is_metric X dX ->
    pointwise_bounded_fun_seq X gn ->
    (forall n :e omega, e n :e X) ->
    (forall n :e omega,
      forall x :e X,
      forall y :e X,
        dX x y < delta ->
