            (mulK
              (basis_coordinates K addK mulK X addX smulX m a x (u 0))
              (mulK
                (basis_coordinates K addK mulK Y addY smulY n b y (u 1 0))
                (basis_coordinates K addK mulK Z addZ smulZ p c z (u 1 1))))
            (coeff (u 0) (u 1 0) (u 1 1)))).
