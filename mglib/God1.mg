//LLM Pi_SNo : "the pi sno associated to #1" | $\mathrm{Pi\_SNo}(#1,#2)$
Definition Pi_SNo : (set -> set) -> set -> set := fun f n =>
  nat_primrec 1 (fun i r => r * f i) n.

// Proof in 100thms_12b.mg
ProofArchived Pi_SNo_0: forall f:set -> set, Pi_SNo f 0 = 1.

