    antisymmetric_mapping X M addM p
      (fun x => antisymmetrization M addM X p f x)
    /\ forall x :e X :^: p,
      (exists i j :e p, i <> j /\ x i = x j) ->
      antisymmetrization M addM X p f x = module_zero M addM.
