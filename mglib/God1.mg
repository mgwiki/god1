ProofArchived null_set_binunion_cseq_eq_tag0_witness :
  forall n,
  forall cseq1,
  forall cseq2,
  forall k,
  forall m :e omega,
    k = nat_pair 0 m ->
    null_set_binunion_cseq n cseq1 cseq2 k = cseq1 m.

