        (polynomial_addition K add 1)
        (polynomial_multiplication K add mul 1) (q i) (q j))) ->
    exists g :e multivariate_polynomial_ring K add 1,
    exists h :e (Pi_ i :e n,
      (multivariate_polynomial_ring K add 1) :^: (ordsucc (r i))),
