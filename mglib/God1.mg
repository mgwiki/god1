Section form12.

(** Basic order-theoretic notions for subsets of the reals (R). **)

//REAL1:55050 upper_bound : "#1 is an upper bound of #2" | $#1 \text{ is an upper bound of } #2$
//LLM upper_bound : "#1 is an upper bound of #2" | $#1 \text{ is an upper bound of } #2$
Definition upper_bound : set -> set -> prop :=
  fun S x => forall s :e S, s <= x.

//REAL1:55225 lower_bound : "#1 is a lower bound of #2" | $#1 \text{ is a lower bound of } #2$
//LLM lower_bound : "#1 is a lower bound of #2" | $#1 \text{ is a lower bound of } #2$
Definition lower_bound : set -> set -> prop :=
  fun S x => forall s :e S, x <= s.

//REAL1:54992 bounded_above : "#1 is bounded above" | $#1 \text{ is bounded above}$
//LLM bounded_above : "#1 is bounded above" | $#1 \text{ is bounded above}$
Definition bounded_above : set -> prop :=
  fun S => exists x :e R, upper_bound S x.

//REAL1:55167 bounded_below : "#1 is bounded below" | $#1 \text{ is bounded below}$
//LLM bounded_below : "#1 is bounded below" | $#1 \text{ is bounded below}$
Definition bounded_below : set -> prop :=
  fun S => exists x :e R, lower_bound S x.

//REAL1:55980 bounded : "#1 is bounded" | $#1 \text{ is bounded}$
//LLM bounded : "#1 is bounded" | $#1 \text{ is bounded}$
Definition bounded : set -> prop :=
  fun S => bounded_above S /\ bounded_below S.

// Proof in 1777388823.mg
ProofArchived upper_bound_Subq : forall S T x, T c= S -> upper_bound S x -> upper_bound T x.

// Proof in 1777388823.mg
ProofArchived lower_bound_Subq : forall S T x, T c= S -> lower_bound S x -> lower_bound T x.

// Proof in 1777388823.mg
ProofArchived bounded_above_Subq : forall S T, T c= S -> bounded_above S -> bounded_above T.

// Proof in 1777388823.mg
ProofArchived bounded_below_Subq : forall S T, T c= S -> bounded_below S -> bounded_below T.

// Proof in 1777388823.mg
ProofArchived upper_bound_Empty : forall x, upper_bound Empty x.

// Proof in 1777388823.mg
ProofArchived lower_bound_Empty : forall x, lower_bound Empty x.

// Proof in 1777388823.mg
ProofArchived upper_bound_Sing : forall x :e R, upper_bound {x} x.

// Proof in 1777388823.mg
ProofArchived lower_bound_Sing : forall x :e R, lower_bound {x} x.

// Proof in 1777388823.mg
ProofArchived bounded_above_Empty : bounded_above Empty.

// Proof in 1777388823.mg
ProofArchived bounded_below_Empty : bounded_below Empty.

// Proof in 1777388823.mg
ProofArchived bounded_Empty : bounded Empty.

// Proof in 1777388823.mg
ProofArchived bounded_above_Sing : forall x :e R, bounded_above {x}.

// Proof in 1777388823.mg
ProofArchived bounded_below_Sing : forall x :e R, bounded_below {x}.

// Proof in 1777388823.mg
ProofArchived bounded_Sing : forall x :e R, bounded {x}.

(** Nonemptiness and least/greatest bound properties. **)

//LLM nonempty : "the nonempty associated to #1" | $\mathrm{nonempty}(#1)$
Definition nonempty : set -> prop := fun S => exists x, x :e S.

//LLM is_lub : "#1 is the least upper bound of #2" | $\mathrm{is\_lub}(#1,#2)$
Definition is_lub : set -> set -> prop :=
  fun S x => upper_bound S x /\ forall y :e R, upper_bound S y -> x <= y.

//LLM is_glb : "#1 is the greatest lower bound of #2" | $\mathrm{is\_glb}(#1,#2)$
Definition is_glb : set -> set -> prop :=
  fun S x => lower_bound S x /\ forall y :e R, lower_bound S y -> y <= x.

// Proof in 1777388823.mg
ProofArchived is_lub_upper_bound : forall S x, is_lub S x -> upper_bound S x.

// Proof in 1777388823.mg
ProofArchived is_lub_least : forall S x, is_lub S x -> forall y :e R, upper_bound S y -> x <= y.

// Proof in 1777388823.mg
ProofArchived is_glb_lower_bound : forall S x, is_glb S x -> lower_bound S x.

// Proof in 1777388823.mg
ProofArchived is_glb_greatest : forall S x, is_glb S x -> forall y :e R, lower_bound S y -> y <= x.

// Proof in 1777388823.mg
ProofArchived lub_unique_R : forall S, forall x y :e R, is_lub S x -> is_lub S y -> x = y.

// Proof in 1777388823.mg
ProofArchived glb_unique_R : forall S, forall x y :e R, is_glb S x -> is_glb S y -> x = y.

// Proof in 1777388823.mg
ProofArchived nonempty_Sing : forall x, nonempty {x}.

// Proof in 1777388823.mg
ProofArchived is_lub_Sing : forall x :e R, is_lub {x} x.

// Proof in 1777388823.mg
ProofArchived is_glb_Sing : forall x :e R, is_glb {x} x.

End form12.

(** Completeness scaffolding (existence of lub/glb). **)

Section form13.

//LLM has_lub : "the has lub associated to #1" | $\mathrm{has\_lub}(#1)$
Definition has_lub : set -> prop := fun S => exists x :e R, is_lub S x.

//LLM has_glb : "the has glb associated to #1" | $\mathrm{has\_glb}(#1)$
Definition has_glb : set -> prop := fun S => exists x :e R, is_glb S x.

//REAL1:55544 sup : "the supremum of #1" | $\sup #1$
//LLM sup : "the supremum of #1" | $\sup #1$
Definition sup : set -> set := fun S => Eps_i (fun x => x :e R /\ is_lub S x).

//REAL1:55848 inf : "the infimum of #1" | $\inf #1$
//LLM inf : "the infimum of #1" | $\inf #1$
Definition inf : set -> set := fun S => Eps_i (fun x => x :e R /\ is_glb S x).

// Proof in 1777388823.mg
ProofArchived sup_spec : forall S, has_lub S -> sup S :e R /\ is_lub S (sup S).

// Proof in 1777388823.mg
ProofArchived inf_spec : forall S, has_glb S -> inf S :e R /\ is_glb S (inf S).

// Proof in 1777388823.mg
ProofArchived has_lub_Sing : forall x :e R, has_lub {x}.

// Proof in 1777388823.mg
ProofArchived has_glb_Sing : forall x :e R, has_glb {x}.

(** Basic consequences. **)

// Proof in 1777388823.mg
ProofArchived bounded_above_of_is_lub : forall S, forall x :e R, is_lub S x -> bounded_above S.

// Proof in 1777388823.mg
ProofArchived bounded_below_of_is_glb : forall S, forall x :e R, is_glb S x -> bounded_below S.

// Proof in 1777388823.mg
ProofArchived bounded_above_of_has_lub : forall S, has_lub S -> bounded_above S.

// Proof in 1777388823.mg
ProofArchived bounded_below_of_has_glb : forall S, has_glb S -> bounded_below S.

(** If S contains a maximal/minimal element, it is a lub/glb. **)

// Proof in 1777388823.mg
ProofArchived is_lub_of_mem_upper_bound :
  forall S, forall x :e R, x :e S -> upper_bound S x -> is_lub S x.

// Proof in 1777388823.mg
ProofArchived is_glb_of_mem_lower_bound :
  forall S, forall x :e R, x :e S -> lower_bound S x -> is_glb S x.

// Proof in 1777388823.mg
ProofArchived lub_exists_of_mem_upper_bound :
  forall S, (exists x :e R, x :e S /\ upper_bound S x) -> exists x :e R, is_lub S x.

// Proof in 1777388823.mg
ProofArchived glb_exists_of_mem_lower_bound :
  forall S, (exists x :e R, x :e S /\ lower_bound S x) -> exists x :e R, is_glb S x.

(** Strict bounds (useful for cut constructions). **)

//LLM strict_upper_bound : "the strict upper bound associated to #1" | $\mathrm{strict\_upper\_bound}(#1,#2)$
Definition strict_upper_bound : set -> set -> prop :=
  fun S y => forall s :e S, s < y.

//LLM strict_lower_bound : "the strict lower bound associated to #1" | $\mathrm{strict\_lower\_bound}(#1,#2)$
Definition strict_lower_bound : set -> set -> prop :=
  fun S y => forall s :e S, y < s.

// Proof in 1777388823.mg
ProofArchived strict_upper_bound_of_upper_bound_not_mem :
  forall S, S c= R -> forall y :e R, upper_bound S y -> y /:e S -> strict_upper_bound S y.

// Proof in 1777388823.mg
ProofArchived strict_lower_bound_of_lower_bound_not_mem :
  forall S, S c= R -> forall y :e R, lower_bound S y -> y /:e S -> strict_lower_bound S y.

(** Main completeness statements (to be proved from the construction of R). **)

// Proof in 1777388823.mg
ProofArchived lub_exists_ext_real :
  forall S, S c= R -> exists x :e ext_real, is_lub S x.

// Proof in 1777388823.mg
ProofArchived lub_exists_R :
  forall S, S c= R -> nonempty S -> bounded_above S -> exists x :e R, is_lub S x.

// Proof in 1777388823.mg
ProofArchived glb_exists_R_of_lub_exists_R :
  (forall S, S c= R -> nonempty S -> bounded_above S -> exists x :e R, is_lub S x) ->
  forall S, S c= R -> nonempty S -> bounded_below S -> exists x :e R, is_glb S x.

// Proof in 1777388823.mg
ProofArchived glb_exists_R :
  forall S, S c= R -> nonempty S -> bounded_below S -> exists x :e R, is_glb S x.

End form13.

