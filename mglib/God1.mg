      (forall i :e I, a i :e L /\ coeff i :e K) ->
      almost_all_zero I (ring_zero K addK) coeff ->
      f (module_finitely_supported_sum L addL I
          (fun i => smulL (coeff i) (a i)))
      = module_finitely_supported_sum M addM I
          (fun i => smulM (coeff i) (f (a i))).
