// Proof in RealAnalysis2.1780624322.mg
ProofArchived modulus_CSNo_eq_0_imp_zero :
  forall z :e complex,
    modulus_CSNo z = 0 ->
    z = 0.

(** The modulus of a nonzero complex number is positive. **)
// Proof in RealAnalysis2.1780624322.mg
ProofArchived modulus_CSNo_nonzero_pos :
  forall z :e complex,
    z <> 0 ->
    0 < modulus_CSNo z.

(** Real multiplication agrees with complex multiplication on real inputs. **)
// Proof in RealAnalysis2.1780626020.mg
ProofArchived mul_CSNo_real_real_eq_mul :
  forall x :e real,
  forall y :e real,
    mul_CSNo x y = x * y.

(** Multiplicativity of the squared complex modulus. **)
// Proof in RealAnalysis2.1780626020.mg
ProofArchived abs_sqr_CSNo_mul_eq_mul :
  forall z :e complex,
  forall w :e complex,
    abs_sqr_CSNo (mul_CSNo z w)
    =
    abs_sqr_CSNo z * abs_sqr_CSNo w.

(** Multiplicativity of the complex modulus. **)
// Proof in RealAnalysis2.1780626020.mg
ProofArchived modulus_CSNo_mul_eq_mul :
  forall z :e complex,
  forall w :e complex,
    modulus_CSNo (mul_CSNo z w)
    =
    modulus_CSNo z * modulus_CSNo w.

(** The complex modulus of `1` is `1`. **)
// Proof in RealAnalysis2.1780624322.mg
ProofArchived modulus_CSNo_1_eq_1 :
  modulus_CSNo 1 = 1.

(** The modulus of a complex reciprocal is the reciprocal modulus. **)
// Proof in RealAnalysis2.1780626020.mg
ProofArchived modulus_CSNo_recip_invL :
  forall z :e complex,
    z <> 0 ->
    modulus_CSNo (recip_CSNo z) * modulus_CSNo z = 1.

(** Moved here from the earlier ratio-test staging area because its proof needs
    both `modulus_CSNo_nonzero_pos` and `modulus_CSNo_recip_invL`. In
    `real2.tex` this is still generic modulus algebra; the relocation is only
    to satisfy dependencies cleanly. **)
// Proof in RealAnalysis2.1782890935.mg
ProofArchived modulus_CSNo_recip_eq_recip :
  forall z :e complex,
    z <> 0 ->
    modulus_CSNo (recip_CSNo z)
    =
    recip_SNo (modulus_CSNo z).

Transparent recip_CSNo div_CSNo.

// Proof in RealAnalysis2.1782892503.mg
ProofArchived modulus_CSNo_div_eq_div :
  forall z :e complex,
  forall w :e complex,
    w <> 0 ->
    modulus_CSNo (div_CSNo z w)
    =
    (modulus_CSNo z) :/: (modulus_CSNo w).

Opaque recip_CSNo div_CSNo.

