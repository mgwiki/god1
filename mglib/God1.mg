      /\ forall m0 :e K0,
        ((forall i :e n0, ring_divides K0 mul0 m0 (x0 i))
        <-> ring_divides K0 mul0 m0 d0).
apply god1_hcf_existence_bezout_and_divisor_characterization.
claim h_s31_t1_all_characterizations :
  coprime_family K add mul n (fun i => x i)
  <-> exists coeff :e K :^: n,
