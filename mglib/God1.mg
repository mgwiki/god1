// Proof in 100thms_12b.mg
ProofArchived Inj0_Inj1_neq : forall X Y:set, Inj0 X <> Inj1 Y.

(*** setsum ***)
//LLM setsum : "the disjoint sum of sets #1 and #2" | $#1 \sqcup #2$
Definition setsum : set -> set -> set := fun X Y => {Inj0 x|x :e X} :\/: {Inj1 y|y :e Y}.
