        (permutation_group p) (permutation_composition p)
        {1,minus_SNo 1} mul_SNo s ->
      (forall tau :e adjacent_transpositions p, s tau = minus_SNo 1) ->
      forall sigma :e permutation_group p,
        s sigma = permutation_signature p sigma)
