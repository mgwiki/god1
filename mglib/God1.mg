Section Alg.

Variable extension_tag:set.
Let ctag : set -> set := fun alpha => SetAdjoin alpha extension_tag.
Postfix '' 100 := ctag.
//LLM pair_tag : "the pair tag associated to #1" | $\mathrm{pair\_tag}(#1,#2)$
Definition pair_tag : set -> set -> set := fun x y => x :\/: {u ''|u :e y}.

Variable F:set -> prop.

Hypothesis extension_tag_fresh: forall x, F x -> forall u :e x, extension_tag /:e u.

ProofArchived ctagged_notin_F : forall x y, F x -> (y '') /:e x.

ProofArchived ctagged_eqE_Subq : forall x y, F x -> forall u :e x, forall v, u '' = v '' -> u c= v.

ProofArchived ctagged_eqE_eq : forall x y, F x -> F y -> forall u :e x, forall v :e y, u '' = v '' -> u = v.

ProofArchived pair_tag_prop_1_Subq : forall x1 y1 x2 y2, F x1 -> pair_tag x1 y1 = pair_tag x2 y2 -> x1 c= x2.

ProofArchived pair_tag_prop_1 : forall x1 y1 x2 y2, F x1 -> F x2 -> pair_tag x1 y1 = pair_tag x2 y2 -> x1 = x2.

ProofArchived pair_tag_prop_2_Subq : forall x1 y1 x2 y2, F y1 -> F x2 -> F y2 -> pair_tag x1 y1 = pair_tag x2 y2 -> y1 c= y2.

ProofArchived pair_tag_prop_2 : forall x1 y1 x2 y2, F x1 -> F y1 -> F x2 -> F y2 -> pair_tag x1 y1 = pair_tag x2 y2 -> y1 = y2.

ProofArchived pair_tag_0 : forall x, pair_tag x 0 = x.

//LLM CD_carr : "the cd carr associated to #1" | $\mathrm{CD\_carr}(#1)$
Definition CD_carr: set -> prop := fun z => exists x, F x /\ exists y, F y /\ z = pair_tag x y.

ProofArchived CD_carr_I: forall x y, F x -> F y -> CD_carr (pair_tag x y).

ProofArchived CD_carr_E: forall z, CD_carr z ->
  forall p:set -> prop,
      (forall x y, F x -> F y -> z = pair_tag x y -> p (pair_tag x y))
    -> p z.

ProofArchived CD_carr_0ext: F 0 -> forall x, F x -> CD_carr x.

//LLM CD_proj0 : "the cd proj0 associated to #1" | $\mathrm{CD\_proj0}(#1)$
Definition CD_proj0 : set -> set := fun z => Eps_i (fun x => F x /\ exists y, F y /\ z = pair_tag x y).
//LLM CD_proj1 : "the cd proj1 associated to #1" | $\mathrm{CD\_proj1}(#1)$
Definition CD_proj1 : set -> set := fun z => Eps_i (fun y => F y /\ z = pair_tag (CD_proj0 z) y).

Let proj0 := CD_proj0.
Let proj1 := CD_proj1.
Let pa : set -> set -> set := pair_tag.

ProofArchived CD_proj0_1: forall z, CD_carr z -> F (proj0 z) /\ exists y, F y /\ z = pa (proj0 z) y.

ProofArchived CD_proj0_2: forall x y, F x -> F y -> proj0 (pa x y) = x.

ProofArchived CD_proj1_1: forall z, CD_carr z -> F (proj1 z) /\ z = pa (proj0 z) (proj1 z).

ProofArchived CD_proj1_2: forall x y, F x -> F y -> proj1 (pa x y) = y.

ProofArchived CD_proj0R: forall z, CD_carr z -> F (proj0 z).

ProofArchived CD_proj1R: forall z, CD_carr z -> F (proj1 z).

ProofArchived CD_proj0proj1_eta: forall z, CD_carr z -> z = pa (proj0 z) (proj1 z).

ProofArchived CD_proj0proj1_split: forall z w, CD_carr z -> CD_carr w -> proj0 z = proj0 w -> proj1 z = proj1 w -> z = w.

ProofArchived CD_proj0_F: F 0 -> forall x, F x -> CD_proj0 x = x.

ProofArchived CD_proj1_F: F 0 -> forall x, F x -> CD_proj1 x = 0.

Section CD_minus_conj.

Variable minus:set -> set.
Prefix - 358 := minus.

//LLM CD_minus : "the cd minus associated to #1" | $\mathrm{CD\_minus}(#1)$
Definition CD_minus : set -> set := fun z => pa (- proj0 z) (- proj1 z).

Prefix :-: 358 := CD_minus.

Variable conj:set -> set.
//LLM CD_conj : "the cd conj associated to #1" | $\mathrm{CD\_conj}(#1)$
Definition CD_conj : set -> set := fun z => pa (conj (proj0 z)) (- proj1 z).

End CD_minus_conj.

Section CD_add.

Variable add:set -> set -> set.
Infix + 360 right := add.

//LLM CD_add : "the cd add associated to #1" | $#1 + #2$
Definition CD_add : set -> set -> set := fun z w => pa (proj0 z + proj0 w) (proj1 z + proj1 w).

End CD_add.

Section CD_mul.

Variable minus:set -> set.
Variable conj:set -> set.
Variable add:set -> set -> set.
Variable mul:set -> set -> set.

Prefix - 358 := minus.
Infix + 360 right := add.
Infix * 355 right := mul.

//LLM CD_mul : "the cd mul associated to #1" | $#1 \cdot #2$
Definition CD_mul : set -> set -> set := fun z w => pa (proj0 z * proj0 w + - conj (proj1 w) * proj1 z) (proj1 w * proj0 z + proj1 z * conj (proj0 w)).
Infix :*: 355 right := CD_mul.

//LLM CD_exp_nat : "the cd exp nat associated to #1" | $\mathrm{CD\_exp\_nat}(#1,#2)$
Definition CD_exp_nat : set -> set -> set := fun z m => nat_primrec 1 (fun _ r => z :*: r) m.

End CD_mul.

