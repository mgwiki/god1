    ExtendedSNoElt_ 3 (SNo_pair x y).

// Proof in RealAnalysis2.1780577032.mg
ProofArchived complex_add_pairs_eq_pair_of_SNo_pairs :
  forall x :e real,
  forall y :e real,
  forall u :e real,
  forall v :e real,
    SNo (SNo_pair x y) ->
    SNo (SNo_pair u v) ->
    SNo_pair x y + SNo_pair u v = SNo_pair (x + u) (y + v).

Axiom complex_add_pairs_eq_pair_raw :
  forall x :e real,
  forall y :e real,
  forall u :e real,
  forall v :e real,
    add_CSNo (SNo_pair x y) (SNo_pair u v) = SNo_pair (x + u) (y + v).

// Proof in RealAnalysis2.1780570675.mg
ProofArchived conj_pa_eq :
  forall x :e real,
  forall y :e real,
    conj_CSNo (SNo_pair x y) = SNo_pair x (- y).

// Proof in RealAnalysis2.1780590273.mg
ProofArchived complex_neg_one_pair_mul_CSNo_eq_pair :
  forall a :e real,
  forall b :e real,
    mul_CSNo (- 1) (SNo_pair a b)
      = SNo_pair (- a) (- b).

(** Moved earlier than its narrative position in `real2.tex` so the
    Stone–Weierstrass imaginary-part arithmetic can share one raw-vs-complex
    multiplication blocker instead of duplicating local bridge admits. **)
// Proof in RealAnalysis2.1780610839.mg
ProofArchived complex_mul_pairs_raw_mul_bridge_of_SNo_pairs :
  forall x,
  forall y,
  forall u,
  forall v,
    SNo (SNo_pair x y) ->
    SNo (SNo_pair u v) ->
    SNo_pair x y * SNo_pair u v
      =
    mul_CSNo (SNo_pair x y) (SNo_pair u v).

