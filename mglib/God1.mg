    module_homomorphism K addK mulK M addM smulM L addL smulL
      (fun y => adjoint_homomorphism K addK mulK L M f g u y)
    /\ (forall x :e L, forall y :e M,
      f x (adjoint_homomorphism K addK mulK L M f g u y) = g (u x) y)
