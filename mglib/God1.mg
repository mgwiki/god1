//GOD1:165500 quadratic_conjugate : "the conjugate of #5 in the quadratic extension #1" | $\overline{#5}$
Definition quadratic_conjugate :
  set -> (set -> set -> set) -> set -> set :=
  fun K add z => (z 0, ring_negation K add (z 1)).

//GOD1:165701 quadratic_norm : "the norm of #6 in the quadratic extension #1 by a square root of #4" | $N(#6)$
Definition quadratic_norm :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  set -> set -> set :=
  fun K add mul d z =>
    add
      (mul (z 0) (z 0))
      (ring_negation K add (mul d (mul (z 1) (z 1)))).

Theorem god1_quadratic_conjugate_and_norm_laws :
