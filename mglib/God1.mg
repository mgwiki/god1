        K addK mulK X addX smulX a (z 0) (z 1))
    /\ determinant_of_two_vectors_in_basis
      K addK mulK X addX smulX a (a 0) (a 1) = ring_one K mulK
    /\ forall f:set -> set,
      alternating_bilinear_mapping K addK mulK
        X addX smulX K addK mulK f ->
