    :e multivariate_polynomial_ring K add 1.
admit.
//GOD1PRF:923036 where $q_{k}$ is a polynomial, whose exact form need not concern us. Hence we conclude that $f^{(k)}(a)=0$ for $k \leqslant r-1$, and in addition
claim h_s30_t7_lower_derivatives_vanish :
  polynomial_root_multiplicity K add mul f a = r ->
  forall k :e r,
    polynomial_evaluation K add mul K add mul 1
      (iterated_polynomial_derivative K add f k) (fun i => a)
