      = polynomial_multiplication K add mul n p' q).
admit.
Admitted.

(** § 30. Derivations and Taylor's formula. **)

//GOD1:897998 ring_derivation : "#4 is a derivation of the ring #1" | $#4(xy)=#4(x)y+x#4(y)$
Definition ring_derivation :
  set -> (set -> set -> set) -> (set -> set -> set) ->
  (set -> set) -> prop :=
  fun K add mul D =>
    ring K add mul
    /\ (forall x :e K, D x :e K)
    /\ (forall x y :e K, D (add x y) = add (D x) (D y))
    /\ forall x y :e K,
      D (mul x y) = add (mul (D x) y) (mul x (D y)).

Theorem god1_derivation_of_one_and_natural_powers :
  forall K, forall add mul:set -> set -> set, forall D:set -> set,
    commutative_ring K add mul -> ring_derivation K add mul D ->
    D (ring_one K mul) = ring_zero K add
    /\ forall x :e K, forall n :e omega, 0 :e n ->
      D (ring_nat_power K add mul x n)
      = mul
        (ring_nat_multiple K add n
          (ring_nat_power K add mul x (Union n)))
        (D x).
let K add mul D.
assume hRing hD.
apply andI.
//GOD1PRF:898778 The conditions (1) and (2) show that
claim h_s30_derivation_one_goal :
  D (ring_one K mul) = ring_zero K add.
admit.
//GOD1PRF:898878 for by putting $y=1$ in (2) we obtain $x . \mathrm{D}(1)=0$ for all $x \in \mathrm{~K}$, in particular for $x=1$. More generally, if K is commutative, we have
claim h_s30_derivation_one_and_power_goal :
  D (ring_one K mul) = ring_zero K add
  /\ forall x :e K, forall n :e omega, 0 :e n ->
    D (ring_nat_power K add mul x n)
    = mul
      (ring_nat_multiple K add n
        (ring_nat_power K add mul x (Union n))) (D x).
admit.
//GOD1PRF:899136 for all $x \in \mathrm{~K}$ and all integers $n \geqslant 0$. For $n=0$, (4) reduces to (3); and if (4) is true for $n-1$, then (2) shows that
claim h_s30_power_derivative_induction : forall x :e K,
  (D (ring_nat_power K add mul x 0) = ring_zero K add)
  /\ forall n :e omega, 0 :e n ->
    D (ring_nat_power K add mul x (Union n))
      = mul
        (ring_nat_multiple K add (Union n)
          (ring_nat_power K add mul x (Union (Union n)))) (D x) ->
    D (ring_nat_power K add mul x n)
      = mul
        (ring_nat_multiple K add n
          (ring_nat_power K add mul x (Union n))) (D x).
admit.
//GOD1PRF:899299 \mathrm{D}\left(x^{n}\right)=\mathrm{D}\left(x^{n-1} \cdot x\right) & =\mathrm{D}\left(x^{n-1}\right) \cdot x+x^{n-1} \mathrm{D}(x)=(n-1) x^{n-2} \mathrm{D}(x) \cdot x+x^{n-1} \mathrm{D}(x) \\
claim h_s30_power_derivative_product_step : forall x :e K, forall n :e omega,
  0 :e n ->
  D (ring_nat_power K add mul x n)
  = add
    (mul (D (ring_nat_power K add mul x (Union n))) x)
    (mul (ring_nat_power K add mul x (Union n)) (D x)).
admit.
//GOD1PRF:899537 if K is commutative.
claim h_s30_power_derivative_formula : forall x :e K, forall n :e omega,
  0 :e n ->
  D (ring_nat_power K add mul x n)
  = mul
    (ring_nat_multiple K add n
      (ring_nat_power K add mul x (Union n))) (D x).
admit.
Admitted.

//GOD1:900246 polynomial_coefficient_derivation : "the polynomial obtained by applying derivation #5 to the coefficients of #7" | $#7^{#5}$
Definition polynomial_coefficient_derivation :
  set -> (set -> set -> set) -> set -> (set -> set) -> set -> set :=
  fun K add n D f =>
    fun exponent :e omega :^: n => D (f exponent).

//GOD1:905121 increment_exponent_coordinate : "the exponent tuple #3 with coordinate #2 increased by one" | $#3+e_{#2}$
Definition increment_exponent_coordinate : set -> set -> (set -> set) -> set :=
  fun n i exponent =>
    fun j :e n => if j = i then ordsucc (exponent j) else exponent j.

//GOD1:905121 polynomial_partial_derivative : "the partial derivative of polynomial #6 with respect to indeterminate #5" | $\partial #6/\partial X_{#5}$
Definition polynomial_partial_derivative :
  set -> (set -> set -> set) -> set -> set -> set -> set :=
  fun K add n i f =>
    fun exponent :e omega :^: n =>
      ring_nat_multiple K add (ordsucc (exponent i))
        (f (increment_exponent_coordinate n i (fun j => exponent j))).

//GOD1:900246 polynomial_derived : "the derived polynomial of the one-variable polynomial #4" | $#4'$
Definition polynomial_derived :
  set -> (set -> set -> set) -> set -> set :=
  fun K add f => polynomial_partial_derivative K add 1 0 f.

//GOD1:911914 iterated_polynomial_derivative : "the #5-th derived polynomial of #4" | $#4^{(#5)}$
Definition iterated_polynomial_derivative :
  set -> (set -> set -> set) -> set -> set -> set :=
  fun K add f k =>
    let h := Eps_i (fun h =>
      h :e (multivariate_polynomial_ring K add 1) :^: (ordsucc k)
      /\ h 0 = f
      /\ forall j :e k, h (ordsucc j) = polynomial_derived K add (h j)) in
    h k.

Theorem god1_s30_theorem1_derivation_extension_to_one_variable_polynomials :
  forall K, forall add mul:set -> set -> set,
  forall D:set -> set, forall u :e multivariate_polynomial_ring K add 1,
    commutative_ring K add mul -> ring_derivation K add mul D ->
    exists Dp:set -> set,
      ring_derivation
        (multivariate_polynomial_ring K add 1)
        (polynomial_addition K add 1)
        (polynomial_multiplication K add mul 1) Dp
      /\ (forall a :e K,
        Dp (polynomial_constant K add mul 1 a)
        = polynomial_constant K add mul 1 (D a))
      /\ Dp (polynomial_indeterminate K add mul 1 0) = u
      /\ (forall f :e multivariate_polynomial_ring K add 1,
        Dp f = polynomial_addition K add 1
          (polynomial_coefficient_derivation K add 1 D f)
          (polynomial_multiplication K add mul 1 u
            (polynomial_derived K add f)))
      /\ forall E:set -> set,
        ring_derivation
          (multivariate_polynomial_ring K add 1)
          (polynomial_addition K add 1)
          (polynomial_multiplication K add mul 1) E ->
        (forall a :e K,
          E (polynomial_constant K add mul 1 a)
          = polynomial_constant K add mul 1 (D a)) ->
        E (polynomial_indeterminate K add mul 1 0) = u ->
        forall f :e multivariate_polynomial_ring K add 1, E f = Dp f.
let K add mul D u.
assume hu hRing hD.
//GOD1PRF:899645 theorem 1. Let D be a derivation of a commutative ring K . Given a polynomial $u \in \mathrm{~K}[\mathrm{X}]$, there exists a unique derivation of the ring $\mathrm{K}[\mathrm{X}]$ which agrees with D on K and maps the polynomial X to the given polynomial u.
claim h_s30_t1_extension_exists : exists Dp:set -> set,
  ring_derivation
    (multivariate_polynomial_ring K add 1)
    (polynomial_addition K add 1)
    (polynomial_multiplication K add mul 1) Dp
  /\ (forall a :e K,
    Dp (polynomial_constant K add mul 1 a)
      = polynomial_constant K add mul 1 (D a))
  /\ Dp (polynomial_indeterminate K add mul 1 0) = u.
admit.
//GOD1PRF:899905 Suppose that $\mathrm{D}^{\prime}$ is such a derivation of $\mathrm{K}[\mathrm{X}]$. Given a polynomial
claim h_s30_t1_candidate_formula : forall Dp:set -> set,
  ring_derivation
    (multivariate_polynomial_ring K add 1)
    (polynomial_addition K add 1)
    (polynomial_multiplication K add mul 1) Dp ->
  (forall a :e K,
    Dp (polynomial_constant K add mul 1 a)
      = polynomial_constant K add mul 1 (D a)) ->
  Dp (polynomial_indeterminate K add mul 1 0) = u ->
  forall f :e multivariate_polynomial_ring K add 1,
    Dp f = polynomial_addition K add 1
      (polynomial_coefficient_derivation K add 1 D f)
      (polynomial_multiplication K add mul 1 u
        (polynomial_derived K add f)).
admit.
//GOD1PRF:900075 the rules of calculation (1), (2), (4) show mat
claim h_s30_t1_derivation_rules_call :
  D (ring_one K mul) = ring_zero K add
  /\ forall x :e K, forall n :e omega, 0 :e n ->
    D (ring_nat_power K add mul x n)
    = mul
      (ring_nat_multiple K add n
        (ring_nat_power K add mul x (Union n))) (D x).
apply (god1_derivation_of_one_and_natural_powers K add mul D hRing hD).
//GOD1PRF:900343 and therefore, in view of the conditions imposed on $\mathrm{D}^{\prime}$,
claim h_s30_t1_candidate_determined : forall Dp:set -> set,
  ring_derivation
    (multivariate_polynomial_ring K add 1)
    (polynomial_addition K add 1)
    (polynomial_multiplication K add mul 1) Dp ->
  (forall a :e K,
    Dp (polynomial_constant K add mul 1 a)
      = polynomial_constant K add mul 1 (D a)) ->
  Dp (polynomial_indeterminate K add mul 1 0) = u ->
  forall f :e multivariate_polynomial_ring K add 1,
    Dp f = polynomial_addition K add 1
      (polynomial_coefficient_derivation K add 1 D f)
      (polynomial_multiplication K add mul 1 u
        (polynomial_derived K add f)).
admit.
//GOD1PRF:900438 \mathrm{D}^{\prime}(f)=\Sigma \mathrm{D}\left(a_{r}\right) \mathrm{X}^{r}+u(\mathrm{X}) \Sigma r a_{r} \mathrm{X}^{r-1} . \tag{5}
claim h_s30_t1_explicit_formula : forall Dp:set -> set,
  ring_derivation
    (multivariate_polynomial_ring K add 1)
    (polynomial_addition K add 1)
    (polynomial_multiplication K add mul 1) Dp ->
  (forall a :e K,
    Dp (polynomial_constant K add mul 1 a)
      = polynomial_constant K add mul 1 (D a)) ->
  Dp (polynomial_indeterminate K add mul 1 0) = u ->
  forall f :e multivariate_polynomial_ring K add 1,
    Dp f = polynomial_addition K add 1
      (polynomial_coefficient_derivation K add 1 D f)
      (polynomial_multiplication K add mul 1 u
        (polynomial_derived K add f)).
admit.
//GOD1PRF:901107 and proves the uniqueness of $\mathrm{D}^{\prime}$.\\
claim h_s30_t1_uniqueness : forall Dp E:set -> set,
  (forall f :e multivariate_polynomial_ring K add 1,
    Dp f = polynomial_addition K add 1
      (polynomial_coefficient_derivation K add 1 D f)
      (polynomial_multiplication K add mul 1 u (polynomial_derived K add f))) ->
  (forall f :e multivariate_polynomial_ring K add 1,
    E f = polynomial_addition K add 1
      (polynomial_coefficient_derivation K add 1 D f)
      (polynomial_multiplication K add mul 1 u (polynomial_derived K add f))) ->
  forall f :e multivariate_polynomial_ring K add 1, E f = Dp f.
admit.
//GOD1PRF:901161 It remains to be shown that the mapping
claim h_s30_t1_constructed_mapping : exists Dp:set -> set,
  forall f :e multivariate_polynomial_ring K add 1,
    Dp f = polynomial_addition K add 1
      (polynomial_coefficient_derivation K add 1 D f)
      (polynomial_multiplication K add mul 1 u
        (polynomial_derived K add f)).
admit.
//GOD1PRF:901288 defined by the formula (8) is effectively a derivation satisfying the conditions of the theorem. The obvious formulae
claim h_s30_t1_constructed_derivation : exists Dp:set -> set,
  ring_derivation
    (multivariate_polynomial_ring K add 1)
    (polynomial_addition K add 1)
    (polynomial_multiplication K add mul 1) Dp
  /\ forall f :e multivariate_polynomial_ring K add 1,
    Dp f = polynomial_addition K add 1
      (polynomial_coefficient_derivation K add 1 D f)
      (polynomial_multiplication K add mul 1 u
        (polynomial_derived K add f)).
admit.
//GOD1PRF:901506 show that $\mathrm{D}^{\prime}$ satisfies (1). To prove (2) we remark first that if $\mathrm{D}_{1}, \mathrm{D}_{2}$ are derivations of a commutative ring L , then for all $u_{1}, u_{2} \in \mathrm{~L}$ the mapping
claim h_s30_t1_linear_combination_derivations :
  forall D1 D2:set -> set, forall u1 u2 :e K,
    ring_derivation K add mul D1 -> ring_derivation K add mul D2 ->
    ring_derivation K add mul
      (fun x => add (mul u1 (D1 x)) (mul u2 (D2 x))).
admit.
//GOD1PRF:901803 of L into L is also a derivation of L . To show that $\mathrm{D}^{\prime}$ satisfies (2), it is therefore sufficient to show that the two mappings
claim h_s30_t1_two_component_derivations :
  ring_derivation
    (multivariate_polynomial_ring K add 1)
    (polynomial_addition K add 1)
    (polynomial_multiplication K add mul 1)
    (polynomial_coefficient_derivation K add 1 D)
  /\ ring_derivation
    (multivariate_polynomial_ring K add 1)
    (polynomial_addition K add 1)
    (polynomial_multiplication K add mul 1)
    (polynomial_derived K add).
admit.
//GOD1PRF:902019 of $\mathrm{K}[\mathrm{X}]$ into $\mathrm{K}[\mathrm{X}]$ are derivations, in other words that
claim h_s30_t1_component_product_rules : forall f g :e multivariate_polynomial_ring K add 1,
  polynomial_derived K add (polynomial_multiplication K add mul 1 f g)
  = polynomial_addition K add 1
    (polynomial_multiplication K add mul 1 (polynomial_derived K add f) g)
    (polynomial_multiplication K add mul 1 f (polynomial_derived K add g)).
admit.
//GOD1PRF:902236 Suppose first that $f$ and $g$ are monomials, say
claim h_s30_t1_monomial_product_rule : forall r s :e omega,
  polynomial_derived K add
    (polynomial_multiplication K add mul 1
      (fun e :e omega :^: 1 => if e 0 = r then ring_one K mul else ring_zero K add)
      (fun e :e omega :^: 1 => if e 0 = s then ring_one K mul else ring_zero K add))
  :e multivariate_polynomial_ring K add 1.
admit.
//GOD1PRF:902761 which shows that the desired formulae are true in this particular case. In the general case we decompose $f$ and $g$ into sums of monomials, which enables us to reduce to the particular case just considered.
claim h_s30_t1_general_product_rule : forall f g :e multivariate_polynomial_ring K add 1,
  polynomial_derived K add (polynomial_multiplication K add mul 1 f g)
  = polynomial_addition K add 1
    (polynomial_multiplication K add mul 1 (polynomial_derived K add f) g)
    (polynomial_multiplication K add mul 1 f (polynomial_derived K add g)).
admit.
//GOD1PRF:902970 We have therefore established that the mapping (8) is indeed a derivation. We have still to check that it agrees with D on K , in other words that
claim h_s30_t1_mapping_is_derivation : exists Dp:set -> set,
  ring_derivation
    (multivariate_polynomial_ring K add 1)
    (polynomial_addition K add 1)
    (polynomial_multiplication K add mul 1) Dp
  /\ forall a :e K,
    Dp (polynomial_constant K add mul 1 a)
      = polynomial_constant K add mul 1 (D a).
admit.
//GOD1PRF:903213 which is clear by (5); and that
claim h_s30_t1_agrees_on_constants : exists Dp:set -> set,
  forall a :e K,
    Dp (polynomial_constant K add mul 1 a)
      = polynomial_constant K add mul 1 (D a).
admit.
//GOD1PRF:903288 which is also clear if we write $X=1 . X$ and remember that $D(1)=0$. The proof of Theorem 1 is therefore complete.
claim h_s30_t1_indeterminate_value : exists Dp:set -> set,
  ring_derivation
    (multivariate_polynomial_ring K add 1)
    (polynomial_addition K add 1)
    (polynomial_multiplication K add mul 1) Dp
  /\ Dp (polynomial_indeterminate K add mul 1 0) = u.
admit.
Admitted.

Theorem god1_s30_theorem2_partial_derivation_interface :
  forall K, forall add mul:set -> set -> set,
  forall n :e omega, forall i :e n,
    commutative_ring K add mul ->
    exists Di:set -> set,
      ring_derivation
        (multivariate_polynomial_ring K add n)
        (polynomial_addition K add n)
        (polynomial_multiplication K add mul n) Di
      /\ (forall a :e K,
        Di (polynomial_constant K add mul n a)
          = polynomial_constant K add mul n (ring_zero K add))
      /\ forall f :e multivariate_polynomial_ring K add n,
        Di f = polynomial_partial_derivative K add n i f.
Admitted.

Theorem god1_s30_theorem2_derivation_extension_to_multivariate_polynomials :
  forall K, forall add mul:set -> set -> set,
  forall D:set -> set, forall n :e omega,
  forall u :e (multivariate_polynomial_ring K add n) :^: n,
    commutative_ring K add mul -> ring_derivation K add mul D ->
    exists Dp:set -> set,
      ring_derivation
        (multivariate_polynomial_ring K add n)
        (polynomial_addition K add n)
        (polynomial_multiplication K add mul n) Dp
      /\ (forall a :e K,
        Dp (polynomial_constant K add mul n a)
        = polynomial_constant K add mul n (D a))
      /\ (forall i :e n, Dp (polynomial_indeterminate K add mul n i) = u i)
      /\ (forall f :e multivariate_polynomial_ring K add n,
        Dp f = polynomial_addition K add n
          (polynomial_coefficient_derivation K add n D f)
          (module_finitely_supported_sum
            (multivariate_polynomial_ring K add n)
            (polynomial_addition K add n) n
            (fun i => polynomial_multiplication K add mul n (u i)
              (polynomial_partial_derivative K add n i f))))
      /\ forall E:set -> set,
        ring_derivation
          (multivariate_polynomial_ring K add n)
