(*** Unj : Left inverse of Inj1 and Inj0 ***)
//LLM Unj : "the coproduct untagging of #1" | $\mathrm{Unj}(#1)$
Definition Unj : set -> set := In_rec_i (fun X f => {f x|x :e X :\: {0}}).

// Proof in 100thms_12b.mg
