    D (polynomial_evaluation K add mul L add mul n f (fun j => u j))
    = ring_finite_sum L add n
      (fun i => mul
        (polynomial_evaluation K add mul L add mul n
          (polynomial_partial_derivative K add n i f) (fun j => u j))
        (D (u i))).
