admit.
//GOD1PRF:921402 Suppose that $a$ is a root of $f$. Then we have $f(\mathrm{~T})=(\mathrm{T}-a) q(\mathrm{~T})$, where
claim h_s30_t6_root_factorization :
  polynomial_zero K add mul K add mul 1 f (fun i => a) ->
  exists q :e multivariate_polynomial_ring K add 1,
    f = polynomial_multiplication K add mul 1
      (polynomial_addition K add 1
        (polynomial_indeterminate K add mul 1 0)
        (ring_negation
          (multivariate_polynomial_ring K add 1)
          (polynomial_addition K add 1)
          (polynomial_constant K add mul 1 a))) q.
admit.
//GOD1PRF:921613 Suppose that $f^{\prime}(a)=0$. Then, by Theorem 5, the polynomial $q(\mathrm{~T})$ is divisible by $\mathrm{T}-a$, so that $f$ is divisible by ( $\mathrm{T}-a)^{2}$, and $a$ is not a simple root. Conversely, if $a$ is not a simple root, then $f$ is of the form
claim h_s30_t6_theorem5_formal_call :
  forall K0, forall add0 mul0:set -> set -> set,
  forall f0 :e multivariate_polynomial_ring K0 add0 1, forall a0 :e K0,
    commutative_ring K0 add0 mul0 ->
    (polynomial_zero K0 add0 mul0 K0 add0 mul0 1 f0 (fun i => a0)
    <-> polynomial_divides K0 add0 mul0
      (polynomial_addition K0 add0 1
        (polynomial_indeterminate K0 add0 mul0 1 0)
        (ring_negation
          (multivariate_polynomial_ring K0 add0 1)
          (polynomial_addition K0 add0 1)
          (polynomial_constant K0 add0 mul0 1 a0))) f0).
apply god1_s30_theorem5_root_iff_linear_factor.
claim h_s30_t6_double_factor_criterion :
  polynomial_evaluation K add mul K add mul 1
    (polynomial_derived K add f) (fun i => a) = ring_zero K add ->
  polynomial_root_multiplicity K add mul f a <> 1.
admit.
//GOD1PRF:921932 so that
claim h_s30_t6_derivative_of_double_factor :
  polynomial_root_multiplicity K add mul f a <> 1 ->
