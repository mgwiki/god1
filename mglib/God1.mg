    (finitely_generated_free_module K addK mulK M addM smulM
    <-> exists n :e omega,
      isomorphic_modules
        K addK mulK
        (K :^: n)
        (module_power_addition n addK)
        (module_power_left_scalar n mulK)
        M addM smulM).
