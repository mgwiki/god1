Opaque recip_CSNo div_CSNo.

// Proof in RealAnalysis2.1782892503.mg
ProofArchived modulus_CSNo_exp_CSNo_nat_ordsucc_eq :
  forall z :e complex,
  forall n :e omega,
    modulus_CSNo (exp_CSNo_nat z (ordsucc n))
    =
    (modulus_CSNo z) * (modulus_CSNo (exp_CSNo_nat z n)).

Transparent recip_CSNo div_CSNo.

// Proof in RealAnalysis2.1782892503.mg
ProofArchived complex_exp_term_modulus_seq_ordsucc_unfold :
  forall z :e complex,
  forall n :e omega,
    complex_exp_term_modulus_seq z (ordsucc n)
    =
    ((modulus_CSNo z) * (modulus_CSNo (exp_CSNo_nat z n)))
