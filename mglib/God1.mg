(** The middle cancellation pattern `(-x) + (x + y) = y` in `complex`. **)
// Proof in RealAnalysis2.1782860327.mg
ProofArchived complex_add_neg_cancel_middle :
  forall x :e complex,
  forall y :e complex,
    add_CSNo (minus_CSNo x) (add_CSNo x y) = y.

// Proof in RealAnalysis2.1782863706.mg
ProofArchived complex_add_neg_cancel_middle_R :
  forall x :e complex,
  forall y :e complex,
    add_CSNo x (add_CSNo (minus_CSNo x) y) = y.

// Proof in RealAnalysis2.1782863706.mg
ProofArchived complex_add_cancel_R :
  forall x :e complex,
  forall y :e complex,
  forall z :e complex,
    add_CSNo y x = add_CSNo z x -> y = z.

(** Moved here so the neg-one multiplication block can use the proved
    middle-cancellation infrastructure without a forward reference. **)
// Proof in RealAnalysis2.1782863706.mg
ProofArchived complex_mul_neg_one_R :
  forall z :e complex,
    mul_CSNo z (- 1) = minus_CSNo z.

// Proof in RealAnalysis2.1782863706.mg
ProofArchived complex_mul_neg_one_L :
  forall z :e complex,
    mul_CSNo (- 1) z = minus_CSNo z.

// Proof in RealAnalysis2.1782863706.mg
ProofArchived complex_add_mul_neg_one_eq_0 :
  forall z :e complex,
    add_CSNo z (mul_CSNo (- 1) z) = 0.

(** Right multiplication by a complex negative is negation of the product. **)
// Proof in RealAnalysis2.1782864673.mg
ProofArchived complex_mul_minus_R :
  forall z :e complex,
  forall w :e complex,
    mul_CSNo z (minus_CSNo w) = minus_CSNo (mul_CSNo z w).

(** Moved here so it can use `complex_add_neg_cancel_middle` without a forward reference. **)
// Proof in RealAnalysis2.1782864979.mg
ProofArchived complex_minus_eq_compat :
  forall x :e complex,
  forall y :e complex,
    x = y -> minus_CSNo x = minus_CSNo y.

(** Left multiplication by a complex negative is negation of the product. **)
// Proof in RealAnalysis2.1782864979.mg
ProofArchived complex_mul_minus_L :
  forall z :e complex,
  forall w :e complex,
    mul_CSNo (minus_CSNo z) w = minus_CSNo (mul_CSNo z w).

(** Expanding `(a+b)(a-b)` in `complex` gives the usual difference of
    squares identity. **)
// Proof in RealAnalysis2.1782864673.mg
ProofArchived complex_mul_add_sub_eq_sq_sub_sq :
  forall a :e complex,
  forall b :e complex,
    mul_CSNo
      (add_CSNo a b)
      (add_CSNo a (minus_CSNo b))
    =
    add_CSNo
      (mul_CSNo a a)
      (minus_CSNo (mul_CSNo b b)).

(** Squaring `i s` produces `-(s^2)`. **)
// Proof in RealAnalysis2.1782863706.mg
ProofArchived complex_mul_i_term_sq_eq_neg_sq :
  forall s :e complex,
    mul_CSNo
      (mul_CSNo Complex_i s)
      (mul_CSNo Complex_i s)
    =
    minus_CSNo (mul_CSNo s s).

(** Negating the square `(i s)^2` recovers `s^2`. **)
// Proof in RealAnalysis2.1782864673.mg
ProofArchived complex_minus_mul_i_term_sq_eq_sq :
  forall s :e complex,
    minus_CSNo
      (mul_CSNo
        (mul_CSNo Complex_i s)
        (mul_CSNo Complex_i s))
    =
    mul_CSNo s s.

(** Conditional Pythagorean identity: it follows from the local complex-valued
    Euler identities together with the exponential addition law. **)
// Proof in RealAnalysis2.1782865706.mg
ProofArchived complex_euler_pair_expanded_eq_cos_sq_add_sin_sq_of_exp_in_complex :
  (forall z :e complex, complex_exp z :e complex) ->
  forall z :e complex,
    mul_CSNo
      (add_CSNo (complex_cos z) (mul_CSNo Complex_i (complex_sin z)))
      (add_CSNo
        (complex_cos z)
        (minus_CSNo (mul_CSNo Complex_i (complex_sin z))))
    =
    add_CSNo
      (mul_CSNo (complex_cos z) (complex_cos z))
      (mul_CSNo (complex_sin z) (complex_sin z)).

