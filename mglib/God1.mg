(** real1.tex: Prop `prop:monotoneintegrable` (monotone functions are Riemann integrable). **)

//LLM monotone_inc_on : "the monotone inc on associated to #1" | $\mathrm{monotone\_inc\_on}(#1,#2)$
Definition monotone_inc_on : (set -> set) -> set -> prop :=
  fun f S =>
    R_fun S f
    /\ forall x :e S, forall y :e S, x <= y -> f x <= f y.

//LLM monotone_dec_on : "the monotone dec on associated to #1" | $\mathrm{monotone\_dec\_on}(#1,#2)$
Definition monotone_dec_on : (set -> set) -> set -> prop :=
  fun f S =>
    R_fun S f
    /\ forall x :e S, forall y :e S, x <= y -> f y <= f x.

//LLM monotone_on : "the monotone on associated to #1" | $\mathrm{monotone\_on}(#1,#2)$
Definition monotone_on : (set -> set) -> set -> prop :=
  fun f S => monotone_inc_on f S \/ monotone_dec_on f S.

// Proof in RealAnalysis1May042026a.mg
ProofArchived monotone_on_Icc_imp_bounded_fun :
  forall a b :e R, a <= b ->
  forall f : set -> set,
    monotone_on f (Icc a b) ->
    bounded_fun (Icc a b) f.

// Proof in RealAnalysis1May042026a.mg
ProofArchived omega_subq_R : omega c= R.

//LLM uniform_partition_step : "the uniform partition step associated to #1" | $\mathrm{uniform\_partition\_step}(#1,#2,#3)$
Definition uniform_partition_step : set -> set -> set -> set :=
  fun a b n => (b + (- a)) * (recip_SNo n).

// Proof in RealAnalysis1May042026a.mg
ProofArchived exists_uniform_partition_step_lt :
  forall a b :e R, a < b ->
  forall delta :e R, 0 < delta ->
    exists n :e omega,
      (nat_p n /\ n <> 0) /\ uniform_partition_step a b n < delta.

//LLM uniform_partition_seq_fun : "the uniform partition seq fun associated to #1" | $\mathrm{uniform\_partition\_seq\_fun}(#1,#2,#3)$
Definition uniform_partition_seq_fun : set -> set -> set -> (set -> set) :=
  fun a b n => fun i => a + i * (uniform_partition_step a b n).

// Proof in RealAnalysis1May042026a.mg
ProofArchived uniform_partition_seq_fun_succ :
  forall a b :e R, forall n :e omega, forall i :e omega,
    uniform_partition_seq_fun a b n (ordsucc i)
      = (uniform_partition_seq_fun a b n i) + (uniform_partition_step a b n).

// Proof in RealAnalysis1May042026a.mg
ProofArchived uniform_partition_is_partition_seq_Icc :
  forall a b :e R, a < b ->
  forall n, nat_p n -> n <> 0 ->
    is_partition_seq_Icc a b n (uniform_partition_seq_fun a b n).

// Proof in RealAnalysis1May042026a.mg
ProofArchived delta_part_uniform_partition :
  forall a b :e R, a < b ->
  forall n, nat_p n -> n <> 0 ->
  forall i :e n,
    delta_part (uniform_partition_seq_fun a b n) i = uniform_partition_step a b n.

// Proof in RealAnalysis1May042026a.mg
ProofArchived dist_R_Icc_Le_len :
  forall a b :e R, a <= b ->
  forall x :e Icc a b, forall y :e Icc a b,
    dist_R x y <= b + (- a).

(** Interval-width monotonicity under refinement: a refined subinterval has length <= coarse length. **)
// Proof in RealAnalysis1May042026a.mg
ProofArchived delta_part_refine_block_Le :
  forall a b n m, forall p q : set -> set,
    is_partition_seq_Icc a b n p ->
    is_partition_seq_Icc a b m q ->
    forall i :e n,
    forall j0 :e ordsucc m, forall j1 :e ordsucc m,
      p i = q j0 ->
      p (ordsucc i) = q j1 ->
      j0 :e j1 ->
      forall j :e m,
        j0 :e ordsucc j ->
        ordsucc j :e ordsucc j1 ->
        delta_part q j <= delta_part p i.

// Proof in RealAnalysis1May042026a.mg
ProofArchived continuous_on_Icc_exists_partition_gap_lt :
  forall a b :e R, a < b ->
  forall f : set -> set,
    continuous_on f (Icc a b) ->
    forall eps :e R, 0 < eps ->
      exists n :e omega,
      exists p : set -> set,
        is_partition_seq_Icc a b n p
        /\ (darboux_sum_upper_seq f n p + (- (darboux_sum_lower_seq f n p))) < eps.

// Proof in RealAnalysis1May042026a.mg
ProofArchived partial_sum_seq_succ_diff_eq :
  forall n, nat_p n ->
  forall g : set -> set,
    (forall i :e ordsucc n, g i :e R) ->
    partial_sum_seq (fun i => g (ordsucc i) + (- (g i))) n
      = g n + (- (g 0)).

// Proof in RealAnalysis1May042026a.mg
ProofArchived partial_sum_seq_neg_eq :
  forall y : set -> set,
    forall n :e omega,
      (forall k :e n, y k :e R) ->
      partial_sum_seq (seq_neg y) n = - (partial_sum_seq y n).

// Proof in RealAnalysis1May042026a.mg
ProofArchived monotone_inc_on_Icc_exists_partition_gap_lt :
  forall a b :e R, a < b ->
  forall f : set -> set,
    monotone_inc_on f (Icc a b) ->
    forall eps :e R, 0 < eps ->
      exists n :e omega,
      exists p : set -> set,
        is_partition_seq_Icc a b n p
        /\ (darboux_sum_upper_seq f n p + (- (darboux_sum_lower_seq f n p))) < eps.

// Proof in RealAnalysis1May042026a.mg
ProofArchived monotone_dec_on_Icc_exists_partition_gap_lt :
  forall a b :e R, a < b ->
  forall f : set -> set,
    monotone_dec_on f (Icc a b) ->
    forall eps :e R, 0 < eps ->
      exists n :e omega,
      exists p : set -> set,
        is_partition_seq_Icc a b n p
        /\ (darboux_sum_upper_seq f n p + (- (darboux_sum_lower_seq f n p))) < eps.

// Proof in RealAnalysis1May042026a.mg
ProofArchived monotone_on_Icc_imp_riemann_integrable_Icc :
  forall a b :e R, a <= b ->
  forall f : set -> set,
    monotone_on f (Icc a b) ->
    riemann_integrable_Icc a b f.

// Proof in RealAnalysis1May042026a.mg
ProofArchived continuous_on_Icc_imp_riemann_integrable_Icc :
  forall a b :e R, a <= b ->
  forall f : set -> set,
    continuous_on f (Icc a b) ->
    riemann_integrable_Icc a b f.

