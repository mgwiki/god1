  (minus_SNo n)
  (omega_SNo (ordsucc n)
    (nat_p_omega (ordsucc n) (nat_ordsucc n (omega_nat_p n hn))))
  (int_SNo
    (add_SNo (minus_SNo (ordsucc n)) 1)
